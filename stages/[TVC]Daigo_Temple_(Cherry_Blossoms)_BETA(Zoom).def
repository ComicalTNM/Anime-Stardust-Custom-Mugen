[Info]
name = "Daigo Temple (Cherry Blossoms)"
displayname = "Daigo Temple (Cherry Blossoms)"
;versiondate = 09,30,2009
;mugenversion = 1.1
author = "jafar"

;--------------------------------------------------------
[Camera]
