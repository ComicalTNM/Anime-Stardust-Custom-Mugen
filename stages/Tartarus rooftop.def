;ペルソナ3より、「タルタロス屋上」
[Info]
name	= "Tartarus Rooftop"	;ステージ名
author	= "Luneth"	;制作者名


;=========================================================================================
;実は記述の順番はある程度無視できるので、
;必ずしも[BGdef]の上でなければならないわけではない
[Music]

bgmusic = sound/Battle for Everyones Souls.mp3

BGMusic.Loop	= 1	;音楽をループ再生するかどうか。1でループ再生する。

bgvolume	= 350	;場合により機能が変化する
;			(例1：in_mp3.dll	音声の再読み込み時の追加音量
;				0 = １ループしたりや超必時にBGMを停止しても２週目、再々生時も同じ音量
;				255 = BGMの再読み込みの度に音量+100%
;			例2：M.U.G.E.N. Stage Viewer	BGMファイルの再生音量
;				255を等倍とし、普通に再生する)


;=====================================================================================
[Camera]

startx		= 0
starty		= 0
boundleft	= -200
boundright	= 200
boundhigh	= -400
boundlow	= 20
verticalfollow	= 0.75
tension			= 50
floortension	= 80
zoomout = .58
zoomin = 1


;=======================================================================================
[PlayerInfo]
;--- Player 1 ---
p1startx	= -70
p1starty	= 0
p1startz	= 0
p1facing	= 1

;--- Player 2 ---
p2startx	= 70
p2starty	= 0
p2startz	= 0
p2facing	= -1

;--- Common ---
leftbound	= -10000
rightbound	= 10000
topbound	= 0
botbound	= 0


;========================================================================================
[Scaling]

topz		= 0
botz		= 50
topscale	= 1
botscale	= 1.2

;=======================================================================================
[Bound]
screenleft	= 15
screenright	= 15


;=====================================================================================
[StageInfo]
zoffset		= 215
autoturn	= 1
resetBG		= 0

hires		= 1


;======================================================================================
[Shadow]

color		= 16,10,16
yscale		= .75
intensity 	= 16
fade.range	= -120,-5

;=========================================================================================
[BGdef]

spr		= Tartarus rooftop.sff	;使うスプライトデータを宣言、Defと同じフォルダにあるならパスは書かなくてよい
debug	= 0						;1にすると全レイヤーより後ろに背景色が見えるようになるが重くなる(?)

;====================================================================
;背景

[BG 遠景(雲の渦)]
type		= normal
spriteno	= 1, 0
layerno		= 0
start		= 0,-450
delta		= .75,.75
mask		= 0
tile		= 1,0
velocity	= -0.45,0
[BG 遠景(霧)]
type		= normal
spriteno	= 1, 1
layerno		= 0
start		= 0,50
delta		= 1.1,1.1
mask		= 1
tile		= 1,0
velocity	= -1.125,0
trans		= addalpha
alpha		= 246,256
sin.x		= 2,2
sin.y		= 2,2

[BG 背景(月)]
type		= normal
spriteno	= 2, 0
layerno		= 0
start		= 0,-390
delta		= .8,.8
mask		= 1
