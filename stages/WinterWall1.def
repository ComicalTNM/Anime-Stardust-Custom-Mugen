;; [options] v1.1 zoom:
;;   4:3   zoomout = 1    zoomin = 1.4.2
;;   16:9  zoomout = 0.9 zoomin = 1.4   (default)


[Info]
name = "Winter Wall"
displayname = "Winter Wall"
versiondate = 03,03,2018
;op;mugenversion = 2002,02,14 ;; [default]


[Camera]
startx = 0
starty = 0
boundleft = -388
boundright = 388
boundhigh = -360
boundlow = 0
verticalfollow = 1
tension = 150
floortension = 150
cuthigh = 30
cutlow = 10
overdrawhigh = 5
overdrawlow = 5
tensionhigh = 85
tensionlow = 25


[PlayerInfo]
p1startx = -70
p1starty = 0
p1startz = 0
p1facing = 1
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1
leftbound = -1000
rightbound = 1000
topbound = 0
botbound = 0

[Scaling]
topz = 0
botz = 50
topscale = 1
botscale = 1.2

[Bound]
screenleft = 15
screenright = 15

[StageInfo]
zoffset = 215
autoturn = 1
resetbg = 0
localcoord = 320,240
portraitscale = 1

[Shadow]
color = 0,0,0
intensity = 128
reflect = 0
yscale = 0.1
;op;fade.range = -100,0
[Reflection]
intensity = 0

[Music]
bgmusic = sound/WinterWall.mp3
bgvolume = 100



;-----------------------
[BGdef]
spr = WinterWall.sff
debugbg = 0


