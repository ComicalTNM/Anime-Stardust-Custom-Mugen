[Info]
name = "MementosUltimate"
displayname = "Mementos"
versiondate = 15,03,2026
mugenversion = 1.1
author = "MozaicoTheRobot"

;--------------------------------------------------------
[Camera]
startx = 0
starty = 230
boundleft = -935
boundright = 935
boundhigh = -4200
boundlow = 0
tension = 400
verticalfollow = 1
floortension = 422
tensionhigh = 422			
tensionlow = 102			
tensionvel = 0.45
autocenter = 1
overdrawhigh = 120
overdrawlow = 120
cuthigh = 0
cutlow = 0
zoomout = 0.9
zoomin =  1.2


;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -320         ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 320
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -400
p3starty = 0
p3facing = 1

;--- Player 4 ---
p4startx = 400
p4starty = 0
p4facing = -1

;--- Common ---
leftbound  = -40000 ;Left bound (x-movement)
rightbound =  40000 ;Right bound

;--------------------------------------------------------
[Bound]
screenleft = 50    ;Dist from left of screen that player can move to
screenright = 50   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 680
autoturn = 1
resetBG = 1
localcoord = 1280, 720
xscale = 0.8
yscale = 1.4
;--------------------------------------------------------
[Shadow]

intensity = 96

color = 0,0,0

yscale = -.13

fade.range = -200, -50

;--------------------------------------------------------
[Reflection]
 ;Intensity of reflection (from 0 to 256). Set to 0 to have no
 ;reflection. Defaults to 0.
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = sound/beneaththemask.wav

bgmloopstart = 1132544
bgmloopend = 8259323




;-------------------------------------
; Model definition
;-------------------------------------
; Model definition
[Model]
offset = 0,-0.22,-1.5
scale = 0.13, 0.13, 0.14
;environment = MementosUltimate.hdr
;environmentintensity = 0.005
;-------------------------------------
; IKEMEN GO ONLY, preview animation used in the Select screen
[Begin Action 9000]
9000,1, 0,0,-1
;-------------------------------------



;========================================================
;--------------------------------------------------------
; Background definition
;-------------------------------------
[BGdef]
 ;Filename of sprite data
spr		= MementosUltimate.sff
model	= MementosUltimate.glb
debugbg = 0

[BG 6]
type = normal
spriteno = 0,0
start = 0,0
delta = 0,0
layerno = -1
zoomdelta = 0



;STARS= 0.5, X0 Y1
;CIRCLES= 0.05 1, 0.06 2, 0.05 3, X1 Y0
;BG CLOUDS= 0.02, X1 Y0
;TRAINS= 1.3, X-1 Y0