p1facing = 1            
p2startx = 280
p2starty = 0
p2facing = -1
p3startx = -400
p3starty = 0
p3facing = 1
p4startx = 400
p4starty = 0
p4facing = -1
leftbound  = -6000 
rightbound =  6000

[Bound]
