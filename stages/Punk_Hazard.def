boundright = -30
tension = 300
overdrawhigh = 120
overdrawlow = 120
cuthigh = 0
cutlow = 0

boundhigh = -450
boundlow = 0
verticalfollow = .85
floortension = 200

zoomin = 1.0
zoomout = 0.4

[PlayerInfo]
