;; Acropolis Stage MUGEN EDITION. Based on Acropolis stage from Tekken. Spriterips by Cenobite 53 and Reginukem. Special thanks to Oldgamer and RazorBakk for all the help. You guys rule!
;--------------------------------------------------------
[Info]
name			= "Acropolis"
Author			= "WATER"
displayname		= "Acropolis"
versiondate		= 06,22,2019;(MM-DD-YYYY)
mugenversion		= 1.1

[Camera]
startx=0
starty=0
boundleft= -270
boundright= 270
boundhigh= -150
boundlow = 5
verticalfollow = 0
floortension = 0
tension = 60

[PlayerInfo]
	p1startx=-70
	p1starty=0
	p1startz=0
	p1facing=1
	p2startx=70
	p2starty=0
	p2startz=0
	p2facing=-1
	leftbound=-1000
	rightbound=1000
	topbound=0
	botbound=0

[Scaling]
	topz=0
	botz=50
	topscale=1
	botscale=1.2

[Bound]
	screenleft=15
	screenright=15

[StageInfo]
	zoffset=215
	autoturn=1
	resetBG=0
        portraitscale = 1

[Shadow]
	color=0,0,0
	intensity=196
	reflect=0
	yscale=0.05
	fade.range=-100,0
[Reflection]
	intensity=0

[Music]
	bgmusic=sound/Acropolis.mp3
	bgvolume=255

[BGdef]
spr = Acropolis.sff
debugbg = 0

;----------

