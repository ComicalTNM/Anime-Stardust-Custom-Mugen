;--------------------------------------------------------
[Info]
name		= "MBTL Moonlit Altar"
Author		= "Beterhans"
displayname	= "MBTL Moonlit Altar TWS"
versiondate	= 04,20,2022;(MM-DD-YYYY)
mugenversion	= 1.1

[Camera]
	startx=0
	starty=0
	boundleft= -260
	boundright= 260
	boundhigh= -280
	boundlow=0
	verticalfollow=1
	tension=100
	floortension=150

	;;--- * v1.1 (zoom) *---
	;;cuthigh=30
	cutlow=10 ;;(240->180)
	;;---
	overdrawhigh=5
	overdrawlow=5
	;;---
	tensionhigh=85 ;;t_hi
	tensionlow=25
	startzoom=1
	zoomout= 0.85 ; 1
	zoomin=  1    ; 1.2
	;;--- * v1.1 (zoom) *---
;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx		= -280          ;Starting x coordinates
p1starty		= 0            ;Starting y coordinates
p1facing		= 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx		= 280
p2starty		= 0
p2facing		= -1

;--- Player 3 ---
p3startx		= -460          ;Starting x coordinates
p3starty		= 0            ;Starting y coordinates
p3facing		= 1            ;Direction player faces: 1=right, -1=left

;--- Player 4 ---
p4startx		= 460
p4starty		= 0
p4facing		= -1

;--- Common ---
;Don't change these values.
leftbound		= -4000 ;Left bound (x-movement)
rightbound		=  4000 ;Right bound
topbound		=  0     ;Top bound (z-movement)
botbound		=  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
;No need to change these values
topz			= 0       ;Top z-coordinate for scaling
botz			= 50      ;Bottom z-coordinate for scaling
topscale		= 1       ;Scale to use at top
botscale		= 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft		= 80  ;Dist from left of screen that player can move to
screenright		= 80  ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset			= 0				;Calculatred
zoffsetlink		= 100
autoturn		= 1
resetBG			= 0
localcoord		= 1280,720
xscale			= 1
yscale			= 1
portraitscale = 1


;--------------------------------------------------------
[Reflection]
intensity		= 0

[Shadow]
intensity		= 128
color			= 0,0,0
yscale			= 1
xshear			= 0
fade.range		= -100,0

;--------------------------------------------------------
[Music]
bgmusic 		= sound/MBTL_Moonlit_Altar_TWS.mp3
bgmvolume	= 255

;Main background definition
[BGdef]
spr				= MBTL_Moonlit_Altar_TWS.sff
debugbg			= 0
