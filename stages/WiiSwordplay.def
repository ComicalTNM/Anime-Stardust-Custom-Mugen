
[Info]
 ;Name of the stage.
name = "Swordplay"
displayname = "Swordplay Colosseum"
versiondate = 24,07,2025
mugenversion = 1.1
author = "MozaicoTheRobot"
attachedchar = common/VP_Ringout.def

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -320
boundright = 320
boundhigh = -1500
boundlow = 100
tension = 400
verticalfollow	= 1
floortension = 422			;-Normal jump highest point Pos Y * 4
tensionhigh = 422			;Same as floortension
tensionlow = 102			;Floor(ScreenHeight*4 - ScreenPos y*4)
tensionvel = 0.45
autocenter = 1
overdrawhigh = 120
overdrawlow = 120
cuthigh = 0
cutlow = 0
startzoom 	= 1
zoomout = 0.9
zoomin =  1.2
zoomindelay = 24
fov = 40
yshift = 0
near = 0.1
far=1500

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
 ;Player 1 starting coordinates.
p1startx = -320         ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 320
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -400
p3starty = 0
p3facing = 1

;--- Player 4 ---
p4startx = 400
p4starty = 0
p4facing = -1

;--- Common ---
leftbound  = -40000 ;Left bound (x-movement)
rightbound =  40000 ;Right bound

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 50    ;Dist from left of screen that player can move to
screenright = 50   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 680
autoturn = 1
resetBG = 1
localcoord = 960,720;1280, 720
xscale = 1.4
yscale = 1.4

;--------------------------------------------------------
[Shadow]
intensity = 96
color = 0,0,0
yscale = .4
fade.range = 0,0

;--------------------------------------------------------
[Reflection]
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = WiiSportsResort.wav
bgmloopstart = 487424
bgmvolume = 100

[Constants]
vnix_no_wallhit = 1
vnix_outofbounds = 1
;-------------------------------------
; Model definition
;-------------------------------------
; Model definition
[Model]
; Move the model away from the camera
offset = 0,-0.62,-2
; Scale of the model
scale = 0.17, 0.17, 0.17
;-------------------------------------
; IKEMEN GO ONLY, preview animation used in the Select screen
[Begin Action 9000]
9000,1, 0,0,-1
;-------------------------------------



;========================================================
; Background definition
;--------------------------------------------------------
[BGdef]
spr	= WiiSwordplay.sff
model	= WiiSwordplay.glb
debugbg = 0

[BG 6]
type = normal
spriteno = 0,0
start = 0,0
delta = 0,0
layerno = -1
zoomdelta = 0

[BG 6]
type = normal
spriteno = 0,1
start = 0,0
delta = 0,0
layerno = -1
zoomdelta = 0
trans = ADD
velocity = -.1, 0
tile = 1,0
tilespacing = 0,0