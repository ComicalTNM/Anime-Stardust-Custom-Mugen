[Info]
name = "DBFZ World Tournament Arena"
displayname = "DBFZ World Tournament Arena"
;versiondate = 09,30,2009
;mugenversion = 1.1
author = "jafar"

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -250
boundright = 250
boundhigh = -990
boundlow = 0
verticalfollow	= 0.9
floortension	= 420		; Player Pos y above ground, Camera start to follow, Ryu normal jump at 240p is -105

tension			= 150
tensionhigh		= 480	;Y Pos camera start to go up (from up to player pos)
tensionlow		= 150	;Y Pos Camera start to zoom out (from up to player pos)
startzoom		= 1
zoomin			= 1
zoomout			= 0.8
overdrawhigh	= 100
overdrawlow		= 100


;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
;--- Player 1 ---
p1startx = -280          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 280
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -380         
p3starty = 0          
p3facing = 1       

;--- Player 4 ---
p4startx = 380
p4starty = 0
p4facing = -1




;--- Common ---
 ;Don't change these values.
leftbound  = -1500 ;Left bound (x-movement)
rightbound =  1500 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound
;--------------------------------------------------------
[Bound]
screenleft = 60    ;Dist from left of screen that player can move to
screenright = 60   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 630
autoturn = 1
resetBG = 0    ;1e.
;localcoord = 320, 240
hires = 1
xscale = 0.25
yscale = 0.25
localcoord = 1280, 720
;--------------------------------------------------------
[Shadow]
intensity = 96
color = 0,0,0
yscale = .3
fade.range = 0,0

;--------------------------------------------------------
[Reflection]
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = sound/[DBFZ]World_Tournament_Arena.mp3
bgmloopstart = 118546
bgmloopend = 7313264
bgmvolume = 100

