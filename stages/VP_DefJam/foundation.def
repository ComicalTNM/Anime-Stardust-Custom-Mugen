;Assets from EA Canada
;Game taken from Def Jam: Fight for NY
;Ripped model taken from The Models Resource (Henchman800) and added vertex colors
;This stage can be worked and made only for 3D fork of I.K.E.M.E.N. Go. Download here: https://drive.google.com/file/d/1MBddb6RfBJFHcwPcjCjK1douxGiT8YWo/view?usp=drive_link
;--------------------------------------------------------
[Info]
name = "Foundation"
displayname = "Def Jam: Fight for NY - Foundation"
versiondate = 09,30,2009
mugenversion = 1.0
author = "WF4123"
; editor = V-Nix
; NPC Sprites = David Bazbar
attachedchar = common/VP_Foundation.def

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -600
boundright = 600
boundhigh = -250
boundlow = 0

verticalfollow = .85
floortension = 200
tension = 200

overdrawhigh = 120
overdrawlow = 120
cuthigh = 0
cutlow = 0

;Zoom is not yet supported in 3D stages.
;zoomout = .8

;Field of view. 30 is good for photorealistic scenes, but feel free to tweak this to your preference.
fov = 30
;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -160
p1starty = 0
p1facing = 1

;--- Player 2 ---
p2startx = 160
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -180
p3starty = 0
p3facing = 1

;--- Player 4 ---
p4startx = 180
p4starty = 0
p4facing = -1

;--- Common ---
leftbound  = -4000
rightbound =  4000

;--------------------------------------------------------
[Bound]
screenleft = 60
screenright = 60

;--------------------------------------------------------
[StageInfo]
zoffset = 660

autoturn = 1
resetBG = 1

localcoord = 640,480;1280, 720
xscale = 1
yscale = 1

portraitscale = 2

;--------------------------------------------------------
[Shadow]
intensity = 96
color = 0,0,0
yscale = .3
fade.range = 0,0

;--------------------------------------------------------
[Reflection]
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = foundation.mp3
bgmvolume = 255

[Constants]
vnix_no_wallhit = 1

;========================================================
[BGdef]

;Filename of 3D model file
;Supported file types are gltf and glb; supported by most modern 3D model programs.
;It is recommended to use PNG/JPEG/embedded image format for textures. Compressed dds textures are not supported.
;Make sure the world origin of the model is at the camera starting point.
model = foundation.glb

;Filename of .sff file, required by spec (and for stage portraits)
spr = foundation.sff

;debugbg = 0

[BG Floor Logo]
type  = normal
spriteno = 0,1
start = 0, 420
delta = 1.00,.95
mask = 1
trans = addalpha
alpha = 190,66
scalestart = .5,.5
xangle = 90
projection = perspective
focallength = 600
;xscale = 1.8,1
;yscalestart = 100
;yscaledelta = -1.0

[BG crowd 2 image]
type  	= anim
actionno = 1
start 	= -885,600
mask	= 1
trans	= add
delta 	= 1.65,1.5
scalestart = 2,2
layerno = 1

[BG crowd image]
type  	= anim
actionno = 1
start 	= 0,600
mask	= 1
trans	= add
delta 	= 1.65,1.5
scalestart = 2,2
layerno = 1

[BG crowd image]
type  	= anim
actionno = 1
start 	= 835,600
mask	= 1
trans	= add
delta 	= 1.65,1.5
scalestart = 2,2
layerno = 1

;-------------------------------------
; Model element definition; similar to [BG] blocks in 2D stages
[Model]

; X, Y, and Z coordinates of the model
offset = 0,-0.2,-1

; Scale of the model
scale = 0.15, 0.15, 0.15

