;; Fatal Fury 3 Andy's Stage MUGEN Edition
;; referred to the original version by Electro, thanks :)

[Info]
name = "Lotus - Morning"
displayname = "Lotus - Morning"
versiondate = 10,15,2014
mugenversion = 1.1

[Camera]
startx = 0
starty = 0
boundleft = -320
boundright = 320
boundhigh = -360
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

[PlayerInfo]
p1startx = -70
p1starty = 0
p1startz = 0
p1facing = 1
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1
leftbound = -1000
rightbound = 1000
topbound = 0
botbound = 0

[Scaling]
topz = 0
botz = 50
topscale = 1
botscale = 1.2

[Bound]
screenleft = 15
screenright = 15

[StageInfo]
zoffset = 215
autoturn = 1
resetBG = 0
portraitscale = 1

[Shadow]
color = 0,0,0
intensity = 196
reflect = 0
yscale = -0.05
fade.range = -100,0
[Reflection]
intensity = 0

[Music]
bgmusic = sound/Lotus.mp3
bgvolume = 100



;-----------------------
[BGdef]
spr = Lotus-Morning.sff
debugbg = 0


