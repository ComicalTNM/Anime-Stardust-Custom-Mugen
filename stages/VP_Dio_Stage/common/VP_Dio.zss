				postype: none;
				bindID: player($i), ID;
				facing: player($i), facing;
				removetime: -2;
				sprpriority: player($i), sprpriority + 1;
				superMoveTime: -1;
				pauseMoveTime: -1;
				#redirectID: player($i), ID;
			}
			playSnd{value: 0, 1; volume: 100;}
		}
	}
	
	if player($i), stateno != 100 {
		stopsnd{channel: 3;}
	}
}

if time >= 1 {
	changestate{value: 27}
}


# ========================================================================================================================================
# Secret Achievement Helper - Not Used
[StateDef 9999; anim: -2;]

if fightScreenState(RoundDisplay) && root, map(_vnix_broken_wall) != 0 {
	DestroySelf{}
}

if root, map(_vnix_broken_wall) != 0 && root, map(_vnix_secret_factor) = 0 {
	for s = 1; 8; 2 {
		if player($s), roundState = 4 && player($s), win {
			explod{
				anim: 20;
				postype: left;
				pos: 160,0;
				scale: .5,.5;
				angle: 0;
				facing: 1;
				ontop: 1;
				random: 0,0;
				bindtime: 1;
				removetime: -1;
				sprpriority: 5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
				palfx.time: -1;
				palfx.add: 255,255,255;
				interpolation.time: 60;
				interpolation.palfx.add: 0,0,0;
			}
			playsnd{value: 1, 2; volumescale: 200; freqmul: 1.0}
			parentmapset{map: "_vnix_secret_factor"; value: 1;}
		}
	}
	for t = 2; 8; 2 {
		if player($t), roundState = 4 && player($t), win {
			explod{
				anim: 21;
				postype: left;
				pos: 160,0;
				scale: .5,.5;
				angle: 0;
				facing: 1;
				ontop: 1;
				random: 0,0;
				bindtime: 1;
				removetime: -1;
				sprpriority: 5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
				palfx.time: -1;
				palfx.add: 255,255,255;
				interpolation.time: 60;
				interpolation.palfx.add: 0,0,0;
			}
			playsnd{value: 1, 2; volumescale: 200; freqmul: 1.0}
			parentmapset{map: "_vnix_secret_factor"; value: 1;}
		}
	}
}


# ========================================================================================================================================

[StateDef 175; anim: -2;]

[StateDef 5900; anim:-2;]
changestate{value:0;}

[StateDef -4]

ignorehitpause {
	screenBound{value: 0; movecamera: 0,0}
	assertSpecial{flag: invisible; flag2: noturntarget; flag3: noinput}
	notHitBy{value: SCA}
	width{value: 0,0}
	
	# Initialize
	if roundstate = 0 && time = 0 {
		# Run config
		call F_Vnix_Stage_Config();
		mapset{map: "_vnix_secret_factor"; value: 0}
		if roundNo = 1 {
			modifyBGCtrl {
				id: 1;
				time: 0,0;
				value: 1;
			}
			modifyBGCtrl {
				id: 2;
				time: 0,0;
				value: 0;
			}
		}
	}
}
