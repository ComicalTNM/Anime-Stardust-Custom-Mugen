# ========================================================================================================================================
# Water Effects P4
[StateDef 23; anim: -2;]

let i = 4;
if playerIDexist(player($i), ID) {

	#Idle
	if player($i), stateno = [0, 9999] && player($i), pos Y >= 0 && numExplod(40) = 0 {
		if time = 1 {
