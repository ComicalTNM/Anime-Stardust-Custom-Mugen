actionno = 3
layerno = 0
delta = .5,.5
start = -600, -50
trans = none
velocity = .6,.2
id = 1
mask = 1
sin.y = 7, 110

[BG Clouds 2 (Background)]
type = normal
spriteno = 2, 1
layerno = 0
start = 0, 79
delta = .7,.6
trans = none
id = 1
mask = 1
tile = 1, 0
velocity = 1.4,0
tilespacing = 0,0

[BG Flag]
type = anim
actionno = 2
layerno = 0
delta = 1,1
start = 334, 173
trans = none
id = 1
mask = 1
sin.y = 7, 150

[BG Fan on the Right]
type = anim
actionno = 1
layerno = 0
delta = 1,1
start = 330, 178
trans = none
id = 1
mask = 1
sin.y = 7, 150

[BG Fan on the Left]
type = anim
actionno = 1
layerno = 0
delta = 1,1
start = -360, 178
trans = none
id = 1
mask = 1
sin.y = 7, 150

[BG Floor]
type = normal
spriteno = 0, 0
layerno = 0
delta = 1,.9
start = 0, 60
trans = none
mask = 1
tile = 0, 0
id = 0
tilespacing = 0,0
sin.y = 7, 150


