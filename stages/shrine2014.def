;; Last Blade "Shrine" MUGEN Edition
;; (options: H-loop)


[Info]
	name="Shrine2014"
	displayname="Shrine2014"
	versiondate=11,23,2014
	mugenversion=1.1


[Camera]
	startx=0
	starty=0
	boundleft= -260
	boundright= 260
	boundhigh= -280
	boundlow=0
	verticalfollow=1
	tension=100
	floortension=150

	;;--- * v1.1 (zoom) *---
	;;cuthigh=30
	cutlow=10 ;;(240->180)
	;;---
	overdrawhigh=5
	overdrawlow=5
	;;---
	tensionhigh=85 ;;t_hi
	tensionlow=25
	startzoom=1
	zoomout= 0.85 ; 1
	zoomin=  1    ; 1.2
	;;--- * v1.1 (zoom) *---

[PlayerInfo]
	p1startx=-73
	p1starty=0
	p1startz=0
	p1facing=1

	p2startx=73
	p2starty=0
	p2startz=0
	p2facing=-1

	leftbound=-1000
	rightbound=1000
	topbound=0
	botbound=0

[Scaling]
	topz=0
	botz=50
	topscale=1
	botscale=1.2

[Bound]
	screenleft=15
	screenright=15

[StageInfo]
	zoffset=215
	autoturn=1
	resetBG=0
	localcoord=320,240
        portraitscale = 1


[Shadow]
	color=0,0,0
	intensity=196
	reflect=1
	yscale=-0.05
	fade.range=-120,0
[Reflection]
	intensity=128


[Music]
	bgmusic=sound/shrine2014.mp3
	bgvolume=0

[BGdef]
	spr=shrine2014.sff
	debugbg=0





