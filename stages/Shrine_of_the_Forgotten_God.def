;--------------------------------------------------------54 anim
[Info]
name = "Shrine of the Forgotten God"
Author = "GDM & Margatroid"

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -380
boundright = 380
boundhigh = -300
boundlow = 0
verticalfollow = 1.2

floortension = 100
tension = 200
overdrawhigh = 100
overdrawlow = 100
cuthigh = 0
cutlow = 0
zoomin = 1
zoomout = .8;.7 
tensionhigh = 250
tensionlow = 200

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
 ;Player 1 starting coordinates.
 ;p1startx is typically -70 and p2startx is 70.
 ;p1starty and p1startz should be 0.
p1startx = -200          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1startz = 0            ;Starting z coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 200
p2starty = 0
p2startz = 0
p2facing = -1

;--- Common ---
 ;Don't change these values.
leftbound  = -4000 ;Left bound (x-movement)
rightbound =  4000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
screenleft = 15    ;Dist from left of screen that player can move to
screenright = 15   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 435 ;420
autoturn = 1
resetBG = 1
localcoord = 850,480
xscale = 1
yscale = .8
;--------------------------------------------------------
[Shadow]
intensity = 90
yscale = 0.15
fade.range = -400,-100

;--------------------------------------------------------
[Reflection]
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = sound/Rooftop.mp3
bgvolume = 0


[BGdef]
spr = stages/Shrine_of_the_Forgotten_God.sff
debugbg = 0

