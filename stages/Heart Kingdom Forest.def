16,0, 0,0, 70,,AS64D256,1,1,0                   
interpolate blend
16,0, 0,0, 90,,AS196D256,1,1,0
interpolate blend
16,0, 0,0, 75,,AS128D256,1,1,0                    
interpolate blend
16,0, 0,0, 120,,AS224D256,1,1,0

; Lens 2
[Begin Action 17]             
interpolate blend
16,1, 0,0, 110, , A
interpolate blend
16,1, 0,0, 240, , A
interpolate blend
16,1, 0,0, 120, , A
interpolate blend
16,1, 0,0, 80, , A
interpolate blend
16,1, 0,0, 120, , A
interpolate blend
16,1, 0,0, 140, , A
interpolate blend
16,1, 0,0, 175, , A
interpolate blend
16,1, 0,0, 320, , A

; Lens 3
[Begin Action 18]             
interpolate blend
16,2, 0,0, 175,,AS256D256,1,1,0                  
interpolate blend
16,2, 0,0, 150,,AS196D256,1,1,0                    
interpolate blend
16,2, 0,0, 120,,AS256D256,1,1,0                   
interpolate blend
16,2, 0,0, 80,,AS256D256,1,1,0                   
interpolate blend
16,2, 0,0, 70,,AS64D256,1,1,0                   
interpolate blend
16,2, 0,0, 120,,AS196D256,1,1,0
interpolate blend
16,2, 0,0, 150,,AS128D256,1,1,0                    
interpolate blend
16,2, 0,0, 130, , AS224D256

