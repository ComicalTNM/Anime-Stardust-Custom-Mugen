[BG 0, Sky]
Type = Normal
Spriteno = 0, 0
Mask = 1
Start = 0, 0
Delta = 2,2
Tile = 1, 0
velocity = -0.1, 0


[BG Base]
type = normal
spriteno =0,1
Delta=2,2
mask=1


[BG 0, Lens Flare 1]
Type = Anim
ActionNO = 16
Mask = 1
Start = 0,0
Delta = 2, 2
LayerNo = 1

[BG 0, Lens Flare 2]
Type = Anim
ActionNO = 17
Mask = 1
Start = 0,0
Delta = 2, 2
LayerNo = 1

[BG 0, Lens Flare 3]
