ActionNO = 18
Mask = 1
Start = 0, 0
Delta = 2,2
LayerNo = 1

; Lens 1
[Begin Action 16]             
interpolate blend
16,0, 0,0, 210,,AS256D256,1,1,0                  
interpolate blend
16,0, 0,0, 240,,AS196D256,1,1,0                    
interpolate blend
16,0, 0,0, 150,,AS256D256,1,1,0                   
interpolate blend
16,0, 0,0, 100,,AS256D256,1,1,0                   
