;--------------------------------------------------------
[Info]
name = "Final Valley (upper)"
displayname = "Final Valley (upper)"
versiondate = 10,30,2242
mugenversion = 1.1
author = "Vogel"
;--------------------------------------------------------
[Camera]
startx =0
starty =0
boundleft=-760
boundright= 760
boundhigh= -200
boundlow =0
verticalfollow = 1.2
floortension = 100
tension = 400
overdrawhigh = 100
overdrawlow = 100
cuthigh = 0
cutlow = 0
zoomin = 1.3
zoomout = .65
tensionhigh = 350
tensionlow = 200
;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -500      
p1starty = 0            ;
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 500
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -720          ;Starting x coordinates
p3starty = 0            ;Starting y coordinates
p3facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 4 ---
p4startx = 720
p4starty = 0
p4facing = -1

;--- Common ---
 ;Don't change these values.


leftbound  = -1800
rightbound =  1800


;leftbound  = -3000
;rightbound =  3000
;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 60;Dist from left of screen that player can move to
screenright = 60  ;Right edge
; use 15 for low res
; use 30 for high res
; use 60 for HD res
;--------------------------------------------------------
[StageInfo]
 ;"Ground" level where players stand at, measured in pixels from the
 ;top of the screen.
 ;Adjust this value to move the ground level up/down in the screen.
 ;***
zoffset = 650


 ;Leave this at 1. It makes the players face each other
autoturn = 1

 ;Set the following to 1 to have the background reset itself between
 ;rounds.
resetBG = 0
localcoord = 1280, 720


 ;Horizontal and vertical scaling factor for drawing.
xscale = 1
yscale = 1
;--------------------------------------------------------
[Shadow]
intensity = 100
color = 0,0,0
yscale = 0.15
fade.range = -400, -100
xshear = -0.55






;--------------------------------------------------------
[Reflection]
intensity = 0


;--------------------------------------------------------
[Music]
bgmusic=stages/Final Valley (upper).mp3
bgmvolume = 255


; Main background definition

;Action code tutorial by vogel
;[Begin Action 1]
sprite |Placement x,y |Flip (H for horizontal/ V for vertical) |Transparency 0-256 |Size (1 default)|angle for rotating animation 0-360 ( the plus sign in fighter factory is the axle! move the sprite with "start=" )
;0,0,  |0,0,0           |,H or V                                 |,0,0               |,1,1            |,0


;____________________________________________________________________________________________________________________________________
