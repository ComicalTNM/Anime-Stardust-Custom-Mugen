[Info]
name = "School Rooftop"
displayname = "School Rooftop"
author = "President Devon"
versiondate = 23,12,2016
mugenversion = 1.1

[Camera]
startx=0
starty=0
boundleft=-130
boundright=130
boundhigh=-130
boundlow = 5
verticalfollow = 0
floortension = 0
tension = 60

[PlayerInfo]
p1startx = -70
p1starty = 0
p1facing = 1

p2startx = 70
p2starty = 0
p2facing = -1

leftbound  = -1000
rightbound =  1000

[Bound]
screenleft = 15
screenright = 15

[StageInfo]
zoffset = 220
autoturn = 1
resetBG = 0
localcoord = 427,240
portraitscale = 1

[Shadow]
intensity = 64
color = 128,128,128
yscale = -.1
fade.range = 0,0

[Reflection]
intensity = 0

[Music]
bgmusic = sound/SchoolRooftop.mp3
bgmvolume = 255

[BGdef]
spr=SchoolRooftop.sff
debugbg=1

