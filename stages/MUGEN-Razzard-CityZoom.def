;-------------------------------------------------------------------------------
;-------------------------[ M U G E N Stage Edit ]------------------------------
;-----------------[ Razzard-A1 City(Zoom) Stage - 03/01/2021 ]------------------
;------------------------------[ By: NexT One ]---------------------------------
;-------------------------------------------------------------------------------
;Informaçăo
[info]
name = "Razzard City" ; Razzard-A1 City  /  R-A1 City 

; "Razzard-A1 City" is a city that most of the times the weather is rainy 
; (the temperature is varied)

; It is found on the planet Andreas One, in an unknown galaxy.


;-------------------------------------------------------------------------------
;Música
[Music]
bgmusic = sound/razzard.mp3
bgvolume = 255

;-------------------------------------------------------------------------------
;Camera
[Camera]
startx = 0
starty = 0
boundleft = -320
boundright = 320
boundhigh = -40
boundlow = 0
verticalfollow = 0.2
floortension = 0
tension = 50

;Zoom option
startzoom = 1
zoomin = 1
zoomout = 0.73

;-------------------------------------------------------------------------------
;Informaçăo do Player
[PlayerInfo]
p1startx = -80
p1starty = 0
p1startz = 0
p1facing = 1
p2startx = 80
p2starty = 0
p2startz = 0
p2facing = -1
leftbound  = -1000
rightbound = 1000
topbound  =  0
botbound  =  0

;-------------------------------------------------------------------------------
;Dimensionamento 
[Scaling]
topz = 0
botz = 50
topscale = 1
botscale = 1.2

;-------------------------------------------------------------------------------
;Limite
[Bound]
screenleft = 20
screenright = 20

;-------------------------------------------------------------------------------
;Informaçőes Básicas do Stage
[StageInfo]
zoffset = 215
autoturn = 1
resetBG = 1
portraitscale = 1

;-------------------------------------------------------------------------------
;Sombra
[Shadow]
intensity = 110
color = 0,0,0
yscale = .2

;-------------------------------------------------------------------------------
;Reflexo
[Reflection]
intensity = 50

;-------------------------------------------------------------------------------
;Local do SFF
[BGdef]
spr = stages/MUGEN-Razzard-City.sff

