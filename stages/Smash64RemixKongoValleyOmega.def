[Info]
name = "Smash 64 Remix - Kongo Valley Omega" ; Ripped From Smash 64 Remix
displayname = "Kongo Valley Omega"
author = "xcheatdeath"
attachedchar = common/VP_Ringout.def

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -225
boundright = 225 
boundhigh = -450 
boundlow = 0

verticalfollow = 1
floortension = 250
tension = 100

overdrawhigh = 120
overdrawlow = 120
cuthigh = 0
cutlow = 0
zoomin=1
zoomout=0.75
;Field of view. 30 is good for photorealistic scenes, but feel free to tweak this to your preference.
fov = 75
yshift = -.25
;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -146
p1starty = 0
p1facing = 1

;--- Player 2 ---
p2startx = 146
p2starty = 0
p2facing = -1

;--- Common ---
leftbound  = -4000
rightbound =  4000

;--------------------------------------------------------
[Bound]
screenleft = 75 ; 30
screenright = 75; 30

;--------------------------------------------------------
[StageInfo]
zoffset = 660

autoturn = 1
resetBG = 0

localcoord = 640,480
xscale = 1
yscale = 1

portraitscale = 1

;--------------------------------------------------------
[Shadow]
intensity=225
yscale=0.25
fade.range=-100,0

;--------------------------------------------------------
[Reflection]
intensity = 0
yscale=1
fade.range=-100,0
;--------------------------------------------------------
[Music]
bgmusic =Smash64RemixKongoValleyOmega.mp3
bgmvolume = 100

[Constants]
vnix_outofbounds = 1
vnix_no_wallhit = 1

;========================================================
[BGdef]

;Filename of 3D model file
;Supported file types are gltf and glb; supported by most modern 3D model programs.
;It is recommended to use PNG/JPEG/embedded image format for textures. Compressed DDS textures are not supported.
;Make sure the world origin of the model is at the camera's starting point.
model = Smash64RemixKongoValleyOmega.glb

;Filename of .sff file, required by spec (and for stage portraits)
spr = Smash64RemixKongoValleyOmega.sff

;debugbg = 0

;-------------------------------------
; Model element definition
[Model]
; X, Y, and Z coordinates of the model
offset = 0,-0.2,-0.47

; Scale of the model
scale = 0.16, 0.16, 0.16
;-------------------------------------
; Stage portrait data
[Begin Action 9000]
9000,1, 0,0,-1
