;; Aurora BG from
;; testeach (tes.com)
;; Create the Aurora Borealis by Beth Laginess


[Info]
name = "Snow Aurora"
displayname = "Snow Aurora"
versiondate = 10,31,2017
mugenversion = 1.1

[Camera]
startx = 0
starty = 0
boundleft = -260
boundright = 260
boundhigh = -280
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

[PlayerInfo]
p1startx = -70
p1starty = 0
p1startz = 0
p1facing = 1

p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1

leftbound = -1000
rightbound = 1000
topbound = 0
botbound = 0


[Scaling]
topz = 0
botz = 50
topscale = 1
botscale = 1.2


[Bound]
screenleft = 15
screenright = 15


[StageInfo]
zoffset = 215
autoturn = 1
resetBG = 0
localcoord = 320,240
portraitscale = 1

[Shadow]
color = 0,0,0
intensity = 196
reflect = 0
yscale = -0.05
fade.range = -100,0
[Reflection]
intensity = 0

[Music]
bgmusic = sound/SnowAurora.mp3
bgvolume = 100

;----------------
[BGdef]
spr = SnowAurora.sff
debugbg = 0





