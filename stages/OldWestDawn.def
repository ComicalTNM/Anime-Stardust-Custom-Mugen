;; RB2 Terry stage MUGEN Edition

[Info]
	name="Old West - Dawn"
	displayname="Old West - Dawn"
	versiondate=12,12,2017
;op;	mugenversion=1.1

[Camera]
startx=0
starty=0
boundleft= -260
boundright= 260
boundhigh= -260
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

[PlayerInfo]
	p1startx=-70
	p1starty=0
	p1startz=0
	p1facing=1

	p2startx=70
	p2starty=0
	p2startz=0
	p2facing=-1

	leftbound=-1000
	rightbound=1000
	topbound=0
	botbound=0

[Scaling]
	topz=0
	botz=50
	topscale=1
	botscale=1.2

[Bound]
	screenleft=15
	screenright=15

[StageInfo]
	zoffset=210
	autoturn=1
	resetBG=0
	localcoord=320,240
        portraitscale = 1


[Shadow]
intensity = 150
color = 0,0,0
yscale = .2
fade.range = -90,0

;[Reflection]
;	intensity=64


[Music]
	bgmusic=sound/OldWestDawn.mp3
	bgvolume=0

[BGdef]
	spr=OldWestDawn.sff
	debugbg=0





