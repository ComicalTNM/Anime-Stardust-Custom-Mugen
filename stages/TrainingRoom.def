;--------------------------------------------------------
[Info]
name = "TrainingRoom"
DisplayName = "MBTL Training Room" 
Author = "David11"
mugenversion = 1.1

[Camera]
startx = 0
starty = 0
boundleft = -3000
boundright = 3000
boundhigh = -4200
boundlow = 0

verticalfollow	= 0.9
floortension	= 420		; Player Pos y above ground, Camera start to follow, Ryu normal jump at 240p is -105

tension			= 150
tensionhigh		= 480	;Y Pos camera start to go up (from up to player pos)
tensionlow		= 150	;Y Pos Camera start to zoom out (from up to player pos)
startzoom		= 1
zoomin			= 1
zoomout			= 0.8
overdrawhigh	= 100
overdrawlow		= 100

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -280          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 280
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -380         
p3starty = 0          
p3facing = 1       

;--- Player 4 ---
p4startx = 380
p4starty = 0
p4facing = -1

;--- Common ---
;Don't change these values.
leftbound  = -4000 ;Left bound (x-movement)
rightbound = 4000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
 ;No need to change these values
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 60   ;Dist from left of screen that player can move to
screenright = 60   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 630
autoturn = 1
resetBG = 0
localcoord = 1280, 720

;--------------------------------------------------------
[Shadow]
intensity = 100
color = 0, 0, 0
yscale = 0
xshear = 0

[Reflection]
intensity = 80

;--------------------------------------------------------
[Music]
bgmusic = sound/TrainingRoom.wav
bgmvolume = 255

;Main background definition
[BGdef]
spr = TrainingRoom.sff
debugbg = 0

;--------------------------------------------------------
; Layers:

[BG Wall]
type = normal
spriteno = 0,0
scalestart = 0.5,0.5
tile = 1, 1
Start = 0, 227
Delta = 0.325, 1.4

[BG 0, Floor]
Type = Parallax
SpriteNO = 0, 0
Start = 0, 800
Delta = 0.325, 0.44
Tile = 1, 1
scalestart = 0.5,0.5
;XScale = 1, 0.8;
Width = 2048, 10240
YScaleDelta = -.3
YScaleStart = 80

[BG Floor Reflex]
type = normal
spriteno = 0,1
scalestart = 0.5,0.65
start = 0, 480
tile = 1, 0
Mask = 1
Delta = 0.325, 1.4
Trans = AddAlpha
Alpha = 128, 128

[BG Gradient]
type = normal
spriteno = 0,2
scalestart = 0.5, 1
start = 0, 482
tile = 1, 0
Mask = 1
Delta = 0.325, 1.4
Trans = AddAlpha
Alpha = 192, 64

[BG Floor Gradient 1]
type = normal
spriteno = 0,2
scalestart = 0.5, -.3
start = 0, 480
tile = 1, 0
Mask = 1
Delta = 0.325, 1.4
Trans = AddAlpha
Alpha = 192, 64

[BG Floor Gradient 2]
type = normal
spriteno = 0,2
scalestart = 0.5, 1
start = 0, 800
tile = 1, 0
Mask = 1
YScaleStart = 80
Trans = AddAlpha
Alpha = 192, 64

[BG 0, Wall Shadow 1]
Type = Normal
SpriteNO = 0, 3
Start = 1500, 490
Delta = 0.325, 1.4
Tile = 0, 0
ScaleStart = -3, 1
Mask = 1
Trans = AddAlpha
Alpha = 192, 64

[BG 0, Floor Shadow 1]
Type = Normal
SpriteNO = 0, 3
Start = 1800, 1510
Delta = 0.325, 1.4
Tile = 0, 0
ScaleStart = -2, 1
Mask = 1
Trans = AddAlpha
Alpha = 192, 64

[BG 0, Wall Shadow 2]
Type = Normal
SpriteNO = 0, 3
Start = -1500, 490
Delta = 0.325, 1.4
Tile = 0, 0
ScaleStart = 3, 1
Mask = 1
Trans = AddAlpha
Alpha = 192, 64

[BG 0, Floor Shadow 2]
Type = Normal
SpriteNO = 0, 3
Start = -1800, 1510
Delta = 0.325, 1.4
Tile = 0, 0
ScaleStart = 2, 1
Mask = 1
Trans = AddAlpha
Alpha = 192, 64



[Begin Action 9000]
Interpolate Scale
Interpolate Blend
9000,1, 0,0, 15, , AS0D0, 0.9,0.9
LoopStart
Interpolate Scale
Interpolate Blend
9000,1, 0,0, 600, , AS256D0, 0.94,0.94
Interpolate Scale
Interpolate Blend
9000,1, 0,0, 600, , AS256D0
