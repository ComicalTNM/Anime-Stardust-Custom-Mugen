;--------------------------------------------------------
[Info]
name			= "UGF-The Rose Garden"
DisplayName		= "UGF-The Rose Garden"
Author			= "Beterhans"
versiondate		= 02,16,2021;(MM-DD-YYYY)
mugenversion		= 1.1

[Camera]
startx			= 0
starty			= 0
boundleft			= -300
boundright		=  300
boundhigh			= -50
boundlow			= 0

tension			= 200	; 0.3125 of width			Back Edge x
tensionhigh		= 230	; 0.42 of Hight  Y Pos camera start to go up (from up to player pos)
tensionlow		= 40	; 0.39 of Hight  Y Pos Camera start to zoom out (from up to player pos)
startzoom			= 1
zoomin			= 1
zoomout			= 0.8
overdrawhigh		= 60
overdrawlow		= 60

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -280          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 280
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -380         
p3starty = 0          
p3facing = 1       

;--- Player 4 ---
p4startx = 380
p4starty = 0
p4facing = -1

;--- Common ---
;Don't change these values.
leftbound		= -5000 ;Left bound (x-movement)
rightbound	=  5000 ;Right bound
topbound		=  0     ;Top bound (z-movement)
botbound		=  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
;No need to change these values
topz			= 0       ;Top z-coordinate for scaling
botz			= 50      ;Bottom z-coordinate for scaling
topscale			= 1       ;Scale to use at top
botscale			= 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft		= 40  ;Dist from left of screen that player can move to
screenright		= 40  ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset			= 0			;Calculatred
zoffsetlink		= 2
autoturn			= 1
resetBG			= 0
localcoord		= 1280,720
xscale			= 1
yscale			= 1


;--------------------------------------------------------
[Reflection]
intensity			= 64

[Shadow]
intensity			= 64
color			= 0,0,0
yscale			= 0.2
fade.range		= -300,-40
xshear			= 0

;--------------------------------------------------------
[Music]
bgmusic 			= sound/stage_grassland_night.ogg
bgm.loop			= 1
bgmloopstart		= 618229
bgmloopend		= 8681705
bgmvolume			= 100

;Main background definition
[BGdef]
spr			= UGF_01_The_Rose_Garden.sff
debugbg			= 0
