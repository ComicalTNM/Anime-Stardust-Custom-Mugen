
[Info]
name ="CorridaColosseum"
displayname="CorridaColosseum"
Autor = "Oonquil"
versiondate=04/04/2012
mugenversion=04,14,2001


;--------------------------------------------------------
[Camera]
 ;Camera starting position: Usually 0 for both
 ;***
startx = 0
starty = 0
boundleft = -400
boundright = 400
boundhigh = -85
boundlow = 0
verticalfollow = 0.3
floortension = 50
tension = 300
cuthigh = 0
cutlow = 0
startzoom = 0.85
zoomin = 1
zoomout = 0.85


;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -100          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 100
p2starty = 0
p2facing = -1

;--- Player 2 ---
p3startx = -170
p3starty = 0
p3facing = 1


;--- Player 2 ---
p4startx = 170
p4starty = 0
p4facing = -1


;--- Common ---
 ;Don't change these values.
leftbound  = -2000 ;Left bound (x-movement)
rightbound = 2000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
 ;No need to change these values
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 15    ;Dist from left of screen that player can move to
screenright = 15   ;Right edge



;--------------------------------------------------------
[StageInfo]
zoffset = 227 ;Regula la altura a la que aparecen los chars 
zoffsetlink = 30 ;
autoturn = 1
resetBG = 1
hires = 1
resetBG = 0
localcoord = 480,270
portraitscale = 1

;--------------------------------------------------------
[Shadow]
color = 255,255,255
yscale = .3

 ;Set to 1 to draw "reflection" shadows. Defaults to 0.
reflect = 0

;--------------------------------------------------------


[Music]
bgmusic  = sound/One Piece Super Grand Battle! X OST - Corrida Colosseum.mp3
bgvolume = 255


;--------------------------------------------------------
[BGdef]
spr = CorridaColosseum.sff
debugbg = 1


