	}

	# Swordplay Stage
	if stagevar(info.name) = "Swordplay" {
		map(_vnix_boundright) := 420; # Ringout Right
		map(_vnix_boundleft) := -420; # Ringout Left
		map(_vnix_maxright) := 725; # Max Stagebound Right
		map(_vnix_maxleft) := -725; # Max Stagebound Left
