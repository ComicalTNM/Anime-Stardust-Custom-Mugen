	if stagevar(info.name) = "Egyptian Crypt" {
		map(_vnix_boundright) := 400; # Ringout Right
		map(_vnix_boundleft) := -340; # Ringout Left
		map(_vnix_maxright) := 725; # Max Stagebound Right
		map(_vnix_maxleft) := -725; # Max Stagebound Left
		map(_vnix_groundlevel) := 300; # Ringout Depth
		map(_vnix_splash) := 0; # Splash Sound
		map(_vnix_smash_fx) := 0; # Smash FX
