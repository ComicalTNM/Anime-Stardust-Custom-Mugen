		map(_vnix_wall_left) := 1; # Left Wall
	}
}

# Ring Out Helper
persistent(0) if numHelper(50) = 0 && (map(_vnix_boundright) != 0 || map(_vnix_boundleft) != 0) {
	helper{id: 50; stateno: 50;}
	if map(_vnix_maxright) > 0 && map(_vnix_wall_right) = 0 {
		modifyStageVar{
			camera.boundright: map(_vnix_maxright);
		}
	}
	if map(_vnix_maxleft) < 0 && map(_vnix_wall_left) = 0  {
		modifyStageVar{
			camera.boundleft: map(_vnix_maxleft);
		}
	}
}

# Wall Helper Right
persistent(0) if numHelper(51) = 0 && map(_vnix_wall_right) && roundState = 2 {
	map(_vnix_wallexist_right) := 1;
	helper{id: 51; stateno: 51;}
}

# Wall Helper Left
persistent(0) if numHelper(55) = 0 && map(_vnix_wall_left) && roundState = 2 {
	map(_vnix_wallexist_left) := 1;
	helper{id: 55; stateno: 55;}
}

# Meta World Helper
persistent(0) if numHelper(100) = 0 && stagevar(info.name) = "spider's web" {
	helper{id: 100; stateno: 100;}
}

# ========================================================================================================================================
# Ring Out Helper
[StateDef 50; anim: -2;]
		
for i = 1; 8; 1 {
	if playerIDExist(player($i), ID) {
		if ((player($i), Pos X + player($i), cameraPos X) > root, map(_vnix_boundright) || (player($i), Pos X + player($i), cameraPos X) < root, map(_vnix_boundleft))
		&& player($i), standBy = 0 && player($i), stateno != const(StateTagEnteringScreen) && player($i), stateno != const(StateTagLeavingScreen)
		&& player($i), stateno != const(StateTagJumpingIn) && player($i), stateno != 4209090 && player($i), stateno != 4209110
		&& player($i), stateno != 4209130 && roundState > 1
		{
			assertspecial{flag: noshadow; redirectID: player($i), ID;}
			assertspecial{flag: skipKODisplay;}
			groundLevelOffset{value: root, map(_vnix_groundlevel); redirectID: player($i), ID;}
			
			#sprpriority{layerno: -1; redirectID: player($i), ID;}
			
			if player($i), alive {
				if player($i), pos Y < 0 {
					stateTypeSet{physics: A; redirectID: player($i), ID;}
					if player($i), moveType = I {
						changeAnim{value: 41; redirectID: player($i), ID;}
					}
				}
			}
			
			if player($i), pos Y >= 0
			|| ((player($i), Pos X + player($i), cameraPos X) > root, map(_vnix_boundright) + 270 || (player($i), Pos X + player($i), cameraPos X) < root, map(_vnix_boundleft) - 270) {
				if player($i), map(_vnix_smash_snd) = 0 && roundState = 2 {
					playsnd{value: 0, 0; volumescale: 200; freqmul: 1.0; channel: 72}
					playsnd{value: 0, 0; volumescale: 200; freqmul: 1.0; channel: 72}
					
					explod{
						anim: 1;
						postype: left;
						pos: const240p(160),const240p(120);
						scale: .5,.25;
						angle: 0;
						facing: 1;
						ontop: 1;
						#trans: addalpha;
						#alpha: 0,256;
						sprpriority: 5;
						pausemovetime: -1;
						supermovetime: -1;
						ownpal: 1;
						palfx.time: -1;
						palfx.add: 255,255,255;
						interpolation.time: 4;
						interpolation.palfx.add: 0,0,0;
						interpolation.scale: .5,.5;
						#interpolation.alpha: 256,0;
					}
					
					# Ring Out Text
					if player($i), teamSide = 1 {
						lifebaraction{text: "Ring Out"; top: 1; time: 180; redirectID: player(2), ID;}
					} else {
						lifebaraction{text: "Ring Out"; top: 1; time: 180; redirectID: player(1), ID;}
					}
					
					player($i), map(_vnix_phoenix_buff) := 0;
					player($i), map(_vnix_phoenix_bufftime) := 0;
					
					player($i), map(_vnix_smash_snd) := 1;
				}
				lifeadd{value: -9999; absolute: 1; kill: 1; redirectID: player($i), ID;}
				#posSet{y: 0; redirectID: player($i), ID;}
				
				if player($i), map(_vnix_ring_out) = 0 && player($i), pos Y >= 0 {
					selfState{value: 5150; redirectID: player($i), ID;}
					stateTypeSet{physics: S; redirectID: player($i), ID;}
					if root, map(_vnix_splash) {
						playsnd{value: 0, 1; volumescale: 200; freqmul: 1.0; channel: 72}
					}
					if root, map(_vnix_smash_fx) {
						playsnd{value: 0, 2; volumescale: 200; freqmul: 1.0; channel: 72}
						envShake{time: 100; freq: 210; ampl: 2}
						explod{
							anim: 50;
							pos: 0, 100 - root, map(_vnix_groundlevel);
							scale: .5,.5;
							postype: none;
							facing: (ifelse(Random <= 500, 1, -1));
							removetime: -2;
							bindtime: 1;
							bindID: player($i), ID;
							sprpriority: 5;
							#trans: addalpha;
							#alpha: 256,256;
						}
					}
					player($i), map(_vnix_ring_out) := 1;
				}
				
			}	
		}
	}
}


# ========================================================================================================================================
# Wall Helper Right
[StateDef 51; anim: -2;]

if time = 0 {
	for i = 1; 8; 1 {
		if playerIDexist(player($i), ID) {
			if player($i), moveType = H
			&& player($i), statetype != L
			&& (player($i), stageBackEdgeDist <= 0 || player($i), stageFrontEdgeDist <= 0)
			&& (player($i), pos X + player($i), cameraPos X) > 0
			&& player($i), incustomanim = 0
			&& roundState = 2
			#&& player($i), time = 1
			{
				if root, map(_vnix_wallhp_right) != 50 {
					if player($i), stateType = S || player($i), stateType = C {
						if player($i), stateno != 301027 && player($i), statetype != L && player($i), selfStatenoExist(301027) {
							selfState{value: 301027; redirectID: player($i), ID;}
						}
					} else if player($i), stateType = A && player($i), pos Y < -20{
						if player($i), stateno != 301028 && player($i), statetype != L && player($i), selfStatenoExist(301028) {
							selfState{value: 301028; redirectID: player($i), ID;}
						}
					}
				}
				changestate{value: 52}
			}
		}
	}
}

if time = 1 {
	changestate{value: 51}
}


# ========================================================================================================================================
# Wall Helper Right 2
[StateDef 52; anim: -2;]

persistent(0) if time = 0 && root, map(_vnix_wall_right) = 1 {
	if root, map(_vnix_wallhp_right) != 50 {
		parentmapadd{map: "_vnix_wallhp_right"; value: 10}
	} else {
		for i = 1; 8; 1 {
			if playerIDexist(player($i), ID) && player($i), moveType = H {
				explod{
					anim: 51;
					postype: none;
					pos: 0,-100;
					scale: .5,.5;
					angle: 90;
					facing: 1;
					ontop: 0;
					under: 0;
					vel: -2,0;
					bindID: player($i), ID;
					sprpriority: 0;
					removetime: -2;
					pausemovetime: -1;
					supermovetime: -1;
					trans: Addalpha;
					alpha: 256,256;
					ownpal: 1;
					interpolation.time: 30;
					interpolation.alpha: 0,256;
				}
				explod{
					anim: 51;
					postype: none;
					pos: 0,0;
					scale: .5,.5;
					angle: 90;
					facing: 1;
					ontop: 0;
					under: 0;
					vel: -2,0;
					bindID: player($i), ID;
					sprpriority: 0;
					removetime: -2;
					pausemovetime: -1;
					supermovetime: -1;
					trans: Addalpha;
					alpha: 256,256;
					ownpal: 1;
					interpolation.time: 30;
					interpolation.alpha: 0,256;
				}
			}
		}
		pause{time: 30}
		bgpalfx{
			time: 30;
			add: -132, -132, -132;
		}
		playsnd{value: 0, 3; volumescale: 200; freqmul: 1.0}
		parentmapset{map: "_vnix_wall_right"; value: 0}
		modifyStageVar{
			camera.boundright: root, map(_vnix_maxright);
		}
	}
}

if root, map(_vnix_wall_right) = 1 {
	if time >= 30 {
		changestate{value: 51}
	}
}

if time = 1 && root, map(_vnix_wall_right) = 0 {
	destroySelf{}
}

# ========================================================================================================================================
# Wall Helper Left
[StateDef 55; anim: -2;]

if time = 0 {
	for i = 1; 8; 1 {
		if playerIDexist(player($i), ID) {
			if player($i), moveType = H
			&& player($i), statetype != L
			&& (player($i), stageBackEdgeDist <= 0 || player($i), stageFrontEdgeDist <= 0)
			&& (player($i), pos X + player($i), cameraPos X) < 0
			&& player($i), incustomanim = 0
			&& roundState = 2
			#&& player($i), time = 1
			{
				if root, map(_vnix_wallhp_left) != 50 {
					if player($i), stateType = S || player($i), stateType = C {
						if player($i), stateno != 301027 && player($i), statetype != L && player($i), selfStatenoExist(301027) {
							selfState{value: 301027; redirectID: player($i), ID;}
						}
					} else if player($i), stateType = A && player($i), pos Y < -20{
						if player($i), stateno != 301028 && player($i), statetype != L && player($i), selfStatenoExist(301028) {
							selfState{value: 301028; redirectID: player($i), ID;}
						}
					}
				}
				changestate{value: 56}
			}
		}
	}
}

if time = 1 {
	changestate{value: 55}
}


