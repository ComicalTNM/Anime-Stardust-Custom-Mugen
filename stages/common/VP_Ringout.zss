[StateDef 56; anim: -2;]

persistent(0) if time = 0 && root, map(_vnix_wall_left) = 1 {
	if root, map(_vnix_wallhp_left) != 50 {
		parentmapadd{map: "_vnix_wallhp_left"; value: 10}
	} else {
		for i = 1; 8; 1 {
			if playerIDexist(player($i), ID) && player($i), moveType = H {
				explod{
					anim: 51;
					postype: none;
					pos: 0,-100;
					scale: .5,.5;
					angle: -90;
					facing: 1;
					ontop: 0;
					under: 0;
					vel: 2,0;
					bindID: player($i), ID;
					sprpriority: 0;
					removetime: -2;
					pausemovetime: -1;
					supermovetime: -1;
					trans: Addalpha;
					alpha: 256,256;
					ownpal: 1;
					interpolation.time: 30;
					interpolation.alpha: 0,256;
				}
				explod{
					anim: 51;
					postype: none;
					pos: 0,0;
					scale: .5,.5;
					angle: -90;
					facing: 1;
					ontop: 0;
					under: 0;
					vel: 2,0;
					bindID: player($i), ID;
					sprpriority: 0;
					removetime: -2;
					pausemovetime: -1;
					supermovetime: -1;
					trans: Addalpha;
					alpha: 256,256;
					ownpal: 1;
					interpolation.time: 30;
					interpolation.alpha: 0,256;
				}
			}
		}
		pause{time: 30}
		bgpalfx{
			time: 30;
			add: -132, -132, -132;
