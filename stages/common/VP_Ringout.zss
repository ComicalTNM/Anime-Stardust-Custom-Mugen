

[Statedef 0; anim:-2;]

if roundState = 0 && time = 0 {
	# Desert Path
	if stagevar(info.name) = "Desert Path" {
		map(_vnix_boundright) := 640; # Ringout Right
		map(_vnix_boundleft) := -640; # Ringout Left
		map(_vnix_groundlevel) := 300; # Ringout Depth
		map(_vnix_splash) := 0; # Splash Sound
