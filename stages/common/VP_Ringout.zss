	# Hyrule Castle
	if stagevar(info.name) = "Hyrule Castle (Omega)" {
		map(_vnix_boundright) := 540; # Ringout Right
		map(_vnix_boundleft) := -540; # Ringout Left
		map(_vnix_maxright) := 2025; # Max Stagebound Right
		map(_vnix_maxleft) := -2025; # Max Stagebound Left
		map(_vnix_groundlevel) := 300; # Ringout Depth
		map(_vnix_splash) := 0; # Splash Sound
		map(_vnix_smash_fx) := 1; # Smash FX
		map(_vnix_wall_right) := 0; # Right Wall
		map(_vnix_wall_left) := 0; # Left Wall
	}

	# Bramble Blast
	if stagevar(info.name) = "Bramble Blast" {
		map(_vnix_boundright) := 600; # Ringout Right
		map(_vnix_boundleft) := -600; # Ringout Left
		map(_vnix_maxright) := 1525; # Max Stagebound Right
		map(_vnix_maxleft) := -1525; # Max Stagebound Left
