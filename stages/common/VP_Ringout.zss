# ========================================================================================================================================
# Meta World Helper - Disabled
[StateDef 100; anim: -2;]

if time = 0 {

	# Meta World Activate
	if player(1), map(_vnix_meta_invert) = 1 || player(2), map(_vnix_meta_invert) = 1 {
		modifyBGCtrl {
			id: 1;
			time: 0,0;
			value: 0;
		}
		modifyBGCtrl {
			id: 50;
			time: 0,0;
			value: 0;
		}
		modifyBGCtrl {
			id: 100;
			time: 0,0;
			value: 1;
		}
	}
	
	# Meta World Deactivate
	if player(1), map(_vnix_meta_invert) = 0 && player(2), map(_vnix_meta_invert) = 0 {
		modifyBGCtrl {
			id: 50;
			time: 0,0;
			value: 1;
		}
		modifyBGCtrl {
			id: 100;
			time: 0,0;
			value: 0;
		}
	}
}

if time = 1 {
	changestate{value: 100}
}

# ========================================================================================================================================

[Statedef 175; anim:-2;]

[Statedef 5900; anim:-2;]
changestate{value:0;}


[StateDef -4]

if roundState = 0 && time = 0 {
	if roundNo = 1 {
		map(_vnix_boundright_original) := stageVar(camera.boundright);
		map(_vnix_boundleft_original) := stageVar(camera.boundleft);
	}
	if roundNo > 1 {
		if map(_vnix_wallexist_right) {
			map(_vnix_wall_right) := 1;
			map(_vnix_wallhp_right) := 0;
			modifyStageVar{
				camera.boundright: map(_vnix_boundright_original);
			}
		}
		if map(_vnix_wallexist_left) {
			map(_vnix_wall_left) := 1;
			map(_vnix_wallhp_left) := 0;
			modifyStageVar{
				camera.boundleft: map(_vnix_boundleft_original);
			}
		}
	}
	for i = 1; 8; 1 {
		if playerIDexist(player($i), ID) {
			player($i), map(_vnix_smash_snd) := 0;
			player($i), map(_vnix_ring_out) := 0;
		}
	}
}

ignorehitpause {
	screenBound{value: 0; movecamera: 0,0}
	assertSpecial{flag: invisible; flag2: noturntarget; flag3: noinput}
	notHitBy{value: SCA}
	width{value: 0,0}
	
}

# Intro Delay by foobs
if stageconst(intro_startup) >= fighttime && stagevar(info.name) = "" {
	assertspecial{flag:roundnotskip; flag2:nobardisplay; flag3:intro;}
}

for i = 56; 121; 1 {
	if playeridexist($i) && !fighttime && stagevar(info.name) = "" {
		pause{time:stageconst(intro_startup); pausebg:0; redirectid: $i}
	}
}

for i = 1; 8; 1 {
	if playerIDexist(player($i), ID) {
		text{
			font: F 7;
			text: "%v";
			params: player($i), Pos X + player($i), CameraPos X;
			removetime: 1;
			layerno: 0;
			velocity: 0,0;
			align: cond(player($i), teamside = 1, 1, -1);
			localcoord: 320, 240;
			pos: cond(player($i), teamside = 1, 30, 290),1150;
			scale: 1,1;
			color: 255,255,255;
		}
		text{
			font: F 7;
			text: "%v";
			params: player($i), stageBackEdgeDist;
			removetime: 1;
			layerno: 0;
			velocity: 0,0;
