;; SFZ2 SecretPoint MUGEN Edition

[Info]
name = "Cloud"
displayname = "Cloud"
versiondate = 09,18,2017
mugenversion = 2002,02,14 ;; [default]

[Camera]
startx = 0
starty = 0
boundleft = -230
boundright = 230
boundhigh = -460
boundlow = 0
verticalfollow = 0
