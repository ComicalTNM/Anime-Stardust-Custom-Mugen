screenright = 15

[StageInfo]
zoffset = 215
autoturn = 1
resetBG = 0
portraitscale = 1

[Shadow]
color = 0,0,0
intensity = 196
reflect = 0
yscale = 0.05
fade.range = -100,0
[Reflection]
intensity = 0

[Music]
bgmusic = sound/Cloud.mp3
bgvolume = 100



