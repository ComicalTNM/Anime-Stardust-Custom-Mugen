[Info]
name = "West City Destroyed"
;displayname = "West City Destroyed"
;versiondate = 09,30,2009
;mugenversion = 1.1
author = "jafar"

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -216
boundright = 216
boundhigh = 0
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60


;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -70          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 70
p2starty = 0
p2facing = -1

;--- Common ---
 ;Don't change these values.
leftbound  = -1000 ;Left bound (x-movement)
rightbound =  1000 ;Right bound

;--------------------------------------------------------
[Bound]
screenleft = 25    ;Dist from left of screen that player can move to
screenright = 25   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 211
autoturn = 1
resetBG = 0    ;1e.
localcoord = 320, 240
hires = 1
xscale = 0.34
yscale = 0.34
portraitscale = 1

;--------------------------------------------------------
[Shadow]
intensity = 96
color = 0,0,0
yscale = .3
fade.range = 0,0

;--------------------------------------------------------
[Reflection]
intensity = 0

;--------------------------------------------------------
[Music]
bgmusic = sound/WestCityDestroyed.mp3
bgmloopstart = 9684
bgmloopend = 15735429
bgmvolume = 100

;========================================================
;--------------------------------------------------------
; Background definition

