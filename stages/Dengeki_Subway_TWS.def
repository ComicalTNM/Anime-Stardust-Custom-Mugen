;----------
[BG Floor]
type			= parallax
spriteno		= 0, 1
start			= 0, 450
mask			= 1
tile			= 1, 0
delta			= 0.48, 1			;1st value is the upper delta; R = Down Width - (Gh*((Down Width-UpperWidth)/Full Height)); Upper Delta = Upper Width / R; UP Delta = Down Width / R
mask			= 0
width			= 1024,4096			;too maintain middle size = to picture the upper width is / 2 but botton is * by 2
scalestart		= 1, 0.4
ID				= 100



