;STAGE:
;--------------------------------------------------------
[Info]
name = "Torture Room"
;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = 0
boundright = 0
boundhigh = 0
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -70          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1startz = 0            ;Starting z coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left
;--- Player 2 ---
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1
;--- Common ---
;DEJAR ASI
leftbound  = -1000 ;Left bound (x-movement)
rightbound =  1000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound
;--------------------------------------------------------
[Scaling]
;DEJAR ASI CASI SIEMPRE
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom
;--------------------------------------------------------
[Bound]
;DEJAR ASI
screenleft = 15
screenright = 15
;--------------------------------------------------------
[StageInfo]
;NIVEL DEL SUELO
zoffset = 205
;PARA QUE GIRE SOLO
autoturn = 1
;DEJAR ASI
resetBG = 0
hires = 1
portraitscale = 1
;--------------------------------------------------------
[Shadow]
intensity = 25
color = 0,0,0
yscale = .3
fade.range = 0,0
;--------------------------------------------------------
[Reflection]
;DEL 0 AL 256
intensity = 0
;--------------------------------------------------------
[Music]
bgmusic  =sound/TortureRoom.mp3
bgvolume = 255
;========================================================
; Main background definition
[BGdef]
 ;Sprites:
spr = TortureRoom.sff
debugbg = 0
;================================================================================
;              COMPONENTES DEL STAGE:
;================================================================================
[BG Back]
type = Normal
spriteno = 0,0
start = 0,135
delta = 2,2
Layerno = 0
mask = 1

[BG Humo]
type = Normal
spriteno = 1,1
start = 1000,100
delta = 2,2
Layerno = 0
mask = 1
tile = 1,0
velocity = .1

[BG Humo]
