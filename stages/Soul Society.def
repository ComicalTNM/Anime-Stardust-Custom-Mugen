;--------------------------------------------------------
[Info]
name = "Bleach Stage 1"
displayname = "Bleach: Soul Society"
versiondate = 09,13,2012
mugenversion = 1.0
author = "Vogel"
;--------------------------------------------------------
[Camera]
startx =0
starty =0
boundleft=-2000
boundright=2000
boundhigh=-50
boundlow =0
verticalfollow = 2
floortension = 100
tension =120
tensionhigh =100
tensionlow = 25
overdrawhigh = 100
overdrawlow = 100
cuthigh = 0
cutlow = 0



;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -500         
p1starty = 0            ;
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 500
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -720          ;Starting x coordinates
p3starty = 0            ;Starting y coordinates
p3facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 4 ---
p4startx = 720
p4starty = 0
p4facing = -1

;--- Common ---
 ;Don't change these values.
leftbound  = -2000 ;Left bound (x-movement)
rightbound =  2000 ;Right bound

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = -15 ;Dist from left of screen that player can move to
screenright = -15   ;Right edge
; use 15 for low res
; use 30 for high res
; use 60 for HD res
;--------------------------------------------------------
[StageInfo]
 ;"Ground" level where players stand at, measured in pixels from the
 ;top of the screen.
 ;Adjust this value to move the ground level up/down in the screen.
 ;***
zoffset = 600


 ;Leave this at 1. It makes the players face each other
autoturn = 1

 ;Set the following to 1 to have the background reset itself between
 ;rounds.
resetBG = 0

 ;Width and height of the local coordinate space of the stage.
localcoord = 1280, 720
; 320,240 = low res stage
; 640,480 = high res stage
; 1280,720 = hd stage

 ;Horizontal and vertical scaling factor for drawing.
xscale = 1
yscale = 1
portraitscale = .25
;--------------------------------------------------------
[Shadow]
intensity = 0
color = 0,0,0
yscale = 0.2
fade.range = 0,0

;--------------------------------------------------------
[Reflection]
 ;Intensity of reflection (from 0 to 256). Set to 0 to have no
 ;reflection. Defaults to 0.
intensity = 100
yscale = 0.20

;--------------------------------------------------------
[Music]
 ;Put a filename for a MOD, MP3 or MIDI here, or just leave it
 ;blank if you don't want music. If an invalid filename is
 ;given, then no music will play. To play CD audio, put
 ;the track number followed by ".da". Using a track number of
 ;0 will play a random audio track. For example, to play
 ;track 3 from a music CD, use:
 ;  bgmusic = 
bgmusic = sound/Soul Society.mp3

;bgmloopstart = <sample number>
;bgmloopend = <sample number>

 ;Adjust the volume. 100 is for 100%.
bgmvolume = 100

;========================================================
;--------------------------------------------------------
; Background definition
; ***
;-------------------------------------
; [BG x]
; type = ?       "Normal"/"Parallax"  (def: "normal")
; spriteno = ?, ? Sprite group and number: groupno, imgno  (req'd)
; start = ?, ?   Starting location (integer)  (def: 0, 0)
; delta = ?, ?   Change in location per camera unit moved (float)  (def: 1,1)
; trans = ?      Transparency settings: "none"/"add"/"add1"/"sub"" (def: "none")
; mask = ?       Masking (int): 0 - off, 1 - on  (def: 0)
; velocity = ?, ? Velocity: x, y (float): speed background moves (def: 0, 0)
; tile = ?, ?    Tiling: xtile, ytile (int): 0 - off, 1 - infinite,
;                        >1 - tile that number of times  (def: 0, 0) - only for Normal BG
; tilespacing = ?, ? Tiling: x, y (int) : space between tiles (def: 0, 0)
;  Parallax-only:
; xscale = ?, ?    Top xscale, bottom xscale (float)
; width = ?, ?     Top width, bottom width (int)  (use either this or above, but not both)
; yscalestart = ?  Starting y-scale (float, in percent)  (def: 100)
; yscaledelta = ?  Change in y-scale per unit (float, in percent)  (def: 0)
;-------------------------------------

;-------------------------------------
; Main background definition
[BGdef]
spr = Soul Society.sff
debugbg = 1

[BG 0,sky]
type = parallax
spriteno = 3,2
start = 0,125
delta = 0.55, 1
tile = 1
yscalestart = 100
width = 1536, 568
velocity =0.40

[BG 0,sky]
type = parallax
spriteno = 3,1
start = 0,125
delta = 0.55, 1
tile = 1
yscalestart = 100
width = 1536, 568
velocity =0.20

[BG 0,city layer 5]
type = normal
spriteno = 2,5
start = 0,125
delta = 0.32, 1
tile = 1
mask = 0

[BG 0,city layer 4]
type = normal
spriteno = 2,4
start = 0,125
delta = 0.34, 1
tile = 1
mask = 0

[BG 0,city layer 3]
type = normal
spriteno = 2,3
start = 0,125
delta = 0.36, 1
tile = 1
mask = 0

[BG 0,city layer 2]
type = normal
spriteno = 2,2
start = 0,125
delta = 0.38, 1
tile = 1
mask = 0

[BG 0,city layer 1]
type = normal
spriteno = 2,1
start = 0,125
delta = 0.40, 1
tile = 1
mask = 0


[BG 0,rain]
type = normal
spriteno = 4,0
start = 0,125
delta = 0.37, 0.8
mask = 1
tile = 1, 1
velocity = -2.5, 1.4
trans = add


[BG 0,column right]
type = normal
spriteno = 0,3
start = 0,125
delta = 0.55, 1
tile = -20
mask = 1

[BG 0,column left]
type = normal
spriteno = 0,2
start = 0,125
delta = 0.55, 1
tile = 20
mask = 1

[BG 0,column left reflection]
type = normal
spriteno = 1,2
start = 0,125
delta = 0.55, 1
tile = 20
mask = 1
trans = addalpha
alpha = 200,100

[BG 0,floor]
type = parallax
spriteno = 0,1
start = 0,125
delta = 0.55, 1
tile = 1
yscalestart = 100
width = 568, 1536

[BG 0,column left reflection]
type = normal
spriteno = 1,2
start = 0,125
delta = 0.55, 1
tile = 20
mask = 1
trans = addalpha
alpha = 50,200

[BG 0,rain splashes 2]
type = anim
actionno = 2
start = 0,125
delta = 0.55, 0.8
mask = 1
tile = 1, 0
tilespacing = 734
velocity = -4, 0
trans = add

[Begin Action 2]
6,1,0,0,8
6,2,0,0,8
6,3,0,0,8

[BG 0,rain splashes]
type = anim
actionno = 1
start = 0,125
delta = 0.55, 0.8
mask = 1
tile = 1, 0
tilespacing = 1536
velocity = -4, 0
trans = add

[Begin Action 1]
5,1,0,0,8
5,2,0,0,8
5,3,0,0,8

[BG 0,rain]
type = normal
spriteno = 4,1
start = 0,125
delta = 0.55, 0.8
mask = 1
tile = 1, 1
velocity = -4, 7
trans = add
layerno = 1














































































