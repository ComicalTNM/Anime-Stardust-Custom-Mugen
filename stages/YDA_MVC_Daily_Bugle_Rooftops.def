
;========================================================
;////***DAILY BUGLE ROOFTOPS STAGE BY  MASTER YODA***////
;--------------------------------------------------------
[Info]
name = "YDA_MVC_Daily_Bugle_Rooftops"; 
author= "Master Yoda"
displayname = "Rooftop of the Daily Bugle"
attachedchar = common/VP_Web.def
ikemenversion = 1.0
;DATE = 15/03/2015
;My site: http://senseiyoda.mugen-infantry.net/

;Thanks to:
;CAPCOM for making this amazing game!
;Just No Point for his Spiderman rips (Intro)
;Juan Carlos for his great contribution to the community with his tutorials!
;and you for downloading this stage!

[BGdef]
spr = YDA_MVC_Daily_Bugle_Rooftops.sff
debugbg = 0
;--------------------------------------------------------
[Music]
bgmusic = sound/Spider-Man.mp3
bgvolume = 225

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -140
boundright = 140
boundhigh = -224
boundlow = 0
verticalfollow = .8
floortension = 60
tension = 50

;--------------------------------------------------------
[PlayerInfo]

;--- Player 1 ---
p1startx = -70          
p1starty = 0            
p1startz = 0            
p1facing = 1            

;--- Player 2 ---
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1

;--- Common ---
 ;Don't change these values.
leftbound  = -1000 ;Left bound (x-movement)
rightbound =  1000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
screenleft = 15    ;Dist from left of screen that player can move to
screenright = 15   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 215
zoffsetlink = 1
autoturn = 1
resetBG = 0
portraitScale = 0.41666

;--------------------------------------------------------
[Shadow]
intensity = 118
color = 0,0,0
yscale = .25
fade.range = -400,-100

;--------------------------------------------------------
[Reflection]
;intensity = 128

[Constants]
intro_startup = 240

;========================================================
;--------------------------------------------------------
; Background definition
; ***
;-------------------------------------

;-------------------------------------
; [BG x]
; type = ?       "Normal"/"Parallax"  (def: "normal")
; spriteno = ?, ? Sprite group and number: groupno, imgno  (req'd)
; start = ?, ?   Starting location (integer)  (def: 0, 0)
; delta = ?, ?   Change in location per camera unit moved (float)  (def: 1,1)
; trans = ?      Transparency settings: "none"/"add"/"add1"/"sub"" (def: "none")
; mask = ?       Masking (int): 0 - off, 1 - on  (def: 0)
; velocity = ?, ? Velocity: x, y (float): speed background moves (def: 0, 0)
; tile = ?, ?    Tiling: xtile, ytile (int): 0 - off, 1 - infinite,
;                        >1 - tile that number of times  (def: 0, 0) - only for Normal BG
; tilespacing = ?, ? Tiling: x, y (int) : space between tiles (def: 0, 0)
;  Parallax-only:
; xscale = ?, ?    Top xscale, bottom xscale (float)
; width = ?, ?     Top width, bottom width (int)  (use either this or above, but not both)
; yscalestart = ?  Starting y-scale (float, in percent)  (def: 100)
; yscaledelta = ?  Change in y-scale per unit (float, in percent)  (def: 0)
;-------------------------------------
[BG SKY]
type  = normal
spriteno = 1,0
delta = 0,.32
mask = 1

[BG BUILDINGS_00]
type  = normal
spriteno = 1,1
delta = .2,.37
start = 0,9
mask = 1

[BG CAR.00]
type  = normal
spriteno = 1,8
delta = .2,.37
start = 0,9
tile = 1, 0
tilespacing = 100, 0
velocity = -1.5,0
mask = 1

[BG SKYSCRAPER_TRICK]
type  = normal
spriteno = 1,4
delta = .24,.39
start = 0,9
mask = 1
[BG SKYSCRAPER_REFLECTION]
type  = normal
spriteno = 1,5
delta = .26,.4075
trans = addalpha
alpha = 100, 100
start = 0,9
mask = 1
[BG SKYSCRAPER_PART]
type  = normal
spriteno = 1,3
delta = .24,.39
start = 0,9
mask = 1

[BG BAXTER_BUILDING]
type  = normal
spriteno = 1,2
delta = .26,.4075
start = 0,9
mask = 1

[BG CAR.00]
type  = normal
spriteno = 1,7
delta = .26,.4075
start = 0,9
tile = 1, 0
tilespacing = 120, 0
velocity = 2.2,0
mask = 1
