;STAGE:
;--------------------------------------------------------
[Info]
 ;Nombre del escenario:
name = "Lava Dimension"
displayname = "Lava Dimension" 
;--------------------------------------------------------
[Camera]
; C�mara posici�n inicial: Por lo general 0 para ambos
startx = 0
starty = 0
boundleft = -50
boundright = 50
boundhigh = -100
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
 ;Player 1 starting coordinates.
 ;p1startx is typically -70 and p2startx is 70.
 ;p1starty and p1startz should be 0.
p1startx = -70          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1startz = 0            ;Starting z coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left
;--- Player 2 ---
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1
;--- Common ---
;DEJAR ASI
leftbound  = -1000 ;Left bound (x-movement)
rightbound =  1000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound
;--------------------------------------------------------
[Scaling]
;DEJAR ASI CASI SIEMPRE
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom
;--------------------------------------------------------
[Bound]
;DEJAR ASI
screenleft = 15
screenright = 15
;--------------------------------------------------------
[StageInfo]
;NIVEL DEL SUELO
zoffset = 200
;PARA QUE GIRE SOLO
autoturn = 1
;DEJAR ASI
resetBG = 0
hires = 1
portraitscale = 1
;--------------------------------------------------------
[Shadow]
intensity = 96
color = 0,0,0
yscale = .3
fade.range = 0,0
;--------------------------------------------------------
[Reflection]
;DEL 0 AL 256
intensity = 0
;--------------------------------------------------------
[Music]
bgmusic  =sound/LavaDimension.mp3
bgvolume = 255
;========================================================
; EJEMPLOS
; [BG x]
; type = ?       Normal = Imagenes/Parallax = suelo
; spriteno = ?, ? Sprite y grupo: groupno, imgno  (req'd)
; start = ?, ?   Posicion (integer)  (def: 0, 0)
; delta = ?, ?   Change in location per camera unit moved (float)  (def: 1,1)
; trans = ?      Opciones de transparencia: "none"/"add"/"add1"/"sub"" (def: "none")
; mask = ?       1 para quitar fondo de las imagenes
; velocity = ?, ? Velocity: x, y (float): speed background moves (def: 0, 0)
; tile = ?, ?    Tiling: xtile, ytile (int): 0 - off, 1 - infinite,
;layerno =        1 = encima del Jugador/0 = Detras
;                        >1 - tile that number of times  (def: 0, 0) - only for Normal BG
; tilespacing = ?, ? Tiling: x, y (int) : space between tiles (def: 0, 0)
;  SOLO EN PARALLAX
; xscale = ?, ?    Top xscale, bottom xscale (float)
; width = ?, ?     Top width, bottom width (int)  (use either this or above, but not both)
; yscalestart = ?  Starting y-scale (float, in percent)  (def: 100)
; yscaledelta = ?  Change in y-scale per unit (float, in percent)  (def: 0)

;EJEMPLO VACIO:

;[BG x]
;type =
;spriteno =
;start =
;delta =
;trans =
;mask =
;velocity =
;tile =
;Layerno =
;-------------------------------------
; Main background definition
[BGdef]
 ;Sprites:
spr = LavaDimension.sff
debugbg = 0

;================================================================================
;              COMPONENTES DEL STAGE:
;================================================================================
[BG BLACK]
type = Normal
spriteno = 4,0
start = 0,0
delta = 0,0
Layerno = 0
mask = 1
tile = 1,1

[BG BACK]
type = Normal
spriteno = 0,1
start = 0,150
delta = 2,2
Layerno = 0
mask = 1
trans = add

[BG BACK]
type = Normal
spriteno = 0,2
start = 0,150
delta = 2,2
Layerno = 0
mask = 1
trans = add

[BG BACK]
