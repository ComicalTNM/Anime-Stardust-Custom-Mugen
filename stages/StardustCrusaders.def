;--------------------------------------------------------
[Info]
;Name of the stage.
name = "Stardust Crusaders"
; Author : Orochi Herman
; Webpage: http://rotb.mgbr.net
; Original Game : Jojo's Bizarre Adventure
; Original Copyright : Capcom
; Updated: April 21, 2005

;
; UPDATES:
;
; * Copied from the original with different colors. Also
;   corrected a sprite placement error.

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -250
boundright = 250
boundhigh = -80
boundlow = 0
verticalfollow = 0
floortension = 0
tension = 60

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -70
p1starty = 0
p1startz = 0
p1facing = 1

;--- Player 2 ---
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1

;--- Common ---
leftbound  = -1000
rightbound =  1000
topbound  =  0
botbound  =  0

;--------------------------------------------------------
[Scaling]
topz     = 0
botz     = 50
topscale = 1
botscale = 1.2

;--------------------------------------------------------
[Bound]
screenleft = 15
screenright = 15

;--------------------------------------------------------
[StageInfo]
zoffset = 208
autoturn = 1
resetBG = 1
portraitscale = 1

;--------------------------------------------------------
[Shadow]
color = 128,128,128
reflect = 0
yscale = .1
;--------------------------------------------------------
[Music]
bgmusic = sound/StardustCrusaders.mp3
bgvolume = 200

;-------------------------------------
[BGdef]
spr = StardustCrusaders.sff
debugbg = 1

[BG RedCity]
