;================================================================
;MADE BY:  DAERON          specially for the Z2 chars!
;================================================================

[info]
name ="V-Nix Namek"
displayname="Namek"
versiondate=22/09/2012
mugenversion=04,14,2001
author="Daeron"; Edited by V-Nix
pal.defaults=1,2,3,4,5
attachedchar = common/VP_Namek.def

[camera]
startx = 0 ;-16
starty = 0
boundleft = -240; -208
boundright = 208
boundhigh = -230; -300
boundlow = 0
verticalfollow = .75
tension = 50
floortension 	= 90


;--------------------------------------------------------
[playerinfo]
p1startx = -70          ;starting x coordinates
p1starty = 0            ;starting y coordinates
p1startz = 0            ;starting z coordinates
p1facing = 1            ;direction player faces: 1=right, -1=left

p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1

leftbound  = -1000 ;left bound (x-movement)
rightbound =  1000 ;right bound
topbound  =  0   ;Top bound (z-movement)
botbound  =  0    ;Bottom bound

;--------------------------------------------------------
[scaling]
topz     = 0       ;top z-coordinate for scaling
botz     = 50      ;bottom z-coordinate for scaling
topscale = 1       ;scale to use at top
botscale = 1.2     ;scale to use at bottom

;--------------------------------------------------------
[bound]
screenleft = 30    ;dist from left of screen that player can move to
screenright = 30   ;right edge

;--------------------------------------------------------
[stageinfo]
 
zoffset = 220
autoturn = 1
resetbg = 0

;--------------------------------------------------------
[shadow]
intensity = 90
color = 20,20,20
fade.range = 0,-50
yscale = 0.3


;--------------------------------------------------------
[music]

bgmusic = Dbnamek.mp3
bgvolume = 50

;looping points for Freeza.mp3
bgmloopstart = 1078940
bgmloopend = 4214936

;looping points for hdbz_namekdying.mp3
;bgmloopstart = 55197
;bgmloopend = 7178150

;========================================================
;-------------------------------------
; main background definition
[bgdef]
spr = stages/VP_Namek.sff
debugbg = 0

