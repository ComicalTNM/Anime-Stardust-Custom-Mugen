# ========================================================================================================================================
# Randragon Outskirts
# ========================================================================================================================================
	
	if stagevar(info.name) = "Randragon Outskirts" {
		# Wall Hit
		if moveType = H
		&& stateno != [120,155]
		&& alive = 1
		&& !isHelper {
			# For Regular Bounds
			if (stageBackEdgeDist <= 0 || stageFrontEdgeDist <= 0)
			&& (vel X < -2 || vel X > 2)
			&& gethitvar(hitshaketime) <= 2
			&& InCustomState = 0
			{
				if stateType = S || stateType = C {
					if stateno != 301027 && statetype != L {
						selfState{value: 301027}
					}
				} else if stateType = A {
					if stateno != 301028 && statetype != L {
						selfState{value: 301028}
					}
				}
			}
		}
		
		if (stateno = 301027 || stateno = 301028)
		&& (pos X + cameraPos X) = [265,270]
		&& map(_vnix_wallbroken_right) = 0
		#&& teamMode = Single
		{
			if map(_vnix_wallhp_right) != 100 && time = 1 {
				mapadd{map: "_vnix_wallhp_right"; value: 10}
				mapadd{map: "_vnix_wallhp_right"; value: 10; redirectID: p2, ID;}
			} else if map(_vnix_wallhp_right) = 100 {
				nothitby{value: SCA}
				if time = 1 {
					#posadd{x: 15}
					#posadd{x: -15; redirectID: p2, ID;}
				}
			}
		}
		
		if p2stateno = 115050
		&& time >= 0 && stateno != 115051 {
			removeexplod{}
			selfstate{value: 115051; ctrl: 0;}
		}
		
		if (stateno = 301027 || stateno = 301028)
		&& (pos X + cameraPos X) = [-270,-265]
		&& map(_vnix_wallbroken_left) = 0
		#&& teamMode = Single
		{
			if map(_vnix_wallhp_left) != 100 && time = 1 {
				mapadd{map: "_vnix_wallhp_left"; value: 10}
				mapadd{map: "_vnix_wallhp_left"; value: 10; redirectID: p2, ID;}
			} else if map(_vnix_wallhp_left) = 100 {
				nothitby{value: SCA}
				if time = 1 {
					#posadd{x: -15}
					#posadd{x: 15; redirectID: p2, ID;}
				}
			}
		}
		
		if p2stateno = 115060
		&& time >= 0 && stateno != 115061 {
			removeexplod{}
			selfstate{value: 115061; ctrl: 0;}
		}		

	}
