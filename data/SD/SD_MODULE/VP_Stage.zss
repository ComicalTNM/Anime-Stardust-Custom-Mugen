

#===============================================================================
# Go Off Screen Right
#===============================================================================
# (a custom gethit state)
[StateDef 115050; type: A; movetype: I; physics: N;]

mapset{map: "_vnix_wallbroken_right"; value: 1;}
mapset{map: "_vnix_wallbroken_right"; value: 1; redirectID: p2, ID;}
nothitby{value: SCA}
playerpush{value: 0;}

if time = 0 {
	changeanim2{value: 5050;}
	velset{x: 0; y: 0;}
}

if time = 1 {
	posadd{x: 600;}
	posset{y: -200;}
}

if time = 80 {
	velset{x: -6;}
	velAdd{y: 10;}
}

if time = [0,10] {
	assertSpecial{flag: invisible}
}

if time = [0,79] {
	screenBound{value: 0}
}

if time = 81 {
	selfstate{value: 5050; ctrl: 0;}
}

#===============================================================================
# Run to Opponent Right
#===============================================================================
# (a custom gethit state)
[StateDef 115051; type: S; movetype: I; physics: N;]

mapset{map: "_vnix_wallbroken_right"; value: 1;}
mapset{map: "_vnix_wallbroken_right"; value: 1; redirectID: p2, ID;}
screenBound{value: 0}
assertspecial{flag: noautoturn}

if time = 0 {
	velset{x: 0; y: 0;}
	posset{y: 0}
	posadd{x: -800}
	changeanim2{value: 100;}
}

if time = 100 {
	velset{x: 8}
}
if time >= 101 && p2bodydist X <= 80 {
	selfstate{value: 0; ctrl: 1;}
}

