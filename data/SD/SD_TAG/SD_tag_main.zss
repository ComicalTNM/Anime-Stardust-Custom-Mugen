#;====================================================================================
#;Combo detection
#;====================================================================================

ignorehitpause if roundstate = 2 && teammode = tag && !ishelper  && playerno = teamleader && map(partnersAlive) > 0  {
	ignorehitpause if ((stateno = [const(normalAttacksStartStateno),const(normalAttacksEndStateno)] && statetype != A) || 
	(stateno = [const(specialAttacksStartStateno),const(specialAttacksEndStateno)])) && 
     map(customSpecialSwitch) && 
	const(Activetag) > 0 && !map(switchOnCombo) && AnimElemVar(NumClsn1) > 0 && !map(switchOnComboCooldown) {
		teammapset{map:"switchOnCombo"; value: 1}
	}
}

ignorehitpause if player(enemynear,teamleader),movetype != H  || 
	stateno = [const(superAttacksStartStateno),const(superAttacksEndStateno)] || 
	player(enemynear,teamleader),statetype = L ||
	player(enemynear,teamleader),statetype = A && player(enemynear,teamleader),vel y > 0 {
		teammapset{map:"switchOnCombo"; value: 1}
	}

 
#;====================================================================================
#; Guard detection
#;====================================================================================

ignorehitpause if roundstate = 2 && teammode = tag && !ishelper && stateno = [120,155] && playerno = teamleader && const(assistCallWhileGuarding) {
	teammapset{map:"assistWhileGuarding"; value: 1}
	} else {
	teammapset{map:"assistWhileGuarding"; value: 0}
}


#;====================================================================================
#; Fix for chars that died in a custom state
#;====================================================================================

ignorehitpause if roundstate = 2 && teammode = tag && !ishelper && stateno = 5150 && playerno = teamleader && time > 100 {
	selfstate{value:5150 ;}
}

#;====================================================================================
#;Show partners at the start of the round
#;====================================================================================

if const(showPartnersAtIntro) {
#do nothing
} else {
if (roundstate = [0,1] || (roundstate = 2 && map(absoluteTime) < 50 && !ishelper)) && teamleader != playerno  {
	assertspecial{flag:invisible}
	if (stateno = [190,194] || stateno = 21) && !ishelper {changestate{value:0}}
	}

#;for training mode
if roundstate = 2 && map(absoluteTime) < 52 {
	mapadd{map:"absoluteTime"; value:1}
	} 
}

#;====================================================================================
#;Teaching the AI how and when to use the switch
#;====================================================================================

if ctrl && roundstate = 2 &&  stateno = 0 && map(ASSISTINPROCESS)=0 && life < 280 && statetype != A && ailevel > 0 && !map(Assistd) && !map(Assistw) {
	if (playerid(map(nextPartner)),life > 500 && map(nextPartnerIsReady)) { 
		mapset{map:"SwitchB"; value:1;} 
		mapset{map:"contadorForSwitch";value:0;} 
		if statetype != A && map(reverseSnapbackIsOn) = 0 {changestate{value:const(switchOnCombo)}}
		}
	if (playerid(map(previousPartner)),life > 500 && map(previousPartnerIsReady))  { 
		mapset{map:"SwitchA"; value:1;}
		mapset{map:"contadorForSwitch";value:0;}
		if statetype != A && map(reverseSnapbackIsOn) = 0 {changestate{value:const(switchOnCombo)}}
		}
	}
