		freq: 160;
		ampl: 2;
	}
	bgpalfx{
		time: 30;
		mul: 100,0,100;
		add: 30, 0, 32;
	}
	# Counter Breaker Announcer
	if map(_vnix_cbreaker_cfg_sound) != 0 {
