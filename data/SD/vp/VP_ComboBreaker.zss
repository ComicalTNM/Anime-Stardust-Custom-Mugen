		alpha: 256,256;
		ownpal: 1;
		interpolation.time: 30;
		interpolation.alpha: 0,256;
	}
}

# Zoom Effect
ignoreHitPause if moveType = A && stateType != A  {
	if movehit = 1 {
		zoom{
			scale: 1.2;
			time: 60;
			pos: const240p((pos x + p2, pos x) / 2.0), 0;
			lag: 0.85;
			stagebound: 1;
			camerabound: 1;
		}
	} else {
		zoom{
			scale: 1.0;
			time: 60;
			pos: const240p((pos x + p2, pos x) / 2.0), 0;
			lag: 0.9;
			stagebound: 1;
			camerabound: 1;
		}
	}
}

if animtime = 0 || time >= 20 {
	mapset{map: "_vnix_break"; value: 0}
	if stateType = A || pos Y < 0 {
		selfstate{value: 50; ctrl: 1}
	} else {
		selfstate{value: 0; ctrl: 1}
	}
}

# ===================================================================================
# Combo Breaker - Crumble
# ===================================================================================

[StateDef 1915201930; 
	type: S;
	moveType: I;
	physics: S;
	ctrl: 0;
	anim: -2;
]

mapset{map: "_vnix_break"; value: 0;}

assertSpecial{flag: noinput; flag2: nohardcodedKeys; flag3: noAILevel}

if time = 0 {
	mapadd{map: "_pots_dash_gauge_cooldown"; value: 120;}
	changeanim{value: 420710}
}

if animTime = 0 {
	changeState{value: 5110;}
}


[StateDef -4]

ignorehitpause if !ishelper && (teamside = 1 || teamside = 2) {

	# Initialize
	if roundstate = 0 && time = 0 {
		# Run config
		call F_Vnix_CBreaker_Config();
	}
}

	
[StateDef +1]

# ========================================================================================================================================
# V-Nix - Combo Breaker
# ========================================================================================================================================

ignoreHitPause if !ishelper && teamside > 0 && map(_vnix_cbreaker_cfg_enable) != 0 && playerNo < 9  && gamemode = "fightchallenge" || gamemode = "fightchallengevs"  {
	# Input handling
	if map(_vnix_combobreaker_input) > 0 {
		mapadd{map: "_vnix_combobreaker_input"; value: -1}
	}
	
	# Precaution to reset flag
	if map(_vnix_break) > 0 && gametime%30 {
		mapset{map: "_vnix_break"; value: 0}
	}
	
	let buffertime = 1;
	if AIlevel {
		if (movetype = H && stateno != 1915201930 && random < ((250 + 500) * AIlevel / 8.0) && (statetype != L || stateno = 5120))
		|| (stateno = 1915201930 && enemy, moveType = A)
		{
			mapset{map: "_vnix_combobreaker_input"; value: $buffertime}
		}
	} else {
		# Hold any button
		if inputtime(s) > 0 ||
		   inputtime(a) > 0 || inputtime(b) > 0 || inputtime(c) > 0 ||
		   inputtime(x) > 0 || inputtime(y) > 0 || inputtime(z) > 0 {
			mapset{map: "_vnix_combobreaker_input"; value: $buffertime}
		}
	}
	
	# Initiate Combo Breaker
	if !ishelper && roundstate = 2 {

		# Combo Breaker
		if !incustomstate
		&& !pausetime
		#&& !time
		&& map(_pots_dash_gauge) >= map(_vnix_cbreaker_cfg_power)
		&& map(_vnix_combobreaker_input) > 0
		&& map(_pots_dash_burnout) = 0
		&& map(_vnix_break) = 0
		&& enemy, map(ikarmor_assertarmor) = 0
		&& enemy, map(ikarmor_assertarmor2) = 0
		&& alive
		&& p2BodyDist X < 60
		&& p2BodyDist Y = [-40,40]
		&& movetype = H
		&& enemy, movetype = A
		&& enemy, stateno != 1915201910
		&& statetype != L
		&& getHitVar(playerNo)
		&& getHitVar(attr) != SCA, AT #HA, HP, AT
		&& enemy, combocount >= map(_vnix_cbreaker_cfg_combo) {
			mapadd{map: "_pots_dash_gauge"; value: -abs(map(_vnix_cbreaker_cfg_power))}
			mapadd{map: "_vnix_break_out"; value: 1}
			mapset{map: "_pots_dash_gauge_cooldown"; value: 120}
			#poweradd{value: -1.0 * map(_vnix_cbreaker_cfg_power)}
			selfstate{value: 1915201910; ctrl: 0;}
		}
		
		# Counter Breaker
		if map(_vnix_ccounter_cfg_enable)
		&& !incustomstate
		&& !pausetime
		#&& !time
		&& map(_pots_dash_gauge) >= map(_vnix_cbreaker_cfg_power)
		&& map(_vnix_combobreaker_input) > 0
		&& map(_pots_dash_burnout) = 0
		&& map(_vnix_break) = 0
		&& alive
		&& p2BodyDist X < 60
		&& p2BodyDist Y = [-40,40]
		#&& movetype = H
		&& (stateno = 1915201930 || moveType = H)
		&& enemy, movetype = A
		&& enemy, stateno = 1915201910
		&& statetype != L
		&& getHitVar(playerNo)
		&& getHitVar(attr) != SCA, HA, HP, AT
		{
			mapadd{map: "_pots_dash_gauge"; value: -abs(map(_vnix_cbreaker_cfg_power))}
			mapadd{map: "_vnix_break_out"; value: 1}
			mapset{map: "_pots_dash_gauge_cooldown"; value: 120}
			#poweradd{value: -1.0 * map(_vnix_cbreaker_cfg_power)}
			selfstate{value: 1915201920; ctrl: 0;}
		}
		
	}
}