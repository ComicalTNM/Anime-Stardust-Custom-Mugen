		postype: p1;
		pos: const(size.mid.pos.x), const(size.mid.pos.y);
		sprpriority: 5;
		scale: .5,.5;
		pausemovetime: -1;
		supermovetime: -1;
		ownpal: 1;
	}
	if facing = p2, facing {
		turn{}
	}
	stopsnd{channel: 2}
	pause{time: 20;}
}

if time = 2 {
	pause{time: 10; movetime: 10;}
}

# Hitdef always on before hit happens
if movehit = 0 {
	hitDef{
		attr: S, SA;
		animtype: Hard;
		damage: 90, 4;
		sparkxy: -10, -60;
		hitsound: -1,0;
		guardsound: 6, 0;
		ground.type: Low;
		ground.slidetime: 12;
		ground.hittime: 17;
		kill: 0;
		pausetime: 20,40;
		ground.velocity: -8, 10;
		air.velocity: -8, 10;
		fall: 1;
		fall.recover: 0;
		hitflag: MAFD;
		priority: 7, hit;
	}
}

