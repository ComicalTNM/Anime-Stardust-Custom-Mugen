		bindtime: 0;
		sprpriority: -5;
		pausemovetime: -1;
		supermovetime: -1;
		ownpal: 1;
		palFx.time: -1;
		palFx.mul: 255, 0, 255;
		palFx.add: 200, 0, 200;
		palfx.color: 0;
		interpolation.time: 40;
		interpolation.alpha: 0,256;
	}
	# Break Effect
	explod{
		anim: VP 120;
		postype: left;
		pos: 0,0;
		scale: 2,2;
		angle: 0;
		facing: 1;
		ontop: 0;
		under: 1;
