		playsnd{value: VP 110, 42; volumescale: 200; freqmul: 1.0}
	}
	playsnd{value: VP 110, 41; volumescale: 200; freqmul: 1.0}
	playsnd{value: VP 110, 41; volumescale: 100; freqmul: 1.0}
	playSnd{value: GO 5400, 0; volume: 200}
	explod{
