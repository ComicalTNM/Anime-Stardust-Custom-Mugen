				#	scale: map(_pots_shadowassist_cfg_text_scale), map(_pots_shadowassist_cfg_text_scale);
				#	color: $textcolor1, $textcolor2, $textcolor3;
				#}
				explod{
					anim: -1; # VP 10023;
					posType: left;
					pos: const240p(192), const240p(17.5);
					velocity: 0, 0;
					sprPriority: -98;
					facing: 1;
					scale: 1, 1;
					removetime: 1;
					bindTime: -1;
					superMoveTime: -1;
					pauseMoveTime: -1;
					removeOnGetHit: 0;
					ignoreHitPause: 1;
				}
				explod{
					anim: -1; # VP 10024;
					posType: left;
					pos: const240p(226.5), const240p(17.5);
					velocity: 0, 0;
					sprPriority: -99;
					facing: -1;
					scale: 0.01 * $shadowcooldown, 1;
					removetime: 1;
					bindTime: -1;
					superMoveTime: -1;
					pauseMoveTime: -1;
					removeOnGetHit: 0;
					ignoreHitPause: 1;
				}
			} 
			else {
				explod{
					anim: -1; # VP 10023;
					posType: left;
					pos: const240p(192), const240p(17.5);
					velocity: 0, 0;
					sprPriority: -98;
					facing: 1;
					scale: 1, 1;
					removetime: 1;
					bindTime: -1;
					superMoveTime: -1;
					pauseMoveTime: -1;
					removeOnGetHit: 0;
					ignoreHitPause: 1;
				}
				explod{
					anim: -1; # VP 10022;
					posType: left;
					pos: const240p(226.5), const240p(17.5);
					velocity: 0, 0;
					sprPriority: -99;
					facing: -1;
					scale: 0.01 * $shadowcooldown, 1;
					removetime: 1;
					bindTime: -1;
					superMoveTime: -1;
					pauseMoveTime: -1;
					removeOnGetHit: 0;
					ignoreHitPause: 1;
				}
			}
		}
	}
	# Reset gauge hidden flag
	mapset{map: "_pots_shadowassist_hidegauge"; value: 0}

	# Debug
