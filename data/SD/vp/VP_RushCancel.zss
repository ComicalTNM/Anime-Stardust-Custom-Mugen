# ====================================================================================
# Flow Gauge
# ====================================================================================

# Only the team leaders display their gauges
ignorehitpause if !ishelper && playerno = teamleader {

	# Display Gauge
	# Uses debug font for compatibility purposes
	if roundstate = 2 && map(_pots_dash_hidegauge) = 0 {

		# Main Text
		let drivegauge = map(_pots_dash_gauge);
		if teamside = 1 {
			# Burnout Refill
			if map(_pots_dash_burnout) != 0 {
				if $drivegauge >= 1 {
					explod{
						anim: VP 10020;
						posType: left;
						pos: const240p(44), const240p(17.5);
						velocity: 0, 0;
						sprPriority: -98;
						facing: 1;
						scale: 0 + cond($drivegauge = [1,199], $drivegauge * 0.005, 1), 1;
						removetime: 1;
						bindTime: -1;
						superMoveTime: -1;
						pauseMoveTime: -1;
						removeOnGetHit: 0;
						ignoreHitPause: 1;
						xshear: 1.1;
						palfx.time: -1;
						palfx.mul: 153,55,204;
						palfx.add: 100,0,200;
