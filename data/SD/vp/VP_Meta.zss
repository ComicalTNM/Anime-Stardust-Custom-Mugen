
#===============================================================================
# Configuration
#===============================================================================

[Function F_Vnix_Meta_Config()]

mapset{map: "_vnix_meta_cfg_enable"; value: 1}			# Enable Meta World, 0 to disable
mapset{map: "_vnix_meta_cfg_cost"; value: 1000}			# How much power it takes to activate

mapset{map: "_vnix_meta_cfg_random"; value: 1}			# Enable random Meta World, 0 to deactivate
mapset{map: "_vnix_meta_cfg_cpu"; value: 1}				# Enable random Meta World for CPU, 0 to deactivate
mapset{map: "_vnix_meta_cfg_random_round"; value: 1}	# Enable random Meta World each round, 0 to make the Meta World from Round 1 persist until End of Match

mapset{map: "_vnix_health_increase"; value: 1}			# Enable 20% more health for all characters (only if item & meta modules are active)


# Hyper Armor Code by Kamekaze
[StateDef 4123119; physics: N; type: S; anim:-2; moveType: A;]

if time = 0 {
	map(hittime):= -1;
}

ignorehitpause {
	attackDist{value: 0}
	if root, facing != facing {
		turn{}
	}
	if root,statetype = A {
		statetypeset{statetype: A}
	} else if root,statetype = C {
		statetypeset{statetype: C}
	} else {
		statetypeset{statetype: S}
	}

	assertspecial{flag:invisible}
	hitOverride {
		time: -1;
		attr: SCA,AA,AP,AT;
		stateno: 4123119;
	}
	if root,movetype != H {
		hitby{value:SCA,AA,AP}
	} else if root, movetype = H || !root, map(ikarmor_assertarmor) {
		nothitby{value:SCA}
	}

	changeanim{value: root, anim; elem: root, animelemno(0)}
	if !map(hitshaketime) {
		bindtoroot{pos: 0, 0} #For nightly as of 5/30/24 or later change to 0,0 otherwise
	}

	if map(hitshaketime) {
		map(hitshaketime) := map(hitshaketime) - 1;

		if map(hitshaketime) % 2 {
			offset{x:-1; redirectid: root, id}
		} else {
			offset{x:1; redirectid: root, id}
		}
		
		assertspecial{flag:animfreeze}
		
		if !map(hitshaketime) {
			map(receivedhit) := 0;
		}
	} else if map(slidetime) {
		if map(xvel) && statetype != A {
			veladd{x: map(xvel)*facing; redirectid: root, id}
			map(xvel) := 0;
		}
		map(slidetime) := max(0, map(slidetime) - 2);
	}

	if map(hittime)>-1 && !map(hitshaketime) {
		map(hittime):=map(hittime)-1;
	}

	if root, map(ikarmor_assertarmor) {
		if gethitvar(hitshaketime) && !map(hitshaketime) && pausetime = 0 {
			map(receivedhit) := 1;
			map(idtarget) := gethitvar(id);
			if root, stateno != [120,155] {
				lifeadd{value: -gethitvar(damage) * 0.5; redirectid: root, id}
			}
			let pausetime = gethitvar(hitshaketime);
			map(hitshaketime) := $pausetime;
			map(hittime) := floor(gethitvar(hittime)*.55);
			map(slidetime) := gethitvar(slidetime);
			map(xvel):=gethitvar(xvel);
			playsnd{value: VP 110, 6; volumescale: 200; freqmul: 1.0; channel: 5}
			palfx{
				time: 15;
				add: 200, 200, 200;
				sinadd: -128, -128, -128, 60;
				redirectID: root, ID;
			}
		}
	}
}

if map(hittime) > 0 && (!playeridexist(map(idtarget)) || !playerid(map(idtarget)),movecontact && !playerid(map(hittime)), ishelper) {
	map(hittime):=0;
}

displaytoclipboard{text:"%d %d %d";params:map(rot),map(rw),map(oto)}

if root, map(ikarmor_assertarmor) = 0 {
	destroySelf{}
}


[StateDef -4]

ignorehitpause if !ishelper && (teamside = 1 || teamside = 2) && playerNo = teamLeader  && gamemode = "fightchallenge" ||  gamemode =  "fightchallengevs"   {

	# Initialize
	if roundState = 0 && time = 0 {
	
		# Run config
		call F_Vnix_Meta_Config();
		
		# Reset variables
		mapset{map: "_vnix_meta_active"; value: 0}
		mapset{map: "_vnix_meta_invert"; value: 0}
		
		if gameMode = "Training" {
			mapset{map: "_vnix_metaworld_type"; value: const(Vnix_Meta_World);}
		} else {
			# Set Maps
			if (AILevel && map(_vnix_meta_cfg_cpu)) || (!AILevel && map(_vnix_meta_cfg_random)) {
				# Define Random Meta World
				mapset{map: "_vnix_metaworld_type"; value: random%9;}
				
				# Random Meta World from Round 1 persist until end of match
				if map(_vnix_meta_cfg_random_round) = 0 {
					if RoundNo = 1 {
						mapset{map: "_vnix_metaworld_static"; value: map(_vnix_metaworld_type);}
					}
					mapset{map: "_vnix_metaworld_type"; value: map(_vnix_metaworld_static);}
				}
				
			} else {
				# Use player defined Meta World
				mapset{map: "_vnix_metaworld_type"; value: const(Vnix_Meta_World);}
			}
		}
		
		# Increase Life if both Items & Meta World
		if map(_vnix_health_increase) && roundNo = 1 && (teamMode = Single || teamMode = Turns) && map(_vnix_meta_cfg_enable) && map(_vnix_potion_cfg_enable) {
			modifyPlayer{lifemax: lifemax * 1.2}
			lifeAdd{value: lifeMax; absolute: 1}
		}
	}
	
	if fightScreenState(RoundDisplay) {
		# Reset Maps 
		if teamMode = Single || teamMode = Turns {
			mapset{map: "_vnix_meta_stock"; value: 3}
		}
	}
	
	if gameMode = "Training" {
		mapset{map: "_vnix_meta_stock"; value: 3}
	}
	
	if roundState = 2 && map(_vnix_meta_cfg_enable) != 0 {
		# Input handling
		if AIlevel && enemy, gethitvar(isbound) = 0 && pausetime = 0 && p2, pausetime = 0 {
			if map(_vnix_metaworld_type) = 0
			&& random <= 200 && random <= 350 && random <= 150
			&& life = [lifeMax * 0.01, lifeMax * 0.5]
			&& (map(_pots_dash_gauge) >= 500 && map(_pots_dash_burnout) = 0)
			&& power >= map(_vnix_meta_cfg_cost)
			&& moveType = I && stateType != A
			&& (statetype != L || stateno = 5120) # Let AI use Meta World
			&& (enemy, map(_vnix_meta_active) = 0 || (map(_vnix_meta_stock) >= 2 && enemy, map(_vnix_meta_active) = 1 && enemy, map(_vnix_meta_time) = [60,180]))
			{
				mapset{map: "_vnix_meta_input"; value: 1}
			}

			if (map(_vnix_metaworld_type) = 1 || map(_vnix_metaworld_type) = 2
			|| map(_vnix_metaworld_type) = 3 || map(_vnix_metaworld_type) = 4
			|| map(_vnix_metaworld_type) = 5 || map(_vnix_metaworld_type) = 6
			|| map(_vnix_metaworld_type) = 7 || map(_vnix_metaworld_type) = 8)
			&& random <= 200 && random <= 350 && random <= 150
			&& (map(_pots_dash_gauge) >= 500 && map(_pots_dash_burnout) = 0)
			&& power >= map(_vnix_meta_cfg_cost)
			&& moveType = I && stateType != A
			&& (statetype != L || stateno = 5120) # Let AI use Meta World
			&& (enemy, map(_vnix_meta_active) = 0 || (map(_vnix_meta_stock) >= 2 && enemy, map(_vnix_meta_active) = 1 && enemy, map(_vnix_meta_time) = [60,180]))
			{
				mapset{map: "_vnix_meta_input"; value: 1}
			}
			
		} else {
			# Hold down buttons button
			if inputtime(s) = 1 && inputtime(D) > 0 && stateType != A {
				mapadd{map: "_vnix_meta_input"; value: 1}
			}
			if inputtime(D) < 0 {
				mapset{map: "_vnix_meta_input"; value: 0}
			}
		}
		
		# Meta World Title
		if map(_vnix_life_hidegauge) = 0 && (teamMode = Single || teamMode = Turns) {
			if map(_vnix_metaworld_type) = 0 {
				# Text
				explod{
					anim: VP 30610;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 214.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 1 {
				# Text
				explod{
					anim: VP 30611;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 217)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 2 {
				# Text
				explod{
					anim: VP 30612;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 215.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 3 {
				# Text
				explod{
					anim: VP 30613;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 221.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 4 {
				# Text
				explod{
					anim: VP 30614;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 237.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 5 {
				# Text
				explod{
					anim: VP 30615;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 221.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 6 {
				# Text
				explod{
					anim: VP 30616;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 223.5)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 7 {
				# Text
				explod{
					anim: VP 30617;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 238)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
			if map(_vnix_metaworld_type) = 8 {
				# Text
				explod{
					anim: VP 30618;
					postype: left;
					pos: const240p(cond(teamside = 1, 24.5, 239)), const240p(35);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					trans: addalpha;
					alpha: cond(map(_vnix_meta_active), 256, 128),cond(map(_vnix_meta_active), 0, 128);
					ownpal: 1;
					palfx.time: -1;
					palfx.color: cond(map(_vnix_meta_active), 256, 0);
				}
			}
		}
		
		# Meta World
		if time > 0
		&& !incustomstate
		&& map(_vnix_meta_input) >= 1
		&& map(_vnix_meta_active) = 0
		&& map(_pots_dash_gauge) >= 500
		&& map(_pots_dash_burnout) = 0
		&& power >= map(_vnix_meta_cfg_cost)
		&& map(_vnix_meta_stock) > 0
		&& alive
		&& (teamMode = Single || teamMode = Turns)
		&& moveType != H
		&& (map(_vnix_metaworld_type) = 0 || map(_vnix_metaworld_type) = 1
		   || (map(_vnix_metaworld_type) = 2 && map(ikarmor_assertarmor2) = 0)
		   || map(_vnix_metaworld_type) = 3 || map(_vnix_metaworld_type) = 4
		   || map(_vnix_metaworld_type) = 5 || map(_vnix_metaworld_type) = 6
		   || map(_vnix_metaworld_type) = 7 || map(_vnix_metaworld_type) = 8)
		&& (enemy, map(_vnix_meta_active) = 0 || (enemy, map(_vnix_meta_active) = 1 && enemy, map(_vnix_meta_time) = [60,180])) # For Meta World Counters
		{
			if enemy, map(_vnix_meta_active) = 1 {
				lifebaraction{text: "Meta World Counter"; top: 1}
			} else {
				lifebaraction{text: "Meta World"; top: 1}
			}
			mapset{map: "_vnix_meta_active"; value: 1}
			mapadd{map: "_pots_dash_gauge"; value: -500}
			mapadd{map: "_vnix_meta_stock"; value: -1}
			mapset{map: "_vnix_meta_invert"; value: 1}
			pause{time: 60; movetime: 60}
			powerAdd{value: -abs(map(_vnix_meta_cfg_cost));}
			# World Summon
			explod{
				anim: VP 20111;
				ID: 20111;
				postype: left;
				pos: const240p(160), const240p(120);
				scale: 1,1;
				angle: 0;
				facing: 1;
				under: 1;
				trans: Addalpha;
				alpha: 128,256;
				layerno: 0;
				sprpriority: -99;
				removetime: -1;
				pausemovetime: -1;
				supermovetime: -1;
				interpolation.time: 60;
				interpolation.scale: 1.2,1.2;
				interpolation.alpha: 0,256;
			}

			explod{
				anim: VP 30601;
				postype: left;
				pos: const240p(0),const240p(0);
				scale: 1, 1;
				angle: 0;
				facing: 1;
				ontop: 1;
				trans: Addalpha;
				alpha: 256,256;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
				interpolation.time: 60;
				interpolation.alpha: 0,256;
			}
			playsnd{value: VP 110, 4; volumescale: 100; freqmul: 1.0}
			posFreeze{value: 1;}
			posFreeze{value: 1; redirectID: enemy, ID;}
			nothitby{value: SCA; time: 30;}
			if enemy, map(_vnix_meta_active) = 1 {
				mapset{map: "_vnix_meta_break"; value: 1; redirectID: enemy, ID}
			}
		}
		

		# Meta World Effects
		if map(_vnix_meta_active) != 0 && alive {
		
			mapadd{map: "_vnix_meta_time"; value: 1}
			
			# Invert World
			if map(_vnix_meta_invert) = 1 {
				if stagevar(info.name) = "spider's web"
				|| stagevar(info.name) = "MvC BathHouse- Mens Area"
				|| stagevar(info.name) = "KOF'96 - Stadium"
				|| stagevar(info.name) = "KOGA - Meta"
				{
					bgpalfx{
						time: 1;
						color: 256;
					}
				} else {
					bgpalfx{
						time: 1;
						color: 64;
					}
				}
			}
			
			# Meta Border
			explod{
				anim: VP 40000;
				postype: left;
				pos: const240p(0), const240p(0);
				scale: 1,1;
				angle: 0;
				facing: 1;
				ontop: 0;
				under: 1;
				sprpriority: -99;
				removetime: 1;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
				trans: add;
				palfx.time: -1;
				palfx.add: 125,125,125;
			}
			
			# Meta World Text
			explod{
				anim: VP 30622;
				postype: left;
				pos: const240p(160), const240p(0);
				scale: 1, 1;
				angle: 0;
				facing: 1;
				ontop: 0;
				removetime: 1;
				sprpriority: -5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1
			}
			
			# Timer
			explod{
				anim: VP 30623;
				id: 30650;
				postype: left;
				pos: const240p(160), const240p(44);
				scale: 1 - float(map(_vnix_meta_time) * 0.00185), 1;
				angle: 0;
				facing: 1;
				ontop: 0;
				removetime: 1;
				sprpriority: -5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
			}
			
			# Timer BG
			explod{
				anim: VP 30623;
				id: 30650;
				postype: left;
				pos: const240p(160), const240p(44);
				scale: 1, 1;
				angle: 0;
				facing: 1;
				ontop: 0;
				removetime: 1;
				sprpriority: -5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1;
				trans: addalpha;
				alpha: 0,128;
				palfx.time: -1;
				palfx.add: -255,-255,-255;
			}
			
			# Buffs ;======================================================
			
			# General Buffs ; ---------------------------------------------
			
			# Extra Damage for Normals & Specials
			if enemy, getHitVar(frame) && enemy, getHitVar(attr) = SCA, NA, SA, NP, SP, NT, ST && pausetime = 0 {
				targetLifeAdd{value: -10; absolute: 1; kill: 0}
			}
			
			# Special Buffs ; ---------------------------------------------
			
			# Yggdrasil's Might - Health Recovery
			if map(_vnix_metaworld_type) = 0 {
				if life < lifeMax && map(_vnix_meta_time)%2 = 0 && moveType != H {
					lifeAdd{value: 1; absolute: 1; kill: 0}
				}
				mapset{map: "_pots_dash_gauge_cooldown"; value: 0}
				if map(_vnix_meta_time) = 30 {
					playsnd{value: VP 110, 3; volumescale: 100; freqmul: 1.0; channel: 5}
				}
				palfx {
					time: 1;
					add: 0,30,0;
				}
				if gametime%15 = 0 {
					explod{
						anim: VP 30603;
						id: 30603;
						postype: p1;
						pos: 10, -30;
						scale: .5,.5;
						random: 20,0;
						velocity: 0, -2;
						angle: 0;
						facing: 1;
						sprpriority: 5;
						removetime: 40;
						pausemovetime: -1;
						supermovetime: -1;
						ownpal: 1;
						trans: addalpha;
						alpha: 256,256;
						palfx.time: -1;
						palfx.mul: 0,200,0;
						interpolation.time: 40;
						interpolation.alpha: 0,256;
					}
				}
				if gametime%18 = 0 {
					explod{
						anim: VP 30603;
						id: 30604;
						postype: p1;
						pos: 10, -40;
						scale: .5,.5;
						random: 20,0;
						velocity: 0, -2;
						angle: 0;
						facing: 1;
						sprpriority: 5;
						removetime: 40;
						pausemovetime: -1;
						supermovetime: -1;
						ownpal: 1;
						trans: addalpha;
						alpha: 256,256;
						interpolation.time: 40;
						interpolation.alpha: 0,256;
					}
				}
			}
			
			# Firebird Encore - Enemy Burn
			if map(_vnix_metaworld_type) = 1 {
				if enemy, life >= 1 && map(_vnix_meta_time)%2 = 0 {
					lifeAdd{value: -1; absolute: 1; kill: 0; redirectID: enemy, ID;}
				}
				mapset{map: "_pots_dash_gauge_cooldown"; value: 1; redirectID: enemy, ID;}
				palfx {
					time: 1;
					add: 30,0,0;
