						random: 20,0;
						velocity: 0, 2;
						angle: 90;
						facing: 1;
						sprpriority: 5;
						removetime: 40;
						pausemovetime: -1;
						supermovetime: -1;
						ownpal: 1;
						trans: addalpha;
						alpha: 256,256;
						palfx.time: -1;
						palfx.mul: 128,128,128;
						#palfx.add: 100,100,100;
						palfx.color: 0;
						interpolation.time: 40;
						interpolation.alpha: 0,256;
					}
				}
				if gametime%18 = 0 {
					explod{
						anim: VP 30625;
						id: 30612;
						postype: p2;
						pos: 0, -90;
						scale: .5,.5;
						random: 20,0;
						velocity: 0, 2;
						angle: 90;
						facing: 1;
						sprpriority: 5;
						removetime: 40;
						pausemovetime: -1;
						supermovetime: -1;
						ownpal: 1;
						trans: addalpha;
						alpha: 256,256;
						palfx.time: -1;
						palfx.mul: 128,128,128;
						#palfx.add: 100,100,100;
						palfx.color: 0;
						interpolation.time: 40;
						interpolation.alpha: 0,256;
					}
				}
				
				if map(_vnix_meta_time) = 1 {
					playsnd{value: VP 7, 11; volumescale: 200; freqmul: 1.0; channel: 5}
				}
			}
			
			# Loki's Deceit - Reverse Inputs
			if map(_vnix_metaworld_type) = 8 {
				
				mapset{map: "_vnix_loki_debuff"; value: 1; redirectID: enemy, ID}
				
				if enemy, stateno = 0 {
					if enemy, selfstatenoexist(5300) {
						changeAnim{value: 5300; redirectID: enemy, ID}
					}
				}
				
				palfx {
					time: 1;
					add: 0,30,30;
					redirectID: enemy, ID
				}
				
				if gametime % 10 = 0 {
					explod{
						postype: p1;
						pos: 0, 0;
						vel: cond(random <= 500, 1, -1), 0;
						facing: 1;
						anim: enemy, anim;
						id: 30700;
						animfreeze: 1;
						animelem: enemy, animelemno(0) - 1;
						sprpriority: enemy, sprpriority - 1;
						pausemovetime: -1;
						supermovetime: -1;
						removetime: 30;
						trans: addalpha;
						alpha: 256, 256;
						scale: enemy, const(size.xscale), enemy, const(size.yscale);
						palfx.time: -1;
						palfx.color: 0;
						palfx.mul: 0, 255,0;
						ownpal: 1;
						interpolation.time: 30;
						interpolation.alpha: 0,256;
						interpolation.scale: enemy, const(size.xscale) * 1.2, enemy, const(size.yscale) * 1.2;
						redirectID: enemy, ID
					}
				}
				
				if map(_vnix_meta_time) = 1 {
					playsnd{value: VP 7, 12; volumescale: 200; freqmul: 1.0; channel: 5}
				}
			}
					
			# Forced Deactivation
			if map(_vnix_meta_time) = 540 || map(_vnix_meta_break) = 1 {
				lifebaraction{text: "World Break"; top: 1}
				defenceMulSet{value: 1;}
				if map(_vnix_raijin_buff) {
					powerAdd{value: powerMax * -1.0}
				}
				if map(_vnix_mercury_buff) {
					mapset{map: "_pots_dash_gauge"; value: 1;}
				}
				# Break Effect
				explod{
					anim: VP 30600;
					postype: left;
					pos: const240p(0),const240p(0);
					scale: 1, 1;
					angle: 0;
					facing: 1;
					ontop: 1;
					trans: Add;
					pausemovetime: -1;
					supermovetime: -1;
					ownpal: 1
				}
				afterImageTime{
					time: 10;
				}
				playsnd{value: VP 110, 2; volumescale: 100; freqmul: 1.0}
				mapset{map: "_vnix_meta_active"; value: 0} # Reset Meta World
				mapset{map: "_vnix_meta_break"; value: 0} # Reset Break Debuff
				mapset{map: "_vnix_meta_input"; value: 0} # Reset Input
				mapset{map: "_vnix_meta_invert"; value: 0} # Reset World Invert
				mapset{map: "_vnix_meta_time"; value: 0} # Reset Timer
				mapset{map: "ikarmor_throw_protect"; value: 0;}
				mapset{map: "ikarmor_assertarmor"; value: 0;}
				mapset{map: "_vnix_mercury_buff"; value: 0}
				mapset{map: "_vnix_raijin_buff"; value: 0}
				mapset{map: "_vnix_loki_debuff"; value: 0; redirectID: enemy, ID}
				removeExplod{id: 30603}
				removeExplod{id: 30604}
				removeExplod{id: 30605}
				removeExplod{id: 30606}
				removeExplod{id: 30607}
				removeExplod{id: 30608}
				removeExplod{id: 30609}
				removeExplod{id: 30610}
				removeExplod{id: 30611}
				removeExplod{id: 30612}
				removeExplod{id: 30613}
				removeExplod{id: 30614}
				removeExplod{id: 30615}
				removeExplod{id: 30616}
				removeExplod{id: 30617}
				removeExplod{id: 30650}
				removeExplod{id: 30700}
				stopSnd{channel: 5;}
			}
		}
		
		# Meta World Stock
		if (teamMode = Single || teamMode = Turns) && map(_vnix_life_hidegauge) = 0 {
			if map(_vnix_meta_stock) >= 1 {
				explod{
					anim: VP 30620;
					postype: left;
					pos: const240p(cond(teamside = 1, 108.5, 211.5)), const240p(38.5);
					scale: 1, 1;
					angle: 0;
					facing: cond(teamside = 1, 1, -1);
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					ownpal: 1
				}
			}
			if map(_vnix_meta_stock) >= 2 {
				explod{
					anim: VP 30620;
					postype: left;
					pos: const240p(cond(teamside = 1, 114, 206)), const240p(38.5);
					scale: 1, 1;
					angle: 0;
					facing: cond(teamside = 1, 1, -1);
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					ownpal: 1
				}
			}
			if map(_vnix_meta_stock) >= 3 {
				explod{
					anim: VP 30620;
					postype: left;
					pos: const240p(cond(teamside = 1, 119.5, 200.5)), const240p(38.5);
					scale: 1, 1;
					angle: 0;
					facing: cond(teamside = 1, 1, -1);
					ontop: 0;
					removetime: 1;
					sprpriority: -5;
					pausemovetime: -1;
					supermovetime: -1;
					ownpal: 1
				}
			}
			# Stock BG
			explod{
				anim: VP 30621;
				postype: left;
				pos: const240p(cond(teamside = 1, 108.5, 211.5)), const240p(38.5);
				scale: 1, 1;
				angle: 0;
				facing: cond(teamside = 1, 1, -1);
				ontop: 0;
				removetime: 1;
				sprpriority: -5;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1
			}
		}
	}
	
	if roundState = 3 && map(_vnix_meta_cfg_enable) != 0 && map(_vnix_meta_active) != 0 {
		# Forced Deactivate
		if power <= 0 || map(_vnix_meta_break) = 1 || roundState = 3 {
			lifebaraction{text: "World Break"; top: 1}
			defenceMulSet{value: 1;}
			# Break Effect
			explod{
				anim: VP 30600;
				postype: left;
				pos: const240p(0),const240p(0);
				scale: 1, 1;
				angle: 0;
				facing: 1;
				ontop: 1;
				trans: Add;
				pausemovetime: -1;
				supermovetime: -1;
				ownpal: 1
			}
			afterImageTime{
				time: 10;
			}
			playsnd{value: VP 110, 2; volumescale: 100; freqmul: 1.0}
			mapset{map: "_vnix_meta_active"; value: 0} # Reset Meta World
			mapset{map: "_vnix_meta_break"; value: 0} # Reset Break Debuff
			mapset{map: "_vnix_meta_input"; value: 0} # Reset Input
			mapset{map: "_vnix_meta_invert"; value: 0} # Reset World Invert
			mapset{map: "_vnix_meta_time"; value: 0} # Reset Timer
			mapset{map: "ikarmor_throw_protect"; value: 0;}
			mapset{map: "ikarmor_assertarmor"; value: 0;}
			mapset{map: "_vnix_mercury_buff"; value: 0}
			mapset{map: "_vnix_raijin_buff"; value: 0}
			mapset{map: "_vnix_loki_debuff"; value: 0; redirectID: enemy, ID}
			removeExplod{id: 30603}
			removeExplod{id: 30604}
			removeExplod{id: 30605}
			removeExplod{id: 30606}
			removeExplod{id: 30607}
			removeExplod{id: 30608}
			removeExplod{id: 30609}
			removeExplod{id: 30610}
			removeExplod{id: 30611}
			removeExplod{id: 30612}
			removeExplod{id: 30613}
			removeExplod{id: 30614}
			removeExplod{id: 30615}
			removeExplod{id: 30616}
			removeExplod{id: 30617}
			removeExplod{id: 30650}
			removeExplod{id: 30700}
			stopSnd{channel: 5;}
		}
	}

	
	# Reset Buffs
	if Roundstate = [3,4] {
		mapset{map: "_vnix_meta_active"; value: 0}
		mapset{map: "_vnix_meta_invert"; value: 0}
		mapset{map: "_vnix_meta_input"; value: 0} # Reset Input
	}

}

# test
ignorehitpause if roundstate = [0,2] && !ishelper && playerNo < 9 && (teamside = 1 || teamside = 2) && playerNo = teamLeader {
	text{
		font: F 7;
		text: "player 1 state %v";
		params: player(1), map(_vnix_intro_stateno); #map(_vnix_intro_stateno);
		removetime: 1;
		layerno: 1;
		velocity: 0,0;
		align: cond(teamside = 1, 1, -1);
		localcoord: 320, 240;
		pos: cond(teamside = 1, 30, 290), 1150;
		scale: 1,1;
		color: 255,255,255;
	}
	text{
		font: F 7;
		text: "player 2 state %v";
		params: player(2), stateno; #map(_vnix_special_intro);
		removetime: 1;
		layerno: 1;
		velocity: 0,0;
		align: cond(teamside = 1, 1, -1);
		localcoord: 320, 240;
		pos: cond(teamside = 1, 30, 290), 1160;
		scale: 1,1;
		color: 255,255,255;
	}
	text{
		font: F 7;
		text: "%v";
		params: float(life) / lifeMax; #map(_vnix_special_intro);
		removetime: 1;
		layerno: 1;
		velocity: 0,0;
		align: cond(teamside = 1, 1, -1);
		localcoord: 320, 240;
		pos: cond(teamside = 1, 30, 290), 1170;
		scale: 1,1;
		color: 255,255,255;
	}
}

[StateDef +1]

map(armor_helper_st) := 4123119;

# Call Hyper Armor Helper
if const(ikarmor_no_armor) = 0 && !ishelper && map(ikarmor_assertarmor) {
	if !numhelper(map(armor_helper_st)) {
		Helper{
			id: map(armor_helper_st);
			stateno: map(armor_helper_st);
			ownpal: 1;
			name: "Ik Armor Hp";
			size.height: 0;
			keyctrl:0;
			pausemovetime: 99999;
			supermovetime: 99999;
		}
	}

	ignoreHitPause if map(ikarmor_assertarmor) || (numhelper(map(armor_helper_st)) && helper(map(armor_helper_st)), map(receivedhit)) {
		if !map(ikarmor_throw_protect) {
			hitby{value:SCA,AT}
		} else {
			nothitby{value:SCA}
		}
	}
}

ignoreHitPause if p2, numhelper(map(armor_helper_st)) && p2, helper(map(armor_helper_st)), map(hitshaketime) && !p2,pausetime && !ishelper {
	pause{time: p2, helper(map(armor_helper_st)), map(hitshaketime) - 1; movetime: p2,helper(map(armor_helper_st)), map(hitshaketime) - 1}
}