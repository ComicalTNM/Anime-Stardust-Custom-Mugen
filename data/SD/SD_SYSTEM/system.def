;-------------------------------------------------------------------
;Demo mode definition
[Demo Mode]
enabled = 1               ;Set to 1 to enable demo mode, 0 to disable
select.enabled = 0        ;Set to 1 to display select screen, 0 to disable
vsscreen.enabled = 0      ;Set to 1 to display versus screen, 0 to disable
fadein.time = 50          ;Ikemen feature
fadein.col = 0, 0, 0      ;Ikemen feature
fadeout.time = 50         ;Ikemen feature
fadeout.col = 0, 0, 0     ;Ikemen feature
title.waittime = 3000      ;Time to wait at title before starting demo mode
fight.endtime = 10000     ;Time to display the fight before returning to title
fight.playbgm = 0         ;Set to 1 to enable in-fight BGM, 0 to disable
fight.stopbgm = 0         ;Set to 1 to stop title BGM (only if playbgm = 0)
fight.bars.display = 1    ;Set to 1 to display lifebar, 0 to disable
intro.waitcycles = 1      ;Cycles to wait before intro cutscene is played again
debuginfo = 0             ;Set to 0 to hide debugging info (debug mode only)

;-------------------------------------------------------------------
;Continue screen definition
[Continue Screen]
enabled = 1
legacymode.enabled = 1            ;Ikemen feature
gameover.enabled = 0              ;Ikemen feature

;legacy continue screen (legacymode.enabled = 1)
pos = 640,240
continue.text = "CONTINUE?"
