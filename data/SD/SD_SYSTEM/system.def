p1.spr = 9000,1
p1.facing = 1
p1.scale = 0.7, 0.7


p1.window = 0,0, 1279,500
p1.name.offset = 150,420
p1.name.font = 7,0,0
;Win quote text
winquote.text 		= "Good Fight!"
winquote.offset 	= 45,550
winquote.textspacing =  10	;Ikemen feature
winquote.font 		= 7,0,1
winquote.window 	= 0,0,1280,1280
winquote.textwrap 	= w	;Word wrap
winquote.textdelay = 5	;Ikemen feature

