p2.yes.state = ;Ikemen feature
p2.no.state = ;Ikemen feature
credits.text = "Credits: %d"      ;Ikemen feature
credits.offset = 40, 40           ;Ikemen feature
credits.font = 7,0,1              ;Ikemen feature
credits.scale = 1.0, 1.0          ;Ikemen feature

