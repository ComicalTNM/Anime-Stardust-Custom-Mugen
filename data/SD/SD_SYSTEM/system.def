no.scale = 1.0, 1.0
no.offset = 80, 60
no.active.text = "NO"
no.active.font = 3,1,0
no.active.scale = 1.0, 1.0
no.active.offset = 80, 60
move.snd = 100, 0                 ;Ikemen feature
done.snd = 100, 1                 ;Ikemen feature
cancel.snd = 100, 2               ;Ikemen feature

