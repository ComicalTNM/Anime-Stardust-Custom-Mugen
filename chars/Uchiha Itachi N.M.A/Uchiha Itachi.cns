type = FallEnvShake
trigger1 = Time = 0

[State 5110, 1] ;For hit up/up-diag type (from state 5081)
type = ChangeAnim
persistent = 0
trigger1 = SelfAnimExist(5110 + ((anim-100) % 10))
trigger1 = anim = [5051+var(10),5059+var(10)]
value = (5110 + ((anim-100) % 10))+var(10)

[State 5110, 2] ;Hit ground anim (normal)
type = ChangeAnim
triggerall = time = 0
triggerall = anim != [5110+var(10),5119+var(10)] ;Not already changed anim
trigger1 = anim != [5161+var(10),5169+var(10)]
trigger2 = !SelfAnimExist(5170 + ((anim-100) % 10))
value = 5170+var(10)

[State 5110, 3] ;Hit ground anim (for hit up)
type = ChangeAnim
triggerall = time = 0
triggerall = anim != [5110+var(10),5119+var(10)] ;Not already changed anim
trigger1 = anim = [5161+var(10),5169+var(10)]
trigger1 = SelfAnimExist(5170 + ((anim-100) % 10))
