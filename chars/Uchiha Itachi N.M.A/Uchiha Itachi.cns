v = 2
value = 0
[State 0, VarSet] ;Finger Genjutsu Timer Start
type = VarSet
trigger1 = Var(2) && !Var(3)
v = 3
value = 360
[State 0, VarSet] ;Finger Genjutsu Timer Start
type = Varadd
trigger1 = Var(3)
v = 3
value = -1
[State 0, VarSet] ;Half Susanoo ON
type = VarSet
trigger1 = !Var(4) && Root,Stateno = 39000
v = 4
value = 10
