; Shuriken Jutsu

[Statedef 1000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 1000
sprpriority = 2

[State 0, Turn]
type = Turn
trigger1 = P2dist x < 0

[State 0, Explod CD]
type = Explod
triggerall = !NumExplod(stateno)
trigger1 = 1
anim = 9999
ID = stateno
pos = 0,0
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,0
accel = 0,0
random = 0,0
removetime = 600
supermovetime = 0
pausemovetime = 0
scale = 1,1
sprpriority = 0
ontop = 0
shadow = 0,0,0
ownpal = 0
removeongethit = 0

[State 0, PosAdd]
type = PosAdd
triggerall = Time = 0
trigger1 = prevstateno = 220
trigger2 = prevstateno = 410
trigger3 = prevstateno = 420
x = 20

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 7||animelem = 8||animelem = 10||animelem = 14||animelem = 16
value = S8,53+random%5
volume = 999

[State 0, Helper]
type = Helper
trigger1 = animelem = 7||animelem = 8||animelem = 10||animelem = 14||animelem = 16
helpertype = normal
name = "Shurikens"
ID = 1050
stateno = 1050
pos = 12+random%7,-30-random%10
postype = p1
ownpal = 1
size.xscale = 1
size.yscale = 1
[State 0, Helper]
type = Helper
trigger1 = animelem = 6||animelem = 9||animelem = 11||animelem = 12||animelem = 13||animelem = 15
helpertype = normal
name = "1050"
ID = 1050
stateno = 1050
pos = 0-random%20,-35-random%10
postype = p1
ownpal = 1
size.xscale = 1
size.yscale = 1
[State 0, Helper]
type = Helper
trigger1 = animelem = 6||animelem = 9||animelem = 11||animelem = 12||animelem = 13||animelem = 15
helpertype = normal
name = "1050"
ID = 1050
stateno = 1050
pos = 0-random%20,-35-random%10
postype = p1
ownpal = 1
size.xscale = 1
size.yscale = 1

[State 200, End]
type = ChangeState
trigger1 = Time = 174-23
value = Cond((!Numexplod(1200)&&!numexplod(1202))&&Power >= 1000,1200,1001)
ctrl = 0
