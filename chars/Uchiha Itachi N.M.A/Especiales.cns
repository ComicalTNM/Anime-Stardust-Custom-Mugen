[Statedef 1050]
type    = A
movetype= A
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 1050+random%4
sprpriority = 3

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0+random%30
value = S2,15+random%10
volume = 999
channel = 11

[State 0, Velset]
type = VarRandom
trigger1 = !time
v = 1
range = -3,2

[State 0, Velset]
type = Velset
trigger1 = 1
x = 7+time*.4
y = var(1)

[State 0, angledraw]
type = angledraw
trigger1 = 1
value = time*60

[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 1060
time = 9999999
ignorehitpause = 1

[State 200, 1]
type = HitDef
triggerall = !movecontact
trigger1 = 1
attr = A, SP
animtype  = Light
damage    = 6,1
Hitflag = MAFDE
guardflag = MA
pausetime = 2,5
sparkno = -1
guard.sparkno = -1
sparkxy = -8,-25
hitsound   = S8,48
guardsound = S4,1
ground.type = High
ground.slidetime = 45
ground.hittime  = 45
ground.velocity = -4
air.velocity = -4,-1
Fall = 0
Envshake.time = 3

[State 0, TargetState]
type = TargetState
trigger1 = movehit
value = 99665
ID = -1
ignorehitpause = 1
persistent = 1

[State 0, Hit Spark]
type = Explod
triggerall = Numexplod(7026) = 0
trigger1 = Movehit = 1
anim = 7026
ID = 7026
postype = P1
pos = 0,0
facing = ifelse(random < 500,1,-1)
vfacing = ifelse(random < 500,1,-1)
sprpriority = 4
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = .14,.14
removeongethit = 1
supermovetime = 999
ignorehitpause  = 1
angle = 0+random%360

[State 0, Guard Spark]
type = Explod
triggerall = numexplod(7000) = 0
trigger1 = moveguarded = 1
anim = 7000
ID = 7000
postype = P1
pos = 0,0
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = .3,.3
removeongethit = 1
ontop = 1
ignorehitpause = 1

[State 200, End]
type = Changestate
trigger1 = frontedgebodydist <= -5
trigger2 = time >= 500
value = 1060

[State 200, End]
type = ChangeState
trigger1 = movecontact
trigger2 = moveguarded
value = 1055

[State 200, End]
type = ChangeState
Trigger1 = Pos Y >= -1
Value = ifelse(random < 500,1065,1070)
