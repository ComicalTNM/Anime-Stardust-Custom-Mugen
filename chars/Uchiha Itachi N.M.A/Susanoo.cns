[Statedef 39001]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 39001
sprpriority = -1

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 5

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0
ignorehitpause = 1

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -40

[State 0, WALK FWD]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "holdfwd"
trigger2 = RoundState = 2 && ailevel > 0 && P2bodydist x >= 100
trigger2 = random < 20
value = 39005

[State 0, WALK BACK]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "holdback"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x <= 75
trigger2 = random < 10
value = 39006

[State 0, Run FWD]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "FF"
trigger2 = RoundState = 2 && ailevel > 0 && P2bodydist x >= 250
trigger2 = random < 20
value = 39007

[State 0, Run BACK]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "BB"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x <= 75 && power < 1000
trigger2 = random < 20
value = 39008

[State -1, 39020]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "a"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,200]
trigger2 = random < 40
value =39020

[State -1, 39030]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "b"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,100]
trigger2 = random < 40
value =39030

[State -1, 39040]
type = ChangeState
triggerall = Helper(39003),Fvar(30) > 0 && Roundstate = 2
trigger1 = command = "c"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,150]
trigger2 = P2statetype != A
trigger2 = random < 40
trigger3 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,200]
trigger3 = P2statetype = A
trigger3 = random < 50
value =39040

[State 200, End]
type = ChangeState
trigger3 = Roundstate != 2
trigger2 = Helper(39003),Fvar(30) <= 0
trigger1 = win||lose||drawgame
value = 554
