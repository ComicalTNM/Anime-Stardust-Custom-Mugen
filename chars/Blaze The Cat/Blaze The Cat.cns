[Quotes]
victory1 = "You see? You couldn't escape my flames!"
victory2 = "Just don't get on my bad side. That'd be another punishment for you!"
victory3 = "Hah. You didn't have a chance against my flames of fire."
victory4 = "My skills are much more superior than yours!"
victory5 = "Quite of a satisfactory result. This battle was interesting."
victory6 = "Didn't I tell you that I can control fire? Even underwater?"
victory7 = "I would've expected a much more skiled opponent than that."
victory8 = "Gotta find the other Sol emeralds. No time for me to waste"
victory9 = "That's right. You've been roasted by my flames!"
victory10 = "Hmp. You'll never be a match for me or my fire power!"
[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 21100 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 21500 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.
