[State 0, AttackMulSet]
type = DefenceMulSet
trigger1 = Var(2) = 2
Value = .5
[State 0, AngleDraw]
Type = AngleDraw
Triggerall = (Alive) && Anim != 10 && Anim != 13 && Anim !=12 && Anim !=500
Trigger1 = Cond(Stateno = 5000,Time <= 5,1)
Value = Cond(Stateno = 5000,5,Cond(Vel x != 0,-(Atan(Vel y/Vel x)*(Const(Size.Air.Back))/Pi),0))
Scale = 1,1+(Sin((Time/50.0)*(Pi/2))*0.0125)
IgnoreHitPause = 1
[State 0, Helper de Conexiones]
