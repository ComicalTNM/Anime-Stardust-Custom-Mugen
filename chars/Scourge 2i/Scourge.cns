ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 150
proj.attack.dist = 90
proj.doscale = 0
head.pos = -1, -41
mid.pos = -1, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 2
walk.back = -2
run.fwd  = 0
run.back = 0
jump.neu = 0,-7.5
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0,-8.1
airjump.back = -2.55
airjump.fwd = 2.5

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 13532 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 13533 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

[Quotes]
victory1 = "Evil Sonic? Anti-Sonic? Old news. The new hotness is a real Scourge"
victory2 = "All hail the king, baby."

;---------------------------------------------------------------------------
; Assists
[StateDef 13532]
Type = S
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 11

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = !Var(2)
Value = Cond(Random >= 500,Cond(Random >= 500,1200,Cond(Random >= 500,Cond(Random >= 500,1500,1300),Cond(NumHelper(495),1050,1000))),Cond(Random >= 500,Cond(NumHelper(495),1350,1300),Cond(Random >= 500,Cond(NumHelper(495),1450,1400),1100)))
Ctrl = 0

[State 0, End]
Type = ChangeState
Trigger1 = Var(2)
Value = Cond(Random >= 500,Cond(Random >= 500,21200,Cond(Random >= 500,Cond(Random >= 500,21500,21300),Cond(NumHelper(2495),21050,21000))),Cond(Random >= 500,Cond(NumHelper(2495),21350,21300),Cond(Random >= 500,Cond(NumHelper(2495),21450,21400),21100)))
Ctrl = 0

