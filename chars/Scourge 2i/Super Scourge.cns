; Anarchy Beryl - 1
[Statedef 820]
type = A
movetype = I
physics = N
anim = 820
sprpriority = 3

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S5,62
volume = 999

[state 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value =  cond(vel x != 0, - (atan(vel y / vel x) * (const(size.air.back)) / pi), 0)
ignorehitpause = 1

[state 0, Posadd]
type = Posadd
trigger1 = 1
x = 2 * ((parentdist x + 0) / (abs(parentdist x - 0) + abs(parentdist y - 20) + 0.0000001))
y = 2 * ((parentdist y + -5) / (abs(parentdist x - 0) + abs(parentdist y - 20) + 0.0000001))

[State 0,VarSet]
type = VarSet
trigger1 =! Time
v = 2
value = 0
ignorehitpause = 1
[State 0,VarAdd]
type = VarAdd
trigger1 = Time > 0
v = 2
value = 20
ignorehitpause = 1

[State 0,Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 0+VAR(2),256-VAR(2)
ignorehitpause = 1

[state 0, Posadd]
type = Posadd
Trigger1 = Root,Time > 75
x = 2 * ((rootdist x + 0) / (abs(rootdist x - 0) + abs(rootdist y - 25) + 0.0000001))
y = 2 * ((rootdist y + -18) / (abs(rootdist x - 0) + abs(rootdist y - 25) + 0.0000001))

[State 0, VarAdd]
type = VarAdd
Triggerall = Root,Stateno = 800
Trigger1 = Root,Time >= 75
v = 5
value = 15
[State 0, Trans]
type = Trans
Triggerall = Root,Stateno = 800
Trigger1 = Root,Time >= 75
