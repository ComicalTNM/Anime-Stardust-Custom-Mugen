; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0
value = Cond(Pos Y >= 0,100,107)

[State 0, PalFXWiz]
type = PalFX
triggerall = var(46)=0&var(98)=0
trigger1 = life<=20
time = 20
add = 0,0,0
mul = 256,16,16
sinadd = -50,-50,-50,40
invertall = 0
color = 256

[State 0, Helper]
type = Helper
triggerall = var(46)=0&var(98)=0
triggerall = life<=20
trigger1 = timemod=30,0
helpertype = normal 
ID = 50067
stateno = 50067
pos = 0,0
postype = p1
name = "Blood splash"
facing = 1
keyctrl = 0
ownpal = 1
size.shadowoffset = 20

[State 0, VarSet]
type = VarSet
trigger1 = !time
v = 1
value = 0
ignorehitpause = 1

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != cond(var(98)=1,1,ifelse(life<=20&var(46)=0,5300,0)) && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 
value = cond(var(98)=1,1,ifelse(life<=20&var(46)=0,5300,0))

[State 0, Null]
type = Null
trigger1 = life<=20
trigger1 = var(0):=2
ignorehitpause = 1

[State 0, 2]
type = VelSet
trigger1 = !Time
y = 0

[State 0, 3]
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time=3
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0

;---------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,100,107)

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2] ;Stop moving if low velocity
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0

[State 10, 3]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,100,107)
[State 11, 1] ;Change from turning animation
type = ChangeAnim
trigger1 = Anim = 6 && AnimTime = 0
value = 11

[State 11, 2] ;Stop moving if low velocity
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0

;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,100,107)
[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0
ctrl = 1;-var(59)
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,100,107)
[State 0, Explod]
type = Explod
trigger1 = (anim = 20 || anim = 21) && timemod = 10,0
anim = 6006
ID = 7014
pos = 0,2
postype = p1 
facing = ifelse(vel x>0,1,-1)
bindtime = 1
removetime = -2
scale = .20,.20
sprpriority = 3
ontop = 0
ownpal = 0
removeongethit = 0
shadow = 1,0,0

[State 0, Walk Sound]
type = PlaySnd
trigger1 = TimeMod = 15,0 && Time > 1
value = s1,1
volumescale = 955
channel= -1

[State 0, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 0, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

[State 0, ChangeState]
Type = ChangeState
Trigger1 = Var(59)
Value = 21
Ctrl = 0

; AI_Walk
[StateDef 21]
Type = S
Physics = S
SprPriority = 0
Ctrl = 0
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,100,107)
[State 0, Explod]
type = Explod
trigger1 = (anim = 20 || anim = 21) && timemod = 10,0
anim = 6006
ID = 7014
pos = 0,2
postype = p1 
facing = ifelse(vel x>0,1,-1)
bindtime = 1
removetime = -2
scale = .20,.20
sprpriority = 3
ontop = 0
ownpal = 0
removeongethit = 0
shadow = 1,0,0

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

[State 0, VelSet]
Type = VelSet
Trigger1 = 1
X = Const(Velocity.Walk.Fwd.X)

[State 0, Walk Sound]
type = PlaySnd
trigger1 = TimeMod = 15,0 && Time > 1
value = s1,1
volumescale = 955
channel= -1

[State 0, Turn]
Type = Turn
trigger1 = p2dist x < 0
ignorehitpause = 1

[State 0, CtrlSet]
type = CtrlSet
triggerall = !animtime
trigger1 = playerid(enemynear,id),pos x < 300
trigger2 = playerid(enemynear,id),hitdefattr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
trigger3 = playerid(enemynear,id),p2dist x<250
trigger3 = playerid(enemynear,id),movetype=a
trigger4 = playerid(enemynear,id),authorname="Wolf_Stak,/(BloodLife,Black&White)"&playerid(enemynear,id),name="WN-Roronoa Zoro"
trigger4 = playerid(enemynear,id),numhelper(602)
trigger4 = playerid(enemynear,id),numhelper(607)
trigger4 = playerid(enemynear,id),numhelper(614)
trigger4 = playerid(enemynear,id),numhelper(615)
trigger5 = playerid(enemynear,id),numproj
trigger6 = !animtime
trigger7 = animelem>=5+abs(random%5)
value = 1
ignorehitpause = 1

[State -1, Ai-Punch]
type = ChangeState
value = cond(playerid(enemynear,id),pos y<const(size.head.pos.y)||playerid(enemynear,id),pos y<pos y,206,cond(random%2,200,cond(random%2,203,cond(random%2,206,cond(random%2,226,228)))))
;triggerall = (helper(50048),var(65)=1)||(helper(50048),var(65)=0)
triggerall = var(59)=1&&numenemy
triggerall = abs(p2dist x)<100
triggerall = abs(p2dist y)<80 
trigger1 = !numprojid(1030)
trigger1 = cond(var(98)=1,random <40+var(58)*7,random <30+var(58)*5)

[State -1, Ai-Guard st]
type = ChangeState
value = 130
triggerall = var(59)=1&&numenemy&& statetype!=A
triggerall = playerid(enemynear,id),hitdefattr=SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT&&inguarddist
triggerall = random <5+var(58)
trigger1 = ctrl
trigger2 = stateno=52

[State -1, Ai-Jump]
type = ChangeState
value = 40
triggerall = var(59)=1
triggerall = roundstate = 2 
triggerall = !numprojid(1030)
triggerall = playerid(enemynear,id),pos y<-5
triggerall = playerid(enemynear,id),p2dist x<800
triggerall = statetype = S
triggerall = ctrl = 1&&stateno!=40
trigger1 = random >= 0 && random <5+var(58)
trigger1 = playerid(enemynear,id),hitdefattr != SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
trigger2 = (enemy, NumProj >= 1)
trigger2 = random >= 0 && random <5+var(58)/3
trigger3 = playerid(enemynear,id),p2dist x<200
trigger3 = playerid(enemynear,id),stateno=[40,51]

[State -1, Ai-Dash-Back]
type = ChangeState
value = 105
triggerall = var(59)=1&&numenemy
triggerall = playerid(enemynear,id),numhelper(602)&playerid(enemynear,id),numhelper(607)&playerid(enemynear,id),numhelper(614)&playerid(enemynear,id),numhelper(615)
triggerall = !numprojid(1030)
triggerall = enemynear, numproj=0 
triggerall = statetype = S||statetype = c
trigger1 = p2movetype = a
trigger1 = random > 10 && random < 5+var(58)/2*(cond(power<200,3,1))
trigger1 = playerid(enemynear,id),hitdefattr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT||playerid(partner,id),gethitvar(damage)
trigger1 = playerid(enemynear,id),movetype=H||playerid(enemynear,id),statetype=l
trigger2 = p2movetype = a
trigger2 = random > 10 && random < 5+var(58)/2
trigger3 = power<200
trigger3 = random > 10 && random < 5+var(58)/2*(cond(power<200,3,1))

[State -1, Ai-Dash-Fwd]
type = ChangeState
value = 100
triggerall = var(59)=1&&numenemy
triggerall = playerid(enemynear,id),p2dist x>300
triggerall = !numprojid(1030)
triggerall = enemynear, numproj=0 
triggerall = statetype = S||statetype = c
triggerall = p2movetype != a
trigger1 = random < 15+var(58)
trigger1 = playerid(enemynear,id),hitdefattr != SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT||playerid(partner,id),gethitvar(damage)
trigger1 = playerid(enemynear,id),movetype!=H||playerid(enemynear,id),statetype!=l||playerid(enemynear,id),anim!=5120
trigger2 = random < 35+var(58)
trigger3 = random < 15+var(58)
trigger3 = playerid(partner,id),gethitvar(damage)

[State 0, ChangeState]
Type = ChangeState
Trigger1 = !Var(59)
Value = 20
Ctrl = 1
