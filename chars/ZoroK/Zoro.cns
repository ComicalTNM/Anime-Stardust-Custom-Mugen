[Quotes]
victory1 = "You want to kill me? You couldn't even kill my boredom!"
victory2 = "I'm a pirate hunter."
victory3 = "If I can't even protect my captain's dream, then whatever ambition I have is nothing but talk..."
victory4 = "I am always serious."
victory5 = "Bring on the hardship. It's preferred in a path of carnage."
victory6 = "You need to accept the fact that you’re not the best and have all the will to strive to be better than anyone you face."
victory7 = "I don’t care what the society says. I’ve regretted doing anything. I will survive and do what I want to."
victory8 = "You sure can talk the talk, but you’re not quite ready to walk the walk. Time’s up, it’s my turn."
victory9 = "There is someone that I must meet again. And until that day…not even Death itself can take my life away!"
victory10 = "I’m going to be the world’s greatest swordsman! All I have left is my destiny! My name may be infamous…but it’s gonna shake the world!!!"
victory11 = "To be the best, you need to accept the fact that you are not the best and have the will to strive to be better than anyone you face."
victory12 = "It does not matter if its as a devil or a saint, my name will be heard all over the world!"
victory13 = "You suck!"

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Random >= 500,224,Cond(Random >= 500,601,Cond(Random >= 800,604,Cond(Random >= 500,605,Cond(Random >= 500,616,Cond(Random >= 800,625,Cond(Random >= 500,631,Cond(Random >= 500,634,Cond(Random >= 500,640,600))))))))); Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

