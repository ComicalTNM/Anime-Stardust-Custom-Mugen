; Stance
[Statedef 4000]
type    = A
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 4000
sprpriority = -2

[State 0, Aura]
type = Helper
triggerall = numhelper(4050) = 0
trigger1 = time > 0
helpertype = normal
name = "boock Aura"
ID = 4050
stateno = 4050
pos = 0,0
postype = p1
ownpal = 1
size.xscale = .15
size.yscale = .15

[State 0, Aura Arriba]
type = Explod
triggerall = time > 0
trigger1 = timemod = 10,0
anim = 4050
ID = 4050
pos = -8+random%16,-20+random%15
postype = p1
bindtime = 1
vel = 0,-1
removetime = -2
ignorehitpause = 1
supermovetime = 999
scale = .1,.1
sprpriority = -1
ontop = 0
ownpal = 1
remappal=3,3
removeongethit = 1

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 200, WALK FWD]
type = Changestate
trigger1 = rootdist x > 30
value = 4020

[State 200, WALK BACK]
type = Changestate
trigger1 = rootdist x < -30
value = 4021

[State 200, WALK DOWN]
type = Changestate
triggerall = root,pos y <= 0
trigger1 = rootdist y > 60
value = 4025

[State 200, WALK UP]
type = Changestate
trigger1 = rootdist y < 30
value = 4030

[State 200, End]
type = Destroyself
trigger1 = time = -1
