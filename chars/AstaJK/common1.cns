; B
[State -1, B]
type = ChangeState
value = Cond(Pos Y >= 0,300,610)
trigger1 = command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 40 && random < (ailevel * 100)/2

; C
[State -1, C]
type = ChangeState
value = Cond(Pos Y >= 0,400,620)+Var(11)
triggerall = time > 2
trigger1 = command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x <30 && random < (ailevel * 100)


