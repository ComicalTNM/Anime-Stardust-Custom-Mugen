;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0
value = Cond(Pos Y >= 0,100,110)

[State 0, DestroySelf] ; Anti Bugs
type = DestroySelf
trigger1 = ishelper

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper
ignorehitpause = 1

[State 0, Remove Explods]
type = RemoveExplod
trigger1 = ishelper
ignorehitpause = 1

[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = Anim != 12000 && Anim != 12005
trigger2 = Anim = 12005 && AnimTime = 0
value = 12000

[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 3
trigger1 = Anim != 13000 && Anim != 13005
trigger2 = Anim = 13005 && AnimTime = 0
value = 13000

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 5+var(11) && Anim != 2000 && Anim != 2005 && Anim != 12000 && Anim != 12005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 5+var(11) || anim = 2005 || anim = 12005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 0+var(11)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10+var(11)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = time = 0
value = 12007
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 3
trigger1 = time = 0
value = 13007
ignorehitpause = 1

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11+var(11)
sprpriority = 0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6+var(11)

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 12011 && Anim != 12006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 12006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11+var(11)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = anim = 12006
value = 12006

[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 2
Trigger1 = Anim != 12011 && Anim != 12006 
Trigger2 = Anim = 12006 && AnimTime = 0
value = 12011

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 3
trigger1 = anim = 13006
value = 13006

[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 3
Trigger1 = Anim != 13011 && Anim != 13006 
Trigger2 = Anim = 13006 && AnimTime = 0
value = 13011
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12+var(11)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = time = 0
value = 12014
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 3
trigger1 = time = 0
value = 13014
ignorehitpause = 1

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 0, Andando]
type = PlaySnd
trigger1 = animelem = 3 || animelem = 7
value = S20,1
volume = 50

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x);+ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x);-ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 12020 && Anim != 12005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 12005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 12021 && Anim != 12005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 12005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)

[State 20, 3]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = vel x > 0
Trigger1 = Anim != 2020 && Anim != 2005 
Trigger2 = Anim = 2005 && AnimTime = 0
value = 2020

[State 20, 4]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = vel x < 0
Trigger1 = Anim != 2021 && Anim != 2005 
Trigger2 = Anim = 2005 && AnimTime = 0
value = 2021

[State 20, 3]
type = ChangeAnim
trigger1 = var(2) = 2
triggerall = vel x > 0
Trigger1 = Anim != 12020 && Anim != 12005 
Trigger2 = Anim = 12005 && AnimTime = 0
value = 12020

[State 20, 4]
type = ChangeAnim
trigger1 = var(2) = 2
triggerall = vel x < 0
Trigger1 = Anim != 12021 && Anim != 12005 
Trigger2 = Anim = 12005 && AnimTime = 0
value = 12021

[State 20, 3]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = vel x > 0
Trigger1 = Anim != 13020 && Anim != 13005 
Trigger2 = Anim = 13005 && AnimTime = 0
value = 13020

[State 20, 4]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = vel x < 0
Trigger1 = Anim != 13021 && Anim != 13005 
Trigger2 = Anim = 13005 && AnimTime = 0
value = 13021
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40+var(11)
ctrl = 0
sprpriority = 2

[state 0]
type=null
trigger1=(animelemtime(1)>=0)&&(var(50):=-5)&&(var(51):=-12)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = time = 0
value = 12040
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = var(2) = 3
trigger1 = time = 0
value = 13040
ignorehitpause = 1

[state 0]
type=envshake
trigger1=!time
time=10
ampl=-6
freq=25

[state 0]
type=varset
trigger1=!time
sysvar(1)=0

[state 0]
type=varset
trigger1=command="holdfwd"
sysvar(1)=1

[state 0]
type=varset
trigger1=command="holdback"
sysvar(1)=-1

[state 0]
type=velset
trigger1=!animtime
x=cond(sysvar(1)=0,const(velocity.jump.neu.x),cond(sysvar(1)=1,const(velocity.jump.fwd.x),const(velocity.jump.back.x)))
y=const(velocity.jump.y)

[state 0]
type=velset
trigger1=!animtime
trigger1=prevstateno=100
trigger1=sysvar(1)=1
x=const(velocity.runjump.fwd.x)

[state 0]
type=veladd
triggerall=(prevstateno=60)||(prevstateno=70)
trigger1=!animtime
x=cond(vel x>0,2,-2)

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
