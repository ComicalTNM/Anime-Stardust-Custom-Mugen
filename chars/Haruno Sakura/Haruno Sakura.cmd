;--------------------------------- Supers --------------------------------------
;-------------------------------------------------------------------------------
[State -1, Gokurakujoudo]
type = ChangeState
Triggerall = power >= 1000
Triggerall = statetype != A
Triggerall = command = "holddown"
Triggerall = command = "a"
trigger1 = ctrl
trigger2 = numhelper(700) > 0
value = 3000
;-------------------------------------------------------------------------------
[State -1, Super 3 Combo]
type = ChangeState
