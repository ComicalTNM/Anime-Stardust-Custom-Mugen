;5ABC- Afterimage Effect
[StateDef 3016]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 9999
SprPriority = 1004

[State 3016, BindToRoot]
Type = BindToRoot
Trigger1 = StateNO = StateNO
IgnoreHitPause = 1

[State 3016, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(0) := Root,Anim
IgnoreHitPause = 1

[State 3016, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(1) := Root,AnimElemNO(0)
IgnoreHitPause = 1

[State 3016, ChangeAnim]
Type = ChangeAnim
Trigger1 = StateNO = StateNO ; 3016
Value = Var(0)
Elem = Var(1)
IgnoreHitPause = 1

[State 3016, NotHitBy]
Type = NotHitBy
Trigger1 = !Time
Value = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT
Time = 10
IgnoreHitPause = 1

[State 3016, AngleDraw]
Type = AngleDraw
Trigger1 = StateNO = StateNO ; 3016
Value = 0
Scale = (1.0 + (Time * 0.015)) * Root,Fvar(3), (1.0 + (Time * 0.015)) * Root,Fvar(3)
IgnoreHitPause = 1

[State 3016, Trans]
Type = Trans
Trigger1 = StateNO = StateNO ; 3016
Trans = AddAlpha
Alpha = 75 - Cond(Time > 5,((Time - 5) *(75 / 5)),0), 256
IgnoreHitPause = 1 

[State 3016, DestroySelf]
Type = DestroySelf
Trigger1 = Time = 10
Trigger2 = Root,StateNO != 3004
Trigger3 = Root,MoveType = H
IgnoreHitPause = 1
