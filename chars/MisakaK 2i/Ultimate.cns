;Zoom
[StateDef 30000]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 9999

[State 30000, ScreenBound]
Type = ScreenBound
Trigger1 = StateNO = 30000
Value = 1
MoveCamera = 0,0
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(26) := (Const(Size.XScale)/Const(Size.Air.Back))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Fvar(26) && Time < Const(Size.Air.Back) 
Trigger1 = Fvar(27) := (Fvar(26) * Time)
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(28) := (Const(Size.XScale)/Const(Size.Air.Front))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Fvar(28) && Time > (Const(Size.Air.Back) + Const(Size.Ground.Back))
Trigger1 = Fvar(29) := (Fvar(28) * (Time - (Const(Size.Air.Back) + Const(Size.Ground.Back))))
IgnoreHitPause = 1

[State 30000, PosSet]
Type = PosSet
Trigger1 = !Time
X = 0
Y = CameraPos Y
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(30) := ((Pos X - Root,Pos X) - (Const(Size.Mid.Pos.X)*Root,Facing))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(31) := ((Pos Y - Root,Pos Y) + Const(Size.Mid.Pos.Y))
IgnoreHitPause = 1

[State 30000, VelSet]
Type = VelSet
Trigger1 = Time < Const(Size.Air.Back)
X = (-(Fvar(30)/ Const(Size.Air.Back)) * Root,Facing)
Y = -(Fvar(31)/ Const(Size.Air.Back))
IgnoreHitPause = 1

[State 30000, VelSet]
Type = VelSet
Trigger1 = Time = [Const(Size.Air.Back),(Const(Size.Air.Back)+Const(Size.Ground.Back))]
X = 0
Y = 0
IgnoreHitPause = 1

[State 30000, VelSet]
Type = VelSet
Trigger1 = Time > (Const(Size.Air.Back) + Const(Size.Ground.Back))
X = ((Fvar(30)/ Const(Size.Air.Front)) * Root,Facing)
Y = (Fvar(31)/ Const(Size.Air.Front))
IgnoreHitPause = 1

[State 30000, VelSet]
Type = VelSet
Trigger1 = Time > (Const(Size.Air.Back) + Const(Size.Air.Front) + Const(Size.Ground.Back))
X = 0
Y = 0
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Time < Const(Size.Air.Back)
Trigger1 = Fvar(25) := (1 + Fvar(27))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Time = [Const(Size.Air.Back),(Const(Size.Air.Back)+Const(Size.Ground.Back))]
Trigger1 = Fvar(25) := (1 + Const(Size.XScale))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Time > (Const(Size.Air.Back) + Const(Size.Ground.Back))
Trigger1 = Fvar(25) := ((1 + Const(Size.XScale)) - Fvar(29))
IgnoreHitPause = 1

[State 30000, Null]
Type = Null
Trigger1 = Time >= (Const(Size.Air.Back) + Const(Size.Air.Front) + Const(Size.Ground.Back))
Trigger1 = Fvar(25) := 1
IgnoreHitPause = 1

[State 30000, Zoom]
Type = Zoom
Trigger1 =StateNO = 30000
Pos = ((Pos X/(Fvar(25))) * CameraZoom),(((Pos Y) -  (CameraPos Y /(Fvar(25)))) * CameraZoom)
Scale = Fvar(25)
IgnoreHitPause = 1

[State 30000, DestroySelf]
Type = DestroySelf
Trigger1 = Time > (Const(Size.Air.Back) + Const(Size.Air.Front) + Const(Size.Ground.Back)) && Fvar(25) = 1
Trigger2 = PlayerIDExist(Const(Size.ShadowOffset))
Trigger2 = PlayerID(Const(Size.ShadowOffset)),MoveType = H
IgnoreHitPause = 1

