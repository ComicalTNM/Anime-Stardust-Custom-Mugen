[StateDef 3001]
Type = S
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 3001
SprPriority = 1002
PowerAdd = -3000

[State 3001, ChangeState]
Type = ChangeState
Trigger1 = Time = 160
Value = StateNO + 1

[State 3001, AngleDraw]
Type = AngleDraw
Trigger1 = StateNO = StateNO ; 3001
Value = 0
Scale = 1.0  * Fvar(3), 1.0  * Fvar(3)
IgnoreHitPause = 1

[State 3001, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Var(54) := 160 + 150 + 220 + 115 + 58 + 170
IgnoreHitPause = 1

[State 3001, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(3) := 0.80 / CameraZoom
IgnoreHitPause = 1

[State 3001, Null]
Type = Null
Trigger1 = AnimElemTime(2) < 0
Trigger1 = Fvar(3) := (0.80 + (Time* (0.40 / 120))) / CameraZoom
IgnoreHitPause = 1

[State 3001, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Fvar(4) := 0
IgnoreHitPause = 1

[State 3001, ScreenBound]
Type = ScreenBound
Trigger1 = StateNO = StateNO ; 3001
Value = 1
MoveCamera = 0, 0
IgnoreHitPause = 1

[State 3001, AssertSpecial]
Type = AssertSpecial
Trigger1 = StateNO = StateNO ; 3001
Flag = NoBarDisplay
Flag2 = NoMusic
Flag3 = NoBG
IgnoreHitPause = 1

[State 3001, AssertSpecial]
Type = AssertSpecial
Trigger1 = StateNO = StateNO ; 3001
Flag = NoFG
Flag2 = NoShadow
Flag3 = TimerFreeze
IgnoreHitPause = 1

[State 3001 Helper]
Type = Helper
Trigger1 = !Time
Name = "BG Floor"
ID = 3210
StateNO = 3210
OwnPal = 1
PauseMoveTime = 99999
Size.Height = 0
IgnoreHitPause = 1

[State 3001, NotHitBy]
Type = NotHitBy
Trigger1 = !Time
Value = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT
Time = Var(54)
IgnoreHitPause = 1

[State 3001, PosSet]
Type = PosSet
Trigger1 = StateNO = StateNO
X = (0 * Facing) / CameraZoom
Y = 0
IgnoreHitPause = 1
Persistent = 0

[State 3001, Helper]
Type = Helper
Trigger1 = !Time
Name = "Black or White FadeIn/FadeOut Effect"
ID = 11020
StateNO = 11020
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = 10 ;StandBy Time
Size.YScale = 10 ;Fade Time
Size.Ground.Back = 1 ;0 - FadeIn / 1 - FadeOut
Size.Ground.Front = 0 ;SprPriority
Size.Air.Back = 1 ;OnTop
Size.Air.Front = 256 ;Transparecy
Size.Height = 0 ;0 - White Fade / 1 - Black Fade 
IgnoreHitPause = 1
Persistent = 0

[State 3001, Helper]
Type = Helper
Trigger1 = !Time
Name = "Black or White FadeIn/FadeOut Effect"
ID = 11020
StateNO = 11020
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = Var(54) ;StandBy Time
Size.YScale = 0 ;Fade Time
Size.Ground.Back = 1 ;0 - FadeIn / 1 - FadeOut
Size.Ground.Front = 996 ;SprPriority
Size.Air.Back = 0 ;OnTop
Size.Air.Front = 256 ;Transparecy
Size.Height = 1 ;0 - White Fade / 1 - Black Fade 
IgnoreHitPause = 1
Persistent = 0

