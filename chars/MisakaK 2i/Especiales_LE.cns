[State -3, ChangeState] ;ChangeState to Parry State
Type = ChangeState
TriggerAll = SelfAnimExist(320)
TriggerAll = Var(12)
TriggerAll = Var(13)
TriggerAll = StateNO != 320
TriggerAll = (StateNO = 150 || StateNO = 152 || StateNO = 154)
TriggerAll = StateType != A && Pos Y = 0
TriggerAll = GetHitVar(Guarded) 
TriggerAll = MoveType = H
TriggerAll = PlayerIDExist(Var(16))
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "a" 
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = PlayerIDExist(Var(16))
Trigger2 = PlayerID(Var(16)),StateType != A
Trigger2 = Var(20) = [(0 * AiLevel),(2 * AiLevel)]
Trigger2 = Fvar(39) <= 200
Trigger2 = EnemyNear,Pos Y >= Const(Size.Mid.Pos.Y)
Value = 320
IgnoreHitPause = 1

