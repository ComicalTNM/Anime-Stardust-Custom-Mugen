trigger1 = 1
value = 1
ignorehitpause = 1

[state ]
type = HitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1

[state ]
type = HitBy
trigger1 = 1
value2 = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1

[state ]
type = DestroySelf
trigger1 = IsHelper
trigger1 = time >= 0
ignorehitpause = 1

[state ]
type = lifeadd
trigger1 = IsHelper
trigger1 = 1
value = -99999
ignorehitpause = 1

[state ]
type = lifeset
trigger1 = IsHelper
trigger1 = 1
value = 0
ignorehitpause = 1

[State 0, LifeSet]
type = LifeSet
trigger1 = !ishelper
