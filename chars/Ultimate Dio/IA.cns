[State 0, AttackMulSet]
type = AttackMulSet
triggerall = Var(30) = 2
trigger1 = 1
value = 1 + 0.2*var(3) + 0.2*numhelper(850)
ignorehitpause = 1

[State 0, DefenceMulSet]
type = DefenceMulSet
triggerall = Var(30) = 2
trigger1 = 1
value = 1 - 0.2*numhelper(850) - ifelse(stateno >= 130 && stateno <= 155, 0.5, 0)
ignorehitpause = 1

[State 0, PowerAdd]
type = PowerAdd
triggerall = Var(30) = 2
triggerall = alive && roundstate = 2
trigger1 = gethitvar(damage) > 0
value = ifelse(gethitvar(damage)*1.5 > 1000, 1000, gethitvar(damage)*1.5)
ignorehitpause = 1

