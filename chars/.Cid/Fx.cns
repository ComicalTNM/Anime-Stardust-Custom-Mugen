paladd=0,0,0
timegap=1
framegap=3
ignorehitpause=1

[State 0,VelSet]
type=VelSet
trigger1=!Time
x=ifelse(random<500,12,ifelse(random<500,-12,0))

[State 0,Turn]
type=Turn
trigger1=p2bodydist x<-10&&time=20

[State 0,VelSet]
type=VelSet
trigger1=time>=20
x=0

[State 0,EnvShake]
type=EnvShake
trigger1=!Time
time=5
ampl=-3


[State 0,Pause]
type=Pause
trigger1=!Time
time=30
movetime=30


[State 0, PosSet]
type = PosSet
trigger1 = pos y >=0
y = 0
ignorehitpause = 1


[State 0, VelSet]
type = VelSet
trigger1 = pos y >=0
y = 0
ignorehitpause = 1




[State 0,ChangeAnim]
type=ChangeAnim
trigger1=!Time
value=200001;1301+random%3
elem=1

; A
[State -1, A]
type = ChangeState
Trigger1 = AiLevel = 0 && Command = "a"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)
trigger2 = P2BodyDist X = [-40,50]
Trigger2 = P2BodyDist y = [-40,40]
value = cond(pos y>=0,200,600)

; B
[State -1, B]
type = ChangeState
Trigger1 = AiLevel = 0 && Command = "b"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)
trigger2 = P2BodyDist X = [-40,50]
Trigger2 = P2BodyDist y = [-40,40]
value = cond(pos y>=0,220,610)

[State 0,StateTypeSet]
type=StateTypeSet
trigger1=pos y>=0
statetype=S
movetype=I
physics=S

[State 200,End]
type=ChangeState
trigger1=Time=35
value=ifelse(pos y<0,50,0)
ctrl=1









