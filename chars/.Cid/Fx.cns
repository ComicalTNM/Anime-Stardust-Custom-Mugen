;-------------------------------------------------------------------------------
; B - Guard Collision 
[Statedef 331]
type = S
movetype = I
physics = N
juggle = 2
ctrl = 0
sprpriority = 3

[State 0, Width]
type = Width
trigger1 = 1
edge = 0,0
player = cond(ishelper(516),-5,-5),cond(ishelper(516),-5,-5)
ignorehitpause = 1

[State 0,ChangeAnim]
type = ChangeAnim
trigger1 = !Time
value = 6
elem = 1
ignorehitpause = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = 1,1
ignorehitpause = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
time = 1
pos = 0,15
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
triggerall = ishelper(515) || ishelper(516)
trigger1 =! Time
x = cond(ishelper(516),2,2)
ignorehitpause = 1

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 1
ignorehitpause = 1

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

[State 0,DestroySelf]
type = DestroySelf
trigger1 = root,stateno != 320
ignorehitpause = 1
