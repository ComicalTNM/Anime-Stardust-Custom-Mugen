[StateDef 999]
type = S
physics = N
sprpriority = 999

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
value2 = S,NA
time = 1
ignorehitpause = 1

[State 0, AfterImage]
type = AfterImage
trigger1 = root,command = "fwd" || root,command = "back" || root,command = "up" || root,command = "down"
time = 20
length = 15
palcolor = 256
palinvertall = Cond(Random<500,0,1)
palpostbright = 0,0,0
palbright = Cond(random<500,150,0),Cond(random<500,150,0),Cond(random<500,150,0)
palcontrast = 70,70,70
paladd = 20,20,20
palmul = 1.3,1.3,1.3
trans = add ;"none","add1","sub"
timegap = 1
framegap = 5

[State 0, VelSet]
type = VelSet
trigger1 = 1
x = Cond(random<500,-1,1)
y = Cond(random<500,-1,1)

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
scale =1+(time/100.0),1+(time/100.0)

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 =1
flag = noshadow
ignorehitpause =1

[State 0, Trans]
type = Trans
trigger1 = time<10
trans = addalpha ;none, add, addalpha, add1, sub
alpha = 256,256

[State 0]
type = Trans
trigger1 = time >= 10
trans = addalpha
alpha = 256-(40*(time-10)), 256

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = time%3=0
value = root,anim
elem = root,animelemno(0)

[State 0, DestroySelf]
type = DestroySelf
trigger1 =time=20
