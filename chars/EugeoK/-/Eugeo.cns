;---------------------------------------------------------------------------
; Assists
[StateDef 13532]
Type = S
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 11

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(((p2bodydist x=[-60,60]))&&(p2bodydist y=[-75,-30]),1300,Cond(P2BodyDist x > 100,Cond(Random >= 500,1100,1500),Cond(Random >= 500,1200,1000))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

;---------------------------------------------------------------------------
; Assists 2
[StateDef 13533]
Type = S
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 11

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(((p2bodydist x=[-60,60]))&&(p2bodydist y=[-75,-30]),1300,Cond(P2BodyDist x > 100,Cond(Random >= 500,1100,1500),Cond(Random >= 500,1200,1000))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

