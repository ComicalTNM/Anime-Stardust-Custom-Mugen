yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 3
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
;===============================================================================
;Base Quotes
victory0="This new-found power is quite amazing!"
victory1="What a feeble and pathetic lowly mortal"
victory2="Tell me, mortal. Why go on when you know you're going to lose in the end?"
victory3="Death is a mercy. To fools like you."
victory4="Damn time ring! I can no longer go back to that era..."
victory5="Looks like the time ring has much more to show me."
victory6="Time to fix the rifts in times, with my timering of course."
victory7="I wonder.. can I use this timering to aquire more allies?"
victory8="This body of mine is simply magnificent!"
victory9="As expected, I have no need for immortality"
