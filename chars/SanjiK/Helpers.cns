;---------------------------------------------------------------------------
;AfterImage
[Statedef 8003]
type = A
movetype = I
physics = N
ctrl = 0

[State 0]
Type = VarSet
Trigger1 = !Time
V = 1
Value = Cond(Parent,AnimElemTime(3) >= 0 && Parent,AnimElemTime(4) < 0 && IsHelper(480),4,Parent,AnimElemNo(0))

[state 0]
type = angledraw
trigger1 = !IsHelper(090) && !IsHelper(091) && !IsHelper(092)
scale = 1.0+(time*0.00375),1.0+(time*0.00375)
value = 0
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = Parent,Anim
elem = Cond(IsHelper(480)||IsHelper(090)||IsHelper(092)||IsHelper(093),Var(1),Parent,AnimElemNo(0))

[state 0]
type = velset
trigger1 = !time
x = cond(Root,Stateno = 320,Cond(IsHelper(230),1,Cond(IsHelper(480),-.5,-1)),0)
y = Cond(IsHelper(480)||IsHelper(093),.5,0)
ignorehitpause = 1

[State 0, Trans]
type = Trans
trigger1 = IsHelper(092)
trans = addalpha
alpha =125-time*15,125+time*20

[State 0, AngleDraw]
type = AngleDraw
trigger1 = IsHelper(090) || IsHelper(091)
scale = 1+time*.030,1+time*.02
value = 0

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = Cond(IsHelper(480)||IsHelper(090)||IsHelper(091)||IsHelper(092)||IsHelper(093),100,150)-(time)*Cond(IsHelper(480),6,10),256;80+(time)*10

[State 0, PalFXWiz]
type = PalFX
trigger1 = IsHelper(092) || IsHelper(093)
time = 1
add = 0,0,0 
mul = 0+Ceil(Time*50),256,256
sinadd = 0,0,0,1
invertall = 0
color = 256

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 0,0

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0, AssertSpecial]
type = AssertSpecial
Trigger1 = 1
flag = noshadow

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,AA,AP,AT,NT,ST,HT,NA,NP,SA,SP,HA,HP
time = -1

[State 0, SprPriority]
type = SprPriority
trigger1 = 1
value = cond(Root,Stateno = 191,4,1)
ignorehitpause = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = time = Cond(Var(1) = 4 && IsHelper(480),8,Cond(IsHelper(092)||IsHelper(093),12,20));Cond(IsHelper(460),10,20)


;============================================================
; AfterImage
;============================================================
[Statedef 98031]
Type = U
SprPriority = 3
Ctrl = 0

;-------------------------
[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Value = Root,Anim
Elem = Cond(Root,Anim = 48,2,Root,AnimElemNo(0))
IgnoreHitPause 	= 1

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = Time > 0
Value = Cond(Root,Anim = 48,48,Anim)
Elem = AnimElemNo(0)
IgnoreHitPause 	= 1

[State 0, NotHitBy]
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = -1
;-------------------------
; SuperJump AfterImage
[State 0, AngleDraw]
Type = AngleDraw
Triggerall = IsHelper(98031)
Trigger1 = 1
Scale = 1.25-(Time*0.05),.8+(Time*0.1)
Value = Cond(Var(2) = 1,-14,Cond(Var(2) = 2,14,0))

[State 0, VarSet]
Type = VarSet
triggerall = !Time
Trigger1 = Root,Command = "holdfwd" && (Root,Stateno = [45,50]) || Root,Command = "holdback" && (Root,Stateno = [45,50])
V = 2
Value = Cond(Root,Command = "holdback" && (Root,Stateno = [45,50]),2,1)

[State 0, Trans]
Type = Trans
Triggerall = IsHelper(98031)
Trigger1 = 1
Trans = AddAlpha
Alpha = 150-(Time*15),110+(Time*15)

[State 0, AssertSpecial]
Type = AssertSpecial
Triggerall = IsHelper(98031)
Trigger1 = 1
Flag = NoShadow

[State 0, End]
Type = DestroySelf
Triggerall = IsHelper(98031)
Trigger1 = Time >= 15

;-----------------
; Run AfterImage
[state 0]
type = null
Triggerall = IsHelper(98032)
trigger1 = !time
trigger1 = selfanimexist(root, anim)
trigger1 = var(0) := root,anim
ignorehitpause = 1

[state 0]
type = null
Triggerall = IsHelper(98032)
trigger1 = !time
trigger1 = selfanimexist(root, anim)
trigger1 = var(1) := root,animelemno(0)
ignorehitpause = 1

[state 0]
type = velset
Triggerall = IsHelper(98032)
trigger1 = !time
x = cond(root,stateno = 100,-1,0)
y = 0
ignorehitpause = 1

[state 0]
type = angledraw
Triggerall = IsHelper(98032)
trigger1 = stateno = stateno
scale = 1.0+(time*0.00375),1.0+(time*0.00375)
value = 0
ignorehitpause = 1

[state 0]
type = trans
Triggerall = IsHelper(98032)
trigger1 = stateno = stateno
trans = addalpha
alpha = 50-cond(time > 5,((time - 5)*10),0),256
ignorehitpause = 1 

[State 0, End]
Type = DestroySelf
Triggerall = IsHelper(98032)
Trigger1 = Time >= 10

