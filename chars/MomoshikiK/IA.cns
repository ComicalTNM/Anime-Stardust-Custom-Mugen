IgnoreHitPause = 1

[State 0, ChangeState]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = AILevel && (Anim = 1 && AnimElem >= 2 || Anim = 10 || Anim = 20 && AnimElem >= 3)
Value = 60

[State 0, DefenceMulSet]
type = DefenceMulSet
trigger1 = Life <= LifeMax/2
value = .8
IgnoreHitPause = 1

[State 0, Helper de Conexiones]
type = Helper
trigger1 = stateno = 200 && movecontact
trigger2 = stateno = 210 && movecontact
trigger3 = stateno = 230 && movecontact
trigger4 = stateno = 236 && movecontact && time >= 35
helpertype = normal
name = "Helper de Conexiones"
ID = 700
stateno = 700
pos = 999999,999999
postype = p1

