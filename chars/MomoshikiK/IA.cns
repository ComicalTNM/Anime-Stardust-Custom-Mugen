Triggerall = AILevel > 0 && RoundState = 2
Triggerall = Ctrl
Triggerall = P2BodyDist x < 9999
Triggerall = P2BodyDist y = [-10,10]
Trigger1 = Random < (AILevel * 100)/2
value = 200

[State 0, B]
