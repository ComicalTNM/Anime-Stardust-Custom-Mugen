[quotes]
victory0 = "Arise."
victory1 = "True strength is not found in the power of your abilities, but in the power of your will."
victory2 = "As long as I've got bones to break, I'll keep coming."
victory3 = "Even in the darkest times, there is a glimmer of hope. It is this glimmer of hope that keeps us fighting."
victory4 = "Growth doesn't happen when things are easy. It's when we face challenges and overcome our limitations that we truly grow."
victory5 = "You've made the wrong choice. You shouldn't have made me your enemy."
victory6 = "You hit like a wet sponge. Try again."
victory7 = "I'm not strong because I'm invincible. I'm strong because I've been weak."
victory8 = "The only one who can protect me... is me."
victory9 = "The power I sought came with a price. But I paid it gladly."
victory10 = "You're not even worth resurrecting."
victory11 = "I am saying you should get ready to become hunted."
victory12 = "The system uses me, and I use the system."
victory13 = "If I rely too much on my summons, my skills would become rusty."
victory14 = "I feel like something within me is lost every time I get stronger."
victory15 = "Now, on to the next target."



