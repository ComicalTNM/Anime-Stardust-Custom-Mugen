[State 0, Special 7: Sword Train]
Type = ChangeState
TriggerAll = StateType != A
Triggerall = Helper(50003),Fvar(24) >= 1000
TriggerAll = Random < (8 * 100)/2
TriggerAll = EnemyNear,StateType != L
TriggerAll = EnemyNear,Pos Y >= -Const(Size.Height)
TriggerAll = FrontEdgeBodyDist >= 50
Trigger1 = P2BodyDist X = [50,220]
Trigger2 = MoveContact
Trigger2 = StateNO = 30310 || StateNO = 30250 || StateNO = 30230
Trigger2 = P2BodyDist X >= 25
Trigger3 = (StateNO = 30621 && MoveHit)
Value = 301600

[State 0, End]
Type = ChangeState
Trigger1 = !AnimTime
Value = 700002
Ctrl = 1

