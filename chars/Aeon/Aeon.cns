[State 0, HitDef]
type = HitDef
hitflag = MAFD
trigger1 =! MoveContact
attr = S,NA
;hitflag = MAFd
priority = 37623634,Hit
;guardflag = MA
animtype = Light
damage = 18,7
pausetime = 9,28
guard.pausetime = 9,7
guard.sparkno = s7000
sparkxy = -8,-25
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime = 15
ground.velocity = -4
air.velocity = -1,-1
EnvShake.Time = 6
EnvShake.Ampl = -5
EnvShake.Freq = 5
fall = 0
GetPower = 70,22

[State 0,Base Hit Spark]
type = Helper
trigger1 = MoveHit = 1
helpertype = normal
ID = 8000
stateno = 8000
pos = Cond((P2Dist X<30),P2Dist X+0,24),-18
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .085*0.90
size.yscale = .085*0.90
ignorehitpause = 1
PERSISTENT = 0

[State 0, Chain]
type = ChangeState
Trigger1 = Ailevel = 0 && Command = "holddown" && Command = "a" && MoveContact
trigger2 = Ailevel = 0 && Command = "holddown" && Command = "a" && AnimElemTime(5)>=0 && !MoveContact
trigger3 = ailevel > 0	&& movecontact && random < (ailevel * 100)/4
trigger4 = roundstate = 2 && AnimElemTime(5)>=0 && ailevel > 0 && random < (ailevel * 100)/4 && p2bodydist x = [0,30]
value = 260

[State 0, Combo]
type = ChangeState
Trigger1 = Ailevel = 0 && Command = "a" && MoveContact
trigger2 = Ailevel = 0 && Command = "a" && AnimElemTime(5)>=0 && !MoveContact
trigger3 = ailevel > 0	&& movecontact && random < (ailevel * 100)/2
trigger4 = roundstate = 2 && AnimElemTime(5)>=0 && ailevel > 0 && random < (ailevel * 100)/2 && p2bodydist x = [0,30]
value = 210

[State 0, Combo]
type = ChangeState
Trigger1 = Ailevel = 0 && Command = "b" && MoveContact
trigger2 = Ailevel = 0 && Command = "b" && AnimElemTime(5)>=0 && !MoveContact
trigger3 = ailevel > 0	&& movecontact && random < (ailevel * 100)/2
trigger4 = roundstate = 2 && AnimElemTime(5)>=0 && ailevel > 0 && random < (ailevel * 100)/2 && p2bodydist x = [0,30]
value = 300

[State 0, Combo]
type = ChangeState
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 400

[State 0,End]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
