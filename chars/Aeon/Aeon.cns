trigger1 = time = 4
value = S5,0+random%3
volume = 999

[State 0, CLASH HIT]
type = HitOverride
triggerall = enemynear,facing != facing
triggerall = !cond(facing = 1,pos x > enemynear,pos x,pos x < enemynear,pos x)
triggerall = (!enemynear,ishelper)
trigger1 = animelem = 4
attr = SCA,NA		
stateno = 8145
forceair = 0
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = time = 4
x = 3

[State 0,Punch - FX]
type = Helper
trigger1 = AnimElemTime(4)=0
name = "Punch - FX"
ID = 01
Stateno = 201
Size.Mid.Pos = 17,-18
postype = p1
facing = 1
ownpal = 1
size.xscale = .18
size.yscale = .14
Size.ShadowOffset = -90
ignorehitpause = 1

[State 0, Hit]
type = PlaySnd
trigger1 = MoveHit = 1
value = S1,30+random%2
volumescale = 100
ignorehitpause = 1
