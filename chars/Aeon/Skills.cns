[State -1,SUPER1]
Type = ChangeState
TriggerALL = Power >= 2000
TriggerAll = Time >= 35
Triggerall = MoveContact
Trigger1 = Command = "SUPER1"
trigger2 = RoundState = 2 && AiLevel > 0 && (Random<(AILevel*100)/3)
trigger2 = P2BodyDist X > 30
value = 1600

[State -1,SPECIAL 3]
type = ChangeState
TriggerALL = Power >= 1000
TriggerAll = Time >= 35
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 3"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/8
trigger2 = P2BodyDist X > 30
value = 1200

[State -1,SPECIAL 4]
type = ChangeState
TriggerALL = Power >= 1000
TriggerAll = Time >= 35
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 4"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/5
trigger2 = P2BodyDist X > 30
value = 1300

[State -1,SPECIAL 5]
type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = Time >= 35
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 5"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/10
trigger2 = P2BodyDist X > 30
value = 1400

[State 0,End]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
