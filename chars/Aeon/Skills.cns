TriggerAll = Time >= 50
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 3"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/8
trigger2 = P2BodyDist X > 30
value = 1205

[State -1,SPECIAL 4]
type = ChangeState
TriggerALL = Power >= 1000
TriggerAll = Time >= 60
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 4"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/5
trigger2 = P2BodyDist X > 30
value = 1305

[State -1,SPECIAL 5]
type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = Time >= 50
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 5"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/10
trigger2 = P2BodyDist X > 30
value = 1405

[State -1,SPECIAL 6]
type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = Time >= 50
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 6"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/12
trigger2 = P2BodyDist X > 30
value = 1505

[State 0,End]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
