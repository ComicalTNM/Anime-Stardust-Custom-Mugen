
; Player information
[Info]
name         = "Bardock"   ; Name of character
displayname  = "Bardock"  ; Name of character to display
versiondate  = 1.1           ; Version date of character (MM,DD,YYYY or X.XX)
mugenversion = 1.1           ; Version of M.U.G.E.N. character works on (X.XX)
author       = "Dry-Mugen"   ; Character author name
pal.defaults = 1,2,3,4,5,6   ; Default palettes in order of preference (up to 4, starts from 1)
     ; Local coordinate space (width, height)

; Files for the player
[Files]
cmd      = Bardock.cmd          ; Command set
cns      = Bardock.cns          ; Constants
st       = Bardock.cns    
st1       = Special.cns   
st2      =  IA.cns          ; States 
stcommon = common1.cns       ; Common states (from data or motif)
sprite   = Bardock.sff          ; Sprite
anim     = Bardock.air          ; Animation
sound    = Bardock.snd          ; Sound
ai       = Bardock.ai           ; AI hints data (not used)

; Arcade mode
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
