; Susanoo Perfect - Stance
[Statedef 39001]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 39001
sprpriority = 0

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, WALK FWD]
type = ChangeState
Triggerall = Numhelper(39003)
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel = 0 && command = "FF"
trigger3 = ailevel > 0 && random < (ailevel * 100)/4 && p2bodydist x > 75
value = 39020

[State 0, WALK BACK]
type = ChangeState
Triggerall = Numhelper(39003)
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel = 0 && command = "BB"
trigger3 = ailevel > 0 && random < (ailevel * 100)/8 && p2bodydist x <= 75
value = 39021

[State 0, Susanoo Cataclism]
type = ChangeState
Triggerall = Numhelper(39003)
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x <= 150
value = 39500

[State 0, Susanoo Storm]
type = ChangeState
Triggerall = Numhelper(39003)
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 39600

[State 0, Lightning Blade]
type = ChangeState
Triggerall = Numhelper(39003)
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 5"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x > 150
value = 39700

[State 0, Susanoo Perfect A]
type = ChangeState
Triggerall = Numhelper(39003)
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 100
trigger2 = p2bodydist y < -50
value = 39200

[State 0, Susanoo Perfect B]
type = ChangeState
Triggerall = Numhelper(39003)
trigger1 = ailevel = 0 && command = "b"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 75
value = 39300

[State 0, Susanoo Perfect C]
type = ChangeState
Triggerall = Numhelper(39003)
trigger1 = ailevel = 0 && command = "c"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 200
trigger2 = p2bodydist y < -50
value = 39400

[State 200, End]
type = ChangeState
trigger1 = numhelper(39100) = 0 || roundstate != 2
value = 39800

[State 200, End]
type = ChangeState
trigger1 = !alive
value = 5050
