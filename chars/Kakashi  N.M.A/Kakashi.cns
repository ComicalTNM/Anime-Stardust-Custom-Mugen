;===================================================================================
;----------------Constants and Normal Attacks---------------------------------------
;===================================================================================

;Var List:

; - Var(7) = DO NOT TOUCH
; - Var(8) = DO NOT TOUCH
; - Var(9) = IA
; - Var(10) = Appearance Transformaations
; - Var(11) = Beaten Transformaations
; - Var(12) = Dark screen
; - Var(13) = Reset pumps
; - Var(14) = Specials Transformaations
; - Var(15) = Supers Transformaations
; - FVar(16) = SCALE

[Data]
life = 2000
power = 4000
attack = 125
defence = 115
fall.defence_up = 50
liedown.time = 30
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ; STATENO: normal assist attack
StateTagAssistHyper = 34365 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. 

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 8
walk.back = -8
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 1
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82
