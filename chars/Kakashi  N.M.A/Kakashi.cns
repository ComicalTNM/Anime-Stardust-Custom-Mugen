[State 0, VarSet] ;DMS Check
type = VarSet
trigger1 = Root,Stateno = 15000 && !var(1)
v = 1  
value = 10
[State 0, VarSet] ;Full Susanoo Check
type = VarSet
trigger1 = Root,Stateno = 39000 && !var(2)
v = 2  
value = 10
[State 0, VarSet] ;Kamui Dimension Check
type = VarSet
trigger1 = Root,Stateno = 18200 && !var(3)
v = 3 
value = 10
[State 0, VarSet] ; Kamui Protection Chance
type = VarRandom
Triggerall = Root,Stateno != 15000
Triggerall = Root,movetype != A
Triggerall = Var(4) > 10 || !Var(4)
trigger1 = Var(1)
v = 4 
range = 1,100
ignorehitpause = 1
persistent = 1
[State 0, VarSet] ; Kamui Protection ON
type = VarSet
Triggerall = Stateno != 0 && Anim != 0
Triggerall = Root,movetype != A && Movetype != H
trigger1 = Var(4) = [1,10]
v = 5
value = 10
ignorehitpause = 1
persistent = 1
[State 0, VarSet] ; Kamui Protection OFF
type = VarSet
Trigger3 = Stateno = 0 || Anim = 0
Trigger2 = Root,movetype = A || Movetype != H
trigger1 = Var(4) > 10
v = 5
value = 0
ignorehitpause = 1
persistent = 1
[State 0, VarSet] ; Life Check | Enemy 1
type = VarSet
triggerall = playeridexist(root,var(52))
trigger1 = Numhelper(18250)
fv = 1
value = playerid(root,var(52)),life
[State 0, VarSet] ; Lifemax Check | Enemy 1
type = VarSet
triggerall = playeridexist(root,var(52))
trigger1 = !fvar(5)
fv = 5
value = playerid(root,var(52)),lifemax
[State 0, VarSet] ; Life Check | Enemy 2
