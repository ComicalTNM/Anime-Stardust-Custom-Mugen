trigger1 = Var(2) = 1
value = 1.12	

[State 0, DefenceMulSet]
type = DefenceMulSet
trigger1 = Var(2) = 1
value = .6

[state -2,]
type = hitoverride
triggerALL = Var(2)=1
trigger1 =random < 30
stateno = 120
time = 2
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
slot = 1




[State 0, Quick Escape Counter]
type = SelfState
