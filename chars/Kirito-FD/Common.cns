; HITG_SLIDE
[Statedef 116001]
type    = S
movetype= H
physics = S

[State 2120]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = 1
ignorehitpause = 1

[State 5001, 1]
type = HitVelSet
trigger1 = Time = 0
x = 1

[State 5001, 2]
type = ChangeAnim
trigger1 = AnimTime = 0
value = 5005+var(10) + GetHitVar(animtype) + (GetHitVar(groundtype)=2)*10

