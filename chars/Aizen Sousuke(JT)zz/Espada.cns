; Ulqiorra - Stand
[Statedef 40000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 40000
sprpriority = 0

[State 22222, HitOverride]
type = HitOverride
trigger1 =  1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 222220
time = 99999999999999999
ignorehitpause = 1
sprpriority = 0

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -20

[State 200, Walk FWD]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x > 30
trigger1 = random < 200
value = 40020

[State 200, Hit 1]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x < 30
trigger1 = random < 100
value = 40200

[State 300, Hit 1]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x < 30
trigger1 = random < 100
value = 40300

[State 300, Hit 1]
type = ChangeState
triggerall = numhelper(401201) = 0
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
triggerall = power >= 1000
trigger1 = p2bodydist x = [0,200]
trigger1 = random < 80
value = 401200

[State 200, End]
type = ChangeState
trigger1 = roundstate != 2
trigger2 = !Root,Alive
trigger3 = root,var(4) = [2,3]
trigger4 = var(9) = 20
value = 230000
