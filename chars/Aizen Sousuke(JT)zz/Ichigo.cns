trigger1 = random < 200
value = 70020

[State 200, Hit 1]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x < 30
trigger1 = random < 100
value = 70200

[State 300, Hit 1]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x < 30
trigger1 = random < 100
value = 70300

[State 300, Hit 1]
type = ChangeState
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
trigger1 = p2bodydist x < 30
trigger1 = random < 100
value = 70400

[State 0, Special 1: GETSUGA TENSHOU]
Type = ChangeState
Triggerall = root,power >= 1000
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
Trigger1 = P2BodyDist x = [100,300]
Trigger1 = Random < 90
Trigger2 = P2BodyDist x = [150,400]
Trigger2 = Random < 80
Value = 701000

[State 0, Special 3: Bunches and bunches of slashes]
Type = ChangeState
Triggerall = root,power >= 1000
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
Triggerall = P2BodyDist x = [20,130]
Triggerall = P2BodyDist y = [-30,30]
Trigger1 = Random < 60
Value = 701200

[state 0, Special 4: Up Slash]
type=changestate
Triggerall = root,power >= 1000
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
triggerall=((p2bodydist x=[-90,90]))&&(p2bodydist y=[-75,-30])
Trigger1 = Random < 75
value=701300

[State 0, Ultimate 1: Purple Getsuga Fr]
type = ChangeState
Triggerall = root,power >=2500
Triggerall = Root,Anim != 0
Triggerall = Root,Alive
triggerall= enemynear,statetype != L
triggerall= enemynear,pos y>= -const(size.height)*1.6
Trigger1 = Random < 25
value = 703000

[State 200, End]
type = ChangeState
trigger1 = roundstate != 2
trigger2 = !Root,Alive
value = 230003
