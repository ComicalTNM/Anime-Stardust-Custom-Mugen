[Statedef -2]


[state 0]
type = lifeadd
trigger1 = life <= 50
value = -500
kill = 1


[State -3, Speed]
type = ChangeAnim
Triggerall = Var(48)
triggerall = anim != [1000,3099]
triggerall = anim != 500
triggerall = anim != 5120
triggerall = (RoundState = 2) && (MoveType != H)
trigger1 = AnimElemTime(AnimElemNo(0) + 1) < 0
trigger1 = AnimElemTime(AnimElemNo(0)) > floor((AnimElemTime(AnimElemNo(0)) - AnimElemTime(AnimElemNo(0) + 1))/2)
ignorehitpause = 1
value = anim
elem = AnimElemNo(0) + 2


[state -2,]
trigger1=random < 50
trigger1 = var(14) < 2
type = hitoverride
stateno = 120
time = 2
attr = SCA,AT,AA,AP
slot = 1


