triggerall = !alive
trigger1 = AnimTime = 0
trigger2 = SysVar(0) ;SysVar(0) = 1 avoids hit ground frame
trigger3 = Anim = [5110+var(10),5119+var(10)]
value = 5150

[State 5110, 11] ;If just died
