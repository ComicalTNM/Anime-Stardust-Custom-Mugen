Triggerall = Numhelper(3200)
Triggerall = Fvar(2)
Triggerall = Fvar(1) < Fvar(2)
Triggerall = Time
Trigger1 = (Ishelper(3200))
Fv = 1
Value = 1

[State 0, Gedo Husk Ultimate CD Set]
type = VarSet
Triggerall = !Fvar(2)
Triggerall = 1
Trigger1 = (Ishelper(3000))
Fv = 2
Value = Cond((Root,Stateno = 191||Root,Stateno = 0),2600/2,2600)
[State 0, Unmasked Ultimate CD Set]
