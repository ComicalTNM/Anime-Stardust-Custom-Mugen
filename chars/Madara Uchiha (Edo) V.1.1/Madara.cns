trigger1 = 1
time = 10
pos = 0,0

[State 0, Gedo Husk Ultimate CD]
type = Varadd
Triggerall = Numhelper(3000)
Triggerall = Fvar(2)
Triggerall = Fvar(1) < Fvar(2)
Triggerall = Time
Trigger1 = (Ishelper(3000))
Fv = 1
Value = 1
[State 0, Unmasked Ultimate CD]
type = Varadd
Triggerall = Numhelper(3100)
Triggerall = Fvar(2)
Triggerall = Fvar(1) < Fvar(2)
Triggerall = Time
Trigger1 = (Ishelper(3100))
Fv = 1
Value = 1
[State 0, 10 Tails Jinjuriki Ultimate CD]
