;===============================================================================
;----------------------RikudouMode----------------------------------------------
;===============================================================================
;===============================================================================
; Rikudou - Fly
[Statedef 130000]
type    = A
physics = N
ctrl = 1
sprpriority = 0

[state 501,1]
type = PosAdd
Triggerall = p2bodydist x < 200
trigger1 = 1
x= -26*((p2bodydist x -0)/(abs(p2bodydist x - 0) + abs(p2bodydist y - 20) + 0.0000001))
persistent = 1
ignorehitpause = 1

[State 0, ChangeState]
type = ChangeState
Trigger2 = Var(2) != 2 && !Ishelper
trigger1 = Ishelper
value =0+(var(11))
ctrl = 1

[State -3, Turn Juubi]
type = ChangeAnim
trigger1 = p2dist x < 0 && anim != 130005
value = 130005

[State 0, Turn]
type = Turn
trigger1 = anim = 130005 && !animtime

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0+var(11) && Anim != 5+var(11)
trigger2 = Anim = 5+var(11) && AnimTime = 0
value = 130000

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 61, 11]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 61, 11]
type = ChangeState
trigger1 = pos y >= 0 && time > 2
value = 0
ctrl = 1

[State 61, 11]
type = ChangeState
trigger1 = RoundState != 2
value = 50

[State 61, 9]
type = VelSet
triggerall = pos y >= -400
trigger1 = ailevel = 0 && command = "holdup"
trigger2 = ailevel > 0 && enemynear,pos y - pos y < -20
y = -4

[State 61, 9]
type = VelSet
trigger1 = ailevel = 0 && pos y < 0 && command = "holddown"
trigger2 = ailevel > 0 && enemynear,pos y - pos y > 20
y = 4

[State 61, 9]
type = VelSet
trigger1 = ailevel = 0 && command != "holdup" && command != "holddown"
trigger2 = ailevel = 0 && command = "holdup" && command = "holddown"
trigger3 = ailevel > 0 && random < 50 && enemynear,pos y - pos y = [-20,20]
trigger4 = pos y < -400 && vel y < 0
y = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel = 0 && command = "holdback"
trigger3 = ailevel > 0 && p2bodydist x > 50 && frontedgedist > 20 && random < 200
value = 130020

[State 0, ChangeState]
type = ChangeState
trigger1 = ailevel > 0 && p2bodydist x <= 50 && random < 100
value = 130021
