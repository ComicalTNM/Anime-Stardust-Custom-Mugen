[State 0, BGPalFX]
type = BGPalFX
trigger1 = time >= 0 && time <70  ; trigger to start when the state begins
time = 1                           ; apply the effect every tick
add = floor(-50 * time / 30), floor(-50 * time / 30), floor(-50 * time / 30)    ; subtracts RGB values to darken the background
mul = 256,256,256     ; multiply factor, set to neutral
sinadd = 0,0,0,10     ; sinusoidal addition (can create a pulse effect if needed)
invertall = 0         ; don't invert the colors
color = 256           ; apply the effect to the whole palette (256 is full effect)

