;value = 19240

[State 200, End]
type = ChangeState
Triggerall = movehit
trigger1 = ailevel = 0 && command = "holddown"
trigger1 = ailevel = 0 && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/4
value = 19245

[State 200, End]
type = ChangeState
Triggerall = movehit
TriggerAll = Power >= 500
trigger1 = ailevel = 0 && command = "holddown"
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/4
value = 19250

;==========
;Into Combo
;==========
[State 200, Into A-3]
type = ChangeState
Triggerall = movehit
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = 19210

[State 200, Into B-1/B-2/B-3]
type = ChangeState
TriggerAll = movehit
trigger1 = ailevel = 0 && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = cond(PrevStateNo!=19215,19215,cond(PrevStateNo!=19220,19220,cond(PrevStateNo!=19225,19225,-1)))

[State 200, Into  C-1]
type = ChangeState
TriggerAll = PrevStateNo != 19230
Triggerall = movehit
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 19230

;==========
;Into Dash Attacks
;==========
[State 200, End]
type = ChangeState
TriggerAll = Var (50) = 1 && Power >= 200
Triggerall = movecontact
trigger1 = ailevel = 0 && (command = "FF" || command = "BB")
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = Cond(command = "FF",60,75)

[State 200, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

