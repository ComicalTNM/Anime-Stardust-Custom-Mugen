triggerall = 1
trigger1 = 1
value = 20

[State 0, VarSet]
type = VarSet
trigger1 = time = 1
fv = 1
value = 0+random%2


[State -1, AI Counter]
type = ChangeState
triggerall = ailevel
triggerall = stateno != 1500+var(11)
triggerall = power >= 1000 
trigger1 = roundstate = 2 && numenemy && EnemyNear(var(58)),movetype != H
trigger1 = cond((EnemyNear(var(58)),stateno = 5120),(EnemyNear(var(58)),animtime > -1),(EnemyNear(var(58)),statetype != L))
trigger1 = p2bodydist x = [-50,155]
trigger1 = p2bodydist y = [-70,10]
trigger1 = random > 300 + ((life/4))
value = 1500+var(11)

[State -1, AI Dash Back]
type = ChangeState
triggerall = ailevel && roundstate = 2 && numenemy && !(p2bodydist x < 200 && statetype != A && EnemyNear(var(58)),movetype = A && (EnemyNear(var(58)),statetype = A || EnemyNear(var(58)), pos y < -50))
trigger1 = EnemyNear(var(58)),movetype = A && (EnemyNear(var(58)), statetype = A && statetype = A || EnemyNear(var(58)), statetype != A && statetype != A) && p2bodydist x = [-3,130]
trigger1 = random < 800
value = 70

[State 200, End]
type = ChangeState
trigger1 = power >= const(data.power) || power >= powermax || roundstate != 2
trigger2 = !AIlevel && command != "hold_s"
trigger3 = AIlevel && (inguarddist*(!var(25)) || (p2bodydist x <= 100) && (EnemyNear(var(58)), stateno != [10221,10224]) && (EnemyNear(var(58)), stateno != [10425,10427]) && (EnemyNear(var(58)), stateno != [11003,11005]) && (EnemyNear(var(58)), stateno != 21666)&& (EnemyNear(var(58)), stateno != 21405) && (EnemyNear(var(58)), stateno != [13006,13008]))
value = 501

