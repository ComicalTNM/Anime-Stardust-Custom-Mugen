[Statedef -2]

[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "fvar(26) = %d,smash = %d,var(11) = Mah Dick"
params = fvar(26),Var(20)
[State 0, SPARKING]
type = ChangeState
triggerall = enemy,statetype != L
triggerall = (enemy,stateno != 5100||enemy,stateno != 5101||enemy,stateno != 5110||enemy,stateno != 1070) 
triggerall = stateno != 1600
triggerall = ailevel > 0 && roundstate = 2
triggerall = numhelper(1610) = 0
triggerall = numexplod(30) = 0
value = 1600
triggerall = life <= lifemax/2 
trigger1 = random < (ailevel * 100)
triggerall = ctrl
