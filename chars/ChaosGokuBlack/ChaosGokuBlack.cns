[Data]
life = 2000
power = 3000
attack = -1000
defence = 80
fall.defence_up = 50
liedown.time = 60
airjuggle = 30
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0 
IntPersistIndex = 60 ;60 Variables
FloatPersistIndex = 40 ;40 FVariables

[Size]
xscale = 1 
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 9999
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
;===============================================================================
;Base Quotes
victory0="The Zero Mortal Plan will continue as normal"
victory1="What a feeble and pathetic lowly mortal"
victory2="Tell me, mortal. Why go on when you know you're going to lose in the end?"
victory3="Death is a mercy. To fools like you."
victory4="Its rather pathetic. I hardly used any of my power"
victory5="That pathetic performance ws nothing, what a pointless fight"
victory6="Before you die, mortal, what did you think my forms color? Was it not beautiful?"
victory7="Come Zamasu, we have more mortals to vanquish"
victory8="How ironic, Project Zero Mortals, yet require mortal power to succeed..."
victory9="As expected, I have no need for immortality"
