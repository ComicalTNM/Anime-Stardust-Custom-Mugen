[State -1, AI Reflect enemy projectile] ;by Inktrebuchet
type = ChangeState
triggerall = Var(29) = 1
triggerall = power >= 1000
value = 1100
triggerall = ailevel  
triggerall = ctrl
triggerall = statetype = S 
;safeguard
trigger1 = cond(numhelper(33333333),helper(33333333), cond(1, var(20) := 15, 0), 0) ; the 15 in "var(20) := 15" represents the 15th time this trigger was used. the number should be different everytime this is added/used.
trigger1 = cond(helper(33333333),numexplod((helper(33333333),var(20)*100000000)+PlayerID(helper(33333333),var(33)),stateno) = 0, 1, helper(33333333),numexplod((helper(33333333),var(20)*100000000)+abs(floor(PlayerID(helper(33333333),var(33)),vel x))) = 0)
trigger1 = PlayerIdExist(helper(33333333),var(33)) ;enemy projectile exists
trigger1 = PlayerID(helper(33333333),var(33)), pos y > -100 || PlayerID(helper(33333333),var(33)), vel y > 0 ; Avoid attempt to reflect projectiles that are to high. 100 = char height or reflector height, unless the enemy projectile is moving downwards.
trigger1 = PlayerID(helper(33333333),var(33)), vel x != 0 ; Avoid "Division by Zero" debug overflow
;distance / velocity = time = startup time + active 
trigger1 = (((PlayerID(helper(33333333),var(33)), pos x - pos x )* facing) - const(size.ground.front) - PlayerID(helper(33333333),var(33)),const(size.ground.front)) / (PlayerId(helper(33333333),var(33)),vel x) = [5,22] ; 5 = startup time, 22 = active ; [0,5] for last second reflect.

[State -1, AI Hop backwards to avoid enemy projectile, when possible] ;by Inktrebuchet
type = changestate
Value = 105 ;This value is based on default MUGEN common1.cns "Hop backwards" state.
triggerall = ailevel
triggerall = ctrl
triggerall = statetype = S 
trigger1 = PlayerIdExist(helper(33333333),var(33)) ;enemy projectile exists
trigger1 = PlayerID(helper(33333333),var(33)), pos y > -100 || PlayerID(helper(33333333),var(33)), vel y > 0 ; Avoid attempt to reflect projectiles that are to high. 100 = char height or reflector height, unless the enemy projectile is moving downwards.
trigger1 = PlayerID(helper(33333333),var(33)), vel x != 0 ; Avoid "Division by Zero" debug overflow
;(distance / velocity)  =  (hop.y/yaccel) + ((((hop.y^2 - 0^2) / (2 * yaccel)) /yaccel) / hop.x)    ||      time = Max height time + ((max height / yaccel ) / hop.x)
;trigger1 = ceil((((PlayerID(helper(33333333),var(33)), pos x - pos x )* facing) - const(size.ground.front) - PlayerID(helper(33333333),var(33)),const(size.ground.front)) / (PlayerId(helper(33333333),var(33)),vel x)) = floor(((abs(const(velocity.run.back.y)) / const(movement.yaccel)) + ((abs(const(velocity.run.back.y))**2 - 0**2) / (2*const(movement.yaccel)) / const(movement.yaccel))) / abs(const(velocity.run.back.x)))
;alternative to above trigger.
trigger1 = ceil((((PlayerID(helper(33333333),var(33)), pos x - pos x )* facing) - const(size.ground.front) - PlayerID(helper(33333333),var(33)),const(size.ground.front)) / (PlayerId(helper(33333333),var(33)),vel x)) = [0,16] ; 16 = the time it takes to start and land the hop.

[State -1, AI Neu jump over enemy projectile] ;by Inktrebuchet
type = ChangeState
value = 40 ;This value is based on default MUGEN common1.cns "Jump Start" state.
triggerall = ailevel
triggerall = ctrl
triggerall = stateno != 40
triggerall = statetype = S || statetype = C
trigger1 = PlayerIDExist(helper(33333333),var(33)) ; enemy projectile exist?
trigger1 = PlayerID(helper(33333333),var(33)), pos y > -100 ; Avoid jumping over projectiles that are to high. 100 = char height
trigger1 = PlayerID(helper(33333333),var(33)), vel x != 0 ; Avoid "Division by Zero" debug overflow.
;distance/speed = time
trigger1 = ceil(((PlayerID(helper(33333333),var(33)), pos x - pos x )* facing) / PlayerID(helper(33333333),var(33)), vel x ) = floor(abs(const(velocity.jump.y)) / const(movement.yaccel))

[State -1, AI fwd jump over enemy projectile part 1 of 4] ;by Inktrebuchet
type = explod
triggerall = ailevel
triggerall = ctrl
triggerall = stateno != [40,52] ; not already jumping
triggerall = statetype = S || statetype = C
triggerall = numexplod(33330001) = 0
trigger1 = PlayerIdExist(helper(33333333),var(33)) ;enemy projectile exists
trigger1 = PlayerID(helper(33333333),var(33)), pos y > -100 ; Avoid jumping over projectiles that are to high. 100 = char height
trigger1 = PlayerID(helper(33333333),var(33)), vel x != 0 ; Avoid "Division by Zero" debug overflow.
;distance / vel x = ((time) * vel x) / vel x
trigger1 = ceil(((PlayerID(helper(33333333),var(33)), pos x - pos x )* facing) / PlayerID(helper(33333333),var(33)), vel x ) = floor(abs(const(velocity.jump.y)) / const(movement.yaccel))
