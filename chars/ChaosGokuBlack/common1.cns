[Statedef 175]
type = S
ctrl = 0
velset = 0,0

[State 175, 1] ; If no anim, use go to lose state.
type = ChangeState
trigger1 = Time = 0
trigger1 = !SelfAnimExist(175)
value = 170

[State 175, 2]
type = ChangeAnim
trigger1 = Time = 0
value = cond(Var(29) = 1,175,cond(Var(29) = 2,4175,cond(Var(29) = 3,20175,cond(Var(29) = -1,13175,5675))))

[State 175, 3]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1
;---------------------------------------------------------------------------
; PREINTRO
[Statedef 5690]
type = S
ctrl = 0
velset = 0,0

[State 190, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(190)
value = cond(Var(29) = 1,190,cond(Var(29) = 2,4190,cond(Var(29) = 3,20190,cond(Var(29) = -1,13190,5690))))

[State 190, 2] ;Go straight to intro.
type = ChangeState
trigger1 = Time = 0
value = 115900
;---------------------------------------------------------------------------
; INTRO (override this state to give character an intro)
[Statedef 191]
type = S
ctrl = 0

[State 191, 1]
type = ChangeState
trigger1 = Time = 0
value = 0
;---------------------------------------------------------------------------
; HITG_SHAKE
[Statedef 5000]
type = S
movetype= H
physics = N
velset = 0,0


[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper
;ignorehitpause = 
;persistent = 
[State 0, LifeAdd]
type = LifeAdd
triggerall = !Ishelper
trigger1 = time = 0
Triggerall = var(3) = 1
Triggerall = var(4) = 0
triggerall = Var(29) = 0
value = GetHitVar(Damage)*0.25
persistent = 1

[State 0, LifeAdd]
type = LifeAdd
triggerall = !Ishelper
trigger1 = time = 0
Triggerall = var(3) = 1
Triggerall = var(4) = 1
triggerall = Var(29) = 0
value = GetHitVar(Damage)*0.45
persistent = 1

[State 5000, 1] ;Anim for HIT_LIGHT to HIT_HARD
type = ChangeAnim
triggerall = !Ishelper
trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = GetHitVar(animtype) != [3,5]
value = cond((GetHitVar(groundtype) = 1),10500+var(10),10510+var(10)) + GetHitVar(animtype)

[State 5000, 2] ;Anim for HIT_BACK
type = ChangeAnim
triggerall = !Ishelper
trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = GetHitVar(animtype) = [3,5]
value = 10530+var(10)

[State 5000, 3] ;Anim for HIT_UP/HIT_DIAGUP (only if it exists)
type = ChangeAnim
triggerall = !Ishelper
trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = (GetHitVar(animtype) = [4,5]) && (SelfAnimExist(10547+var(10) + GetHitVar(animtype)))
value = 10547+var(10) + GetHitVar(animtype) ;5051 - 4 + type

[State 5000, 4] ;Freeze anim
type = ChangeAnim
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = Time > 0
value = anim

[State 5000, 5] ;State type gets set to aerial if getting hit up
type = StateTypeSet
triggerall = !Ishelper
trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = GetHitVar(yvel) != 0 || GetHitVar(fall)
trigger2 = Pos Y != 0
statetype = a

[State 5000, 6]
type = ChangeState
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = HitShakeOver
trigger1 = GetHitVar(yvel) = 0 && !GetHitVar(fall)
value = 5001 ;HITG_SLIDE

[State 5000, 7]
type = ChangeState
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = HitShakeOver
value = 5030

[State 5000, FFB Light]
type = ForceFeedback
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = anim = 10500+var(10)
trigger2 = anim = 10510+var(10)
persistent = 0
time = 6
waveform = square

[State 5000, FFB Medium]
type = ForceFeedback
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = anim = 10501+var(10)
trigger2 = anim = 10511+var(10)
persistent = 0
time = 8
waveform = sinesquare
ampl = 110,-1,-.3

[State 5000, FFB Hard]
type = ForceFeedback
triggerall = !Ishelper
triggerall = Var(29) = 0
trigger1 = anim = 10512+var(10)
trigger2 = anim = 10502+var(10)
trigger3 = anim = 10530+var(10)
persistent = 0
time = 15
waveform = sinesquare
ampl = 140



