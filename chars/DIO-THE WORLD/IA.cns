;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[Statedef -2]
;时停结束后才反馈伤害开关
[State 0, VarSet]
type = VarSet
trigger1 = !ishelper
v = 44  
value = 1   ;1 on|打开/0 off|关闭
ignorehitpause = 1

;AI时停对策开关|;AI time stop countermeasure switch
[State 0, VarSet]
type = VarSet
trigger1 = !ishelper
v = 51
value = 1 ;1 on|打开 / 0 off|关闭

;开局形态调整
[State 0, VarSet]
type = VarSet
trigger1 = !ishelper
v = 16  
value = 0 ;1 High Dio / 0 Dio
ignorehitpause = 1
;===============================================================================
; 以下请勿妄动:
;===============================================================================
[State -2]
type = palfx
triggerall = roundstate = 2
triggerall = alive
triggerall = life <= lifemax*.3
trigger1 = gametime % (25 + (life / 50)) = 0
time = 40
add = 0, (-66 + floor(life / 15)), (-66 + floor(life / 15))
sinadd = 0, (-66 + floor(life / 15)), (-66 + floor(life / 15)), (-66 + floor(life / 15))
color = 200 + floor(life / 17.6)
ignorehitpause = 1

[State -2, Counting system]
type = Helper
trigger1 = numhelper(720) = 0 && roundstate = 2
helpertype = normal
name = "Counting system"
ID = 720
stateno = 720
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
supermovetime = 999
pausemovetime = 999
size.xscale = 1
size.yscale = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = (anim = [5000,5999]) && var(15) = 1 &&(anim != [15000,15999])
value  = anim +cond(var(15) = 1,10000,0)
ignorehitpause = 1

[State -2]
type = RemapPal
trigger1 = 1
source = 1,1
dest = 1,var(4)
ignorehitpause = 1

[State 0, Pause]
type = Pause
triggerall = numhelper(710) = 1 && numhelper(1350) = 0
trigger1 = time%3
time = 1
movetime = 1
ignorehitpause = 1

[State 0, PowerSet]
type = PowerSet
triggerall = teammode != simul
triggerall = var(15) = 0
trigger1 = power >= 3000
value = 3000
ignorehitpause = 1

[State 0, Die Sound]
type = Helper
trigger1 = numhelper(6150)=0 && life = 0
name = "Die Sound"
ID = 6150
stateno = 6150
helpertype = Normal
pos = 0,0
ownpal = 1
postype = p1
supermovetime = 99999999999
pausemovetime = 99999999999

[State 0, Joseph]
type = Helper
trigger1 = numhelper(16000)=0 && var(16) = 0
name = "Joseph"
ID = 16000
stateno = 16000
pos = 0,0
ownpal = 1
facing = 1
postype = p1
size.shadowoffset = 6
supermovetime = 99999999999
pausemovetime = 99999999999

[State 0,NotHitBy]
type=NotHitBy
trigger1= stateno = 3000
trigger2= stateno = 4000
value=,NA,NP,NT,SP
time=5
ignorehitpause=1

[State 0, VarSet]
type = VarSet
triggerall = numhelper(1350)=0
trigger1 = 1
fv = 14
value = 0
[State 0, VarSet]
type = VarSet
triggerall = numhelper(1350)=0
trigger1 = 1
fv = 15
value = 0
[State 0, VarSet]
type = VarSet
triggerall = numhelper(1350)=0
trigger1 = 1
fv = 16
value = 0 

[State 0, VarSet]
type = VarSet
trigger1 = stateno = 1650 && helper(1655),movehit
v = 21
value = 1

[State 0, VarSet]
type = VarSet
trigger1 = enemynear,movetype != h
v = 21
value = 0
