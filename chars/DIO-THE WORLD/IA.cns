trigger8 = stateno = 400 && helper(340),movecontact
trigger9 = stateno = 230 && movecontact
trigger10 = stateno = 240 && movecontact
trigger11 = stateno = 250 && movecontact
trigger12 = stateno = 260 && movecontact
trigger13 = stateno = 610 && helper(340),movecontact
trigger14 = stateno = 611 && helper(340),movecontact
trigger15 = stateno = 620 && helper(340),movecontact
