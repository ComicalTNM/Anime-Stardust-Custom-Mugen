;---------------------------------- Var System

[State 0, Game Start]
type = VarSet
trigger1 = !time 
v = 55
value = cond(roundno = 1,100,20)
ignorehitpause = 1
[State 0, Reversal Limit Reset]
type = VarSet
trigger1 = !time 
v = 56
value = 2
ignorehitpause = 1
persistent = 0
[State 0, Reversal ON]
type = VarSet
trigger1 = root,movetype = H 
v = 57
value = 1
ignorehitpause = 0
[State 0, Reversal OFF]
type = VarSet
trigger1 = root,movetype != H 
v = 57
value = 0
ignorehitpause = 0

[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
triggerall = !numhelper(4100) 
triggerall = time
triggerall = timemod = 1,0;3,0
trigger1 = var(55) = [0,255]
v = 55   
value = 3

