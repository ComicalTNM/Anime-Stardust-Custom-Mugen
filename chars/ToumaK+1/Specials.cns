;-[特效]--------------------------------------------------------------
[state CZZL,Explod]
type = Explod
trigger1 = time = 0
anim = 10060 + var(14)
id = 10060
postype = back
pos = 0,0
bindtime = 1
removetime = -1
sprpriority = -99
under = 1
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
ontop = 0
scale = 2 / CameraZoom,2 / CameraZoom
pausemovetime = 9999999
supermovetime = 9999999

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [0,var(11)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = time * (256/var(11)),256 - time * (256/var(11))

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11),var(11) + var(13)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = 256,0

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11) + var(13),var(11) + var(13)+ var(12)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = 256 - (time - (var(11) + var(13))) * (256/var(12)),(time - (var(11) + var(13))) * (256/var(12))

[State CZZL, RemoveExplod]
type = RemoveExplod
trigger1 = time >= (var(11) + var(12) + var(13))
id = 10060

[state CZZL, ]
type = destroyself
trigger1 = time > (var(11) + var(12) + var(13))

