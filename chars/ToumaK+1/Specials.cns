[State CZZL, VarSet]
type = Varadd
trigger1 = 1
v = 6   
value = 1
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
triggerall = var(5) != -1
trigger1 = !var(40)
trigger1 = var(6) := 1
trigger2 = root,movetype = H
trigger2 = var(6) := 1
v = 5    
value = -1
ignorehitpause = 1

[State CZZL, VarSet]
type = parentVarSet
trigger1 = parent,var(19)
trigger1 = var(6) >= var(11)
v = 19 
value = 0
ignorehitpause = 1

[State CZZL, VarSet];与人物对其
type = VarSet
trigger1 = var(5) = 0
trigger1 = var(6) >= var(11)
trigger1 = var(6) := 1
v = 5    
value = 1
ignorehitpause = 1

[State CZZL, VarSet];移回到屏幕中间
type = VarSet
trigger1 = var(5) = [1,2]
trigger1 = var(6) >= var(14)
trigger1 = parent,var(19) = 0
trigger1 = var(6) := 1
v = 5    
value = 3
ignorehitpause = 1

;-[控制摄像机移动]-----------------------------------------
[State CZZL, PosSet]
type = PosSet
trigger1 = !time
x = 0
y = camerapos y
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 11
trigger1 = var(5) = 1
x = parent,pos x + var(15) * Root,Facing
y = parent,pos y + var(16)
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 21
trigger1 = var(5) = 1
x = enemyNear(enemyNear,ishelper),pos x + var(15) * enemyNear(enemyNear,ishelper),facing
y = enemyNear(enemyNear,ishelper),pos y + var(16)
ignorehitpause = 1

[State CZZL, ]
type = DisplayToClipboard
trigger1 = 1
text="fvar(20) = %d,var(5) = %d,var(6) = %d,vel x = %d,vel y = %d"
params = fvar(20) ,var(5),var(6),vel x,vel y
ignorehitpause = 1

[State CZZL, ]
type = AppendToClipboard
trigger1 = 1
text="parentdist x = %d,var(42) = %d,fvar(22) = %d,posadd = %d,fvar(50) = %d,fvar(51) = %d"
params = parentdist x,var(42),fvar(22),(var(50) - var(51)),var(50),var(51)
ignorehitpause = 1

;-[跟随移动x轴]---------------------------------------------------------------------
[State CZZL, VarSet]
type = VarSet
;trigger1 = time = 0
triggerall = var(42) = 11 || var(42) = 21
trigger1 = time = 0
v = 50   
value = ifelse((var(42) = 11),root,pos x,enemyNear(enemyNear,ishelper),pos x)
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
trigger1 = var(42) = 11 || var(42) = 21
v = 51  
value = ifelse((var(42) = 11),root,pos x,enemyNear(enemyNear,ishelper),pos x)
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动到人物的身上
type = PosAdd
triggerall = var(42) = 11
trigger1 = var(5) = 0
trigger1 = var(50) != var(51)
x = (var(51) - var(50)) * root,facing
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动到人物的身上
type = PosAdd
triggerall = var(42) = 21
trigger1 = var(5) = 0
trigger1 = var(50) != var(51)
x = (var(51) - var(50)) * enemyNear(enemyNear,ishelper),facing
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
triggerall = var(42) = 11 || var(42) = 21
trigger1 = var(50) != var(51)
v = 50   
value = var(51)

;-[跟随移动y轴]---------------------------------------------------------------------
[State CZZL, VarSet]
type = VarSet
;trigger1 = time = 0
triggerall = var(42) = 11 || var(42) = 21
trigger1 = time = 0
v = 52 
value = ifelse((var(42) = 11),root,pos y,enemyNear(enemyNear,ishelper),pos y)
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
trigger1 = var(42) = 11 || var(42) = 21
v = 53 
value = ifelse((var(42) = 11),root,pos y,enemyNear(enemyNear,ishelper),pos y)
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动到人物的身上
type = PosAdd
triggerall = var(42) = 11 || var(42) = 21
trigger1 = var(52) != var(53)
y = (var(53) - var(52))
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
triggerall = var(42) = 11 || var(42) = 21
trigger1 = var(52) != var(53)
v = 52 
value = var(53)

;-[正常移动]---------------------------------------------------------------
[State CZZL, VelSet] ;镜头移动到人物的身上
type = VelSet
triggerall = var(42) = 1 || var(42) = 10 || var(42) = 11
triggerall = fvar(20) = 1
trigger1 = var(5) = 0
trigger1 = var(6) = 1
x = (parentdist x + var(15)) / var(11)
y = (parentdist y + var(16)) / var(11)
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动到人物的身上
type = VelSet
triggerall = var(42) = 2 || var(42) = 20 || var(42) = 21
triggerall = fvar(20) = 1
trigger1 = var(5) = 0
trigger1 = var(6) = 1
x = (((enemyNear(enemyNear,ishelper),pos x - pos x) * facing) + var(15)) / var(11)
y = (((enemyNear(enemyNear,ishelper),pos y - pos y) * facing) + var(16)) / var(11)
ignorehitpause = 1

[State CZZL, VelSet] ;镜头固定到人物的身上
type = VelSet
trigger1 = var(5) = 1
trigger1 = var(6) = 1
x = 0
y = 0
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动回屏幕中间
type = VelSet
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = 1
x = -facing * pos x / (var(12)*1.0)
y = -(pos y - camerapos y) / (var(12)*1.0)
ignorehitpause = 1


;-[计算每帧zoom多少]-----------------------------------------
[State CZZL, VarSet];镜头移动到人物时
type = VarSet
trigger1 = var(5) = 0
trigger1 = var(6) = [0,var(11)]
fv = 22    
value = 1 + var(6) * ((fvar(21)+fvar(20))/((var(11)*(fvar(17)*0.001))))
ignorehitpause = 1

[State CZZL, VarSet];存储fvar(22)的值(用于镜头返回)
type = VarSet
triggerall = fvar(23) != fvar(22)
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = 1
fv = 23   
value = fvar(22)
ignorehitpause = 1

[State CZZL, VarSet];镜头回到屏幕中间时
type = VarSet
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = [1,var(12)]
fv = 22   
value = fvar(23) - ((fvar(23)-1)/(var(12)*1.0))*var(6)
ignorehitpause = 1

;-[镜头使用]-----------------------------------------
[State CZZL, VarSet]
type = zoom
triggerall = fvar(22)
trigger1 = time >= 0
scale = fvar(22)
pos = ((pos x) / fvar(22)) * camerazoom,((pos y)-(camerapos y / fvar(22))) * camerazoom
ignorehitpause = 1

