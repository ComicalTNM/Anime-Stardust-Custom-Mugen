;------------------------------------------------------------------------------
; Shock
[Statedef 42001]
type     = A
movetype = I
physics  = N
juggle   = 0
ctrl     = 0
anim     = 9999
sprpriority = 1

[state CZZL, ]
type = AssertSpecial
trigger1 = 1
flag = noshadow
flag2 = invisible

[State CZZL, VarSet] ;震动时间
type = VarSet
trigger1 = !time 
v = 11    
value = const(size.head.pos.x)
ignorehitpause = 1

[State CZZL, VarSet] ;震动速度
type = VarSet
trigger1 = !time 
v = 12    
value = const(size.head.pos.y)
ignorehitpause = 1

[State CZZL, VarSet] ;震动的相位偏移
type = VarSet
trigger1 = !time 
v = 13    
value = const(size.air.front)
ignorehitpause = 1

[State CZZL, VarSet] ;震动模式 1:左右 2:上下左右混合
type = VarSet
trigger1 = !time 
v = 14   
value = const(size.air.back)
ignorehitpause = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,1

[State CZZL, PosSet]
type = PosSet
trigger1 = 1
y = root,pos y

[State CZZL, 防止玩家相互重叠]
type = PlayerPush               ;停止1帧之内玩家的推挤检测.推挤检测用于防止玩家相互重叠.通过暂时停止推挤检测,dodge(闪避)类型的招式(玩家能穿过另一个人,但是仍然能被击中)能被实现.
trigger1 = 1                    ;触发条件
value = 0                       ;则能够进行推挤检测.如果是0,则停止推挤检测.

[State 0, VelSet]
type = VarAdd
trigger1 = time % var(13) = 0
v = 1
value = 1

[State CZZL, PosSet]
type = Posset
triggerall = time = [0,var(11) + var(13)]
trigger1 = time = 0
trigger2 = time % var(13) = 0
x = 0

[State CZZL, PosSet]
type = PosAdd
triggerall = time = [0,var(11) + var(13)]
trigger1 = time = 0
trigger2 = time % var(13) = 0
x = ifelse(var(1) % 2 = 0,FrontEdgeBodyDist - 30,-(BackEdgeBodyDist-30))

[State CZZL, PosSet]
type = Posadd
trigger1 = time = [0,var(11) + var(13)]
x = (var(12) / CameraZoom) * ifelse(var(1) % 2 = 0,1,-1)

[State CZZL, EnvShake]
type = EnvShake
trigger1 = time = var(13) / 2
trigger1 = var(14) = 2
time = var(11)
ampl = var(12) * 2
phase = (10 - var(13)) * 20

[state CZZL, ]
type = destroyself
trigger1 = time > var(11) + var(13)

