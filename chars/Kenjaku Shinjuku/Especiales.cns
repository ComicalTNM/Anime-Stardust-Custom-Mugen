;==================================================
; Helper: Permanent Power Seal (activates every 10s)
;==================================================
[Statedef 1012]
type    = A
movetype= H
physics = N
anim    = 1008
velset  = 0,0
ctrl    = 0

;-----------------------------------------------
; Position relative to enemy (floats near)
;-----------------------------------------------
[State 0, PosAdd]
type = PosAdd
trigger1 = 1
x = p2dist x + 2
y = p2dist y - 30

;-----------------------------------------------
; Apply Seal Effect (every 10 seconds)
;-----------------------------------------------
[State 0, Apply Seal Effect]
type = HitDef
trigger1 = time % 600 = 0
trigger1 = enemy, power >= 0
attr = S, SP
animtype  = Light
damage    = 100, 0        ; 100 HP damage on activation
pausetime = 0,0
sparkno = -1
guard.sparkno = -1
hitsound   = -1
guardsound = -1
ground.type = High
ground.slidetime = 10
ground.hittime  = 10
ground.velocity = 0
air.velocity = 0
fall = 0
numhits = 0
hitonce = 1
PalFX.time = 60
PalFX.add = -40,-40,-40
PalFX.mul = 200,200,200
PalFX.sinadd = 30,30,30,20
PalFX.color = 256
GivePower = -100,-200


;-----------------------------------------------
; Drain a small amount of power each time seal hits
;-----------------------------------------------
[State 0, TargetPowerAdd]
type = TargetPowerAdd
trigger1 = movehit
value = -150                      ; small drain amount

;-----------------------------------------------
; Optional: show that this effect can't be blocked
;-----------------------------------------------
[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = unguardable

