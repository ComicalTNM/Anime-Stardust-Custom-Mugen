TriggerAll = GetHitVar(Guarded) 
TriggerAll = MoveType = H
TriggerAll = PlayerIDExist(Var(16))
Triggerall = StateType != A
TriggerAll = !HitOver
Triggerall = AiLevel && NumEnemy
Triggerall = RoundState = 2
Triggerall = PlayerIDExist(Var(16))
Triggerall = Var(20) = [(0 * AiLevel),(2 * AiLevel)]
Triggerall = Fvar(39) <= 200/5
Triggerall = EnemyNear,Pos Y >= Const(Size.Mid.Pos.Y)
trigger1 = power >= 1000
Value = 1017
IgnoreHitPause = 1

