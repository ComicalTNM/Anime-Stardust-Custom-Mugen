;===============================================================================
; KENJAKU COMPLETE OPTIMIZED AI - Enhanced Version
;===============================================================================
; Place in Statedef -2 or IA.cns

[Statedef -2]

;===============================================================================
; FASTER POWER REGENERATION
;===============================================================================
[State -2, Power Regen]
type = PowerAdd
triggerall = stateno != [1500,1509]
trigger1 = 1
value = 3  ; Increased from 2 to 3 (50% faster)
persistent = 8  ; Decreased from 10 (regens more often)

;===============================================================================
; AUTO GOKUMONKYO AT 60% HEALTH
;===============================================================================
[State -2, Auto GokuMonkyo]
type = ChangeState
triggerall = numhelper(19000) = 0
triggerall = power >= 2000
triggerall = statetype != A
triggerall = roundstate = 2
triggerall = life <= (lifemax * 0.6)  ; 60% health trigger
triggerall = life > 0
trigger1 = ctrl
trigger1 = p2bodydist x = [0, 80]
trigger1 = random < 800  ; Very high chance
value = 1004
ignorehitpause = 1

;===============================================================================
; ESQUIVA - COMBO BREAKER (ONLY IN MASK STATE - var(2) >= 1)
;===============================================================================
[State -2, VarAdd - Hit Counter]
type = VarAdd
trigger1 = movetype = H
trigger1 = !time
v = 55  ; Hit counter
value = 1
ignorehitpause = 1

[State -2, VarSet - Reset Hit Counter]
type = VarSet
trigger1 = stateno = 0
trigger1 = ctrl
v = 55
value = 0

[State -2, Esquiva Combo Breaker - MASK STATE ONLY]
type = ChangeState
triggerall = var(2) >= 1  ; <<< ONLY ACTIVE IN MASK STATE
triggerall = power >= 100
triggerall = statetype != A
triggerall = roundstate = 2
triggerall = var(55) >= 10  ; After 10 hits in combo
trigger1 = movetype = H
trigger1 = random < (ailevel * 200)
value = 422
ignorehitpause = 1

;===============================================================================
; SUMMON LIMITER SYSTEM - MAX 2 ACTIVE SUMMONS
;===============================================================================

;--- Count Active Summons (stores in var(54))
[State -2, Count Active Summons]
type = VarSet
trigger1 = 1
v = 54
value = 0
ignorehitpause = 1

[State -2, Count Summon Helpers]
type = VarAdd
trigger1 = numhelper(12000) > 0  ; Summon 1
trigger2 = numhelper(12010) > 0  ; Summon 2
trigger3 = numhelper(12016) > 0  ; Summon 3
trigger4 = numhelper(12022) > 0  ; Summon 4
trigger5 = numhelper(12028) > 0  ; Summon 5
trigger6 = numhelper(12034) > 0  ; Summon 6
trigger7 = numhelper(12041) > 0  ; Summon 7
trigger8 = numhelper(707) > 0    ; Summon 8
v = 54
value = 1
ignorehitpause = 1

;--- Summon Cooldown Timer (var(56) - counts down every tick)
[State -2, Summon Cooldown]
type = VarAdd
trigger1 = var(56) > 0
var(56) = -1
ignorehitpause = 1

;--- Reset Summon Cooldown at Round Start
[State -2, Reset Summon Cooldown]
type = VarSet
trigger1 = roundstate = 1
var(56) = 0
ignorehitpause = 1

;--- Activate Cooldown When 2 Summons Die (wait 5 seconds = 300 ticks)
[State -2, Set Summon Cooldown]
type = VarSet
trigger1 = var(54) = 0  ; No active summons
trigger1 = var(56) = 0  ; Cooldown not already active
v = 56
value = 300  ; 5 second cooldown
ignorehitpause = 1

;===============================================================================
; EXISTING SYSTEMS (HitOverride, Multipliers, etc)
;===============================================================================
[state -2, HitOverride]
type = hitoverride
trigger1 = Var(2)=0
trigger1 = random < 12
trigger2 = Var(2)=1
trigger2 = random < 15
trigger3 = Var(2)=2
trigger3 = random < 20
stateno = Cond(pos y = 0,422,422)
time = 2
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
slot = 1

[State 0, AttackMulSet]
type = AttackMulSet
trigger1 = var(2) = 1
value = 1.4

[State 0, DefenceMulSet]
type = DefenceMulSet
trigger1 = var(2) = 1
value = .7

[State 0, AttackMulSet]
type = AttackMulSet
trigger1 = var(2) = 2
value = 1.5

[State 0, DefenceMulSet]
type = DefenceMulSet
trigger1 = var(2) = 2
value = .6

[state 0]
type = changestate
value = 5200
trigger1 = (ailevel>4) && (numenemy)
trigger1 = (roundstate = 2) && (alive)
trigger1 = (stateno = 5050) && gethitvar(fall.recover)
trigger1 = (vel y > 0) && (pos y >= -20)
trigger1 = (random<(100*(ailevel**2/64.0)))

[state 0]
type = changestate
value = 5210
trigger1 = (ailevel>4) && (numenemy)
trigger1 = (roundstate = 2) && (alive)
trigger1 = (stateno = 5050) && (canrecover)
trigger1 = (vel y > 0) && (pos y<-20)
trigger1 = (random<(25*(ailevel**2/64.0)))

;===============================================================================
; MELEE PRIORITY SYSTEM - A, B, C, D, E ATTACKS
;===============================================================================
; CLOSE RANGE = 0-50 pixels: Use ONLY A/B/C/D/E
; MID RANGE = 50-100 pixels: Mix of melee + specials
; LONG RANGE = 100+ pixels: Specials, summons, projectiles

