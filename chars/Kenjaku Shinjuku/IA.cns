triggerall = power >= 3000
triggerall = roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,80]
triggerall = ailevel > 0
triggerall = StateType != A
triggerall = enemynear, pos y >= -const(size.height)*1.6
;--- COOLDOWN: Must wait 120 seconds between uses (10800 ticks at 60fps)
triggerall = var(53) <= 0
;--- CONDITION: Enemy has 500 HP or less OR you have 100 HP or less
trigger1 = enemynear, life <= 500
trigger1 = random < (ailevel * 75)*2
trigger2 = life <= 300
trigger2 = random < (ailevel * 75)*2
value = 1502

