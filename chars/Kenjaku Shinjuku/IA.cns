[State -1, Special 2: Counter]
Type = ChangeState
Triggerall = AiLevel && NumEnemy
Triggerall = RoundState = 2
Triggerall = StateNO != [120,155]
Triggerall = StateType != A
Triggerall = EnemyNear,HitDefAttr != SCA,NA
Triggerall = (Cond(Stateno = 500 || Stateno = 501 || Stateno = 60 || Stateno = 61 || Stateno = 65 || Stateno = 66 || Stateno = 70 || Stateno = 80,!Ctrl,Ctrl))
Triggerall = (Fvar(39) < 200/5 && (EnemyNear, MoveType = A || EnemyNear, NumProj > 0)) || InGuardDist
triggerall = p2bodydist x = [35,80]
trigger1 = power >= 1000
Value = 1017

[State -1, Special 2: Counter (BackUp)]
