;===============================================================================
; SPECIAL ATTACKS - MID TO LONG RANGE ONLY (50+ pixels)
;===============================================================================
[State 0, ESPECIAL 3]
type = ChangeState
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl 
trigger1 = p2bodydist x = [60,9999]
