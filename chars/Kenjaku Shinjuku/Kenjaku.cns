;------------------------------------------------------------------------------------------------
;Fly mode/six eyes included
;------------------------------------------------------------------------------------------------
[Statedef 80001]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 0]
type = VarSet
Trigger1 = command != "holdfwd"
Trigger1 = command != "holdback"
Trigger1 = command != "holdup"
Trigger1 = command != "holddown"
Trigger1 = var(30) != 2
Trigger2 = var(30) = 2
Trigger2 = Vel Y >= 0.5
v = 30
value = 1

[State 0]
type = VarSet
Triggerall = var(30) = 1
Trigger1 = Vel Y <= -0.5
Trigger2 = P2BodyDist Y > 250
Trigger2 = Vel Y < 0
v = 30
value = 2

[State 1500, papar2]
type = ChangeAnim
trigger1 = command != "holdup"
trigger1 = command != "holddown"
trigger1 = command != "holdfwd"
trigger1 = command != "holdback"
trigger1 = anim != 0 + ifelse(var(5)=1,10000,193)
value = 0 + ifelse(var(5)=1,10000,193)

[State 0, Turn]
type = Turn
trigger1 = p2dist x <= -10

[State 40, 4]
type = VelSet
trigger1 = command != "holdfwd"
trigger2 = command != "holdback"
trigger3 = command != "holdup"
trigger4 = command != "holddown"
x = 0
y = sin(gametime*0.07)

[State 40, 4]
type = VelSet
trigger1 = command = "holdfwd"
x = 4

[State 1500, GoDownAnim]
type = ChangeAnim
triggerall = Anim != 192
trigger1 = command = "holdfwd" || command = "holddownfwd"
value = 192


[State 40, 4]
type = VelSet
trigger1 = command = "holdback"
x = -4

[State 1500, GoDownAnim]
type = ChangeAnim
triggerall = Anim != 189
trigger1 = command = "holdback" || command = "holddownback"
value = 189


[State 40, 4]
type = VelSet
triggerall = command = "holdup"
trigger1 = Pos Y >= -110
y = -3

[State 1500, GoDownAnim]
type = ChangeAnim
triggerall = Anim != 187
trigger1 = command = "holdup" || command = "holdupfwd"
value = 187


[State 1500, GoDownAnim]
type = ChangeAnim
triggerall = Anim != 189
trigger1 = command = "holdupback"
value = 189

[State 1500, GoDownAnim]
type = ChangeAnim
triggerall = Anim != 193
trigger1 = command = "holddown" && command != "holddownback" && command != "holddownfwd"
value = 193

[State 40, 4]
type = VelSet
triggerall = command = "holddown"
trigger1 = Pos Y <= 0
y = 3


[State 370, end2]
type = changestate
trigger1 = !alive
trigger2 = DrawGame=1
trigger3= Lose=1
trigger4 = Win=1
value = 0

[State 200, End]
type = ChangeState
Triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "b" 
trigger2 = ailevel > 0 && roundstate = 2 && random = [600,800]
value = 80003

[State 200, End]
type = ChangeState
trigger1 = ailevel = 0 && command = "a" 
value = 80002

[State 200, End]
type = ChangeState
trigger1 = random < (ailevel * 100)/4
value = 80004

[State 200, End IA]
type = ChangeState
trigger1 = random < (ailevel * 100)/3
value = 80005


[State 200, End]
type = ChangeState
trigger1 = ailevel = 0 && command = "c"
value = 80005
