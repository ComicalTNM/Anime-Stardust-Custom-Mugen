[State 5001, 2]
type = ChangeAnim
triggerall = Ishelper(30000)  || Ishelper(40000)
trigger1 = AnimTime = 0
value = (ifelse(Ishelper(30000),9385005,9405005) + GetHitVar(animtype) + (GetHitVar(groundtype)=2)*10)


[State 5001, 3] ;Stop sliding back
type = VelMul
trigger1 = Time >= GetHitVar(slidetime)
x = .6

[State 5001, 4]
