ignorehitpause = 1

[State 0, Remove Explods]
type = RemoveExplod
trigger1 = ishelper && !Ishelper(30000) && !Ishelper(40000) && !Ishelper(30000) && !Ishelper(40000)
ignorehitpause = 1
[State 0, PlaySnd]
type = PlaySnd
trigger1 = random < 5
value = S0,50
volumescale = 425
channel = 0
persistent = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 4
value = S20,5
volumescale = 70

[State 45, 3]
