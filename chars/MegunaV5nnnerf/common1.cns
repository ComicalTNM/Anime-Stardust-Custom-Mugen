physics = S
anim =  ifelse(var(23) =1,20740,40+var(11))
ctrl = 0
sprpriority = 1

[state 40, self]
type = selfstate
triggerall = ailevel > 3 && statetype != A 
trigger1 = enemynear(var(58)), statetype = L
trigger2 = p2bodydist x > 180 && enemynear(var(58)), movetype != A && enemynear(var(58)), vel x = 0.0
trigger3 = facing = enemynear(var(58)),facing && inguarddist
trigger4 = (EnemyNear(var(58)), stateno = [10221,10224]) || (EnemyNear(var(58)), stateno = [10425,10427]) || (EnemyNear(var(58)), stateno = 11003) || (EnemyNear(var(58)), stateno = [13006,13008]) || (EnemyNear(var(58)), stateno = 21666)
