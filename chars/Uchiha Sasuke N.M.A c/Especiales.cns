;P2 Hurt
[Statedef 44665]
type    = S
movetype= H
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
sprpriority = 1
Facep2 = 1

[State 0, Posset]
type = posset
trigger1 = !time 
y = 0
[State 0, VelAdd]
type = VelAdd
triggerall =  statetype != A
trigger1 = !time
x = -1
[State 0, VelAdd]
type = Velset
triggerall = statetype != A
trigger1 = time = 3
x =0
[State 0, HitBy]
type = HitBy
trigger1 = 1
value = SCA,AA,AP,AT
time = 10
[State 0, Anim]
type = ChangeAnim
trigger1 = 1
value = 5000+Cond(enemy,name != "Sukuna" ,var(10),0)

[State 0, End]
type = Selfstate
trigger1 = time >= cond(p2stateno = [4900,4950],9999,30)
value = 0
ctrl = 1


