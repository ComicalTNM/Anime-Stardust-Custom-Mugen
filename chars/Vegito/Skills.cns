; Kamehameha - SHAFT PARTS
[Statedef 1444]
type    = A
movetype= A
physics = N
juggle  = 0
velset = 0,0
ctrl = 0
anim = 1444
sprpriority = 2

[State 0, VelSet]
type = VelSet
trigger1 = 1
x = -parent,fvar(21)/3
y = -parent,fvar(22)/3
ignorehitpause = 1

[State 0, ParentVarSet]
type = ParentVarSet
triggerall = (Parent,Cond(1,(Helper(1450),frontedgedist <-10),0))
trigger1 = movehit = 1
v = 12   
value = 1
ignorehitpause = 1

[State 0, HitDef]
type = HitDef
triggerall = !(Parent,Cond(1,(Helper(1450),frontedgedist <-10),0))
trigger1 = !movecontact
attr = S,SP        
hitflag = MAF        
guardflag = MA       
animtype = hard      
air.animtype = medium
damage = 7+floor(parent,const(size.shadowoffset)*.2),2+floor(parent,const(size.shadowoffset)*.1)
pausetime = 0,0
guard.pausetime = 3,2
sparkno = -1
guard.sparkno = -1
sparkxy = 0,0
hitsound = S5,162
guardsound = S4,0
ground.type = high      
ground.slidetime = 20
ground.hittime = 30
air.hittime = 40
guard.dist = 205
ground.velocity = (-6-parent,const(size.shadowoffset)*.05)*const(size.xscale),0
guard.velocity = (-2-parent,const(size.shadowoffset)*.05)*const(size.xscale)
air.velocity = (-8-parent,const(size.shadowoffset)*.05)*const(size.xscale),cond(enemynear,pos y > -10,-1,1)
airguard.velocity = (-2-parent,const(size.shadowoffset)*.05)*const(size.xscale),-3
ground.cornerpush.veloff = -4-parent,const(size.shadowoffset)*.05
air.cornerpush.veloff = -4-parent,const(size.shadowoffset)*.05
guard.cornerpush.veloff = -5-parent,const(size.shadowoffset)*.05
airguard.cornerpush.veloff = -5-parent,const(size.shadowoffset)*.05
forcestand = 1
fall = 0
air.fall = 1
fall.recover = 1
fall.recovertime = 20
down.bounce = 0
envshake.time = 3+ceil(parent,const(size.shadowoffset))

