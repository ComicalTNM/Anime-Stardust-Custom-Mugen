; P2 - Thrown BASE
[Statedef 8200]
type = S
movetype = H
physics = N
juggle = 1
ctrl = 0
sprpriority = 1
Facep2 = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = 5050+Var(10)
elem = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = -atan (vel y / vel x) * 180 / PI
ignorehitpause = 1

[State 0,ChangeAnim]
type = ChangeAnim
TriggerAll =  Enemy,NumExplod(8385) = 1 || Enemy,NumExplod(8386) = 1 || Enemy,NumExplod(8387) = 1 || Enemy,NumExplod(8388) = 1 || Enemy,NumExplod(8389) = 1
Trigger1 = 1
value = 5305+Var(10)
elem = 1

[State 0,AngleDraw]
type = AngleDraw
TriggerAll =  Enemy,NumExplod(8385) = 1 || Enemy,NumExplod(8386) = 1 || Enemy,NumExplod(8387) = 1 || Enemy,NumExplod(8388) = 1 || Enemy,NumExplod(8389) = 1
Trigger1 = Anim = 5305+Var(10)
trigger1 = 1
value = 0+(Time*20)
[State 0,PosAdd]
type = PosAdd
TriggerAll =  Enemy,NumExplod(8385) = 1 || Enemy,NumExplod(8386) = 1 || Enemy,NumExplod(8387) = 1 || Enemy,NumExplod(8388) = 1 || Enemy,NumExplod(8389) = 1
Trigger1 = Anim = 5305+Var(10)
trigger1 = 1
y = -25
Persistent = 0

[State 0,ScreenBound]
type = ScreenBound
TriggerAll =  Enemy,NumExplod(8380) = 1 || Enemy,NumExplod(8382) = 1 || Enemy,NumExplod(8386) = 1 || Enemy,NumExplod(8388) = 1
Trigger1 = 1
value = 1
movecamera = 0,1
ignorehitpause = 1

[State 0,Gravity]
type = Gravity
trigger1 = 1
ignorehitpause = 1

[State 0,PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0,NotHitBy]
type = NotHitBy
trigger1 = !Time
value = SCA,AA,AP,AT
time = 5

[State 5050, 5]
type = SelfState
TRIGGERALL = Time >= 25
TRIGGERALL=Vel Y > -1
TRIGGERALL=alive
TRIGGERALL=CanRecover
trigger1 = Command = "recovery"
value = 5210

[State 0,ChangeState]
type = ChangeState
trigger1 = backedgebodydist<5
trigger1 = Pos Y<=-8
value = 8205

[State 0, End]
type = SelfState
trigger1 = Time>=5
trigger1 = Pos Y>=-5
value = 5050
