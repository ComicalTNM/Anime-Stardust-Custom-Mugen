type = A
movetype = H
physics = N
juggle = 1
velset = 0,0
ctrl = 0
sprpriority = 1

[State 5050, 5]
type = SelfState
TRIGGERALL = Time >= 5
TRIGGERALL=Vel Y > -1
TRIGGERALL=alive
TRIGGERALL=CanRecover
trigger1 = Command = "recovery"
value = 5210

[State 0, Gravity]
type = Gravity
trigger1 = 1
ignorehitpause = 1

[State 0,AngleDraw]
type = AngleDraw
trigger1 = 1
value = 0

[State 0,PosAdd]
type = PosAdd
trigger1 =! Time
y = -15

[State 0,VelSet]
type = VelSet
trigger1 = Time = 4
x = 2
y = -2.5
ignorehitpause = 1
persistent = 0

[State 0,Turn]
type = Turn
TriggerAll = Enemy,NumExplod(8381) = 1 || Enemy,NumExplod(8382) = 1 || Enemy,NumExplod(8387) = 1 || Enemy,NumExplod(8388) = 1 
trigger1 = Time = 5
ignorehitpause = 1
persistent = 0

[State 0,VelSet]
type = VelSet
TriggerAll = Enemy,NumExplod(8381) = 1 || Enemy,NumExplod(8382) = 1 || Enemy,NumExplod(8387) = 1 || Enemy,NumExplod(8388) = 1
trigger1 = Time = 4
x = 4
y = -4
ignorehitpause = 1
persistent = 0

[State 0,EnvShake]
type = EnvShake
trigger1 =! Time
time = 20

[State 0,LifeAdd]
type  =  LifeAdd
trigger1 =! Time
value = -10
kill = 1

[State 0,ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 1,1
ignorehitpause = 1

[State 0,PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0,End]
type = Selfstate
trigger1 = Time >= 5
value = 5050
ctrl = 0
