PauseMoveTime = 999
;--------- SPARKS

[State 0, PosAdd]
type = PosAdd
triggerall = p2bodydist x != [0,40]
trigger1 = !time
x = -8
y = 0
ignorehitpause = 1
[State 0, PosAdd]
type = PosAdd
triggerall = p2bodydist x = [0,40]
trigger1 = !time
x = -5-ceil(p2bodydist x*.5)
y = 0
ignorehitpause = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S4,3+random%3
volumescale = 300

[State 0, SuperPause]
type = SuperPause
trigger1 = !time
time = 10
anim = -1
sound = S10,0
pos = 0,0
movetime = 10
darken = 0
unhittable = 1
ignorehitpause = 1

[State 0, NotHitBy]
type = NotHitBy
trigger1 = !time
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 15
ignorehitpause = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = time < 10
value = anim
elem = AnimElemNo(0) 
ignorehitpause = 1

[State 8145, End]
type = ChangeState
trigger1 = AnimTime = 0
value = Cond(Pos Y < 0,50,0)
ctrl = 1
