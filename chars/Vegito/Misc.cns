helpertype = normal
ID = 8025
stateno = 8025
pos = Cond((P2Dist X=[0,45]),P2Dist X+0,30),Cond((P2Dist Y=[-50,0]),P2Dist Y-25,-70)
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
