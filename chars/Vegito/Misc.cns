Size.Yscale = .098*0.90
Size.ShadowOffset = 25
ignorehitpause = 1
PERSISTENT = 0

[state 0,Explod]
Type = Explod
Trigger1 =! Time
Anim = 7013
Id = 7013
pos = Cond((P2Dist X=[0,45]),P2Dist X+0,30),Cond((P2Dist Y=[-50,0]),P2Dist Y-25,-70)
PosType = p1
Facing = 1
BindTime = -1
Removetime = -2
Sprpriority = 3
Scale = .2,.2
Angle = var(1)
Ownpal = 1
Alpha = 156,256
Removeongethit	=1
