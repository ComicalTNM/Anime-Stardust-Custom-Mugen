trigger1 = AnimElemTime(2)=0
value = S0,260+Fvar(1)
volume = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElemTime(2)=0
value = S0,260+Fvar(1)
volume = 999

