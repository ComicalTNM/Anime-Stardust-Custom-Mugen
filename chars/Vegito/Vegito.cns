;===================================================================================
;------------------------------ Vegito ----------------------------------;
;===================================================================================

;===============================================================================
; Var List
;-------------------------------------------------------------------------------
;Var(1) = Used for random voices
;Var(2) = Used for random values
;Var(3) = Used for charged attacks
;Var(4) = Used for Air Dash limiter
;Var(5) = Used for OK text in intro
;Var(7) = Boundary Push
;Var(8) = Infinite Void
;Var(10) = Transformations (If character has any)
;Var(11) = HUD position
;Var(12) = RSD
;Var(55) = Palette Selector
;===============================================================================
; FVar List
;-------------------------------------------------------------------------------
;FVar(10) = Combo A
;FVar(11) = Combo B
;FVar(12) = Combo C
;FVar(13) = Down A
;FVar(14) = Down B
;FVar(15) = Down C
;FVar(16) = Forward A
;FVar(17) = Backward A
;FVar(18) = Forward B
;FVar(19) = Backward B
;FVar(20) = Forward C
;FVar(21) = Backward C
;--------
;FVar(22) = Air Combo A
;FVar(23) = Air Combo B
;FVar(24) = Air Combo C
;FVar(25) = Air Down A
;FVar(26) = Air Down B
;FVar(27) = Air Down C
;--------
;FVar(28) = A+B
;FVar(29) = B+C
;FVar(30) = A+C
;===============================================================================
; FVar List
;-------------------------------------------------------------------------------
;FVar(10) to FVar(30) Combo System
;-------------------------------------------------------------------------------
;------------------------------------------------------------------------------
[Data]
life = 2500			;Amount of life to start with
power = 3000			;Power Charge (more is Power)
attack = 170		;attack power (more is stronger)
defence = 160		;defensive power (more is stronger)
fall.defence_up = 50;Percentage to increase defense everytime player is knocked down
liedown.time = 60		;Time which player lies down for, before getting up
airjuggle = 15		;Number of points for juggling
sparkno = -1			;Default hit spark number for HitDefs
guard.sparkno = -1	;Default guard spark number
KO.echo = 0			;1 to enable echo on KO
IntPersistIndex = 55	;Variables with this index and above will not have their values
FloatPersistIndex = 35  ;reset to 0 between rounds or matches. There are 60 int variables,
  				;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
  				;If omitted, then it defaults to 60 and 40 for integer and float
  				;variables repectively, meaning that none are persistent, i.e. all
  				;are reset. If you want your variables to persist between matches,
  				;you need to override state 5900 from common1.cns.

[Size]
xscale = 1			;Horizontal scaling factor.
yscale = 1			;Vertical scaling factor.
ground.back = 10		;Player width (back, ground)
ground.front = 10		;Player width (front, ground)
air.back = 10		;Player width (back, air)
air.front = 10		;Player width (front, air)
height = 40			;Height of player (for opponent to jump over)
attack.dist = 100		;Default attack distance
proj.attack.dist = 90	;Default attack distance for projectiles
proj.doscale = 0		;Set to 1 to scale projectiles too   
head.pos = -1, -41	;Approximate position of head
mid.pos = -1, -25		;Approximate position of midsection
shadowoffset = 0		;Number of pixels to vertically offset the shadow
draw.offset = 0,0		;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 2		;Walk forward
walk.back = -2		;Walk backward
run.fwd  = 0		;Run forward (x, y)
run.back = 0	;Hop backward (x, y)
jump.neu = 0,-7		;Neutral jumping velocity (x, y)
jump.back = -3.5		;Jump back Speed (x, y)
jump.fwd = 3.5		;Jump forward Speed (x, y)
runjump.back = 0;Running jump speeds (opt)
runjump.fwd = 0	;.
airjump.neu = 0	;.
airjump.back = -3	;Air jump speeds (opt)
airjump.fwd = 3		;.

[Movement]
airjump.num = 1		;Number of air jumps allowed (opt)
airjump.height = 35	;Minimum distance from ground before you can air jump (opt)
yaccel = .45		;Vertical acceleration
stand.friction = .80	;Friction coefficient when standing
crouch.friction = .88 	;Friction coefficient when crouching

[Quotes]
victory1 = "Alright, now my body should be warmed up."
victory2 = "What's wrong? You got quiet."
victory3 = "Sorry! Guess i Don't Know my own Strength"
victory4 = "C'mon... Make me get serious here!"
victory5 ="Did you really think that move would work on me?"
victory6 ="Do what now? Wanna keep going?"
victory7 ="Whats wrong? Is that all you can do?"
victory8 ="Hmph. Sorry, but you were wide open."
victory9 ="Guess it's not fair for me to fight you like this,huh?"
victory10 ="YOSHAAAAAAAAAAAAAAA"
;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...

;===============================================================================
; Losing
;-------------------------------------------------------------------------------
[Statedef 170]
type = S

[State 0, ChangeState]
type = ChangeState
TriggerAll = Var(2) = 1
trigger1 = Time = 0
value = 12171

[State 0, ChangeState]
type = ChangeState
TriggerAll = Var(2) = 6
trigger1 = Time = 0
value = 34171+Random%2

[State 170, 1]
Type = ChangeState
Trigger1 =! Time
Value = 171
;===============================================================================
; Lose
;-------------------------------------------------------------------------------
[Statedef 171]
type = S
ctrl = 0
anim = 170+Random%2
velset = 0,0

;--------------------------
[State 0,AngleDraw]
Type = AngleDraw
Trigger1 = 1
Scale = 1, 1 + (sin((time/ 50.0) * (pi / 2)) * 0.0125)
Value = 0
IgnoreHitPause = 1
;--------------------------

[State 0, VarSet]
type = VarSet
Trigger1 = !Time
fv = 1
value = random%3

[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElemTime(2)=0
value = S0,230+Fvar(1)
volume = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElemTime(2)=0
value = S0,230+Fvar(1)
volume = 999

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1
;===============================================================================
; Winnig:
;-------------------------------------------------------------------------------
[Statedef 180]
type = S

[State 0, ChangeState]
type = ChangeState
TriggerAll = Var(2) = 1
trigger1 = Time = 0
value = 12181+Random%2

[State 0, ChangeState]
type = ChangeState
TriggerAll = Var(2) = 6
trigger1 = Time = 0
value = 34181+Random%3

[State 180, 1]
Type = ChangeState
Trigger1 =! Time
Value = 181+Random%2
