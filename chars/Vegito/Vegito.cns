;===============================================================================
; Pre - Intro
;-------------------------------------------------------------------------------
[Statedef 190]
type = S
ctrl = 0
velset = 0,0
sprpriority = 2

[State 0]
type = VarSet
TriggerALL = PrevStateNo != 12190
TriggerALL = PrevStateNo != 34190
trigger1 = Time = 0
var(53) = 500

[State 0, ChangeAnim]
type = ChangeAnim
Trigger1 = !Time
value = 190
Elem = 1
IgnoreHitPause = 1

;-------------------------------------
;---------------------------------------
;------------------------------------
; Change Pallete
[State 0]
Type = Null
TriggerALL = NumHelper(9755) = 0
TriggerAll = TIME >= 5
trigger1 = var(55) = 31
trigger1 = var(55):= 1
trigger2 = var(55) = 1
trigger2 = Cond(teamside=2,Command="fwd",Command="back")
trigger2 = var(55):= 31

[State 0]
Type = VarAdd
TriggerALL = NumHelper(9755) = 0
TriggerAll = TIME >= 5
trigger1 = TeamSide = 1 && Command = "fwd"
trigger2 = TeamSide = 2 && Command = "back"
var(55) = 1

[State 0]
Type = VarAdd
TriggerALL = NumHelper(9755) = 0
TriggerAll = TIME >= 5
trigger1 = TeamSide = 1 && Command = "back"
trigger2 = TeamSide = 2 && Command = "fwd"
var(55) = -1

[State 0,PlaySnd]
Type = PlaySnd
TriggerALL = NumHelper(9755) = 0
TriggerAll = TIME >= 5
trigger1 = Command = "fwd"|| Command = "back" || Command = "up" || Command = "down"
value = S600,1
volumescale = 100
ignorehitpause = 1
[State 0,COLOR PALFX]
Type = Helper
TriggerALL = NumHelper(9755) = 0
TriggerAll = TIME >= 5
trigger1 = Command = "fwd" || Command = "back" || Command = "up" || Command = "down"
helpertype = normal
ID = 9769
name = "9769"
stateno = 9769
pos = 0,0
postype = p1
facing = 1
ownpal = 1
keyctrl = 0
Size.Xscale = Const(Size.Xscale)
Size.Yscale = Const(Size.Yscale)
IgnoreHitPause = 1
SuperMoveTime = 99999
PauseMoveTime = 99999

[State 0,COLOR]
Type = Helper
TriggerALL = AiLevel = 0
TriggerALL = NumHelper(9755) = 0
trigger1 = NumHelper(9750) = 0
ID = 9750
stateno = 9750
pos = 0,10
postype = p1
facing = Cond(Facing = 1, 1,-1)
ownpal = 1
keyctrl = 0
size.xscale = .1
size.yscale = .09
IgnoreHitPause = 1
SuperMoveTime = 99999
PauseMoveTime = 99999
PERSISTENT = 0

[State 0,SELECT - TEXT 1 Appear]
Type = Helper
TriggerALL = AiLevel = 0
TriggerAll = NumHelper(9760) = 0
Trigger1 = NumHelper(9754) = 1
Trigger2 = Command = "s"
ID = 9760
stateno = 9760
pos = 0,8
postype = p1
Facing = Cond(Facing = 1,1,-1)
ownpal = 1
keyctrl = 0
size.xscale = .09
size.yscale = .08
IgnoreHitPause = 1
SuperMoveTime = 99999
PauseMoveTime = 99999
PERSISTENT = 0
;-------------------------------------------------------------------------------

;--------------------------
[State 0,AngleDraw]
Type = AngleDraw
Trigger1 = 1
Scale = 1, 1 + (sin((time/ 50.0) * (pi / 2)) * 0.0125)
Value = 0
IgnoreHitPause = 1
;--------------------------

[State 190, AssertSpecial]
type = AssertSpecial
Trigger1 = StateNO = 190
flag = Intro

;----------------------FROMS------------------------------
[State 34190, Pre - Intro - 6]
type = ChangeState
Triggerall = Time >= 5
Trigger1 = Command = "up"
value = 34190
IgnoreHitPause = 1
;-------
[State 12190, Pre - Intro - 1]
type = ChangeState
Triggerall = Time >= 5
Trigger1 = Command = "down"
value = 12190
IgnoreHitPause = 1
;----------------------------------------------------

[State 0,VarSet]
Type = VarSet
trigger1 =! Time
v = 1
value = 191+Random%3

[State 190,Intro - 1]
type = ChangeState
Trigger1 = AILevel && Time >= 1
Trigger2 = Command = "s"
Trigger3 = NumHelper(9755) = 1
Trigger4 = Time >= 2000
value = VAR(1)
IgnoreHitPause = 1
Persistent = 0
