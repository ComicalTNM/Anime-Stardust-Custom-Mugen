ignorehitpause = 1
persistent = 1
[State 0, Mahoraga | Defence Type 1]
type = LifeAdd
Triggerall = Helper(30992),Var(14) <= 1
Triggerall = !Helper(30990),Var(10) && (Movetype = H || Incustomstate)
Triggerall = Numhelper(3604)
triggerall = Alive
trigger1 = !Time && (Movetype = H || Incustomstate) 
value = GetHitVar(damage)/Cond(Helper(3604),Var(10)>=3,2,4)
kill = 0
absolute = 1
ignorehitpause = 1 
[State 0, Adaptation | Accelerate]
type = Varadd
Triggerall = Helper(30990),Var(1) > Helper(30990),Var(2)/4
Triggerall = Alive
Trigger1 = ReceivedDamage >= Lifemax*(.06/Helper(30992),Var(2)) && Helper(30990),Var(1) >= Helper(30990),Var(2)/1.2
Trigger2 = ReceivedDamage >= Lifemax*(.12/Helper(30992),Var(2)) && Helper(30990),Var(1) >= Helper(30990),Var(2)/1.5
Trigger3 = ReceivedDamage >= Lifemax*(.18/Helper(30992),Var(2)) && Helper(30990),Var(1) >= Helper(30990),Var(2)/2
Trigger4 = ReceivedDamage >= Lifemax*(.24/Helper(30992),Var(2)) && Helper(30990),Var(1) >= Helper(30990),Var(2)/3
v = 1
value = -Helper(30990),Var(2)/6
ignorehitpause = 1
persistent = 1
RedirectID = Helper(30990),ID
[state 0, CE Aura]
type = helper
Triggerall = Numhelper(3604) && !Helper(30990),Var(3)
Triggerall = Helper(3604),Var(40) >= Helper(30992),Var(7) && Helper(3604),Stateno = 4 && Helper(3604),Time > 58
