; Bar
[Statedef 6900000]
type    = A
movetype= I
physics = N
anim = 9999
ctrl = 0

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
time = 10
pos = 0,0

[State 0, Store Meter Value]
type = VarSet
trigger1 = 1
var(40) = Helper(3604),Var(40)

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = -10
ignorehitpause = 1
[State 0, VarSet | Member 2]
type = VarSet
Triggerall = Teammode != Single
Triggerall = Teamleader != Playerno
Triggerall = Root,Alive
trigger1 = Playerno = 3 || Playerno = 4
v = 1
value = Cond(Playerid(Root,Var(51)),Numhelper(6900000),1,0)
[State 0, VarSet | Member 3]
type = VarSet
Triggerall = Teammode != Single
Triggerall = Teamleader != Playerno
Triggerall = Root,Alive
trigger1 = Playerno = 5 || Playerno = 6
