;Custom Counter
[statedef 2999998]
type=s
physics=n
juggle=2
ctrl=0
sprpriority=2
anim=98
velset=0,0

[State 0, Explod CD]
type = Explod
Triggerall = Ailevel
triggerall = !NumExplod(stateno)
trigger1 = 1
anim = 9999
ID = stateno
pos = 0,0
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,0
accel = 0,0
random = 0,0
removetime = 1200
supermovetime = 0
pausemovetime = 0
scale = 1,1
sprpriority = 0
ontop = 0
shadow = 0,0,0
ownpal = 0
removeongethit = 0

[State 0, Helper]
Type = Helper
Triggerall = time >= 6
Trigger1 = timemod = 6,0
HelperType = Normal
ID = 560000
Stateno = 560000
Pos = 0,0
PosType = P1
Facing = 1
KeyCtrl = 0
OwnPal = 1
SuperMoveTime = 999
PauseMoveTime = 999
IgnoreHitPause = 1

[State 0, TargetState]
type = ReversalDef
trigger1 = 1
Reversal.Attr = SCA,AA,AP,AT
pausetime = 0,0
hitsound = -1


[State 0, TargetState]
type = TargetState
triggerall = !target,ishelper
trigger1 = Movehit
value = 99666
ID = -1
;ignorehitpause = 
;persistent = 

[State 0, SelfState]
type = SelfState
trigger1 = EnemyNear,stateno = 99666
trigger2 = Movehit
value = 1400



[State 200, End]
type = ChangeState
Triggerall = !Helper(30990),Var(10)
trigger1 = time >= 150/2
value = 0
ctrl = 1


