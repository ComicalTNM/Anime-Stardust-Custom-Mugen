trigger1 = Time > 0
value = anim

[State 5000, 5] 
type = StateTypeSet
trigger1 = Time = 0
trigger1 = GetHitVar(yvel) != 0 || GetHitVar(fall)
trigger2 = Pos Y != 0
statetype = a

[State 0, SelfState]
type = SelfState
trigger1 = time >= 200 || !Alive
value = 5050
