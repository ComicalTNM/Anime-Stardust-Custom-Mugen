type    = L
movetype= H
physics = N
ctrl = 0

[State AngleDraw-gdghf]
type = AngleDraw
trigger1 = 1
value = 0
scale = 1,1
ignorehitpause = 1
persistent = 1

[State 0, HitBy]
type = HitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 100
ignorehitpause = 1
persistent = 1

[State 2120]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0


[State 5100, 1]
type = VelSet
trigger1 = Time = 0
trigger1 = GetHitVar(fall.yvel) = 0
trigger1 = vel x > 1
x = 1

[State 5100, EnvShake]
type = FallEnvShake
trigger1 = Time = 0

[State 5100, Var] ;Save fall velocity
type = VarSet
trigger1 = Time = 0
sysvar(1) = floor(vel y)

[State 5100, 2] ;Hit ground anim (normal)
type = ChangeAnim
triggerall = time = 0
trigger1 = (anim != [5051+var(10),5059+var(10)]) && (anim != [5061+var(10),5069+var(10)])
trigger2 = !SelfAnimExist(5100 + ((anim-111000) % 10))
value = 5100

[State 5100, 3] ;Hit ground anim (for hit up)
type = ChangeAnim
trigger1 = time = 0
trigger1 = (anim = [5051+var(10),5059+var(10)]) || (anim = [5061+var(10),5069+var(10)])
trigger1 = SelfAnimExist(5100 + ((anim-100) % 10))
value = (5100 + ((anim-100) % 10))+var(10)

[State 5100, 4]
type = PosSet
trigger1 = Time = 0
y = 0

[State 5100, 5]
type = VelSet
trigger1 = Time = 0
y = 0

[State 5100, 6] ;Reduce speed
type = VelMul
trigger1 = Time = 0
x = 0.75

[State 5100, 12]
type = ChangeState
trigger1 = AnimTime = 0
value = 116101

[State 5100, 7]
type = changeState
trigger1 = Time = 0
trigger1 = GetHitVar(fall.yvel) = 0
value = 116110 ;HIT_LIEDOWN

[State 5100, 9]
type = HitFallDamage
trigger1 = Time = 3

[State 5100, 11]
type = PosFreeze
trigger1 = 1

[State 5100, 13]
type = ForceFeedback
trigger1 = Time = 0
waveform = sinesquare
ampl = 128,-3,-.2,.005
time = 20

