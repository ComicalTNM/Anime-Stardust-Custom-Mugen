type    = L
movetype= H
physics = N

[State AngleDraw-gdghf]
type = AngleDraw
trigger1 = 1
value = 0
scale = 1,1
ignorehitpause = 1
persistent = 1

[State 2120]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = 1
ignorehitpause = 1

[State 5101, 1] ;Coming hit ground anim (normal)
type = ChangeAnim
triggerall = time = 0
trigger1 = anim != [5101,5109]
trigger2 = !SelfAnimExist(5160 + ((anim-111000) % 10))
value = 5160+var(10)

[State 5101, 2] ;Coming hit ground anim (for hit up)
type = ChangeAnim
triggerall = time = 0
trigger1 = anim = [5101,5109]
trigger1 = SelfAnimExist(5160 + ((anim-111000) % 10))
value = 5160 +var(10)+ ((anim-111000) % 10)

