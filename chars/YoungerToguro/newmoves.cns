trigger1 = Time && Life> 80
value = 80

[State 2000, LifeAdd]
type = LifeAdd 
trigger1 =! Time 
value = -GetHitVar (damage) 
;-----------------------------------
;Sets postion for Blue Collission
[State 2000, PosSet]
type = Posset
trigger1 = helper(114411),gethitvar(damage)>0
x = Pos X - Helper(114411),Pos x

[State 2000, BindToParent]
type = BindToParent
trigger1 = 1
time = 1
facing = 0
pos = 0,0

;Hit Override
[State 2000, HitOverride]
type = HitOverride 
trigger1 = 1 
attr = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT 
slot = 0 
stateno = stateno 
time = 0 
forceair = 0 
