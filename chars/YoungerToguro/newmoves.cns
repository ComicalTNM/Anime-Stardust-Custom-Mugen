type = ChangeState 
trigger1 = life <= 1 
trigger2 = parent,stateno!=114411
trigger3 =(ScreenPos Y <= 0)
trigger4 =time>=125
trigger5 = numhelper(114411) < 1
value = 2001 
ctrl = 1 



