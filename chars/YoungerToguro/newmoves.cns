;[State 0, PalFXWiz]
;type = PalFX
;trigger1 = time = 0
;time = -1
;add = 0,100,50
;mul = 20,120,24
;sinadd = 85,110,55,10
;invertall = 0
;color = 256

[state ] ; prevents the helper from being hit
type = nothitby
trigger1 = time = 0
value = sca,aa,at,ap
time = -1

[state ]
type = changeanim
trigger1 = 1
value = parent,anim ;go to root animation
elem = (parent,animelemno(0)) ; go to root elem

[state ]
type = trans
trigger1 = 1
trans = addalpha ;"addalpha" lets you use a custom alpha value
alpha = 256-(time*5),0+(time*5)
[state ]
type = angledraw
triggerall = parent, stateno = 2610
trigger1 = 1
scale = 1+(time*.05),1+(time*.05)
[state ]
type = angledraw
triggerall = root, NumHelper(1121912)>0
trigger1 = 1
scale = 1+(time*.15),1+(time*.15)

[State ] ;destroys the helper after some time
type = destroyself
triggerall = root, NumHelper(1121912)<1
;triggerall = root, stateno = 1121912
trigger1 = time =15
recursive = 1
[state ]
type = angledraw
triggerall = root, NumHelper(11255)>0
trigger1 = 1
scale = 1+(time*.05),1+(time*.05)

[State ] ;destroys the helper after some time
type = destroyself
triggerall = root, NumHelper(11255)<1
;triggerall = root, stateno = 1121912
trigger1 = time =15
recursive = 1
;trigger2 = root,animelemtime(195) = 0
[State ] ;destroys the helper after some time
type = destroyself
triggerall = parent, stateno = 2610
trigger1 = time =12
recursive = 1
