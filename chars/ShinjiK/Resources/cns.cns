;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = !Var(22) && !Var(50)
Value = Cond(Random >= 500,Cond(Random >= 700,1000,Cond(Random >= 500,1200,Cond(Random >= 750,1400,1300))),Cond(Random >= 500,1300,Cond(Random >= 500,1200,1000)))
Ctrl = 0

[State 0, End]
Type = ChangeState
Trigger1 = Var(22) && !Var(50)
Value = Cond(Random >= 500,Cond(Random >= 700,25000,Cond(Random >= 500,25102,Cond(Random >= 750,25400,25200))),Cond(Random >= 500,25300,Cond(Random >= 500,25500,25000)))
Ctrl = 0

[State 0, End]
Type = ChangeState
Trigger1 = Var(22) && Var(50)
Value = Cond(Random >= 500,Cond(Random >= 700,701000,Cond(Random >= 500,701300,Cond(Random >= 750,701400,701600))),Cond(Random >= 500,701700,Cond(Random >= 500,701000,701300)))
Ctrl = 0

