trigger1 = root,stateno = 4600
value = 4610

[State 200, Combo Air C]
type = Changestate
trigger1 = root,stateno = 4605
value = 4630

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 1100
value = 111010

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 12000
value = 12100

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 30000
value = 30010

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 30200
value = 30210

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 30400
value = 30410

[State 200, End]
