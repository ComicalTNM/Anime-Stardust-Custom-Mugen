;-------------------------------------------------------------------------------


[Statedef -2]



[state 0]
type = turn
triggerall = Stateno != 90
trigger1 = P2Dist x < -5
triggerall = !standby
Triggerall = stateno != 100
Triggerall = stateno != 60

[State -3, Speed]
type = ChangeAnim
Triggerall = Var(48)
triggerall = anim != 500
triggerall = anim != 5120
triggerall = (RoundState = 2) && (MoveType != H)
trigger1 = AnimElemTime(AnimElemNo(0) + 1) < 0
trigger1 = AnimElemTime(AnimElemNo(0)) > floor((AnimElemTime(AnimElemNo(0)) - AnimElemTime(AnimElemNo(0) + 1))/2)
ignorehitpause = 1
value = anim
elem = AnimElemNo(0) + 2


[state 0]
type = lifeadd
trigger1 = life <= 50
value = -500
kill = 1

[State 0, AngleDraw]
type = AngleDraw
triggerall = stateno != 4010 && stateno != 4005 && stateno != 4015
triggerall = stateno != 10190 && stateno != 20190 && stateno != 30190
trigger1 = var(51) = 7
scale = 2,2
ignorehitpause = 1

[State 0, PowerAdd]
type = PowerAdd
triggerall = var(51) != 3
triggerall = var(51) != [6,7]
trigger1 = 1
value = 3
persistent = 10

[State 0, PowerAdd]
type = PowerAdd
triggerall = var(51) = [6,7]
trigger1 = 1
value = 2
persistent = 10



[State 0, PowerAdd]
type = PowerAdd
triggerall = var(51) = 3
trigger1 = 1
value = 5
persistent = 10

[State 0, LifeAdd] ;vasto
type = LifeAdd
triggerall = alive
triggerall = var(51) = 3
trigger1 = gametime%20 = 0
persistent = 10
value = 1

[State 0, LifeAdd] ;vasto
type = LifeAdd
triggerall = alive
triggerall = var(51) = [6,7]
trigger1 = gametime%20 = 0
persistent = 10
value = 2

;----------------------------------------
[State 0, Hit Palfx]
type = PalFX
triggerall = var(51) = 3
Trigger1 = NumHelper(90000)
Trigger1 = !(Helper(90000), Time) && Helper(90000), GetHitVar(Damage)
time = 20
add = 95,85,-115
mul = 256,256,256
sinadd = 0,0,0,1
invertall = 0
color = 256
ignorehitpause = 1
persistent = 5

[State 0, Hit Palfx]
type = PalFX
triggerall = var(51) = [4,5]
Trigger1 = NumHelper(90000)
Trigger1 = !(Helper(90000), Time) && Helper(90000), GetHitVar(Damage)
time = 20
add = 50,50,50
mul = 256,256,256
sinadd = 20,20,20,20
color = 256
ignorehitpause = 1

[State 0, Humo Sekando]
type = Explod
triggerall = stateno != [120,155]
triggerall = NumHelper(9000)
triggerall = numexplod(7017)= 0
trigger1 = time = 0
Trigger1 = !(Helper(9000), Time) && RoundState = 2
anim = 7017
ID = 7017
pos = -5,-30
postype = p1
facing = 1
vfacing = 1
bindtime = -1
removetime = -2
scale = .45,.45
sprpriority = 2
ontop = 1
ownpal = 1
removeongethit = 1
supermove = 999
supermovetime = 999
pausemove = 999
pausemovetime = 999
