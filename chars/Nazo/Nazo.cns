[data]
life = 2000
power = 3000
attack = 150
defence = 130
fall.defence_up = 150
liedown.time = 50
airjuggle = 10
sparkno = -1
guard.sparkno = -1
ko.echo = 0
intpersistindex = 60
floatpersistindex = 40

[Size]
