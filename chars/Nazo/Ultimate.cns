[Statedef 3221]
type = A
movetype = I
physics = N
juggle = 1
velset = 0,0
ctrl = 0
anim = 3220
sprpriority = 1

[State 0, PalFXWiz]
Type = PalFX
Trigger1 = 1
Time = -1
Add = -80,-0,-80
Mul = 512,512,512
Color = 0

[State 0,Trans]
type = Trans
trigger1 = 1
trans = Sub
ignorehitpause=1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 15,-28

[State 0, Master Breaker - Particule]
type = Helper
trigger1 =! time
name = "Master Breaker - Particule"
ID = 3222
stateno = 3222
pos = 0,-0
postype = p1
ownpal = 1
supermovetime = 999
pausemovetime = 999
size.xscale = .12
size.yscale = .12
[State 0, Master Breaker - Charge FXADD]
type = Helper
trigger1 =! time
name = "Master Breaker - Charge FXADD"
ID = 3226
stateno = 3226
pos = 0,-0
postype = p1
facing = 1
ownpal = 1
size.xscale = .062
size.yscale = .062
supermovetime = 999
pausemovetime = 999
Ignorehitpause = 1

[State 0, VarSet]
type = VarSet
trigger1 = !Time
fv = 6
value = 0

[State 0,VarAdd]
type = VarAdd
trigger1 = time < 50
Fv = 1
value = .01

[State 0,AngleDraw]
type = AngleDraw
trigger1 = 1
scale = 1+Fvar(1),1+Fvar(1)
value = 0+time*.5
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 200, End]
type = Destroyself
trigger1 = Root,stateno != 3200
trigger1 = Root,stateno != 3205

[State 200, End]
type = Destroyself
Triggerall= Root,Stateno = 3200 || Root,Stateno = 3205
trigger1 = Root,AnimelemTime(4)= 0
