;---------------------------------- Var System

[State 0, Game Start]
type = VarSet
trigger1 = !time
v = 55
value = cond(roundno = 1,100,20);100
ignorehitpause = 1
[State 0, Reversal Limit Reset]
type = VarSet
trigger1 = !time 
v = 56
value = 2
ignorehitpause = 1
persistent = 0
[State 0, Reversal ON]
type = VarSet
trigger1 = root,movetype = H 
v = 57
value = 1
ignorehitpause = 0
[State 0, Reversal OFF]
type = VarSet
trigger1 = root,movetype != H 
v = 57
value = 0
ignorehitpause = 0

[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
trigger1 = 1
v = 55   
value = 1;training

[State 0, Summon PLAYER Normal]
type = VarSet
triggerall = numhelper(123231)=0
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = command = "y"
v = 55   
value = -1
ignorehitpause = 1
[State 0, Summon PLAYER Reversal]
type = VarSet
triggerall = numhelper(123231)=0
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
triggerall = numexplod(4020) 
triggerall = var(56) > 0
triggerall = root,movetype = H ;|| root,stateno = [120,155]
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = command = "y"
v = 55   
value = -1
ignorehitpause = 1

;IA
