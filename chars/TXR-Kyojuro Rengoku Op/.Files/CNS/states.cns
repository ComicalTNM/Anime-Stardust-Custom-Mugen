crouch.friction = .82

[Quotes]
victory1 = "I must do what is my duty. I wont let anyone know whats here..."
victory2 = "I will FULFILL my DUTY! I will not allow ANYONE here to DIE"
victory3 = "Let me be clear, the two of us will NEVER see eye to eye... No matter what TWISTED reasons you GIVE."
victory4 = "We HASHIRAS need to be the glue that holds the demon slayer corps TOGETHER!"
victory5 = "Warriors who strive to save other peoples lives are precious... Their pure and single-minded dedication is separate from their natural talent."
victory6 = "Growing old and dying is what gives meaning and beauty to the fleeting span of a human life... Its precisely because we age and die that our lives have value and nobility..."
victory7 = "SET YOUR HEART ABLAZE!"
victory8 = "STRENGHT is not a WORD that means much in regard to the FLESH!"
[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

