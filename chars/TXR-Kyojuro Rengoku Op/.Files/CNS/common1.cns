[State 0, PosSet]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 0, EnvShake]
type = EnvShake
trigger1 = time = 0
time = 10
freq = 40
ampl = -7
phase = 90
ignorehitpause = 1
persistent =  1

[State 0, VelSet]
type = VelSet
Triggerall = 1
trigger1 = Time = 4
x = 7
y = 0

[State 0, VelAdd]
type = VelAdd
Triggerall = vel x <= 14
Triggerall = Time >= 4
trigger1 = 1
x = cond(var(54) = 1,.45,.2)

[State 0, Gravity]
type = Gravity
trigger1 = time > 2 && pos y < 0

[State 0, PosSet]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 200, LAND]
type = ChangeState
triggerall = time >= 0
trigger1 = p2bodydist x < 60
value = 200

[State 200, LAND]
type = ChangeState
triggerall = time >= 0
trigger1 = p2bodydist x < 80
value = 450

[State 200, JUMP]
type = ChangeState
triggerall = pos y >= 0
triggerall = time > 2
trigger1 = command = "up"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100) 
trigger2 = p2bodydist x = [0,50]
value = 40

[State 200, LAND]
type = ChangeState
triggerall = time > 2
trigger1 = pos y > 0
value = 12

[State -1, C - Dash]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "a" && command = "holddown"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,40]) && random < (ailevel * 500)
[State -1, B - Holddown]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "b" && command = "holddown"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,35]) && random < (ailevel * 100*cond(p2bodydist y < 68,6,0))
[State -1, C - Dash]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "b" && command = "holdfwd"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,38]) && random < (ailevel * 100)*1.5
; C - Dash
[State -1, C - Dash]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "a" && command = "holdfwd"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,45]) && random < (ailevel * 1000)*3
[State -1, C - Dash]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "a" 
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,30]) && random < (ailevel * 100)
; A
[State -1, A]
type = ChangeState
value = ifelse(pos y >= 0,450,600)
triggerall = time > 2
trigger1 = command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,30]) && random < (ailevel * 100)

; B
[State -1, B]
type = ChangeState
value = ifelse(pos y >= 0,450,610)
triggerall = time > 2
trigger1 = command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,35]) && random < (ailevel * 100)
; C - Dash
[State -1, C - Dash]
type = ChangeState
value = 450
triggerall = time > 2
trigger1 = command = "c" && command = "holdfwd"
trigger2 = roundstate = 2 && ailevel > 0 && (p2bodydist x = [0,40]) && random < (ailevel * 900)

; C
[State -1, C]
type = ChangeState
value = cond(pos y >= 0,450,620)
triggerall = time > 2
trigger1 = command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/8
trigger2 = p2bodydist x = [75,150]

[State 200, End]
type = ChangeState
triggerall = time > 10
trigger1 = ailevel = 0 && command != "holdfwd"
trigger2 = ailevel > 0 && time = 100+random%200
trigger3 = ailevel > 0 && p2bodydist x < 50
value = 61
