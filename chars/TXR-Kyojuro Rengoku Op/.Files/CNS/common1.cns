;---------------------------------------------------------------------------
; HITA_FALL (knocked up, falling)
[Statedef 5050]
type    = A
movetype= H
physics = N

[State 5050, 1] ;Change anim when done with transition
type = ChangeAnim
trigger1 = AnimTime = 0
trigger1 = Anim = 5035+0
trigger2 = Time = 0     ;If no transition anim
trigger2 = Anim != 5035+0
trigger2 = (Anim != [5051, 5059])+0 && (Anim != [5061, 5069])+0
trigger2 = Anim != 5090+0 ;Not if hit off ground anim
value = 5050+0

[State 5050, 2] ;Coming down anim
type = ChangeAnim
trigger1 = (anim = [5050,5059])+0
trigger1 = Vel Y >= ifelse(anim = 5050+0, 1, -2)
trigger1 = SelfAnimExist(anim+10)
value = anim+10
persistent = 0

[State 5050, 3] ;Gravity
type = VelAdd
trigger1 = 1
y = GetHitVar(yaccel)+cond(prevstateno = 257,0.125,0)
[State 0, NotHitBy]
type = NotHitBy
triggerall = prevstateno = 257
trigger1 = time >= 17
value = S,NA
time = 1
ignorehitpause = 1

[State 5050, 4] ;Recover near ground
type = ChangeState
triggerall = Vel Y > 0
triggerall = Pos Y >= -20
triggerall = alive
triggerall = CanRecover
trigger1 = Command = "recovery"
value = 5200 ;HITFALL_RECOVER

[State 5050, 5]; Recover in mid air
type = ChangeState
triggerall = Vel Y > -1
triggerall = alive
triggerall = CanRecover
trigger1 = Command = "recovery"
value = 5210 ;HITFALL_AIRRECOVER

[State 5050, 6]
type = ChangeState
trigger1 = Vel Y > 0
trigger1 = Pos Y >= ifelse((anim = [5051,5059])+0 || (anim = [5061,5069])+0, 0, 25)
value = 5100 ;HIT_BOUNCE
