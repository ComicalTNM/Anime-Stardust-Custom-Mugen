;---------------- Constantes y Ataques normales--------------------------------------------R
;===================================================================================Y

;Var List:

; - Var(1) = Zero Chiten Toppa System
; - Var(2) = Healing Magic Limitador
; - Var(3) = Sheet Heart Attack
; - Var(4) = Stand power
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(10) = Apariencia Transformaciones
; - Var(11) = Golpeado Transformaciones
; - Var(12) = Oscurecer Pantalla
; - Var(14) = Specials Transformaciones
; - FVar(16) = ESCALA
; - Var(17) = VS
; - Var(20) = C-moon Transform
[Data]
life = 2000
power = 3000
attack = 160
defence = 155
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 0
FloatPersistIndex = 0

[Size]
xscale = 0.99
yscale = 1.05
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = -1
draw.offset = 0,-1

[Velocity]
walk.fwd  = 2
walk.back = -2
run.fwd  = 0
run.back = 0
jump.neu = 0,-6.5
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 1
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 456700 ; STATENO: normal assist attack
StateTagAssistHyper = 21400 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.
[Quotes]
victory0 = "DIO,Alfin estoy en tu mundo"
victory1 = " Por el nombre de Dios, yo voy a castigarte a golpes!"
victory2 = "Crees en la gravedad?"
victory3 = "Las personas deben de aprovechar sus vidas estando atadas a los cielos"
victory4 = "Este es,made in heaven"
victory5 = "2 pasos,estuviste a 2 pasos de vencerme"
;-------------------------------------------------------------------------------
; Start
[Statedef 160]
type    = A
movetype= I
physics = N
anim = 160
sprpriority = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 20*Helper(999999),Fvar(16),5*Helper(999999),Fvar(16)

[State 0, Trans]
type = Trans
trigger1 = time < 5
trans = addalpha
alpha = 0+time*50,256-time*50

[State 200, End]
type = Destroyself
trigger1 = root,stateno != [120,155]

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 140
value = 161
;-------------------------------------------------------------------------------
; Fin Destroy
[Statedef 161]
type    = A
movetype= I
physics = N
sprpriority = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 20*Helper(999999),Fvar(16),5*Helper(999999),Fvar(16)

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256-time*50,0+time*50

[State 200, End]
type = Destroyself
trigger1 = time >= 5
trigger2 = root,stateno != [120,155]

[Statedef 167]
