v = 58
value = cond(var(58) = 2,1,cond(var(58) = 6,-4,1))
[State 0, ALL Start]
type = VarSet
trigger1 =  !time
v = 58  
value = 1;1
ignorehitpause = 1
[State 0, ALL Rotation]
type = VarAdd
trigger1 = var(55) = -1
v = 58
value = cond(var(58) = 1,1,cond(var(58) = 6,-5,1));cond(var(58) = 1,1,cond(var(58) = 3,-2,1))
[State 0, RANDOM Start]
type = VarSet
trigger1 = !time
;trigger2 = time%120=0
v = 58  
value = 6-random%5
ignorehitpause = 1
[State 0, Random Rotation]
type = VarAdd
trigger1 = time%50=0
v = 58
value = cond(var(58) = 1,1,cond(var(58) = 6,-5,1))
