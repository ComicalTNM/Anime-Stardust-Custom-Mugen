;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Random >= 500,1000,Cond(Random >= 500,1500,Cond(Random >= 500,1200,Cond(Random >= 500,1400,1100))));Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),Cond(Random >= 500,1300,Cond(Random >= 750,1540,1501)),Cond(P2BodyDist x >= 60,1400,Cond(Random >= 500,1280,1000))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

