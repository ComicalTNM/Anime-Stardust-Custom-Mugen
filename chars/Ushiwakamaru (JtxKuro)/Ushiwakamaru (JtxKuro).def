
; Player information
[Info]
name         =  "Ushiwakamaru"  ; Name of character
displayname  = "Ushiwakamaru (JT/Kuro)"    ; Name of character to display
versiondate  = 1.1           ; Version date of character (MM,DD,YYYY or X.XX)
mugenversion = 1.0          ; Version of M.U.G.E.N. character works on (X.XX)
author       = "Dry-Mugen"   ; Character author name
pal.defaults = 1;,101,201,301,401,501,601   ; Default palettes in order of preference (up to 4, starts from 1)
     ; Local coordinate space (width, height)

; Files for the player
[Files]
cmd      = Ushiwakamaru.cmd          ; Command set
cns      = Ushiwakamaru.cns          ; Constants
st       = Ushiwakamaru.cns    
st1       = Special.cns 
st2      =  IA.cns  
;st2      =  IA simple.cns       ; States 
stcommon = common1.cns       ; Common states (from data or motif)
sprite   = Ushiwakamaru.sff          ; Sprite
anim     = Ushiwakamaru.air          ; Animation
sound    = Ushiwakamaru.snd          ; Sound
;ai       = Ushiwakamaru.ai           ; AI hints data (not used)

; Arcade mode
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
