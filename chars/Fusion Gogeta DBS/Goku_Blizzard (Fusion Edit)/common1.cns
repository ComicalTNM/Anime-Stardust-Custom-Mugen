; HIT_BOUNCE (hit ground)
[Statedef 5100]
type    = L
movetype= H
physics = N

[State 5100, 1]
type = VelSet
triggerall = var(20) = 0
trigger1 = Time = 0
trigger1 = GetHitVar(fall.yvel) = 0
trigger1 = vel x > 1
x = 1

[State 5100, EnvShake]
type = FallEnvShake
triggerall = var(20) = 0
trigger1 = Time = 0

[State 5100, Var] ;Save fall velocity
type = VarSet
triggerall = var(20) = 0
trigger1 = Time = 0
sysvar(1) = floor(vel y)

[State 5100, 2] ;Hit ground anim (normal)
type = ChangeAnim
triggerall = var(20) = 0
triggerall = time = 0
trigger1 = (anim != [5051,5059])+var(10) && (anim != [5061,5069])+var(10)
trigger2 = !SelfAnimExist(5100 + (anim % 10))
value = 5100+var(10)

[State 5100, 3] ;Hit ground anim (for hit up)
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = time = 0
trigger1 = (anim = [5051,5059])+var(10) || (anim = [5061,5069])+var(10)
trigger1 = SelfAnimExist(5100 + (anim % 10))
value = (5100+var(10)) + (anim % 10)

[State 5100, 4]
type = PosSet
triggerall = var(20) = 0
trigger1 = Time = 0
y = 0

[State 5100, 5]
type = VelSet
triggerall = var(20) = 0
trigger1 = Time = 0
y = 0

[State 5100, 6] ;Reduce speed
type = VelMul
triggerall = var(20) = 0
trigger1 = Time = 0
x = 0.75

[State 5100, 7]
type = ChangeState
triggerall = var(20) = 0
trigger1 = Time = 0
trigger1 = GetHitVar(fall.yvel) = 0
value = 5110 ;HIT_LIEDOWN

[State 5100, 8]
type = GameMakeAnim
triggerall = var(20) = 0
trigger1 = Time = 1
value = 60 + (sysvar(1) > 5) + (sysvar(1) > 14)
pos = -5, 0
under = sysvar(1) <= 14

[State 5100, 9]
type = HitFallDamage
triggerall = var(20) = 0
trigger1 = Time = 3

[State 5100, 10]
type = PlaySnd
triggerall = var(20) = 0
trigger1 = Time = 1
value = F7, (sysvar(1) > 5) + (sysvar(1) > 14)

[State 5100, 11]
type = PosFreeze
triggerall = var(20) = 0
trigger1 = 1

[State 5100, HitGroundMoanVariable]
type = VarRandom
triggerall = var(20) = 0
trigger1 = time = 0
v = 7
range = 1,22

[State 5100, Voice-1]
type = PlaySnd
triggerall = var(20) = 0
triggerall = Var(7) = 1 && alive = 1
trigger1 = time = 0
value = 5000,0

[State 5100, Voice-2]
type = PlaySnd
triggerall = var(20) = 0
triggerall = Var(7) = 2 && alive = 1
trigger1 = time = 0
value = 5001,0

[State 5100, Voice-3]
type = PlaySnd
triggerall = var(20) = 0
triggerall = Var(7) = 3 && alive = 1
trigger1 = time = 0
value = 5002,0

[State 5100, Voice-4]
type = PlaySnd
triggerall = var(20) = 0
triggerall = Var(7) = 4 && alive = 1
trigger1 = time = 0
value = 5003,0

[State 5100, VarSet]
type = VarSet
triggerall = var(20) = 0
trigger1 = Var(7) = 1 || Var(7) = 2 || Var(7) = 3 || Var(7) = 4
v = 7
value = 5

[State 5100, 12]
type = ChangeState
triggerall = var(20) = 0
trigger1 = AnimTime = 0
value = 5101

[State 5100, 13]
type = ForceFeedback
triggerall = var(20) = 0
trigger1 = Time = 0
