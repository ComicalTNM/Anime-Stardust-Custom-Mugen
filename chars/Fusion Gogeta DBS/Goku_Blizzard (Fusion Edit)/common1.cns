; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 1
trigger1 = anim = 5
value = 2005
[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 4
trigger1 = anim = 5
value = 17005
[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 5
trigger1 = anim = 5
value = 2005
[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 6
trigger1 = anim = 5
value = 17005

[State -3, Turn Base]
type = ChangeAnim
triggerall = var(21) = 0
triggerall = var(20) = 1
trigger1 = anim = 5
value = 20005

[State -3, Stand SSJ]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = var(21) = 1
trigger1 = anim = 0
value = 31000

[State -3, Turn SSJ]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = var(21) = 1
trigger1 = anim = 5
value = 31005

[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(4) = 0
triggerall = var(20) = 1
trigger1 = var(21) = 2
trigger1 = anim = 5
value = 39005

[State -3, Turn SSB Full Power]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = var(4) = 1
trigger1 = var(21) = 1
trigger1 = anim = 5
value = 41005

[State 0, 1]
Type = ChangeAnim
triggerall = var(20) = 0
Trigger1 = Anim != 0 + Var(11) && Anim != 5 + Var(11)
Trigger2 = Anim = 5 + Var(11) && AnimTime = 0
Value = 0 + var(11)

[State 0, 1]
type = ChangeAnim
triggerall = var(21) = 0
triggerall = var(20) = 0
triggerall = var(2) < 6
trigger1 = (Anim != 0 && Anim != 5 && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 0+var(11)

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 0
triggerall = var(2) = 6
trigger1 = (Anim != 17001 && Anim != 5 && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 17001

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = var(21) = 0
triggerall = var(4) = 0
trigger1 = (Anim != 20000 && Anim != 20005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20000

[State 0, 1]
type = ChangeAnim
triggerall = anim != 39000
triggerall = var(20) = 1
triggerall = var(21) = 2
triggerall = var(4) = 0
trigger1 = (Anim != 20000 && Anim != 20005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 39000

[State 0, 1]
type = ChangeAnim
triggerall = anim != 31000
triggerall = var(20) = 1
triggerall = var(21) = 1
triggerall = var(4) = 0
trigger1 = (Anim != 20000 && Anim != 20005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 31000

[State 0, 1]
type = ChangeAnim
triggerall = anim != 41000
triggerall = var(20) = 1
triggerall = var(21) = 2
triggerall = var(4) = 1
trigger1 = (Anim != 20000 && Anim != 20005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 41000

[State 0, 2]
type = VelSet
triggerall = var(20) = 0
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
triggerall = var(20) = 0
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
triggerall = var(20) = 0
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = ifelse(Var(20) = 1,20010,10+var(11))

[State 10, 1]
type = VelMul
triggerall = var(20) = 0
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = ifelse(Var(20) = 1,20011,11+var(11))
sprpriority = 0

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = anim = 6
value = 6+var(11)

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006)
trigger2 = (Anim = 6 || anim = 2006) && AnimTime = 0
value = 11+var(11)

;-------------------GOGETA-----------------
[State 10, 1]
type = VelMul
triggerall = var(20) = 1
trigger1 = Time = 0
x = .75

[State 0, PosSet]
type = PosSet
triggerall = var(20) = 1
trigger1 = 1
y = 0

[State 0, Velset]
type = Velset
triggerall = var(20) = 1
trigger1 = 1
y = 0

[State 0, PosSet]
type = PosSet
triggerall = var(20) = 1
trigger1 = time = 0
y = 0

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = anim = 6
value = 20006

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = (Anim != 20011 && Anim != 20006 && Anim != 2006 && Anim != 17011 && Anim != 17006)
trigger2 = (Anim = 20006 || anim = 2006 || anim = 17006) && AnimTime = 0
value = 20011

;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = ifelse(var(20)= 1,20012,12+var(11))

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
triggerall = var(20) = 0
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)+ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
triggerall = var(20) = 0
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)-ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = var(20) = 0
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = var(20) = 0
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)
;------------------------GOGETA
[State 20, 1]
type = VelSet
triggerall = var(20) = 1
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
triggerall = var(20) = 1
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = vel x > 0
trigger1 = (Anim != 20020 && Anim != 20005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20020

[State 20, 4]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = vel x < 0
trigger1 = (Anim != 20021 && Anim != 20005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 20005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20021
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = ifelse(Var(20) = 1,20040,40+var(11))
ctrl = 0
sprpriority = 1

[State 40, 1]
type = VarSet
triggerall = var(20) = 0
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdback"
sysvar(1) = -1


[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
triggerall = var(20) = 0
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 0, VelAdd] ; FROM RUN
type = VelAdd
triggerall = var(20) = 0
triggerall = prevstateno = 60||prevstateno = 70
trigger1 = animtime = 0
x = ifelse(vel x > 0,2,-2)

[State 0, VelSet] ; From Uppercut
type = VelSet
triggerall = var(20) = 0
triggerall = ailevel > 0
triggerall = prevstateno = 310
trigger1 = animtime = 0
x = 4

[State 40, 6]
type = ChangeState
triggerall = var(20) = 0
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;------------------------GOGETA-------------------------

[State 40, 1]
type = VarSet
triggerall = var(20) = 1
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
triggerall = var(20) = 1
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
triggerall = var(20) = 1
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
triggerall = var(20) = 1
trigger1 = AnimTime = 0
value = 50
ctrl = 1
