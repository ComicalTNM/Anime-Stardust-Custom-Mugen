type = HitFallDamage
triggerall = var(20) = 0
trigger1 = Time = 0

[State 5110, 5]
type = PosSet
triggerall = var(20) = 0
trigger1 = Time = 0
y = 0

[State 5110, Var] ;Get fall velocity
type = VarSet
triggerall = var(20) = 0
trigger1 = Time = 0
trigger1 = GetHitVar(fall.yvel) != 0
sysvar(1) = floor(vel y)

[State 5110, 6]
type = PlaySnd
triggerall = var(20) = 0
trigger1 = Time = 0
trigger1 = !SysVar(0)
value = F7, (sysvar(1) > 5) + (sysvar(1) > 14)

[State 5110, 7]
type = GameMakeAnim
triggerall = var(20) = 0
trigger1 = Time = 0
trigger1 = !SysVar(0)
value = 60 + (sysvar(1) > 5) + (sysvar(1) > 14)
pos = -5, 0
under = sysvar(1) <= 14

[State 5110, 8]
