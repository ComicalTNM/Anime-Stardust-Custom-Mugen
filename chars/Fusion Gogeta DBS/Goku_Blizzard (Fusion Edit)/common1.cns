; A
[State -1, A]
type = ChangeState
triggerall = var(20) = 0
value = ifelse(pos y >= 0,200+var(11),600+var(11))
triggerall = time > 2
trigger1 = command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 400)

; B
[State -1, B]
type = ChangeState
triggerall = var(20) = 0
value = ifelse(pos y >= 0,300+var(11),610+var(11))
triggerall = time > 2
trigger1 = command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 400)

; C
[State -1, C]
type = ChangeState
triggerall = var(20) = 0
value = ifelse(pos y >= 0,20400,20620)
triggerall = time > 2
triggerall = power >= 200
trigger1 = command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x > 50 && p2bodydist x < 200 && random < (ailevel * 100)/8

; Super Dash
[State -1, Super Dash]
triggerall = var(20) = 0
type = ChangeState
value = 710
triggerall = time > 2
triggerall = power >= 200
trigger1 = command = "s"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x > 50 && p2bodydist x < 200 && random < (ailevel * 100)/8

[State 200, End]
type = ChangeState
triggerall = time > 10
triggerall = var(20) = 0
