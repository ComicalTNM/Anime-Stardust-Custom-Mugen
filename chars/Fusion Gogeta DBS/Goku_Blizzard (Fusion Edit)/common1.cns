trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
