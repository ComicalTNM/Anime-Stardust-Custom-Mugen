; Shockwave FX1
[Statedef 820]
type    = A
movetype= I
physics = N

; [GUIDELINES] ==================================
; - 000: Standard Shockwave GRAY || (FG/SPR:3)
; - 001: Pulse Shockwave RED     || (FG/SPR:3)
; ===============================================

[State 0, ChangeAnim]
type = ChangeAnim
TriggerALL = IsHelper(000)
trigger1 = !Time
value = 7022
elem = 1
persistent = 0
[State 0, ChangeAnim]
type = ChangeAnim
TriggerALL = IsHelper(001)
trigger1 = !Time
value = 7025
elem = 1
persistent = 0

[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(000)
trigger1 = !Time
value = 3
ignorehitpause = 1
[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(001)
trigger1 = !Time
value = 3
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
TriggerALL = IsHelper(000)
trigger1 = 1
x = -.5
ignorehitpause = 1
[State 0, VelSet]
type = VelSet
TriggerALL = IsHelper(001)
trigger1 = 1
x = -.5
ignorehitpause = 1

[State 0, PalFX]
type = PalFX
TriggerALL = IsHelper(000)
trigger1 = !Time
time = 99999
add = 0,-150,-140
mul = 512,512,512
color = 0
ignorehitpause = 1
[State 0, PalFX]
type = PalFX
TriggerALL = IsHelper(001)
trigger1 = !Time
time = 99999
add = 0,-100,-90
mul = 512,512,512
color = 0
ignorehitpause = 1

[State 0, VarSet]
type = VarSet
trigger1 = Time=0
fv = 7
value = 0
[State 0, VarSet]
type = VarSet
trigger1 = Time=0
fv = 8
value = 0

[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(000)
trigger1 = Time = [1,5]
fv = 7
value = .025
[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(000)
trigger1 = Time >=9
fv = 7
value = -.05

[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(000)
trigger1 = Time >= 9
fv = 8
value = 40

[State 0, AngleDraw]
type = AngleDraw
TriggerALL = IsHelper(000)
trigger1 = 1
scale = 1,1+FVAR(7)
ignorehitpause = 1
[State 0, AngleDraw]
type = AngleDraw
TriggerALL = IsHelper(001)
trigger1 = 1
scale = 1+(Time*0.05),1+(Time*0.05)
ignorehitpause = 1

[State 0, Trans]
type = Trans
TriggerALL = IsHelper(000)
trigger1 = 1
trans = AddAlpha
Alpha = 256-FVAR(8),256
[State 0, Trans]
type = Trans
TriggerALL = IsHelper(001)
trigger1 = 1
trans = AddAlpha
Alpha = 256,256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = NoShadow
ignorehitpause = 0

[State 200, End]
type = Destroyself
trigger1 = AnimTime = 0

