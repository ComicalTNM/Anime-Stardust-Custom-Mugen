;===============================================================================
; VISUALS ======================================================================
;===============================================================================

;-------------------------------------------------------------------------------
; GuardSpark1
[Statedef 800]
type    = A
movetype= I
physics = N
anim = 7000
sprpriority = 5

;[State 0, VarSet]
;type = VarSet
;trigger1 = time = 0
;Fv = 1
;value = random%360

[State 0, PalFX]
type = PalFX
trigger1 = !Time
time = 99999
add = -128,-64,0
mul = 512,512,512
color = 0
ignorehitpause = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = Fvar(1);+(time*1)
scale = 1,1

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256,256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 200, End]
type = Destroyself
trigger1 = AnimTime = 0

;-------------------------------------------------------------------------------
; HitSparks A
[Statedef 801]
type    = A
movetype= I
physics = N

; [GUIDELINES] ===================
; - 001: Hitspark A1 ADD ||(FG/Pr=3)
; - 002: Hitspark B1 ADD ||(FG/Pr=3)
; - 012: Hitspark B1 RED ||(FG/Pr=3)
; ================================

[State 0, VarSet]
type = VarSet
trigger1 = !Time
Fv = 1
value = Random%360

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = Fvar(1)+(Time*.5)
scale = 1+(Time*.025),1+(Time*.025)

[State 0, ChangeAnim]
type = ChangeAnim
TriggerALL = IsHelper(001)
trigger1 = !Time
value = 7001
elem = 1
[State 0, ChangeAnim]
type = ChangeAnim
TriggerALL = IsHelper(002)||IsHelper(012)
trigger1 = !Time
value = 7002
elem = 1

[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(001)
trigger1   = !Time
value      = 3
ignorehitpause = 1
[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(002)||IsHelper(012)
trigger1   = !Time
value      = 4
ignorehitpause = 1

[State 0, PalFXWiz] ;Hitspark A1 ADD
type = PalFX
TriggerALL = IsHelper(001)
trigger1 = !Time
time = 99999
add = 0,-64,-156
mul = 512,512,512
color = 0
[State 0, PalFXWiz] ;Hitspark B1 ADD
type = PalFX
TriggerALL = IsHelper(002)
trigger1 = !Time
time = 99999
add = 0,-100,-156
mul = 512,512,512
color = 0
[State 0, PalFXWiz] ;Hitspark B1 RED
type = PalFX
TriggerALL = IsHelper(012)
trigger1 = !Time
time = 99999
add = 0,-128,-116
mul = 512,512,512
color = 0

[State 0, VarSet]
type = VarSet
trigger1 = !Time
Fv = 2
value = 0
[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(001)
trigger1 = AnimElemTime(3)>0
Fv = 2
value = 30

[State 0, Trans]
type = Trans
TriggerALL = IsHelper(001)
trigger1 = 1
trans = addalpha
alpha = 256-FVAR(2),256
[State 0, Trans]
type = Trans
TriggerALL = IsHelper(002)||IsHelper(012)
trigger1 = 1
trans = addalpha
alpha = 256,256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 200, End]
type = Destroyself
trigger1 = AnimTime = 0

;-------------------------------------------------------------------------------
; HitSparks B
[Statedef 802]
type    = A
movetype= I
physics = N
anim = Cond(!IsHelper(021),7002,7006)
;sprpriority = Cond(IsHelper(001),4,Cond(IsHelper(002),3,Cond(IsHelper(003),0,-1)))

; [GUIDELINES] ========================
; - 001: Default Hitspark |------|
; - 002: Blue Hitspark    |------|
; - 003: Yellow Hitspark  |------|     ;NARUTO
; - 011: Default Hitspark |BACKGROUND|
; - 012: Blue Hitspark    |BACKGROUND|
; - 021: Default Hitspark |SLOW|
; - 022: Blue Hitspark    |SLOW|
; =====================================

[State 0, SprPriority]
type = SprPriority
trigger1 = IsHelper(001)
trigger2 = IsHelper(002)
trigger3 = IsHelper(003)
trigger4 = IsHelper(004)
trigger5 = IsHelper(005)
trigger6 = IsHelper(006)
trigger7 = IsHelper(007)
trigger8 = IsHelper(008)
trigger9 = IsHelper(009)
trigger10= IsHelper(010)
trigger11= IsHelper(021)
trigger12= IsHelper(022)
trigger13= IsHelper(023)
trigger14= IsHelper(024)
trigger15= IsHelper(025)
trigger16= IsHelper(026)
trigger17= IsHelper(027)
trigger18= IsHelper(028)
trigger19= IsHelper(029)
trigger20= IsHelper(030)
value = 4
ignorehitpause = 1

[State 0, SprPriority]
type = SprPriority
trigger1 = IsHelper(011)
trigger2 = IsHelper(012)
trigger3 = IsHelper(013)
trigger4 = IsHelper(014)
trigger5 = IsHelper(015)
trigger6 = IsHelper(016)
trigger7 = IsHelper(017)
trigger8 = IsHelper(018)
trigger9 = IsHelper(019)
trigger10= IsHelper(020)
value = 0
ignorehitpause = 1

; Default
[State 0, PalFXWiz]
type = PalFX
TriggerALL = IsHelper(001)||IsHelper(011)||IsHelper(021)
trigger1 = Time = 0
time = 99999
add = 0,0,0
mul = 300,300,300
color = 256
;add = 0,-80,-140
;mul = 512,512,512
;color = 0

; Blue
[State 0, PalFXWiz]
type = PalFX
TriggerALL = IsHelper(002)||IsHelper(012)||IsHelper(022)
trigger1 = Time = 0
time = 99999
add = -128,-64,0
mul = 512,512,512
color = 0

; Yellow
;[State 0, PalFXWiz]
;type = PalFX
;TriggerALL = IsHelper(003)||IsHelper(013)||IsHelper(023)
;trigger1 = Time = 0
;time = 99999
;add = 0,-45,-128
;mul = 512,512,512
;color = 0

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
Fv = 1
value = random%360

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = Fvar(1)+(time*.5)
scale = 1+(Time*.025),1+(Time*.025)

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256,256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 200, End]
type = Destroyself
trigger1 = AnimTime = 0

