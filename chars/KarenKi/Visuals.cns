value = 7201
elem = 1

[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(001)||IsHelper(002)
trigger1   = !Time
value      = 3
ignorehitpause = 1

[State 0, PalFXWiz] ;Shockspark Red ADD
type = PalFX
TriggerALL = IsHelper(001)
trigger1 = !Time
time = 99999
add = 0,-150,-225
mul = 512,512,512
color = 0
[State 0, PalFXWiz] ;Shockspark Yellow ADD
type = PalFX
TriggerALL = IsHelper(002)
trigger1 = !Time
time = 99999
add = 0,-75,-225
mul = 512,512,512
color = 0

[State 0, VarSet]
type = VarSet
;TriggerALL = IsHelper(001)
trigger1 = !Time
Fv = 2
value = 0
[State 0, VarAdd]
type = VarAdd
;TriggerALL = IsHelper(001)
trigger1 = AnimElemTime(3)>0
