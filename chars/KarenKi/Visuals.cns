[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = Fvar(1)+(time*.5)
scale = 1+(Time*.05),1+(Time*.05)

[State 0, ChangeAnim]
type = ChangeAnim
TriggerALL = IsHelper(001)||IsHelper(002)
