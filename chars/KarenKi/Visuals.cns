;TriggerALL = IsHelper(001)
trigger1 = 1
trans = addalpha
alpha = 300-(Time*25),256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 200, End]
type = Destroyself
trigger1 = Time>=20

