;===========================================================================
;--------------------------Constantes Básicas-------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0
value = Cond(Pos Y >= 0,60,110)

[State 0, Bugged Helper Killer]
type = DestroySelf
trigger1 = ishelper

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 5 && Anim != 10000 && Anim != 10005)
trigger2 = (Anim = 5 || anim = 10005) && AnimTime = 0
value = 0+var(41)

[State 0, 1]
type = ChangeAnim
trigger1 = p2dist X < -5
value = 5+Var(41)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10+var(41)

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,110)

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11+var(41)
sprpriority = 0
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,110)
[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6+var(41)

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11+var(41)
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12+var(41)
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,110)
[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0
[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,110)
[State 20, 1]
type = VelSet
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && p2bodydist x > 0
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && p2bodydist x > 0
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 10020 && Anim != 10005)
trigger2 = (Anim = 5 || anim = 10005) && AnimTime = 0
value = 20+var(41)

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 10021 && Anim != 10005)
trigger2 = (Anim = 5|| anim = 10005) && AnimTime = 0
value = 21+var(41)

;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40+Var(41)
ctrl = 0
sprpriority = 1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && enemy,pos x > pos x
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && (p2movetype = A) || (enemy,numproj > 0)
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)



[State 0, VelAdd] ; FROM RUN
type = VelAdd
triggerall = prevstateno = 60||prevstateno = 70
trigger1 = animtime = 0
x = ifelse(vel x > 0,2,2)

[State 0, VelSet] ; From Uppercut
type = VelSet
triggerall = ailevel > 0
triggerall = prevstateno = 230
trigger1 = animtime = 0
x = 4
[State 0, VelSet] ; From Uppercut (KAREN)
type = VelSet
triggerall = prevstateno = 451
trigger1 = animtime = 0
x = 4

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0


[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44+Var(41)

[State 45, 2]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41+Var(41)



[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && enemy,pos x > pos x
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && enemy,pos x < pos x
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 0, VarSet]
type = VarSet
trigger1 = command != "holdup"
v = 6    
value = 1
; Air Jump
[State -1,Air Jump]
type = ChangeState
triggerall = prevstateno < 110
triggerall = var(6) = 1
triggerall = var(5) = 0
trigger1 = ailevel = 0 && command = "up"
trigger2 = ailevel > 0 && enemy,pos y < pos y
value = 80

[State 0, AngleDraw]
type = AngleDraw
Triggerall = prevstateno = 332
trigger1 = TIME = 0
value = 0

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 0, VelSet]
type = VelSet
triggerall = prevstateno = 2060||prevstateno = 11060||prevstateno = 13060
trigger1 = time = 0
x = 2

[State 0, VelSet]
type = VelSet
triggerall = prevstateno = 2070||prevstateno = 11070||prevstateno = 13070
trigger1 = time = 0
x = -2

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, ifelse(prevstateno = 40,43,44)))+Var(41)

