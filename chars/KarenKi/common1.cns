triggerall = alive
trigger1 = time= 35;AnimTime = 0
;trigger2 = SysVar(0) ;SysVar(0) = 1 avoids hit ground frame
;trigger3 = Anim = [116110,116119]
value = 5120

[State 5110, 12]
