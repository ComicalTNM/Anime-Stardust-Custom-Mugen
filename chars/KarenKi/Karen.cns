walk.back    = -4
run.fwd      = 0
run.back     = 0
jump.neu     = 0,-7 ;Prev: -6.5
jump.back    = -3.5
jump.fwd     = 3.5
airjump.neu  = 0
airjump.back = -3
airjump.fwd  = 3
runjump.back = 0
runjump.fwd  = 0

[Movement]
airjump.num = 0
airjump.height = 45
yaccel = .45          ;Default: .44
stand.friction = .80  ;Default: .85
crouch.friction = .88 ;Default: .82

[Quotes]
Victory0 = "A mere fool such as yourself has no chance against my Wondrous Tactics!"
victory1 = "Haha! What a battle! Get up and feast with me, you earn a respect!"
victory2 = "To resort to this curse..is to face my shame, To have such burden, is to be a emperor."
victory3 = "What a true pain.. countless battles i've been to, this can't stop me!"
victory4 = "Preserverance, strength and courage! Have those, and no foe will be more than a pest."
victory5 = "To be victorious thou need endurance and roaring strength! Find your inner balance!"
victory6 = "Will you be a coward, a corpse, or a victor? I'll watch upon thee."
victory7 = "These lands may be otherwordly to me, alas they stand below my feet, as thou."
victory8 = "Absolute concentration, strive for balance. To avoid failures, is to find my inner equilibrium."
victory9 = "Stop being a fool and return stronger, then thou shall be rewarded with my finest sake."

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = !Var(2)
Trigger1 = RoundState = 2
Value = Cond(((p2bodydist x=[-60,60])&&(p2bodydist x!=[-20,20]))&&(p2bodydist y=[-75,-30]),1400,Cond(P2BodyDist x > 100,Cond(Random >= 500,1300,1400),Cond(Random >= 500,1000,Cond(Random >= 800,1500,1100)))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = Var(2)
Trigger1 = RoundState = 2
Value = Cond(((p2bodydist x=[-60,60])&&(p2bodydist x!=[-20,20]))&&(p2bodydist y=[-75,-30]),1400,Cond(P2BodyDist x > 100,Cond(Random >= 500,1300,4400),Cond(Random >= 650,4500,Cond(Random >= 800,1500,1100)))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

