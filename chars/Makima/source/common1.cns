;---------------------------------------------------------------------------
; Flying in Air (Bounce Off Wall)
[StateDef 5403]
Type = A
MoveType = H
Physics = N
VelSet = 0,0
Ctrl = 0

[State 5403, ScreenBound]
Type = ScreenBound
Trigger1 = StateNO = StateNO ; 5403
Value = 1
MoveCamera = 0, 1
IgnoreHitPause = 1

[State 5403, PosAdd]
Type = PosAdd
Trigger1 = !Time
Y = Const(Size.Mid.Pos.Y) * -1
IgnoreHitPause = 1

[State 5403, VelSet]
Type = VelSet
Trigger1 = !Time
X = ((GetHitVar(XVel)  / 4)* -1) * Facing
Y = GetHitVar(YVel)
IgnoreHitPause = 1

[State 5403, VelAdd]
Type = VelAdd
Trigger1 = StateNO = StateNO ; 5403
Y =  GetHitVar(YAccel)
IgnoreHitPause = 1

[State 5403, ChangeAnim] ;Self falling animation
type = ChangeAnim
Trigger1 = !Time
Value = 5050

[State 5403, ChangeAnim] ;Coming down - normal
type = ChangeAnim
Trigger1 = Vel Y > -8
Trigger1 = Anim = 5050
Trigger1 = SelfAnimExist(5060)
Persistent = 0
Value = 5060

[State 5403, SelfState]
Type = SelfState
Trigger1 = (Vel y > 0) && (Pos y >= 0)
Value = 5100
