[state 0]
type = changestate
trigger1 = time = 200
value = cond(pos y != 0, 50, 0)
ctrl = 1

[Statedef 3001]
type    = u
movetype= a
physics = s
juggle  = 2
ctrl = 0
anim = 3010
velset = 0,0
sprpriority = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = time = 1000
ignorehitpause = 1
