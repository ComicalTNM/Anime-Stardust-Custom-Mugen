add = Var(12),Var(12),Var(12)

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = nobardisplay

[state 0]
type = velset
triggerall = (pos y = 0)
trigger1 = (time > 30) && (time < 70)
y = -.9

[state 0]
type = velset
trigger1 = time >= 70
y = 0

[State 0, VelSet]
type = VelSet
triggerall = !animelem = 1
trigger1 = time > 160
y = .9

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
value2 = S,NA
time = 1
ignorehitpause = 1

