value = 5000,ifelse(random < 500,1,ifelse(random < 500,2,3))

[State 0, Solucion Stand Aire]
type = ChangeState
triggerall = stateno = 0||stateno = 20
trigger1 = pos y < 0
value = 50
ctrl = 1

[State 0, StopSnd]
type = StopSnd
trigger1 = prevstateno = 500 
channel = 1
[State 0, StopSnd]
type = StopSnd
trigger1 = prevstateno = 500 
channel = 2

