[State 0, AfterImage]
type = Null
trigger1 = numhelper(10004) = 0
time = 900
length = 9
palcolor = 256
palbright = 1,500,1
palcontrast = 1,500,1
paladd = 1,500,1
palmul = .4,5,.9
