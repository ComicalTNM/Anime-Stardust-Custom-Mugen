;===============================================================================
;-----------------------KURAMA SUSANOO------------------------------------------
;-------------------------------------------------------------------------------
; Stance
[Statedef 40000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 33000
sprpriority = -1
 
[State 0, VarSet]
type = VarSet
trigger1 = time = 0
fv = 5
value = 0

[State 0, VarAdd]
type = VarAdd
trigger1 = animelemtime(1) = [0,30]
fv = 5
value = .001

[State 0, VarAdd]
type = VarAdd
trigger1 = animelemtime(1) = [31,60]
fv = 5
value = -.001

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 0
scale = 1-(fvar(5)/4),1+(fvar(5)/2)

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, Walk FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 50
value = 40020

[State 0, Walk BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && random < (ailevel * 100)/6
trigger2 = p2bodydist x < 50 && p2movetype = H
value = 40021

[State 0, Jump]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdup"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x < 100 && p2movetype = A
value = 40040

[State 0, Angry Roar Raiton]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "x"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x = [100,200]
value = 40650

[State 0, Rasen Shuriken Amaterasu]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "y"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x = [150,350]
value = 40700

[State 0, Renzoku Bijuudama Amaterasu]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "c" && command = "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [150,300]
value = 40800

[State 0, Cataclism]
type = ChangeState
triggerall = power >= 2000
trigger1 = ailevel = 0 && command = "b" && command = "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [150,300]
value = 40850

[State 0, Enton Rasen Shuriken Bijuudama]
type = ChangeState
triggerall = power >= 3000
trigger1 = ailevel = 0 && command = "z"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [150,300]
value = 40900

[State 0, A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x < 60
trigger2 = p2bodydist y >= -50
value = 40200

[State 0, B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x < 60
trigger2 = p2bodydist y >= -50
value = 40300

[State 0, C]
type = ChangeState
trigger1 = ailevel = 0 && command = "c" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x = [80,150]
trigger2 = p2bodydist y >= -50
value = 40400

[State 0, Fin]
type = ChangeState
trigger1 = ailevel = 0 && command = "holddown" && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)/50
value = 40002

[State 0, Power Charge]
type = ChangeState
Triggerall = power < 3000
trigger1 = ailevel = 0 && command = "s" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 100
value = 40500

[State 200, End]
type = ChangeState
trigger1 = numhelper(40100) = 0 || roundstate != 2
value = 40002
