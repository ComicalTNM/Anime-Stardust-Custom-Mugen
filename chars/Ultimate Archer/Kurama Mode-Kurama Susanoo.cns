; Stance
[Statedef 33000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 32056
sprpriority = 0

[State 0, Kurama ADD]
type = Helper
trigger1 = !time
helpertype = normal
name = "Kurama ADD"
ID = 330000
stateno = 330000
pos = 0,0
facing = 1
postype = p1
ownpal = 1
size.xscale = .8 
size.yscale = .8 
ignorehitpause = 1

[State 0, Kurama SUB]
type = Helper
trigger1 = !time
helpertype = normal
name = "Kurama SUB"
ID = 330005
stateno = 330005
pos = 0,0
facing = 1
postype = p1
ownpal = 1
size.xscale = .8 
size.yscale = .8 
ignorehitpause = 1

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, Walk FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 250
value = 33020

[State 0, Walk BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && random < (ailevel * 100)/6
trigger2 = p2bodydist x < 60 && p2movetype = H
value = 33021

[State 0, Jump]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdup"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x < 100 && p2movetype = A
value = 33040

[State 0, Cho Oodama Rasengan]
type = ChangeState
triggerall = power >= 2000
trigger1 = ailevel = 0 && command = "c" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x = [40,100]
trigger2 = p2bodydist y < -50
value = 33600

[State 0, Angry Roar]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "x"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 50
value = 33700

[State 0, Renzoku Bijuudama]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "b" && command = "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x = [75,150]
value = 34000

[State 0, Bijuudama]
type = ChangeState
triggerall = power >= 2500
trigger1 = ailevel = 0 && command = "z"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [100,300]
value = 34100

[State 0, Susanoo Kurama]
type = ChangeState
triggerall = power >= 3000
trigger1 = ailevel = 0 && command = "SPECIAL 19"
trigger2 = ailevel > 0 && random < (ailevel * 100) 
trigger2 = p2bodydist x = [100,300]
value = 40001

[State 0, A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x < 50
trigger2 = p2bodydist y > -200
value = 33300

[State 0, Fin]
type = ChangeState
trigger1 = command = "holddown" && command = "s"
Triggerall = statetype !=A
trigger1 = ctrl
value = 33002

[State 0, B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 100
trigger2 = p2bodydist y > -75
value = 33400

[State 0, Power Charge]
type = ChangeState
Triggerall = power < powermax
trigger1 = ailevel = 0 && command = "s" && command != "holddown"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 100
value = 33500

[State 0, Timer]
type = Helper
triggerall = numhelper(84034) = 0
trigger1 = Time = 0
helpertype = Normal
name = "Timer"
ID = 84034
stateno = 84034
pos = 999,999
postype = p1
facing = 1
keyctrl = 0
ownpal = 1

[State 200, End]
type = ChangeState
trigger1 = numhelper(33100) = 0 
value = 33002
