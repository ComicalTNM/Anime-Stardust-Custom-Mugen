ignorehitpause = 1

[State 0]
Type = Helper
Trigger1 = !IsHelper(1703)
Trigger1 = NumHelper(1703) >= 1
Trigger1 = GameTime%6 = 0 
ID = 1704
StateNO = 1704 
OwnPal = 1
IgnoreHitPause = 1

;===============================================================
;-------------------        Config      ------------------------
;===============================================================
[State 0, HUD]
type = Helper
triggerall = stateno != [180,182]
triggerall = stateno != 170
triggerall = roundstate = 2
Triggerall = Var(40)
triggerall = !numhelper(400000) 
trigger1 = alive
helpertype = normal ;player
name = "HUD"
ID = 400000
stateno = 400000
pos = -99999,-99999
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 1
ownpal = 0
supermovetime = 0
pausemovetime = 0

[State 0, ASSIST ACTIVATION]
type = VarSet
trigger1 = 1
v = 6    
value = 3;1
;!!!!!!!!!!
; set this value to 0 if you want to deactivate assists 
; 1 for XMEN Characters
; 2 for Spider-Man 616
; 3 for all of above 
; 4 for cycle
;!!!!!!!!!!

[State 0, HUD POSITION]
type = VarSet
trigger1 = 1 ;goto state bud
v = 27    
value = 40 ;edit this <-- !!!   DEFAULT 40

