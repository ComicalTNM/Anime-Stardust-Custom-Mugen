airjump.height = 40
yaccel = .42
stand.friction = .8
crouch.friction = .8


[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 1200 ; STATENO: normal assist attack
StateTagAssistHyper = 1500 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

;Default language victory quotes **MUGEN 1.0**
;The default language victory quotes must be implemented in English.
[Quotes]
; Up to 100 victory quotes can be specified per language (victory0 - victory99)
victory1= "Brilliant people shine more brightly than ordinary ones. They never regret or agonize over what they’ve done."
victory2= "I killed many people to act on my ideal. I killed so many that I stopped caring about innocent people and I saved a thousand times as many as I killed."
victory3= "Is it really worth saving this sad and ugly world, when there is nothing left after it is saved? With all this death, cruelty and sadness, do you still want to become a hero?"
victory4= "The wish of wanting everyone to be happy is merely a fairy tale!"
victory5= "Atone for my sins? … I have no sins to atone for, nor have I forced such a meaningless concept on anyone"
