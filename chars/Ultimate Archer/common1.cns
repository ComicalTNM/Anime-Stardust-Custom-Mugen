;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, PosSet]
type = PosSet
trigger1 = pos y != 0
y = 0
ignorehitpause = 1

[State 0, 1]
Type = ChangeAnim
Trigger1 = Anim !=  0   && Anim != 5 
Trigger2 = Anim = 5  && AnimTime = 0
Value = 0

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper


[State 0, PlaySnd]
type = PlaySnd
trigger1 = time=0
value = S10,0

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem=4 || animelem=9
value = S20,0+random%2

[State 20, 1]
triggerall =1
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x);+cond(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
triggerall = 1
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x);-cond(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
Trigger1 = Anim != 20  && Anim != 5 
Trigger2 = Anim = 5  && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
Trigger1 = Anim != 21  && Anim != 5 
Trigger2 = Anim = 5  && AnimTime = 0
value = 21
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time=0
value = S40,0

[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 = time = 0 
anim = 8030
pos =-1,0
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
bindtime = 1
removetime = -2
scale = .4,.4
sprpriority =3
ownpal = 1
removeongethit = 1

[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 =time = 0&&(command != "holdfwd"&&command != "holdback")
anim = 8020
pos = -1,-4
postype = p1
facing = -1 ;P2, Front, Back, Left, Right
removetime = -2
scale = .5,.6
sprpriority = -3
remappal = 690,0
ownpal = 1
removeongethit = 1

[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 =time = 0&&command = "holdfwd"
anim = 8021
pos = -1,-1
postype = p1
facing = 1 ;P2, Front, Back, Left, Right
removetime = -2
scale = .5,.6
sprpriority = -3
remappal = 690,0
ownpal = 1
removeongethit = 1
[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 =time = 0&&command = "holdback"
anim = 8021
pos = -1,-1
postype = p1
facing = -1 ;P2, Front, Back, Left, Right
removetime = -2
scale = .5,.6
sprpriority =-3
remappal = 690,0
ownpal = 1
removeongethit = 1

[State 40, 1]
type = varset
trigger1 = !time;!ailevel
;trigger2 = ailevel && numenemy&&roundstate = 2
sysvar(1) = 0

[State 40, 2]
type = varset
trigger1 = !ailevel
trigger1 = Command = "holdfwd" 
sysvar(1) = 1

[State 40, 2]
type = varset
triggerall =  (ailevel )&& (roundstate = 2) && (numenemy) ;&&random<((700)*(ailevel**2/64.0)) 
trigger1 = prevstateno=100 &&  p2dist  x <170
trigger2 = prevstateno=250
sysvar(1) = 1

[State 40, 3]
type = varset
;trigger1 = !AiLevel
trigger1 = Command = "holdback"
;trigger2 = AiLevel && NumEnemy&&RoundState = 2&&random<((700)*(ailevel**2/64.0)) 
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 45, air jump - finish]
type = VarSet
trigger1 = !Time
var(31) = 3

[State 0, Turn]
type = Turn
trigger1 = p2dist x <-10

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S5,10
persistent = 0
[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S5,11
volumescale = 20
persistent = 0

[State 0, PalFX]
type = PalFX
triggerall =  (helper(9010),var(1)>10)
trigger1 =1
time = 1
add = (helper(9010),var(1))  ,  (helper(9010),var(1))  , (helper(9010),var(1))  
mul = 0+var(12),0+var(13),0+var(14)
color = 256

[State 45, 1]
type = ChangeAnim
trigger1 = time=2
value = cond(sysvar(1) = -1,52,cond(sysvar(1) = 1,51,50))

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = cond(sysvar(1)=0, const(velocity.airjump.neu.x), cond(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 = time=2
anim = 7011
ID = 7010
pos = cond(sysvar(1) = -1,5,cond(sysvar(1) = 1,-5,0)) , cond(sysvar(1) = -1,-10,cond(sysvar(1) = 1,-10,-10))
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
scale = .2,.2
vel = cond(sysvar(1) = -1,1,cond(sysvar(1) = 1,-1,0)) , cond(sysvar(1) = -1,.5,cond(sysvar(1) = 1,.5,.7))
accel = cond(sysvar(1) = -1,.01,cond(sysvar(1) = 1,-.01,0)) , cond(sysvar(1) = -1,.005,cond(sysvar(1) = 1,.005,.007))
sprpriority = 3
angle = cond(sysvar(1) = -1,135,cond(sysvar(1) = 1,45,90))
remappal = 700,0
ownpal = 1
removeongethit = 1
[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
trigger1 = time=2
anim = 7011
ID = 7010
pos = cond(sysvar(1) = -1,0,cond(sysvar(1) = 1,0,0)) , cond(sysvar(1) = -1,-20,cond(sysvar(1) = 1,-20,-20))
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
scale = .12,.12
vel = cond(sysvar(1) = -1,1,cond(sysvar(1) = 1,-1,0)) , cond(sysvar(1) = -1,.5,cond(sysvar(1) = 1,.5,.7))
accel = cond(sysvar(1) = -1,.01,cond(sysvar(1) = 1,-.01,0)) , cond(sysvar(1) = -1,.005,cond(sysvar(1) = 1,.005,.007))
sprpriority = 3
angle = cond(sysvar(1) = -1,135,cond(sysvar(1) = 1,45,90))
remappal = 700,0
ownpal = 1
removeongethit = 1

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, PalFX]
type = PalFX
triggerall =  (helper(9010),var(1)>10)
trigger1 = prevstateno=45
time = 1
add = (helper(9010),var(1))  ,  (helper(9010),var(1))  , (helper(9010),var(1))  
mul =  0+var(12),0+var(13),0+var(14)
color = 256

;[State 0, VelSet]
;type = Veladd
;triggerall = time>=1&&(vel x=2 || vel x =-2)
;trigger1 = ailevel=0&& ( command != "fwd" && command != "back")
;x = cond(vel x>0,-.1,.1) 
;ignorehitpause = 1

[State 0, VelSet]
type = VelSet
triggerall = vel x =0&&time>=1
trigger1 =ailevel=0&&  command = "fwd"
trigger2 = ailevel>0&& (p2bodydist x = [0,80])
x = 2

[State 0, VelSet]
type = VelSet
triggerall = vel x =0&&time>=1
trigger1 =ailevel=0&& command = "back"
trigger2 = ailevel>0&& (p2bodydist x = [0,80])&&enemy,statetype=A
x = -2

[State 0, Explod]
type = Explod
supermovetime = 99999999
pausemovetime = 99999999
triggerall = prevstateno =[0,59]
trigger1 = time = 0
anim = 7530
ID = 7530
pos = cond(command ="holdfwd",-10,cond(command ="holdback",10,0)),-15
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
vfacing = 1
bindtime = 9999
vel = 0,1
removetime = -2
scale = .4,.2
angle = cond(command ="holdfwd",-40,cond(command ="holdback",40,0))
sprpriority = -2
trans = sub
ownpal = 1
removeongethit = 1

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0 &&prevstateno!=45&&prevstateno!=80
value = cond((vel x)=0, 41, cond((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > -2&&prevstateno!=45
persistent = 0
value = 44
