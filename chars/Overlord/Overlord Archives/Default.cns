StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Random >= 500,Cond(Random >= 500,1500,Cond(Random >= 500,1850,Cond(Random >= 500,1900,Cond(Random >= 500,1950,1300)))),Cond(Random >= 700,1400,Cond(Random >= 500,1800,Cond(Random >= 500,1600,Cond(Random >= 500,Cond(Random >= 500,1950,1700),1000)))))
Ctrl = 0

