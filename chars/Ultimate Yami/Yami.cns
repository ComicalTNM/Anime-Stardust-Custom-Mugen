pausetime = 0,10
p1stateno = 1906
numhits = 0

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 10

[State 0, ChangeState]
type = ChangeState
trigger1 = p2bodydist x <5
value = 1903
ctrl = 0
ignorehitpause = 1




[State 0, ChangeState]
type = ChangeState
trigger1 = ailevel = 0
;trigger1 = command != "hold_y"
trigger1 = command = "holddownback" || command = "holdback" || command = "holdupback"
trigger1 = !(command = "holdfwd" || command = "holddownfwd" || command = "holdupfwd")
trigger2 = ailevel > 0
trigger2 = p2bodydist x > 100
trigger2 = backedgedist >= 100
trigger2 = power < powermax*0.5
trigger2 = random < 200
trigger3 = ailevel > 0
trigger3 = p2movetype = H
trigger3 = p2bodydist x = [50,100]
trigger3 = power < 1500
trigger3 = random < 500
value = 1905

[State 0, ChangeState]
type = ChangeState
trigger1 = ailevel = 0
;trigger1 = command != "hold_y"
trigger1 = command = "holdfwd" || command = "holddownfwd" || command = "holdupfwd"
trigger1 = !(command = "holddownback" || command = "holdback" || command = "holdupback")
trigger2 = ailevel > 0
trigger2 = p2bodydist x > 300 || abs(p2bodydist y) < 50
trigger2 = random < (50+time)
value = ifelse(ailevel > 0 && p2movetype = H, 1903, 1904);1904

[State 0, ChangeState]
type = ChangeState
trigger1 = ailevel = 0
trigger1 = command != "hold_y"
trigger1 = !(command = "holdfwd" || command = "holddownfwd" || command = "holddownback" || command = "holdback" || command = "holdupback" || command = "holdup" || command = "holdupfwd")
trigger2 = ailevel > 0
trigger2 = p2bodydist x > 200 || abs(p2bodydist y) > 50
trigger3 = ailevel > 0
trigger3 = p2bodydist x > 100 || abs(p2bodydist y) > 20
trigger3 = random < (100 + time)
trigger4 = pos y = 0 && time > 90
trigger5 = pos y < 0
value = 1903
