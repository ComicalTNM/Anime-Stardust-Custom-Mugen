;===================================================================================
;---------------- Constantes y Ataques normales--------------------------------------------
;===================================================================================

;Var List:

; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(10) = Apariencia Transformaciones
; - Var(11) = Golpeado Transformaciones
; - Var(12) = Oscurecer Pantalla
; - Var(14) = Specials Transformaciones
; - Var(15) = Supers Transformaciones
; - FVar(16) = ESCALA

[Data]
life = 2100
power = 3000
attack = 180
defence = 150
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 3
walk.back = -3
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

[Quotes]
victory1 = "I See Shit Other Niggas Can't"

;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Random >= 500,Cond(Random >= 500,1800,1200),Cond(Random >= 500,Cond(Random >= 500,1700,Cond(Var(48) && Random >= 500,1447,1300)),1000)) ;Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),Cond(Random >= 500,1300,Cond(Random >= 750,1540,1501)),Cond(P2BodyDist x >= 60,1400,Cond(Random >= 500,1280,1000))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

;-----------------------------------------------------------
; Assists Changer 2
;-----------------------------------------------------------
[StateDef 34366] ; Just To Make Sure 2 Cannons Are Placed In Mode
Type = S
MoveType = I
Physics = S
VelSet = 0,0
Anim = 11

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno-1
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Random >= 500,Cond(Random >= 750 && Power >= 2000,Cond(Random >= 750 && Power >= 3000,1000,Cond(Var(48) && Random >= 500,1447,1400)),Cond(Random >= 500,1800,1200)),Cond(Random >= 500,Cond(Random >= 500,1700,1300),1000));Cond((p2bodydist x >= -60)&&(p2bodydist y=[-75,-30]),1400,Cond(Random >= 500,3000,1200)); Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0


