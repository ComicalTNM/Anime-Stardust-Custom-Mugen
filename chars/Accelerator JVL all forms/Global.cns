Anim = 11020
ID = 11020
Pos = 0,0
Space =Screen
Facing = 1
RemoveTime = -1
PauseMoveTime = 99999
Scale = ScreenWidth,ScreenHeight
SprPriority = Const(Size.Ground.Front)
OnTop = Const(Size.Air.Back)
