;---------------------------------------------------------------------------
;AfterImage Palette Selector
[Statedef 550]
type = A
movetype = I
physics = N
ctrl = 0

[State 0,PalFXWiz]
type=PalFX
trigger1=1
Time=99999
add=0,0,0
mul=512,512,512
color=256

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = parent,anim
elem = parent,animelemno(0)

[State 0, SprPriority]
type = SprPriority
trigger1 = 1
value = 7
ignorehitpause = 1

[State 0, AngleDraw]
type = null
trigger1 = 1
scale = const(size.xscale)+(time)*.003,const(size.yscale)+(time)*.003
value = 0

[State 0,Trans]
type=Trans
trigger1=1
trans=addalpha
alpha=125-(Time*10),125+(Time*10)

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 0,0

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0, AssertSpecial]
type = AssertSpecial
Trigger1 = 1
flag = noshadow

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 9999999999999

[State 0, DestroySelf]
type = DestroySelf
trigger1 = time = 20
