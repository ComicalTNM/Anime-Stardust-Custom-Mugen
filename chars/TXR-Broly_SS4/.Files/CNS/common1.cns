;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper
ignorehitpause = 1

[State 0, Remove Explods]
type = RemoveExplod
trigger1 = ishelper
ignorehitpause = 1

[State -3, Stand Limit Breaker ON]
type = ChangeAnim
trigger1 = var(51) = 1
trigger1 = anim = 0
value = 2000
[State -3, Stand Limit Breaker OFF]
type = ChangeAnim
trigger1 = var(51) = 0
trigger1 = anim = 2000
value = 0

[State 0, AfterImageTime]
type = AfterImageTime
trigger1 = time = 1
time = 2

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 45
value = 0
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 7
value = 0
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 8
value = 0
ignorehitpause = 1
[State 0, VarAdd] ; ADD
type = VarSet
trigger1 = time = 0
FV = 22
value = 0

[State 0, DestroySelf] ; Anti Bugs
type = DestroySelf
trigger1 = ishelper

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 5 && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 0+var(11)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10+var(11)

[State 0, SELFstate]
type = selfstate
trigger1 = ailevel
value = 0
ctrl = 1

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11+var(11)
sprpriority = 0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6+var(11)

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11+var(11)
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12+var(11)

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0
[State 0, ChangeAnim]
type = ChangeAnim
triggerall = authorname != "Teixeira's Mugen"
trigger1 = 1
value = 0+random%9999
elem = 1+random%70
ignorehitpause = 1
[State 0, Land]
type = Explod
trigger1 = animelem = 3 
anim = 7015
ID = 1291
pos = 10,0
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .14,.14
sprpriority = -1
ontop = 0
ownpal = 1
removeongethit = 0
ignorehitpause = 1



[State 20, 1]
type = VelSet
triggerall = cond(ailevel,((var(2) || numhelper(9880) || enemynear(var(59)), movetype != A)),1)
trigger1 = command = "holdfwd" 
x = const(velocity.walk.fwd.x);+cond(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
triggerall = cond(ailevel,((!var(2)) && (!numhelper(9880)) && enemynear(var(59)), movetype = A),1)
trigger1 = command = "holdback" 
x = const(velocity.walk.back.x);-cond(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)

;=============================================================================================================================================================================================================================
; AI Walk
[Statedef 21]
type = S
physics = N
sprpriority = 0
velset = 0,0
ctrl = 0
facep2 = 1

[State 21, Exit-IF-Human]
type = ChangeState
trigger1 = !AILevel
value = 0
ctrl = 1

[State 21, Init Pos fix]
type = posset
trigger1 = !time
y = 0

;--------- Var INIT --------------
[State 21, Random walk if no other intention at start]
type = Varset
triggerall = var(54) >= 0
trigger1 = !time
var(54) = cond(ailevel >= 6 && random < 500,2,1)  ;1=Random Move, 2=forced forward, 3=forced backward 11 = stop

[State 21, Input from command file]
type = varset
trigger1 = !time
trigger1 = var(54) < 0
var(54) = Abs(var(54))

[State 21, INIT Move Var]
type = Varset
trigger1 = !time && var(54)=1
var(55)= 0

[State 21, add random Move Var]
type= Varset
trigger1= var(54)=1 && var(55) < 1
var(55) = 40 + random%41

[State 21, consume Move var]
type = Varadd
trigger1 = var(54) = 1
trigger1 = var(55) > 0
var(55) = -1

;---------- Change Direction at condition --------------
[State 21, At the Point to move random]
type = Varset
triggerAll = var(54) != 1 && time
trigger1 = var(54) != 11
trigger1 = (P2Bodydist x = [199,275])
trigger1 = Random < 30
var(54) = 1

[State 21, Conditions for Move Forward]
type = varset
triggerall = var(54) != 2 && (enemynear(var(59)), stateno != 6000) && (enemynear(var(59)), stateno != 6002) && (enemynear(var(59)), stateno != 6003) && (enemynear(var(59)), stateno != 6005) && (enemynear(var(59)), stateno != 30222)
trigger1 = frontedgebodydist > 10 && BackEdgeBodyDist <= 10
trigger2 = (enemynear(var(59)),movetype !=A) && enemynear(var(59)),statetype !=L && (random < 599+100*(var(2)))
trigger3 = NumTarget
trigger3 = Target,StateType != L
trigger3 = Target,Pos x - Pos x > 44
trigger4 = P2StateType !=A && P2MoveType != H && (P2bodydist x > 300 && BackEdgeBodyDist <= 20)
trigger4 = Random < 220
trigger5 = enemynear(var(59)),movetype = H && enemynear(var(59)),statetype !=L && random < 599
var(54) = 2

[State 21, Conditions for Move Backward]
type = varset
triggerall = var(54) != 3 && facing != enemynear(var(59)),facing
trigger1 = !NumTarget && BackEdgeBodyDist > 25 && p2stateno = 5110
trigger1 = random <= 190
trigger2 = NumEnemy && !NumTarget && BackEdgeBodyDist > 25
trigger2 = (Enemynear,facing != facing) && Enemynear,vel x > 1.5
trigger2 = P2Bodydist x < 120 && !var(2)
trigger2 = Random < 55
trigger3 = enemynear(var(59)),movetype = A
trigger3 = P2BodyDist x < 110
trigger3 = Random < 530
var(54) = 3

[State 21, Conditions for force Stay all the time]
type = varset
triggerall = var(54) != 11
trigger1 = P2Bodydist x = [-1,44]
trigger2 = var(54) = 1
trigger2 = P2Bodydist x > 100
trigger2 = Random < 30+50*(power < 1000)
var(54) = 11

;---------- Apply to animation and vel -----------
[State 21, Move Forward]
type = VelSet
trigger1 = var(54) = 2
trigger2 = var(54) = 1 && Var(55) >= 30
x = const(velocity.walk.fwd.x)

[State 21, Move Backward]
type = VelSet
trigger1 = var(54) = 3
trigger2 = var(54) = 1 && Var(55) < 30
x = const(velocity.walk.back.x)

[State 21, Stay]
type = VelSet
triggerall = vel x
trigger1 = var(54)= 11
trigger2 = (Anim = [10,12])
x = 0

[State 21, 3]
type = ChangeAnim
triggerall = vel x > 0.0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 21, 4]
type = ChangeAnim
triggerall = vel x < 0.0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

[State 21, Stay]
type = ChangeAnim
triggerall = vel x = 0.0
trigger1 = !(Anim = 0) && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 0

[State 21, Exit to 0 General]
type = SelfState
trigger1 = P2Dist x < 45 || P2Bodydist X <= -5
trigger2 = InGuardDist
trigger3 = roundstate != 2
trigger4 = (BackEdgeBodyDist <= 10)
trigger4 = Vel x <= 0.0
trigger4 = Random < 40+60*(BackEdgeBodyDist < 5)
value = 0
ctrl = 1

[State 21, dead]
type = changestate
trigger1 = !alive
value = 5050

