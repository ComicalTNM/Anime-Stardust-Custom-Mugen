trigger3 = facing = enemynear(var(59)),facing && inguarddist
trigger4 = (enemynear(var(59)), stateno = 6000) || (enemynear(var(59)), stateno = 6002) || (enemynear(var(59)), stateno = 6003) || (enemynear(var(59)), stateno = 6005)
value = 0
ctrl = 1

[state 40,asd]
type = changeanim
trigger1 = time = 0
value = 40+var(11)

