;===============================================================================
; ASSIST SYSTEM:
;-------------------------------------------------------------------------------
[Statedef 4002]
type    = A
movetype= I
physics = N
anim = 9999
ctrl = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = 0
ignorehitpause = 1

;---------------------------------- Var System

[State 0, Game Start]
type = VarSet
trigger1 = !time 
v = 55
value = cond(roundno = 1,100,20)
ignorehitpause = 1
[State 0, Reversal Limit Reset]
type = VarSet
trigger1 = !time 
v = 56
value = 2
ignorehitpause = 1
persistent = 0
[State 0, Reversal ON]
type = VarSet
trigger1 = root,movetype = H 
v = 57
value = 1
ignorehitpause = 0
[State 0, Reversal OFF]
type = VarSet
trigger1 = root,movetype != H 
v = 57
value = 0
ignorehitpause = 0

[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
triggerall = !numhelper(4100) 
triggerall = time
triggerall = timemod = 1,0;3,0
trigger1 = var(55) = [0,255]
v = 55   
value = Cond(Root,Var(3),2,1)

[State 0, Summon PLAYER Normal]
type = VarSet
triggerall = root,pos y > -200;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = command = "y"
v = 55   
value = -1
ignorehitpause = 1
[State 0, Summon PLAYER Reversal]
type = VarSet
triggerall = numexplod(4020) 
triggerall = var(56) > 0
triggerall = enemynear,hitdefattr != sca,ha,hp,ht,st,nt,np,sp
triggerall = enemynear,hitdefattr = sca,na,sa
triggerall = enemynear,stateno != [3000,4000]
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,statetype != L
triggerall = root,movetype = H ;|| root,stateno = [120,155]
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
triggerall = root,p2bodydist x = [0,80]
trigger1 = command = "y"
v = 55   
value = -1
ignorehitpause = 1

;IA
[State 0, Summon IA Reversal]
type = VarSet
triggerall = numexplod(4020) 
triggerall = var(56) > 0
triggerall = enemynear,hitdefattr != sca,ha,hp,ht,st,nt,sp,np
triggerall = enemynear,hitdefattr = sca,na,sa
triggerall = enemynear,stateno != [3000,4000]
triggerall = gametime > 500
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,statetype != L
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
triggerall = root,p2bodydist x = [-90,80]
trigger1 = random < (root,ailevel * root,gethitvar(hitcount))/15
trigger1= enemynear,pos y>= -const(size.height)
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA SpiderMan616 Normal]
type = VarSet
triggerall = var(58) = 1
triggerall = root,pos y > -80;root,statetype != A
triggerall = root,var(19) = 0
triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
trigger1= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(18-cond((root,stateno = 1000&&root,movehit),9,0))
trigger1= root,p2bodydist x = [-45,45]
trigger1= enemynear,pos y>= -const(size.height)
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA Deadpool Normal]
