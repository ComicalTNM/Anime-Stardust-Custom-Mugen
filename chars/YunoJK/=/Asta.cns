triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
triggerall= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(18-cond((root,stateno = 1001),9,0))
triggerall= root,p2bodydist x = [-100,185]
triggerall= enemynear,pos y>= -const(size.height)
