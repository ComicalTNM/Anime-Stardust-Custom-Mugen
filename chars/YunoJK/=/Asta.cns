triggerall = root,var(19) = 0
triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
trigger1= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(14-cond((root,stateno = 1000&&root,movehit),9,0))
trigger1= root,p2bodydist x = [-55,55]
trigger1= enemynear,pos y>= -const(size.height)
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA Cyclops Normal]
