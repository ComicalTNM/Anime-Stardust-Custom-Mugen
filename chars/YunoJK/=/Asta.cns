triggerall= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(18-cond((root,stateno = 1101&&root,movehit),9,0))
triggerall= root,p2bodydist x = [-175,175]
triggerall= enemynear,pos y>= -const(size.height)
