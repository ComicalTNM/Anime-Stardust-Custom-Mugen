value = Cond(Random >= 500,Cond(Random >= 500,Cond(Random >= 500 && (P2BodyDist x = [-60,60]),81470,81350),Cond(Random >= 500,Cond(Pos Y >= 0 && Random >= 750,81440,Cond(Random >= 500,Cond(Random >= 750,81360,Cond(Random >= 500,81370,81480)),Cond(Random >= 500,81340,Cond(Random >= 500,81370,81460)))),81450)),Cond(Random >= 500,42310,Cond(Random >= 500,Cond(Pos Y >= 0 && Random >= 750,81440,Cond(Random >= 500,Cond(Random >= 750,81360,Cond(Random >= 500,81370,81480)),Cond(Random >= 500,81340,Cond(Random >= 500,81370,81460)))),81380)))
