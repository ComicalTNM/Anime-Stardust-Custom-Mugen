;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = !Var(2) && !Var(45); Triggers If Mode ISN'T Active (You can Replace It With A Var If You Want Iso); Triggers If Mode ISN'T Active (You can Replace It With A Var If You Want Iso)
Value = Cond(Random >= 500,Cond(Random >= 500,1000,Cond(Random >= 500,1600,1100)),Cond(Random >= 500,1300,Cond(Random >= 500,1500,1400)))
