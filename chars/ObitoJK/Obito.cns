; COMMON

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 0, Pos]
type = PosAdd
trigger1 = 1
x = rootdist x - 3
y = rootdist y - 55

; INVISIBILIDAD:

[State 0, AssertSpecial]
