;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = !Var(6) ; Triggers If Mode ISN'T Active (You can Replace It With A Var If You Want Iso)
Value = Cond(((p2bodydist x=[-60,60])&&(p2bodydist x!=[-20,20]))&&(p2bodydist y=[-75,-30]),1200,Cond(Random >= 500,1000,1500)) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(6) ; Triggers If Mode Is Active (You can Replace It With A Var If You Want Iso)
Value = Cond(((p2bodydist x=[-60,60])&&(p2bodydist x!=[-20,20]))&&(p2bodydist y=[-75,-30]),301200,Cond(Random >= 500,301500,301000)) ; Change This To Whatever Assist You Want (After Mode)
Ctrl = 0

