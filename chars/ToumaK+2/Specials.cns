type = VelSet
triggerall = var(42) = 2 || var(42) = 20 || var(42) = 21
triggerall = fvar(20) = 1
trigger1 = var(5) = 0
trigger1 = var(6) = 1
x = (((enemyNear(enemyNear,ishelper),pos x - pos x) * facing) + var(15)) / var(11)
y = (((enemyNear(enemyNear,ishelper),pos y - pos y) * facing) + var(16)) / var(11)
ignorehitpause = 1

[State CZZL, VelSet] ;镜头固定到人物的身上
type = VelSet
trigger1 = var(5) = 1
trigger1 = var(6) = 1
x = 0
y = 0
ignorehitpause = 1

[State CZZL, VelSet] ;镜头移动回屏幕中间
type = VelSet
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = 1
x = -facing * pos x / (var(12)*1.0)
y = -(pos y - camerapos y) / (var(12)*1.0)
ignorehitpause = 1


;-[计算每帧zoom多少]-----------------------------------------
[State CZZL, VarSet];镜头移动到人物时
type = VarSet
trigger1 = var(5) = 0
trigger1 = var(6) = [0,var(11)]
fv = 22    
value = 1 + var(6) * ((fvar(21)+fvar(20))/((var(11)*(fvar(17)*0.001))))
ignorehitpause = 1

[State CZZL, VarSet];存储fvar(22)的值(用于镜头返回)
type = VarSet
triggerall = fvar(23) != fvar(22)
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = 1
fv = 23   
value = fvar(22)
ignorehitpause = 1

[State CZZL, VarSet];镜头回到屏幕中间时
type = VarSet
trigger1 = var(5) = 3 || var(5) = -1
trigger1 = var(6) = [1,var(12)]
fv = 22   
value = fvar(23) - ((fvar(23)-1)/(var(12)*1.0))*var(6)
ignorehitpause = 1

;-[镜头使用]-----------------------------------------
[State CZZL, VarSet]
type = zoom
triggerall = fvar(22)
trigger1 = time >= 0
scale = fvar(22)
pos = ((pos x)/fvar(22))*camerazoom,(((pos y)-(camerapos y / fvar(22)))*camerazoom)*.1
ignorehitpause = 1

