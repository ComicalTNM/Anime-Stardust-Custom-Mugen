trigger1 = 1
value = 0
movecamera = 1,1
ignorehitpause = 1

;-[检测当前zoom值]-----------------------------------------

[State CZZL, VarSet]
type = VarSet
triggerall = var(13)
trigger1 = !time
trigger1 = camerazoom > 0 && camerazoom < 1
fv = 21
value = (1 / camerazoom) - 1
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
triggerall = var(13)
trigger1 = !time
trigger1 = camerazoom >= 1
fv = 21
value = 0
ignorehitpause = 1

