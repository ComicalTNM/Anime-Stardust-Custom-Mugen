; Gradient Background
[Statedef 8200]
type     = U
movetype = I
physics  = N
juggle   = 0
ctrl     = 0
anim     = 9999
sprpriority = 1

[state CZZL, ]
type = AssertSpecial
trigger1 = 1
flag = noshadow
flag2 = invisible

;-[参数设置]-------------------------------------------------------------
[State CZZL, VarSet] 
type = VarSet ;淡入时间
trigger1 = !time 
v = 11    
value = const(size.head.pos.x)
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet ;淡出时间
trigger1 = !time 
v = 12    
value = const(size.head.pos.y)
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet ;持续时间
trigger1 = !time 
v = 13    
value = const(size.shadowoffset)
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet ;底图 0 白，1黑，2红
trigger1 = !time 
v = 14    
value = const(size.height)
ignorehitpause = 1

;-[特效]--------------------------------------------------------------
[state CZZL,Explod]
type = Explod
trigger1 = time = 0
anim = 10060 + var(14)
id = 10060
postype = back
pos = 0,0
bindtime = 1
removetime = -1
sprpriority = -99
under = 1
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
ontop = 0
scale = 2 / CameraZoom,2 / CameraZoom
pausemovetime = 9999999
supermovetime = 9999999

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [0,var(11)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = time * (256/var(11)),256 - time * (256/var(11))

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11),var(11) + var(13)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = 256,0

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11) + var(13),var(11) + var(13)+ var(12)]
ID = 10060
trans = add
remappal = cond(numhelper(856)=1,3,0),cond(numhelper(856)=1,7,0)
alpha = 256 - (time - (var(11) + var(13))) * (256/var(12)),(time - (var(11) + var(13))) * (256/var(12))

[State CZZL, RemoveExplod]
type = RemoveExplod
trigger1 = time >= (var(11) + var(12) + var(13))
id = 10060

[state CZZL, ]
type = destroyself
trigger1 = time > (var(11) + var(12) + var(13))

