[State CZZL, VarSet]
type = Varadd
trigger1 = 1
v = 6   
value = 1
ignorehitpause = 1

[State CZZL, VarSet]
type = VarSet
triggerall = var(5) != -1
trigger1 = !var(40)
trigger1 = var(6) := 1
trigger2 = root,movetype = H
trigger2 = var(6) := 1
v = 5    
value = -1
ignorehitpause = 1

[State CZZL, VarSet]
type = parentVarSet
trigger1 = parent,var(19)
trigger1 = var(6) >= var(11)
v = 19 
value = 0
ignorehitpause = 1

[State CZZL, VarSet];与人物对其
type = VarSet
trigger1 = var(5) = 0
trigger1 = var(6) >= var(11)
trigger1 = var(6) := 1
v = 5    
value = 1
ignorehitpause = 1

[State CZZL, VarSet];移回到屏幕中间
type = VarSet
trigger1 = var(5) = [1,2]
trigger1 = var(6) >= var(14)
trigger1 = parent,var(19) = 0
trigger1 = var(6) := 1
v = 5    
value = 3
ignorehitpause = 1

;-[控制摄像机移动]-----------------------------------------
[State CZZL, PosSet]
type = PosSet
trigger1 = !time
x = 0
y = camerapos y
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 11
trigger1 = var(5) = 1
x = parent,pos x + var(15) * Root,Facing
y = parent,pos y + var(16)
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 21
trigger1 = var(5) = 1
x = enemyNear(enemyNear,ishelper),pos x + var(15) * enemyNear(enemyNear,ishelper),facing
y = enemyNear(enemyNear,ishelper),pos y + var(16)
ignorehitpause = 1

[State CZZL, ]
type = DisplayToClipboard
trigger1 = 1
text="fvar(20) = %d,var(5) = %d,var(6) = %d,vel x = %d,vel y = %d"
params = fvar(20) ,var(5),var(6),vel x,vel y
ignorehitpause = 1

[State CZZL, ]
type = AppendToClipboard
trigger1 = 1
text="parentdist x = %d,var(42) = %d,fvar(22) = %d,posadd = %d,fvar(50) = %d,fvar(51) = %d"
params = parentdist x,var(42),fvar(22),(var(50) - var(51)),var(50),var(51)
ignorehitpause = 1

