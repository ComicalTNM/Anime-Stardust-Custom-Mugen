[State CZZL, PosSet]
type = PosSet
trigger1 = !time
x = 0
y = camerapos y
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 11
trigger1 = var(5) = 1
x = parent,pos x + var(15) * Root,Facing
y = parent,pos y + var(16)
ignorehitpause = 1

[State CZZL, PosSet]
type = PosSet
triggerall = var(42) = 21
trigger1 = var(5) = 1
x = enemyNear(enemyNear,ishelper),pos x + var(15) * enemyNear(enemyNear,ishelper),facing
y = enemyNear(enemyNear,ishelper),pos y + var(16)
ignorehitpause = 1

