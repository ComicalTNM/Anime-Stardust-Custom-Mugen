[State -2, VarSet];Checks if opponent is in attack state
type = VarSet
triggerall = numenemy >= 1 
trigger1 = enemy, movetype = A
var(16) = 1
ignorehitpause = 1

[State -2, VarSet];This resets the condition if counter not succesful and succesful
type = VarSet
triggerall = numenemy
trigger1 = enemy, movetype = I || var(17) >= 1  ;Enemy is Idle | Counter was Succesful
trigger2 = var(17) > 10 && enemy, movetype = H  ;10 ticks passed & enemy is on gethit state
var(16) = 0
ignorehitpause = 1

[State -2, VarSet];Counter Hit Succesful
type = VarSet
trigger1 = var(16) = 1 && movehit ;Counter Check Ok, Move Hit Succesfully.
trigger1 = stateno != [190,199] ;Does not activate during intros.
trigger2 = var(16) = 1 && projhit = 1  ;Counter Check Ok, Projectile Hit Succesfully.
var(17) = 1
ignorehitpause = 1

[State -2, VarAdd];Counter Hit Timer
type = VarAdd
trigger1 = var(17) >= 1 ;Counter was succesful
var(17) = 1
ignorehitpause = 1

[State -2, VarSet];Counter Hit Reset
type = VarSet
trigger1 = var(17) >= 22 && movehit ;Reset if 22 ticks passed and move hit
trigger2 = p2movetype != H ;Reset if P2 is no longer in gethit state
trigger3 = movetype = H ;Reset if P1 is getting hit
trigger4 = var(17) >= 22 && projhit = 1 ;Reset if 22 ticks passed and projectile hit
var(17) = 0
ignorehitpause = 1



