[State 0, Explod]
type = Explod
triggerall = anim = 20 || anim = 21 
trigger1 = animelemtime(2) = 2
trigger2 = animelemtime(4) = 2
anim = 7061
ID = 7061
pos = 7.7,-3
postype = p1
facing = 1
vfacing = 1
bindtime = 0
