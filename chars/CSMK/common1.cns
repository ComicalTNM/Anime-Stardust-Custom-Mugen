;===============================================================================
;--------------------------Constantes Bßsicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0
value = Cond(Pos Y >= 0,60,65)

[State 0, AfterImageTime]
type = AfterImageTime
trigger1 = time = 1
time = 2

[State 0, PalFXWiz]
type = PalFX
triggerall = var(39) = 1
trigger1 = timemod = 2,0
time = 1
add = -9,-59,-94
mul = 512,512,512
sinadd = 0,0,0,1
invertall = 0
color = 0

[State 0, DestroySelf] ; Anti Bugs
type = DestroySelf
trigger1 = ishelper
trigger1 = ishelper != (51000)
trigger1 = ishelper != (8105)

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 5 && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 0

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = 1
id = 8777
ignorehitpause = 1
;persistent = 


[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = prevstateno = 196
trigger1 = roundstate != 2
value = 3008
ignorehitpause = 1
;persistent =

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,65)

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel
value = Cond(Pos Y >= 0,60,65)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
fv = 5
value = 0

[State 0, VarSet]
type = VarSet
trigger1 = animelemtime(1) = 0
fv = 5
value = 0

[State 0, VarAdd]
type = VarAdd
trigger1 = animelemtime(1) = [0,30]
fv = 5
value = .0014

[State 0, VarAdd]
type = VarAdd
trigger1 = animelemtime(1) = [50,80]
fv = 5
value = -.0014

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 0
scale = 1-(fvar(5)/8),1+(fvar(5)/4)


[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11
