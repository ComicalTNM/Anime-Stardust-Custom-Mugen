alpha=50,256
supermove

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
trigger2 = ailevel > 4 && enemynear(0),movetype = H 
trigger3 = ailevel > 5 && (enemynear(0),pos x = [-30,30]) && (enemynear(0),pos y = [-200,-10])
trigger4 = ailevel > 5 && enemynear(0),backedgebodydist = 0
x = const(velocity.walk.fwd.x);+ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x);-ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
facep2 = 1
sprpriority = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S4,2
volumescale = 50

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,149
volumescale = 50

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

;ai
[State 40, 2]
type = VarSet
triggerall = ailevel > 0 
triggerall = numtarget(310)
trigger1 = target(310),pos y < 0
sysvar(1) = 1

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
trigger2 = ailevel > 0
trigger2 = enemynear(0),statetype = L
trigger3 = ailevel > 0
trigger3 = numhelper(1305)
trigger3 = helper(1305),movetype = A
trigger4 = ailevel > 5
trigger4 = enemynear(0),movetype = H
trigger5 = ailevel > 5
trigger5 = enemynear(0),canrecover
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
trigger2 = ailevel > 0
trigger2 = enemynear(0),movetype != H
trigger3 = ailevel > 0
trigger3 = enemynear(0),movetype = A
trigger3 = (Floor(50+AILevel*0.65)>Random) && (Random%2)
trigger4 = ailevel > 0
trigger4 = numhelper(1305)
trigger4 = helper(1305),movetype != A
trigger4 = enemynear(0),movetype != H
trigger4 = (Floor(50+AILevel*0.65)>Random) && (Random%2)
sysvar(1) = -1

[State 40, 4]
type = VelSet
triggerall = AnimTime = 0
trigger1 = command = "holdup"
trigger2 = ailevel > 0
trigger2 = prevstateno = 310
trigger4 = ailevel > 0 && p2bodydist x < 150 && (enemynear(0),pos y = 0) && (enemynear(0),backedgebodydist = 0) 
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

;ai
[State 40, 4]
type = VelSet
triggerall = AnimTime = 0
triggerall = numtarget(310)
trigger1 = ailevel > 5
trigger1 = target(310),pos y <= -8
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 4]
type = VelSet
triggerall = Animtime = 0
trigger1 = command != "holdup"
trigger2 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && prevstateno != 310 && random%4 > 1
trigger3 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && prevstateno = 420 && random%4 > 1
trigger4 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && prevstateno = 300 && random%4 > 1
trigger5 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && (enemynear(0),backedgebodydist <= 2) && prevstateno != 310 && random%4 = 1
trigger6 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && (enemynear(0),statetype = L) && prevstateno != 310 && random%4 > 1
trigger7 = ailevel > 0 && p2bodydist x < 100 && enemy(0),pos y = 0 && (enemynear(0),statetype = C) && prevstateno != 310 && random%4 > 1
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)/1.8


[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 0, VelAdd]
type = VelAdd
triggerall = prevstateno = 60||prevstateno = 70
trigger1 = animtime = 0
x = cond(vel x > 0,2,-2)

[State 0, VelSet] ; From Uppercut
type = VelSet
triggerall = ailevel > 0
triggerall = prevstateno = 310
trigger1 = animtime = 0
x = 4

[State 0, AfterImage]
type = AfterImage
triggerall = prevstateno = 60 && var(39) != 1
trigger1 = time = 0
time = 12
timeGap = 1
framegap = 2
length = 8
palcolor = 256
palinvertall = 0
palBright = 0,0,0
palContrast = 80,44,42
palPostBright = 0,0,0
palAdd = 0,0,0
palMul= 0.75,0.75,0.75
trans = Add1

[State 0, AfterImage]
type = AfterImage
triggerall = prevstateno = 60 && var(39) = 1
trigger1 = time = 0
time = 12
timeGap = 1
framegap = 2
length = 8
palcolor = 256
palinvertall = 0
palBright = 0,0,0
palContrast = 220,220,220
palPostBright = 0,0,0
palAdd = 0,0,0
palMul= 2,.4,.4
trans = Add1


[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
