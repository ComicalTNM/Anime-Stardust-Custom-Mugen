;---------------------- Integer variable list ----------------------

; var(0):= 653 - Floor Crack, 805 - HitSparks, 807 - Special Charge, 950 - Rocks, 951 - Rocas Fin, 952 - Rocks - Override, 1350 - Special 2 - Hit/Helper 1.1, 1600 - Special 2 - Hit/Helper2, 1601 - Special 2 - Hit/Helper2.1, 3600 - Super - Butterfly Dance, 4502 - Super - Jump/Strike, 9000 - Super Charge - Begin, 9001 - Super Charge - End, 40 - Jump Start, 45 - AirJump Start, 50 - Jump up, 55 - AirJump Start, 60 - Jump up, 132 - Air Guard (Guarding), 155 - AGuardHit2 (knocked away), 5080 - HitL_Shake, 5081 - HitL_Slide, 5100 - Hit_BOUNCE (Hit Ground), 5110 - Hit_LIEdown
; var(1):= 9000 - Super Charge - Begin
; var(7):= 5100 - Hit_BOUNCE (Hit Ground)
; var(8):= 5120 - Hit_GETup
; var(35):= -3 - States Always Used

;---------------------- Float variable list ----------------------

