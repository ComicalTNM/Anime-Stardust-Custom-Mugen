Value = Cond(Random >= 500,Cond(Random >= 500,1500,2500),Cond(Random >= 500,Cond(Random >= 500,1500,Cond(Random >= 500,3000,3500)),Cond(Random >= 500,3500,Cond(Random >= 500,1500,1000)))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

