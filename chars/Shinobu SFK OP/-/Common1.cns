; Hit_FallRECOVER (still Falling)
[StateDef 5200]
Type    = A
MoveType= H
Physics = N

[State 5200, 1] ;Change Anim if done with Transition
Type = ChangeAnim
Trigger1 = Anim = 5035+Var(10)
Trigger1 = AnimTime = 0
Value = 5050+Var(10)

[State 5200, 2]
Type = VelAdd
Trigger1 = 1
y = GetHitVar(yaccel)

[State 5200, 3]
Type = SelfState
Trigger1 = Vel Y > 0
Trigger1 = Pos Y >= 10
Value = 5201
