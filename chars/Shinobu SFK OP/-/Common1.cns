; Stance To Crouch
[StateDef 10]
Type    = C
Physics = C
Anim = 10

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel && Enemy,Life > 0
value = Cond(Pos y >= 0,100,102)

[State 10, 1]
Type = VelMul
Trigger1 = Time = 0
x = .75

[State 0, PlaySnd]
Type = PlaySnd
Trigger1 = Time = 0
Value = S35,0

[State 10, 2]
Type = ChangeState
Trigger1 = AnimTime = 0
Value = 11

;=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
; Crouching
[StateDef 11]
Type    = C
Physics = C
Anim = 11
SprPriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel && Enemy,Life > 0
value = Cond(Pos y >= 0,100,102)

[State 11]
Type = ChangeAnim
Trigger1 = Anim = 6 && AnimTime = 0
Value = 11

;=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
; Crouch To Stance
[StateDef 12]
Type    = S
Physics = S
Anim = 12

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel && Enemy,Life > 0
value = Cond(Pos y >= 0,100,102)

[State 0, RemoveExplod]
Type = RemoveExplod
Trigger1 = 1
ID = 6306
IgnoreHitPause = 1

[State 12, 1]
Type = ChangeState
Trigger1 = AnimTime = 0
Value = 0

;----------------------------------------------------------
; Walk
[StateDef 20]
Type    = S
Physics = S
SprPriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = AILevel && Enemy,Life > 0
value = Cond(Pos y >= 0,100,102)

[State 0, PlaySnd]
Type = PlaySnd
Trigger1 = AnimElem = 3
Trigger2 = AnimElem = 6
Value = S20,0

[State 20, 1]
Type = VelSet
Trigger1 = Command = "holdfwd"
x = Const(Velocity.Walk.fwd.x)+Cond(Var(4)=1,2,0)

[State 20, 2]
Type = VelSet
Trigger1 = Command = "holdback"
x = Const(Velocity.Walk.back.x)-Cond(Var(4)=1,2,0)

[State 0, 1]
Type = ChangeAnim
Triggerall = Vel x > 0
Trigger1 = (Anim != 20 && Anim != 5 && Anim != 4020 && Anim != 1005)
Trigger2 = (Anim = 5 || Anim = 1005) && AnimTime = 0
Value = 20

[State 0, 1]
Type = ChangeAnim
Triggerall = Vel x < 0
Trigger1 = (Anim != 21 && Anim != 5 && Anim != 4021 && Anim != 1005)
Trigger2 = (Anim = 5 || Anim = 1005) && AnimTime = 0
Value = 21

