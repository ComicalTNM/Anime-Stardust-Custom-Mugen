;--------------------------------------------
; Stance
[StateDef 0]
Type = S
Physics = S
SprPriority = 0

[State 0, ChangeState]
type = ChangeState
trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0
value = Cond(Pos y >= 0,100,102)

[State 0, AfterImage]
Type = AfterImage
Trigger1 = Time = 0
Time = 1
Palbright = 250,9,55
Palcontrast = 220,70,40
Length = 10
TimeGap = 1
FrameGap =2
Trans = Add

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = Anim != 0 && Anim != 5
Trigger2 = Anim = 5 && AnimTime = 0
Value = 0

[State 0]
Type = VelSet
Trigger1 = Time = 0
y = 0

[State 0]
Type = VelSet
Trigger1 = abs(Vel x) < 2
Trigger2 = Time = 4
x = 0

[State 0]
Type = ChangeState
Trigger1 = !alive
Value = 5050

