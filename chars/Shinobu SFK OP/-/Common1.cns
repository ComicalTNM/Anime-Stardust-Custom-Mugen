Trigger1 = Time <= 10 && Vel Y < -6.5
y = 6

[State 0, VelAdd]
Type = VelAdd
Trigger1 = Time > 10
y = 0.4

[State 0, VelAdd]
Type = VelAdd
Triggerall = (Vel X <= 2) && Time > 1
Trigger1 = (!AILevel) && Command = "holdfwd"
Trigger2 = ((AILevel) && (RoundState = 2)) && (Random < (AILevel * 100) && P2BodyDist X >= 10)
x = Cond((Vel Y < 0),0.8,0.2)

[State 0, VelAdd]
Type = VelAdd
Triggerall = (Vel X >= -2) && Time > 1
Trigger1 = (!AILevel) && Command = "holdback"
Trigger2 = ((AILevel) && (RoundState = 2)) && (Random < (AILevel * 100) && P2BodyDist X <= -10)
x = Cond((Vel Y < 0),-0.8,-0.2)
