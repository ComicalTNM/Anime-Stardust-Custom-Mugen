; Jump up
[StateDef 50]
Type    = A
Physics = A

[State 0, VelAdd]
Type = VelAdd
Triggerall = Time > 5
Trigger1 = Command = "holdback"
x = -1.3

[State 0, VelSet]
Type = VelSet
Triggerall = Time > 5
Trigger1 = Vel x < -3
x = -3

[State 0, VelAdd]
Type = VelAdd
Triggerall = Time > 5
Trigger1 = Command = "holdfwd"
x = 1.3

[State 0, VelSet]
Type = VelSet
Triggerall = Time > 5
Trigger1 = Vel x > 3
x = 3

[State 50, 1]
Type = VarSet
Trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
Type = ChangeAnim
Trigger1 = Time = 0
Value = Cond((Vel x)=0, 41+Cond(Var(4) = 1,20,0), Cond((Vel x)>0, 42+Cond(Var(4) = 1,20,0), 43+Cond(Var(4) = 1,20,0)))

[State 50]
Type = VelAdd
Trigger1 = Command = "holdfwd"
x = .09
[State 50]
Type = VelAdd
Trigger1 = Command = "holdback"
x = -.09

[State 50, 3]
Type = ChangeAnim
Trigger1 = Vel y > -2
Trigger1 = SelfAnimExist(Anim + 3)
persistent = 0
Value = Anim + 3

