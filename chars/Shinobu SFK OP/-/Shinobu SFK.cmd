;===========================================================================
; Controls
[Statedef -1]

;===========================================================================
; Power Charge
[State 0, Power Charge]
Type = ChangeState
Triggerall = Power < PowerMax && (RoundState = 2) && (Alive) && (Ctrl) && (Pos y = 0)
Trigger1 = (Command = "s")
Value = 500
;===========================================================================
; Air Dash - back
[State -1, Air Dash back]
Type = ChangeState
Value = 103
Trigger1 = Command = "BB"
Trigger1 = StateType = A
Trigger1 = Ctrl
;===========================================================================
; Air Dash - fwd
[State -1, Air Dash fwd]
Type = ChangeState
Value = 102
Trigger1 = Command = "FF"
Trigger1 = StateType = A
Trigger1 = Ctrl
;===========================================================================
; Run fwd
[State -1, Run fwd]
Type = ChangeState
Value = 100
Trigger1 = Command = "FF"
Trigger1 = StateType = S
Trigger1 = Ctrl
;===========================================================================
; Run back
[State -1, Run back]
Type = ChangeState
Value = 70
Trigger1 = Command = "BB"
Trigger1 = StateType = S
Trigger1 = Ctrl
;===========================================================================
; Super Jump
[State -1, Super Jump]
Type = ChangeState
Triggerall = Ctrl
Triggerall = RoundState = 2 && Alive
Triggerall = StateType != A || StateType = S || StateType = C
Triggerall = Pos Y = 0
Trigger1 = AILevel = 0
Trigger1 = Command = "Super Jump"
Trigger2 = AILevel > 0
Trigger2 = Random < 500
Trigger2 = Enemy,Pos Y <= -100
Value = 80
;===========================================================================
; Specials/Supers
;===========================================================================
; Special 1
[State -1, Hidden Knife]
Type = ChangeState
Value = 1000
Triggerall = Power >= 1000
Trigger1 = Command = "D,F,a"
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;===========================================================================
; Special 2
[State -1, Silent Walk]
Type = ChangeState
Value = 1500
Trigger1 = Command = "D,F,b"
Triggerall = Power >= 1000
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;===========================================================================
; Special 3
[State -1, Kick Star]
Type = ChangeState
Value = 2000
Trigger1 = Command =  "D,B,a"
Triggerall = Power >= 1000
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;============================================================================
; Special 4
[State -1, Poison: Life Decress]
Type = ChangeState
Value = 2500
Triggerall = Power >= 1000
Trigger1 = Command = "D,B,c"
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;============================================================================
; Special 5
[State -1, Poison: Power Decress]
Type = ChangeState
Value = 3000
Trigger1 = Command = "D,F,c"
Triggerall = Power >= 2000
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;============================================================================
; Special 6
[State -1, Sky Flip]
Type = ChangeState
Value = 3500
Triggerall = Power >= 1000
Trigger1 = Command = "D,B,b"
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;============================================================================
; Special 7
[State -1, Slayer Mark]
Type = ChangeState
Value = 3600
Triggerall = Life <= 500
Triggerall = Var(4) = 0
Triggerall = Power >= 2000
Trigger1 = Command = "y"
Triggerall = StateType = S
Triggerall = Ctrl
;==========================================================================
; Super
[State -1, Butterfly Dance: Caprice]
Type = ChangeState
Value = 4500
Triggerall = !AILevel
Triggerall = Power >= 3000
Trigger1 = Command = "D,D,a"
Trigger2 = Command = "D,D,b"
Trigger3 = Command = "D,D,c"
Triggerall = Command != "holddown"
Triggerall = StateType = S
Triggerall = Ctrl
;===========================================================================
; C
[State -1, C]
Type = ChangeState
Value = 320
Triggerall = NumHelper(8020) = 0
Triggerall = Command = "c"
Triggerall = Command != "holddown"
Trigger1 = StateType = S
Trigger1 = Ctrl
;===========================================================================
; B
[State -1, B]
Type = ChangeState
Value = 260
Triggerall = Command = "b"
Triggerall = Command != "holddown"
