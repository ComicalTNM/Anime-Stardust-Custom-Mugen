triggerall = hitcount < 2
triggerall = !moveguarded
trigger1 = time
attr = S,NP        
hitflag = MAF        
guardflag = MA       
animtype = Medium    
damage = 15+const(size.shadowoffset),3
pausetime = 7+ceil(const(size.shadowoffset)*.4) ,6+const(size.shadowoffset)
guard.pausetime = 8+ceil(const(size.shadowoffset)*.4),6
sparkno = -1
guard.sparkno = -1
sparkxy = 0,0
hitsound = S2,11
guardsound = S4,2
ground.type = High      
ground.slidetime = 10+const(size.shadowoffset)
ground.hittime = 16+const(size.shadowoffset)
air.hittime = 20+const(size.shadowoffset)*2
guard.dist = 90
ground.velocity = -2+const(size.shadowoffset)*.1,0
air.velocity = -2+const(size.shadowoffset)*.15,-2-const(size.shadowoffset)*.21
fall = 0
fall.recover = 1
fall.recovertime = 15+const(size.shadowoffset)*2
air.fall = cond(const(size.shadowoffset) >= 5,1,0)
envshake.time = 5+const(size.shadowoffset)

[State 0, Helper]
type = Helper
trigger1 = moveguarded = 1
helpertype = normal
name = "sparkpeta"
ID = 019
stateno = 800
pos = 5*const(size.xscale),0
postype = p1
keyctrl = 0
ownpal = 1
supermovetime = 0
pausemovetime = 0
size.xscale = .15*const(size.xscale)+const(size.shadowoffset)*.002
size.yscale = .15*const(size.yscale)+const(size.shadowoffset)*.002
ignorehitpause = 1
persistent = 0
[State 0, Helper]
type = Helper
trigger1 = movehit = 1
helpertype = normal
name = "sparkpeta"
ID = 022
stateno = 800
pos = 5*const(size.xscale),0
postype = p1
keyctrl = 0
ownpal = 1
supermovetime = 0
pausemovetime = 0
size.xscale = (.14*const(size.xscale)+hitcount*.01)+const(size.shadowoffset)*.002
size.yscale = (.14*const(size.yscale)+hitcount*.01)+const(size.shadowoffset)*.008
ignorehitpause = 1
persistent = 7

[State 200, End]
type = ChangeState
triggerall = time > 5
trigger1 = frontedgedist < -8
value = 491
ctrl = 0
ignorehitpause = 0
[State 200, End]
type = ChangeState
trigger1 = movehit && hitcount > 1
trigger2 = moveguarded
value = 492
ctrl = 0
[State 200, End]
type = ChangeState
trigger1 = ScreenPos Y <= 0
value = 493
ctrl = 0
ignorehitpause = 0
[State 200, End]
type = ChangeState
trigger1 = pos y >= -2
Trigger2 = Time = 300
value = 495
ctrl = 0
ignorehitpause = 0
