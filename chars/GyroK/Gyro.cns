;===============================================================================
; SPIN:
;-------------------------------------------------------------------------------
[Statedef 6900]
type    = A
movetype= I
physics = N
anim = 9999
ctrl = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = -10
ignorehitpause = 1

;---------------------------------- Var System  
[State 0, SPIN A]
type = VarSet
trigger1 = var(57) > 99
v = 57
value = 100
ignorehitpause = 1
[State 0, SPIN B]
type = VarSet
trigger1 = var(57) < 0 
v = 57
value = 0
ignorehitpause = 1

[State 0, GOLD Start]
type = VarSet
trigger1 = !time 
v = 56
value = 0
ignorehitpause = 1
[State 0, SPIN Start]
type = VarSet
trigger1 = !time 
v = 57
value = 0
ignorehitpause = 1

[State 0, Spin A]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = root,stateno = 500
triggerall = var(57) = [0,99]
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = timemod = 3,0
v = 57
value = 1
[State 0, Spin B]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = var(57) = [0,99]
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = root,movehit=1
v = 57
value = floor(root,var(54)*.3)
persistent = 10
ignorehitpause = 0
[State 0, Spin C]
type = VarAdd
triggerall = root,stateno != 901 
triggerall = root,stateno != [1200,1201]
triggerall = root,stateno != [3001,3002]
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = root,stateno != 500
triggerall = root,stateno != 1300
triggerall = var(57) = [0,99]
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = time%30=0
v = 57
value = 1

[State 0, Spin D]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = root,stateno = 1300 && root,time >12
triggerall = var(57) = [0,99]
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = timemod = 6,0
v = 57
value = -1

[State 0, GOLD ON]
type = VarSet
trigger1 = var(57) > 99 && root,stateno = 500;501
v = 56
value = 1
ignorehitpause = 1
[State 0, GOLD OFF]
type = VarSet
trigger1 = var(57) = 0
v = 56
value = 0
ignorehitpause = 1

[State 0, GOLD]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 1
triggerall = var(57) = [0,100]
triggerall = root,stateno != 901 
triggerall = root,stateno != [1200,1201]
triggerall = root,stateno != [3001,3002]
trigger1 = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = timemod = 10,0
trigger2 = (root,stateno = [120,155])
trigger2 = timemod = 10,0
v = 57
value = -1

[State 0, Substract]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = var(57) = [0,100]
trigger1 = root,stateno = 400 && root,animelem = 10|| root,stateno = 401 && root,animelem = 8
trigger2 = root,stateno = 410 && root,animelem = 10|| root,stateno = 411 && root,animelem = 8
trigger3 = root,stateno = 420 && root,animelem = 10|| root,stateno = 421 && root,animelem = 10|| root,stateno = 650 && root,animelem = 5
trigger4 = root,stateno = 1401 && animelem = 10||root,stateno = 1402 && animelem = 5
v = 57  
value = -5
ignorehitpause = 1
[State 0, SubstractB]
type = VarAdd
triggerall = roundstate = 2
triggerall = var(56) = 0
triggerall = var(57) = [0,100]
trigger1 = root,stateno = 1000 && root,animelem = 12
trigger2 = root,stateno = 1100 && root,animelem = 4
trigger3 = root,stateno = 1200 && root,animelem = 11|| root,stateno = 1201 && root,animelem = 10
trigger4 = root,stateno = 1400 && root,animelem = 10
trigger5 = root,stateno = 3001 && root,animelem = 11
v = 57
value = -10
ignorehitpause = 1

[State 0, AntiBug]
type = VarSet
trigger1 = var(57) = 0 && roundstate != 2
v = 57
value = 1
ignorehitpause = 1

[State 0, Spin Value]
type = VarSet
triggerall = roundstate = 2
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
trigger1 = 1
v = 55
value = cond(var(56) = 1,10,ceil(var(57)*.1))

[State 0, Balls Start]
type = ParentVarSet
trigger1 = !time
v = 58    
value = 2
ignorehitpause = 1
persistent = 0

