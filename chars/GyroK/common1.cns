value = ifelse(pos y >= 0,320,620)
trigger1 = command = "c" && command = "holddown" && ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 25 && enemynear,pos y>= -const(size.height)*.25 && random < (ailevel * 100)/3
trigger2= enemynear,statetype != L
; Fwd C
[State -1, Fwd C]
type = ChangeState
value = ifelse(pos y >= 0,430,620)
trigger1 = command = "c" && command = "holdfwd"  && ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 60 && random < (ailevel * 100)/2
trigger2= enemynear,statetype != L
; C
[State -1, C]
type = ChangeState
value = ifelse(pos y >= 0,220,620)
trigger1 = command = "c" && ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 40 && random < (ailevel * 100)/3
trigger2= enemynear,statetype != L
trigger2= enemynear,statetype != L

; Down Z
[State -1, Down Z]
type = ChangeState
triggerall = numhelper(6900) 
triggerall = var(58) > 0
triggerall = power >= 200
value = 410
trigger1 = command = "z" && command = "holddown" && ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 50 && random < (ailevel * 100)/4
trigger2 = enemynear, pos y < -50
trigger2= enemynear,statetype != L
; Fwd Z
