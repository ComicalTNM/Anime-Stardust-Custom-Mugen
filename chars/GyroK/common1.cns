trigger1 = ailevel=0&&command = "holddown"
;trigger2 =  ailevel>0&& enemy,statetype = C
value = 131

[State 130, Hi to Lo AI]
type = ChangeState
triggerall = ailevel
trigger1 = p2statetype = C  ||  enemy,hitdefattr = C,AA
value = 131

[State 130, Stop Guarding]
