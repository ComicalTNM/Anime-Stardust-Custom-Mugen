trigger1 = !ailevel
trigger1 = command != "holdback"
trigger2 = !inguarddist
value = 140

[State 120, Stop Guarding]
type = ChangeState
trigger1 = ailevel&&numenemy
trigger1 = !inguarddist ;|| enemy,statetype!=A
value = 140
