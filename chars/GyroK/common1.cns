type = ChangeState
value = ifelse(pos y >= 0,440,610)
triggerall = time >= 2
trigger1 = command = "b" && ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 70 && random < (ailevel * 100)
trigger2= enemynear,statetype != L

; C Low
[State -1, C Low]
