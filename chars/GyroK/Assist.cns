[State 0, Summon IA Diego Normal]
type = VarSet
triggerall = var(58) = 5
triggerall = root,pos y > -100;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(25) = 0
triggerall = gametime > 500
