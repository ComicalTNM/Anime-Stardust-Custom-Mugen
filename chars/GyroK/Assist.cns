
;===============================================================================
; ASSIST SYSTEM:
;-------------------------------------------------------------------------------
[Statedef 4000]
type    = A  
movetype= I
physics = N 
anim = 9999
ctrl = 0
 
[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = 0
ignorehitpause = 1

;---------------------------------- Var System  

[State 0, Game Start]
type = VarSet
trigger1 = !time
v = 55
value = 255
ignorehitpause = 1
persistent = 0
[State 0, Game Start]
type = VarSet
trigger1 = roundstate = 2
v = 55
value = cond(roundno = 1,100,20)
ignorehitpause = 1
persistent = 0

[State 0, Reversal Limit Reset]
type = VarSet
trigger1 = !time 
v = 56
value = 2
ignorehitpause = 1
persistent = 0
[State 0, Reversal ON]
type = VarSet
trigger1 = root,movetype = H 
v = 57
value = 1
ignorehitpause = 0
[State 0, Reversal OFF]
type = VarSet
trigger1 = root,movetype != H 
v = 57
value = 0
ignorehitpause = 0  
 
[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
triggerall = !numhelper(4100) 
triggerall = time
triggerall = timemod = 2,0;3,0
trigger1 = var(55) = [0,255]
v = 55   
value = 3

[State 0, Summon PLAYER Normal]
type = VarSet
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(25) = 0
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = root,command = "x"
v = 55   
value = -1
ignorehitpause = 1
[State 0, Summon PLAYER Reversal]
type = VarSet
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
triggerall = numexplod(4020) 
triggerall = var(56) > 0
triggerall = enemynear,hitdefattr != sca,ha,hp,ht,st,nt,np,sp
triggerall = enemynear,hitdefattr = sca,na,sa
triggerall = enemynear,stateno != [3000,4000]
triggerall = root,stateno != [5110,5150]
triggerall = root,stateno != [5400,5401]
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,statetype != L
triggerall = root,movetype = H ;|| root,stateno = [120,155]
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
triggerall = root,p2bodydist x = [0,80]
trigger1 = root,command = "x"
v = 55    
value = -1
ignorehitpause = 1 
 
;IA
[State 0, Summon IA Reversal]
type = VarSet
triggerall = !(root,movetype = H && root,stateno != [5000,5150])
triggerall = numexplod(4020) 
triggerall = var(56) > 0
triggerall = enemynear,hitdefattr != sca,ha,hp,ht,st,nt,sp,np
triggerall = enemynear,hitdefattr = sca,na,sa
triggerall = enemynear,stateno != [3000,4000]
triggerall = root,stateno != [5110,5150]
triggerall = root,stateno != [5400,5401]
triggerall = gametime > 500
triggerall = root,pos y > -60;root,statetype != A
triggerall = root,statetype != L
triggerall = root,movetype = H ;|| root,stateno = [120,155]
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
triggerall = root,p2bodydist x = [0,80]
trigger1 = random < (root,ailevel * root,gethitvar(hitcount))/15
trigger1= enemynear,pos y>= -const(size.height)
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA JOSUKE 4 Normal]
type = VarSet
triggerall = var(58) = 1
triggerall = root,pos y > -30;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(25) = 0
triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
trigger1= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(18-cond((root,stateno = 1000),9,0))
trigger1= root,p2bodydist x = [0,45]
trigger1= enemynear,pos y>= -const(size.height)
trigger1= enemynear,statetype != L
trigger1= enemynear,vel x > -.7
trigger1= root,vel x < 5
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA Johnny Normal]
type = VarSet
triggerall = var(58) = 2
triggerall = root,pos y > -30;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(25) = 0
triggerall = gametime > 500
