trigger1 = Helper(4000),stateno = 4002 && Helper(4000),time >= 20
v = 2
value = 10

[State 0, VarSet] ; Clone Death Checker
type = VarSet
triggerall = Numhelper(4000)
trigger1 = Helper(4000),fvar(18) <= -900
v = 3   
value = 10

[state 0]
type = destroyself
trigger1 = (roundstate >= 3) || (root, life = 0)
removeexplods = 1


