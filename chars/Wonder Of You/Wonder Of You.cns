value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1

; quick fade-out
[State 720, FadeOut]
type = Trans
trigger1 = Time <= 2
trans = addalpha
alpha = 256 - Time*128, Time*128

; face the opponent after snapping (optional)
[State 720, FaceEnemy]
type = Turn
trigger1 = Time = 3
trigger1 = P2Dist X < 0

; fade-in
[State 720, FadeIn]
type = Trans
trigger1 = Time >= 3 && Time <= 6
trans = addalpha
alpha = (Time-3)*128, 256 - (Time-3)*128

; hand off to your existing "fin" state (711), then your own end logic
[State 720, Finish]
type = ChangeState
trigger1 = Time >= 6
value = 721

