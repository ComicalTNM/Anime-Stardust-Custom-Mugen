;-------------------------------------------------------------------------------
;Super
[Statedef 1600]
type    = S
movetype= I
physics = S
juggle  = 0
ctrl = 0
poweradd = -2000
anim = 1600
sprpriority = 2

[state < cooldown]
type = explod
trigger1 = !time
anim = 6
id = 25
removetime = 3000
ignorehitpause = 1
supermovetime = 999
pausemovetime = 999

[state 0, heal]
type = lifeadd
triggerall = life <= lifemax*0.6
triggerall = var(37)
trigger1 = timemod = 60,0
value = lifemax*.01
absolute = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Unguardable
ignorehitpause = 1

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0

[State 0, Helper]
type = helper
triggerall = var(37) > 0 && helper(1900),var(16) > 0
trigger1 = !time
helpertype = Normal
name = "Car"
ID = 3010
stateno = 3010
pos = -200,0
postype = P1
facing = 1
ownpal = 1
supermovetime = 0
pausemovetime = 99999

[State 0, Helper]
type = helper
triggerall = var(37) = 2 && helper(1900),var(16) > 0
trigger1 = timemod = 30,0
helpertype = Normal ;Player
name = "leaf"
ID = 1210
stateno = 1210
pos = p2bodydist x +10+random%10,-20
postype = P1    ;P2, Front, Back, Left, Right
facing = 1
ownpal = 1
size.xscale= .65
size.yscale= .65
pausemovetime = 0
supermovetime = 0
size.shadowoffset = 0
ignorehitpause = 1

; Summon Tornado Helper if fewer than 2 tornadoes are active
[State 0, Tornado Summon]
type = Helper
triggerall = var(37) = 2 && helper(1900),var(16) = 2
triggerall = NumHelper(2404) < 2
trigger1 = !time
helpertype = normal
name = "Tornado"
ID = 2404
stateno = 2404
pos = (random%300)-100,0 ; Random horizontal position within a range
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
supermovetime = 999
pausemovetime = 999

[state 0]
type = helper
Triggerall = NumHelper(1250) < 6
triggerall = var(37) && helper(1900),var(16) = 2
