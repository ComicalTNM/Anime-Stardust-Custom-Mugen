;-------------------------------------------------------------------------------
;Throw glass tue
[Statedef 1000]
type    = S
movetype= I
physics = S
juggle  = 0
ctrl = 0
anim = 1000
poweradd = -500
sprpriority = 2

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = 0

[State 0, Turn]
type = Turn
trigger1 = time = 3
trigger1 = facing*(enemynear,pos x - pos x) < 0
ignorehitpause = 1

[State 0, PosAdd]
type = PosAdd
triggerall = ailevel > 0
triggerall = P2BodyDist X = [0,1500]
trigger1 = time = 0
x = p2bodydist x -10

[State 0, VarSet]
type = VarSet
trigger1 = !time
fv = 1
value = 0+random%2
ignorehitpause = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 1
value = S1000,0+fvar(1)
volumescale = 255
channel = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 2
value = S1001,0
volumescale = 155

[State 0, Helper]
type = helper
trigger1 = animelem = 3
helpertype = Normal ;Player
name = "OB-LA-DI-OB-LA-DA"
ID = 1010
stateno = 1010
pos = 10,-35
postype = P1    ;P2, Front, Back, Left, Right
facing = 1
ownpal = 1
size.xscale= 1
size.yscale= 1
pausemovetime = 0
supermovetime = 0
size.shadowoffset = 1
ignorehitpause = 1

[State 0, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
;-------------------------------------------------------------------------------
;
[Statedef 1010]
type    = A
movetype= A
physics = A
juggle  = 1
ctrl = 0
anim = 1010
sprpriority = 2
ignorehitpause = 1

[State 0, Turn]
type = Turn
trigger1 = p2dist X < 0

[State 0, Tracking]
type = PosAdd
trigger1 = time < 30
x = 10*((p2bodydist x - 0)/(abs(p2bodydist X - 0) + abs(p2bodydist y - 20) + 0.0000001))
y = 10*((p2bodydist y - 20)/(abs(p2bodydist x - 0) + abs(p2bodydist y - 20) + 0.0000015))

[state 0]
type = helper
trigger1 = time % 3 = 0 && time > 5 && pos y < -15
stateno = 8072
id = 8070
pos = 0, 0
postype = p1
supermovetime = 999
pausemovetime = 999

[State 0, VelSet]
type = VelSet
triggerall = !Root,Ailevel
trigger1 = !time
x = cond(root,command = "holdfwd",5,2)
y = cond(root,command = "holdback",-7,-3)
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
triggerall = Root,Ailevel > 0
trigger1 = !time
x = cond(frontedgebodydist > 20&&root,p2bodydist x > 50,5,2)
y = cond(root,p2bodydist y < -20,-7,-3)
ignorehitpause = 1

[State 0, HitDef]
type = HitDef
triggerall = !movecontact
trigger1 = 1
attr = S, NA
animtype  = Medium
damage    = 20*(root,fvar(4)+.2*helper(1900),var(16)),15
guardflag = MA
pausetime = 3,18
guard.pausetime = 7,5
sparkno = -1
guard.sparkno = -1
sparkxy = -8,-25
hitsound   = -1
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = 0,0
air.velocity = 0,0
guard.velocity = -1
getpower = 25
Fall = 0
fall.recover = 10

