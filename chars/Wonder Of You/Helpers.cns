trigger1 = 1
flag = noautoturn

[State 231, end]
type = ChangeState
trigger1 = (helper(50003),fvar(30) <= 0 || fvar(18) <= fvar(17)*-1)
value = 230003

[state 0, Clone | Damage Taken]
type = varadd
trigger1 = !time
fv = 18
value = cond((Helper(4000),Var(18)),-floor(gethitvar(damage)/2),-floor(gethitvar(damage)))
persistent = -1

[State 231, end]
type = ChangeState
;triggerall = (helper(50003),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger1 = Time = 20
value = cond(pos y < 0,4045,4000)

