Trigger1 = fvar(10);(or whatever thing says sa is on)
Fv=10
Value=-1 
persistent = 1
ignorehitpause = 1

[State 0]
Type = varset
Triggerall = fvar(11) = 0
Trigger1 = fvar(10) = 1
Fv=11
Value = 600;(cooldown or resource requirement number.)
ignorehitpause = 1

[State 0]
Type=varadd
Trigger1= fvar(11)
Fv= 11
Value = -1
ignorehitpause = 1;(if its damage based put -enemynear,gethitvar(damage) and a triggerall movecontact up above, gonna need to divide the dmg prolly so it doesnt charge so quick. Or if its just a timer put -1 or -2)
;Fvar(11) will be the Meter filler thingy.
;Fvar(10)=0 will say to the nothitby to activate

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = 1
Value =  Root, Anim
Elem = Root, AnimElemNo(0) 
IgnoreHitPause = 1

[State 0, BindToRoot]
