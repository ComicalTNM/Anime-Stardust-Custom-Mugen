;Power Charge by Night_Stalker/Laslab Games
;===========================================================================
;---------------------------------------------------------------------------
;Power Charge by Night_Stalker/Laslab Games
[Statedef 50760]
type = S ;Um movimento usado quando o char esta em pé
movetype = I ;Um movimento usado com o char parado
physics = S ;Um movimento com fisicas e hitbox para estar em pé
anim = 50760 ;ID da animação
ctrl = 0 ;O char não pode ser controlado enquanto carrega o poder
velset = 0,0 ;Velocidade do char, tem que ser 0,0 já que ele não se movimenta

[State 0, PowerAdd] ;Adiciona poder (barra de especial)
type = PowerAdd ;Adiciona poder
trigger1 = 1 ;Ativado o tempo todo
value = 18 ;Pontos de poder que dá em cada tick, quanto maior esse valor mais rápido ele carrega

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0 || time = 100 || time = 200 || time = 300 || time = 400
value = S2201,16
channel = 7

[State 3000, PlaySnd - Super Charge]
type = PlaySnd
trigger1 = Time = 0
value = S6,0;2
volumescale = 256
channel = 2

[State 3000, PlaySnd - Super Charge]
type = PlaySnd
trigger1 = Time = 0
value = S6,0;2
volumescale = 150
channel = 3

[state 0]
type = helper
trigger1 = (time % 10 = 0) && (time >= 10)
stateno = 5098060
id = 98060
pos = 0, 0
postype = p1
supermovetime = 999
pausemovetime = 999

