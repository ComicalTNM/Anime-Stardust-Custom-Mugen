
; 功夫人的中文化def文档。
; 由MKII翻译。
; 包括人物所需要的文件名。

; 人物信息
[Info]
name ="Senju - Hashirama"        ;人物名
displayname = "Hashirama [Raz]" ;显示名
versiondate = 09,01,2012    ;人物版本号 (月-日-年 或者 X.XX)
mugenversion = 1.1          ;人物对应的MUGEN版本 (X.XX)
author = "MKII"         ;作者名
pal.defaults = 1,2,3,4      ;默认色表顺序 (最多4个)
                            ;序号从1开始
localcoord = 320,240        ;分辨率宽度和高度

; 人物文件
[Files]
cmd     = Senju - Hashirama.cmd
cns     = Senju - Hashirama.cns           ;常量定义
st      = Senju - Hashirama.cns
stcommon = common1.cns      ;公用state (人物文件夹或者common文件夹中)           ;操作输入
st1 = IA.cns         ;系统AI用文件 (未实装，可以无视)    
st2    =    murenzhishu.cns    ;State定义
st3    =    mu bunshin.cns    ;State定义 
st4    =    Skill.cns    ;State定义 
sprite  = Senju - Hashirama.sff           ;图像文件
anim    = Senju - Hashirama.air           ;动作文件
sound   = Senju - Hashirama.snd           ;声效文件

; 将选人时的按键对应到色表上
[Palette Keymap]
x = 1 ;按X按键选色表1，以此类推
y = 2
z = 3
a = 4
b = 5
c = 6
;x2 = 7 ;按start和X按键选色表7，以此类推
;y2 = 8
;z2 = 9
;a2 = 10
;b2 = 11
;c2 = 12

; arcade模式的开头结局动画
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
