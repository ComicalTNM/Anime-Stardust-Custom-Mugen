attr = , HP                         ;Hitdef属性： (S-站立,C-蹲,A-空中),首字符(N-普通,S-特殊,H-超级中).第2个字符(A-普通攻击,T-投掷类攻击,P-飞行道具攻击).
damage    = 0, 9                    ;招式造成的伤害, 防御伤害
animtype  = Back                     ;动作种类: Light-轻, Medium-中, Heavy-重, Back-后仰,Up-垂直向上飞，DiagUp-打到空中-向后-最终头着地.(默认: Light)
hitflag = MAF                        ;能击中什么状态的敌人:H-上段,L-下段,A-空中,M=H+L.F-下落状态,D-躺下(H,L或A或M必须出现在hitflag字符串中).默认值为"MAF"
priority = 10, Hit                   ;攻击优先度: 0 (最低) to 7 (最高), 4 默认，相杀式的处理：Hit-可以击中非dodge情况的敌方,Miss-我方攻击一定miss,Dodge-一定躲避敌方攻击 (默认: Hit)
pausetime = 2,1500                    ;攻击时每个玩家将会停顿的时间：（攻击者暂停的时间, 对手击中 后退前造成P2震动的时间）
sparkno = -1                         ;火花的动作号 (默认: 在[Data]组下面)
sparkxy = -25,-60                    ;火花相对于p2的X坐标偏移量，火花相对于p1的Y坐标偏移量
hitsound   = s-1,4                    ;击中时播放的声音（要从玩家自己的SND文件中播放声音,在第一个数字前加上"S".）
guardsound = s2,1                    ;被防御时播放的声音（要从玩家自己的SND文件中播放声音,在第一个数字前加上"S".）
ground.type = Low                    ;种类: High-上段, Low-下段, Trip-绊倒 (默认: Normal)(如果AnimType=Back,则P2的High,Low类型动画将被替代)
ground.slidetime = 35                ;对方向后滑的时间
ground.hittime  = 35                 ;对方在被击中状态的时间
ground.velocity = -3,0               ;对方被向后推的速度
airguard.velocity = -2,0             ;空中防御时减少速度 (默认: (air.xvel*1.5, air.yvel/2))
air.type = Low                       ;空中击中的种类: High-上段, Low-下段, Trip-绊倒 (默认: 和ground.type一样)
air.velocity = -3,0                  ;空中击中时对方被向后推的横向速度, 空中击中时对方被向后推的纵向速度
air.hittime = 35                     ;空中击中对方在被击中状态的时间、
air.animtype = Back                  ;同"animtype"参数相似,此动画类型设置的是P2在空中而不是地面.
fall.recover = 0                     ;让P2在"下落"状态中不能够恢复.缺省默认为1.(可以恢复)
ground.cornerpush.veloff = 0         ;确定给予玩家的额外速度(速度偏移量)如果他在版边的攻击被对手防御住.此数值设置的越高将导致玩家反弹离版边更远.
air.cornerpush.veloff = 0            ;确定给予玩家的额外速度(速度偏移量)如果他在版边攻击空中的对手.此数值设置的越高将导致玩家反弹离版边更远.
p2StateNo = 3005

[State 19040, 攻击覆盖]
type = HitOverride                                ;如果玩家被指定攻击类型击中,他将进入指定的状态号而不是他默认的受击行为.同一时间能有8个覆盖被激活.
trigger1 = time = 0
attr = SCA,NA,SA,HA,AA,NT,ST,HT,AT,NP,SP,HP,AP    ;指定了要覆盖的hit类型.                      
stateno = 3001                                   ;如果被攻击且指定的属性击中后将要进入的状态.
time = -1                                         ;指定此击中覆盖应激活的时间.默认是1(1帧).设置为-1使得此覆盖一直持续直到被另一个覆盖.

[State CZZL, 状态变更]
type = ChangeState
trigger1 = numtarget > 0
trigger1 = !(target,ishelper)
trigger1 = hitcount > 0
value = 3011
ignorehitpause = 1

[State CZZL, 消除Helper]
type = destroySelf
trigger1 = root,StateNo != 3000

