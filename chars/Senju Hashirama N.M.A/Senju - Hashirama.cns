type = Explod
trigger1 = time = 0
anim = 8505 + var(14)
id = 8501
postype = back
pos = 0,0
bindtime = 1
removetime = -1
under = 0
sprpriority = var(15)
ontop = var(16)
pausemovetime = 9999999
supermovetime = 9999999

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [0,var(11)]
ID = 8501
trans = add
alpha = time * (var(17)/var(11)),256 - time * ((256-var(18))/var(11))

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11),var(11) + var(13)]
ID = 8501
trans = add
alpha = var(17),var(18)

[State CZZL, ModifyExplod]
type = ModifyExplod
trigger1 = time = [var(11) + var(13),var(11) + var(13)+ var(12)]
ID = 8501
trans = add
alpha = var(17) - (time - (var(11) + var(13))) * (var(17)/var(12)),var(18) + (time - (var(11) + var(13))) * ((256-var(18))/var(12))

[State CZZL, RemoveExplod]
type = RemoveExplod
trigger1 = time >= (var(11) + var(12) + var(13))
id = 8501

[state CZZL, ]
type = destroyself
trigger1 = time > (var(11) + var(12) + var(13))
