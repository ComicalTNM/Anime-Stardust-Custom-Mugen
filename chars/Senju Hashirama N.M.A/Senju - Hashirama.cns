physics  = N          ;物理: S-站立, C-蹲, A-空中,N(没有物理属性),且在空中状态中指定你自己的加速度和落地检测.
juggle  = 0;   = 0          ;增加的juggle  = 0;点数
poweradd = 0          ;增加能量
velset   = 0,0        ;分别代表x和y方向速度.(这里有个特例.即使你设置了velset=0,在版边攻击P2的时候P1将被弹开.)
anim     = 3010       ;改变动作 (不写这行则不改变anim)
ctrl     = 0          ;设定可控与否 (不写这行则不改变ctrl)
sprpriority = 3       ;设定p1的贴图优先度到2 (在前面)

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = 0

[State CZZL, 无敌]
