value = S2500,0
volume = 100
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 1
value = S2500,0
volume = 100
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 1
value = S2500,0
volume = 100

