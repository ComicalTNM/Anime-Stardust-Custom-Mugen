trigger1 = time % var(10) = 0
v = 13
range = -450,450
ignorehitpause = 1
persistent = 1

[State CZZL,闪光]
type = Explod
trigger1 = time % var(10) = 0
anim = 3043
postype = p1
ID = 3043
pos = GameWidth * var(12) * 0.001,-ScreenPos y + GameHeight * 0.5 + GameHeight * var(13) * 0.001
bindtime = -1
scale = (GameWidth / 640) * var(11) * 0.01,(GameWidth / 640) * var(11) * 0.01
under = 0
ownpal = 1
sprpriority = 430 + Random % 20
pausemovetime = 9999999
supermovetime = 9999999

