yscale=1.10
ground.back=11
ground.front=11
air.back=11
air.front=11
height=50
attack.dist=160
proj.attack.dist=90
proj.doscale=0
head.pos=0,-39
mid.pos=-1,-26
shadowoffset=0
draw.offset=0,0

[Velocity]
