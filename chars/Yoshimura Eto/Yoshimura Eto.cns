;---------------------------------------------------------------------------
; 重载common1.cns里的state（用同样的state号）
;---------------------------------------------------------------------------
[statedef -2]
[State 0, ]
type = varset
trigger1 = life <= lifemax/2
v= 11
value= 2000

[state 0]
type = angledraw
trigger1 = (alive) && (statetype != l)
value = cond(vel x != 0, - (atan(vel y / vel x) * (const(size.air.back)) / pi), 0)
scale = 1 + (sin((time / (12.8 + (life / 25))) * (pi / 2)) * 0.0025), 1 + (sin((time / (12.5 + (life / 25))) * (pi / 2)) * 0.012)
ignorehitpause = 1

[State 0, ]
type = RemoveExplod
trigger1 = stateno != 300
ID = 1031
;---------------------------------------------------------------------------
; 在自己的state里每一帧执行(statedef -3)
;---------------------------------------------------------------------------
[Statedef -3]
;跳跃落地或者后跃时播放的声音
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 40, 0

[State -3]
type = null
trigger1 = random = 90
triggerall = !lose
triggerall = !drawgame
triggerall = life > 0
triggerall = !matchover
triggerall = !win
value = S1,3+(random%2)
volume = 10
channel = 5

[State 0, SelfState]
type = SelfState 
triggerall = !ishelper
triggerall = life <= lifemax/2 && numhelper(950) = 0
triggerall = stateno != 114514
trigger1 = movetype = H
trigger1 = anim = [5000,5110]
trigger1 = alive
trigger1 = pos y > -5
value = 114514

[State -3, VarSet - Ropa Rota]
type = VarSet
triggerall = var(13) = 0
Triggerall = life < lifemax /2
triggerall = !numhelper(950)
trigger1 = 1
v = 13
value = 1
; Armor Break:
;-------------------------------------------------------------------------------
[State -3, VarSet - Armor Break]
type = VarSet
trigger1 = numhelper(950) = 1
v = 3
value = 1

[State -3, VarSet, Golpeado]
type = VarSet
trigger1 = var(3) = 1
v = 10
value = 1000

[State -3, VarSet, Apariencia]
type = VarSet
trigger1 = var(3) = 1
v = 11
value = 2000
