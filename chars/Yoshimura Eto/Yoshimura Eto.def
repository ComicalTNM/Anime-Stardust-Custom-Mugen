; 人物信息
[Info]
name = "Yoshimura Eto"        ;人物名
displayname = "Yoshimura Eto" ;显示名
versiondate = 09,01,2025    ;人物版本号 (月-日-年 或者 X.XX)
mugenversion = 1.1          ;人物对应的MUGEN版本 (X.XX)
author = "刃下心"         ;作者名
pal.defaults = 1,2,3,4      ;默认色表顺序 (最多4个)
                            ;序号从1开始
localcoord = 320,240        ;分辨率宽度和高度

; 人物文件
[Files]
cmd     = Yoshimura Eto.cmd           ;操作输入
cns     = Yoshimura Eto.cns           ;常量定义
st      = Yoshimura Eto.cns
st2      =Yoshimura Eto-Noroi.cns           ;State定义
st3      =Yoshimura Eto-Tatara.cns           ;State定义
st4      =Yoshimura Eto-skill.cns           ;State定义
stcommon = common1.cns      ;公用state (人物文件夹或者common文件夹中)
sprite  = Yoshimura Eto.sff           ;图像文件
anim    = Yoshimura Eto.air           ;动作文件
sound   = Yoshimura Eto.snd           ;声效文件
;ai      = Yoshimura Eto.ai            ;系统AI用文件 (未实装，可以无视)

; arcade模式的开头结局动画
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
