[Statedef -2]

[State 0, Run]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = 60

[State 0, Run Atras]
type = ChangeState
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = 70

[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

; Bankai:
;Seiken: Senbonzakura Kageyoshi
[State -1, Seiken: Senbonzakura Kageyoshi]
type = ChangeState
value = 710
;PLAYER
trigger1 = command = "Seiken"
trigger1 = var(50) = 0
;AI RANDOM
trigger2 = p2dist x != [-50,50]
trigger2 = random = [950,951+var(49)/((power/500)+var(49))/200+(power/500)+(p2dist x)/200]
trigger2 = var(50) = 1
trigger2 = p2statetype != L
;WARUNEK
triggerall = pos y = 0 && ctrl
triggerall = stateno != 710
triggerall = power >= 1000
triggerall = var(0) = 1
triggerall = var(1) = 0

