;Var List:
;---------------------- Integer variable list ----------------------

; var(1):= 180 - Ganar:, 190 - Introducción:, 555, 556 - Aura - Fin
; var(5):= 441 - Succes LAND, 8510, 8511, -3
; var(6):= 441 - Succes LAND
; var(7):= 5100 - HIT_BOUNCE (hit ground)
; var(8):= 5120 - HIT_GETUP
;var(12):= 441 - Succes LAND, 1000 - Muerte Destructiva - Estilo Aplastante, 1100 - Muerte Destructiva - Aguja De Brujula, 1200 - Estilo De Pierna - Destello de Luz Fluida, 1300 - Muerte Destructiva - Estilo Vacio, 1302 - Void Style Air - Start, 1400 - Muerte Destructiva - Estilo Caotico, 1500 - Counter:, 3000
;var(16):= 999999 - HELPER ESCALA:
;var(45):= 3110

;---------------------- Float variable list ----------------------

; fvar(1):= 806 - Hit spark full
; fvar(5):= 0 - Stand
;fvar(33):= 50 - Jump Up


; - Var(2) = Kimetsu no Yaiba
; - Var(5) = Limitador Air Jump
; - Var(6) = Lifeadd Super Armor
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(12) = Oscurecer Pantalla
; - FVar(16) = ESCALA

[Data]
life = 2100
power = 3000
attack = 130
defence = 140
fall.defence_up = 50
liedown.time = 60
airjuggle = 150
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 1
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 1500 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 1400 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

