y = 0
ignorehitpause = 1
[State 0, VelSet]
type = VelSet
trigger1 = cond(facing = 1,pos x > enemynear,pos x +20,pos x < enemynear,pos x -20)
trigger2 = vel x < 0
x = .3-time*.001
y = 0
ignorehitpause = 1

[State 0, Turn]
type = Turn
trigger1 = animtime = 0 && cond(facing = 1,pos x > enemynear,pos x +1,pos x < enemynear,pos x -1)
