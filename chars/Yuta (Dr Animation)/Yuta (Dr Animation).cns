;Blood bounce
[Statedef 26102]  
type    = S
movetype= H
physics = N
velset = 0,0
ctrl = 0
sprpriority = 1


[State 0, Velset]
type = Velset
trigger1 = time = 1;I use 5 so they stick to the floor for a quick sec. Use whatever time you want
x = -1;bounces backwards. Set to zero if you want a straight up bounce
y = -4;upwards bounce speed

[State 0, VelAdd]
type = VelAdd
trigger1 = time < 30 ||  time > 60
y = 0.25
;ignorehitpause = 
;persistent = 


[State 0, ChangeAnim]
type = ChangeAnim;changes to the bounce animation
trigger1 = time >= 1;this is so they'll be in the fall animation till they actually bounce 
value = 5100
elem = 1 

[State 0, water]
type = Explod
trigger1 = time = 0
anim = 5100
ID = 5100
pos = 0,-30
postype = p1
facing = 1
vfacing = 1
bindtime = -1
vel = 0,0
accel = 0,0
random = 0,0
removetime = -1
scale = 1,1
sprpriority = 2
ontop = 0
removeongethit = 1
angle = 180

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Invisible

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = time > 30
trigger1 = pos y > 0; usually add 1 to whenever they start to bounce
id = 5100
;ignorehitpause = 
;persistent = 


[State 200, End]
type = SelfState;Puts them back in their own states instead of your custom one 
triggerall = time > 30
trigger1 = pos y > 0; usually add 1 to whenever they start to bounce
value = 5050;default value I recommend


