trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = (GetHitVar(animtype) = [4,5]) && (SelfAnimExist(10547+var(10) + GetHitVar(animtype)))
value = 10547+var(10) + GetHitVar(animtype) ;5051 - 4 + type

[State 5000, 4] ;Freeze anim
type = ChangeAnim
triggerall = Var(29) = 0
trigger1 = Time > 0
value = anim

[State 5000, 5] ;State type gets set to aerial if getting hit up
