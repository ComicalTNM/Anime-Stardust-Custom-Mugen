movetype= H
physics = N
velset = 0,0


[State 5000, 1] ;Anim for HIT_LIGHT to HIT_HARD
type = ChangeAnim
trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = GetHitVar(animtype) != [3,5]
value = ifelse((GetHitVar(groundtype) = 1),10500+var(10),10510+var(10)) + GetHitVar(animtype)

[State 5000, 2] ;Anim for HIT_BACK
