trigger1 = Time = 0
triggerall = Var(29) = 0
trigger1 = GetHitVar(animtype) = [3,5]
value = 10530+var(10)

[State 5000, 3] ;Anim for HIT_UP/HIT_DIAGUP (only if it exists)
