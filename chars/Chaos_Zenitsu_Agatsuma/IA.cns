;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[StateDef -2]

[State 0, Run Atras]
type = ChangeState
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = p2bodydist x < 100 && p2movetype = A && p2stateno != 500
trigger1 = random < (ailevel * 100)/2
value = 70

[State 0, Seventh form]
type = ChangeState
triggerall = Var(20) = 1
triggerall = power >= 3000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = random < (ailevel * 100)
value = 3000

[State 0, Godlike speed]
type = ChangeState
triggerall = power >= 3000
triggerall = Var(20) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = random < (ailevel * 100)
value = 1210

[State 0, Run]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = 60

[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0 && enemy,movetype = A)
trigger1 = random < (ailevel * 100)+100
value = ifelse(statetype = A,132,130)

[State 0, Power Charge End]
type = ChangeState
triggerall = time >= 12
triggerall = stateno = 500
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0 && enemy,movetype = A && abs(enemy,pos x - pos x) < 150)
trigger2 = power >= 3000
trigger2 = random < (power-3000)/10
trigger3 = power >= powermax
trigger4 = roundstate > 2
value = 501

[State 0, Power Charge]
type = ChangeState
triggerall = power < 3000
triggerall = ailevel > 0
triggerall = ctrl
triggerall = ailevel > 0 && roundstate = 2
trigger1 = p2bodydist x > 150
trigger1 = random < (ailevel * 100)/3
trigger2 = p2bodydist x > 250
trigger2 = random < (ailevel * 100)
trigger3 = p2bodydist y > 150
trigger3 = random < (ailevel * 100)/4
trigger4 = (abs(p2bodydist x) + abs(p2bodydist y)) > 100
trigger4 = p2movetype = H || (p2stateno = 5120 || p2stateno = 5150 || p2stateno = 5201 || p2stateno = 5210)
trigger4 = random < 900
value = 500

[State 0, Super Jump]
type = ChangeState
triggerall = ctrl
triggerall = ailevel > 0 && roundstate = 2
triggerall = pos y = 0
trigger1 = p2bodydist x < 50
trigger1 = p2bodydist y < -20
trigger1 = random < 100
value = 80


[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0 && enemy,movetype = A)
trigger1 = random < (ailevel * 100)+100
value = 1850

[State 0, A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = p2bodydist x < 30
trigger1 = abs(p2bodydist y) < 20
trigger1 = random < (ailevel * 100)
value = 200

[State 0, B]
