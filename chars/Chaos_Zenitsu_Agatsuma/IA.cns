trigger1 = p2movetype = A && p2stateno != 500
trigger1 = enemynear,facing != facing
value = 1700

[State 0, Multiple Slash]
type = ChangeState
Triggerall = var(2) = 0
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
triggerall = p2bodydist x <= 20
trigger1 = random < (ailevel * 100)/2
value = 1300

[State 0, Hekireki Issen]
type = ChangeState
Triggerall = var(2) = 0
Triggerall = numhelper(111350)=0
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = random < (ailevel * 100)/2
trigger2 = p2bodydist x > 10 && p2bodydist x < 100
trigger2 = random < (ailevel * 100)*1
value = 1200

[State 0, Eightfold]
type = ChangeState
triggerall = power >= 1500
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = p2bodydist x > 30 && p2bodydist x < 200 
trigger1 = random < (ailevel * 200)/2
trigger2 = p2bodydist x > 200 
value = 1501



[State 0, Wind Slash]
type = ChangeState
Triggerall = var(2) = 0
triggerall = power >= 2500
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = p2bodydist x >= 70
trigger1 = random < (ailevel * 100)*1
