[Statedef -3]
[State 0, Helper de Conexiones]
type = Helper
Triggerall = numhelper(700) = 0
trigger1 = (stateno = 200||stateno = 210||stateno = 600) && movecontact
trigger2 = (stateno = 300||stateno = 310||stateno = 610) && movecontact
trigger3 = (stateno = 400||stateno = 620) && movecontact
helpertype = normal
name = "Helper de Conexiones"
ID = 700
stateno = 700
pos = 999999,999999
postype = p1

[State 0, HELPER ESCALA]
type = Helper
trigger1 = NUMHELPER(999999) = 0
helpertype = normal
name = "HELPER ESCALA"
ID = 999999
stateno = 999999
pos = 9999,9999
postype = P1
facing = 1
keyctrl = 0
ownpal = 1
supermove = 999999
pausemove = 999999
supermovetime = 999999
pausemovetime = 999999



[state -3, P1 ID Single or Simul Mode]
type = varset
trigger1 = !numpartner
trigger2 = numpartner
trigger2 = id<partner,id
var(24) = (ID)
 
[state -3, P3 ID Simul Mode]
type = varset
trigger1 = numpartner
trigger1 =partner,id>id
var(25) = (Partner,ID)
 
[state -3, P2 ID Single Mode]
type = varset
trigger1 = numenemy = 1
var(26) = (enemy,ID)
 
[state -3, P2 ID Simul Mode]
type = varset
trigger1 = numenemy > 1
var(26) = (enemy(0),ID)
 
[state -3, P4 ID Simul Mode]
type = varset
trigger1 = numenemy > 1
var(27) = (enemy(1),ID)


