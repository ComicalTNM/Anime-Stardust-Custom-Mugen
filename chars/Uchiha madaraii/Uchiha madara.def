 ; 人物信息
[Info]
name = "Uchiha madara"        ;人物名
displayname = "Ultimate madara(Iso)" ;显示名 
versiondate = 04,22,2022    ;人物版本号 (月-日-年 或者 X.XX)
mugenversion = 1.1          ;人物对应的MUGEN版本 (X.XX)
author = "feiqiu"         ;作者名
pal.defaults = 1,2,3,4      ;默认色表顺序 (最多4个)

; 人物文件
[Files]
sprite  = madara.sff           ;图像文件
anim    = madara.air           ;动作文件
sound   = madara.snd           ;声效文件
cmd     = madara.cmd           ;操作输入
cns     = Madara.cns           ;常量定义
stcommon = common1.cns      ;公用state (人物文件夹或者common文件夹中)
st = Madara.cns
st1 = IA.cns
st2 = EMS.cns
st3 = Rinnegan.cns
st4 = Perfect Susano'o.cns
st5 = RikudouMode.cns
[Palette Keymap]
a = 1
b = 2
c = 3
x = 4
y = 5
z = 6

a2 = 7
b2 = 8
c2 = 9
x2 = 10
y2 = 11
z2 = 12

; arcade模式的开头结局动画
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
