
;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;-------------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, Helper]
type = Helper
triggerall = numhelper(340)= 0
trigger1 = time > 2&&var(10)
trigger1 = numhelper(1701) < 1 && stateno = 0
helpertype = normal
name = ""
ID = 1701
stateno = 1701
pos = 5,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
ontop = 1
ignorehitpause = 0
supermovetime = 9999999
pausemovetime = 9999999
supermove = 9999999999
move = 999999999
movetime = 9999999

[State 0, 1]
type = ChangeAnim
triggerall=!var(10)
triggerall=life>400
trigger1 = Anim != 0 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 0

[State 0, 1]
type = ChangeAnim
triggerall=!var(10)
triggerall=life<=400
trigger1 = Anim != 1 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 1
[State 0, 1]
type = ChangeAnim
triggerall=var(10)=1
triggerall=life>400
trigger1 = Anim != 2 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 2
[State 0, 1]
type = ChangeAnim
triggerall=var(10)=1
triggerall=life<=400
trigger1 = Anim != 3 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 3

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper
ignorehitpause = 1

[State 0, Remove Explods]
type = RemoveExplod
trigger1 = ishelper
ignorehitpause = 1

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = cond(life>400,10,10011)
[state 0]
type = angledraw
trigger1 = time <= 5
scale = .95, 1.05 - (sin((time/ 50.0) * (pi / 2)) * 0.0125)
ignorehitpause = 1

[State 0, SELFstate]
type = selfstate
trigger1 = ailevel
value = 0
ctrl = 1

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = cond(life>400,10,11011)
sprpriority = 0

[State 0, Andando // Corriendo]
type = PlaySnd
trigger1 = time=0
value = S9110,0
[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = anim = 6
value = 6+var(11)

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11+var(11)
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = cond(life>400,12,12011)
[state 0]
type = angledraw
trigger1 = time <= 5
scale = .95, 1.05 - (sin((time/ 50.0) * (pi / 2)) * 0.0125)
ignorehitpause = 1
[State 0, Andando // Corriendo]
type = PlaySnd
trigger1 = time=0
value = S9110,0
[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0
[state 0]
type = angledraw
trigger1 = time <= 5
scale = .95, 1.05 - (sin((time/ 50.0) * (pi / 2)) * 0.0125)
ignorehitpause = 1

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40+var(11)
ctrl = 0
sprpriority = 1
[state 0]
type = angledraw
trigger1 = time <= 5
scale = .95, 1.05 - (sin((time/ 50.0) * (pi / 2)) * 0.0125)
ignorehitpause = 1

[state 40, self]
type = selfstate
triggerall = ailevel && (stateno != 380 && stateno != 250) && prevstateno != 380 && prevstateno != 250 && ! (numhelper(1350) && enemynear(var(59)),statetype = A && (enemynear(var(59)),movetype = A || enemynear(var(59)),movetype = I))
trigger1 = (enemynear(var(59)), movetype = I || enemynear(var(59)), movetype = H) && (!PlayerIdExist(helper(33333333),var(3))) && (enemynear(var(59)),statetype != A)
trigger2 = (enemynear(var(59)), statetype = A && enemynear(var(59)),movetype = H && (p2bodydist x > 200 || (enemynear(var(59)), vel x < -1 && p2bodydist x > 80) || (enemynear(var(59)), pos y >= -50 && enemynear(var(59)), vel y > 0)))
trigger3 = (enemynear(var(59)), statetype = A && enemynear(var(59)), vel y > 0 && enemynear(var(59)), pos y >=-40)
trigger4 = (enemynear(var(59)), stateno = [1255,1258]) || (enemynear(var(59)), stateno = [455,457]) || (enemynear(var(59)), stateno = 1005)
value = 0
ctrl = 1

[state 0]
type = angledraw
trigger1 = time <= 5
scale = 1.05 - (sin((time/ 50.0) * (pi / 2)) * 0.0125), .95
ignorehitpause = 1

[state 0]
type = playsnd
trigger1 = animelem = 1
value = s140, 0
[State 0, Helper]
type = helper
trigger1 = time = 0 && command = "holdfwd"
helpertype = Normal ;Player
name = "1"
ID = 8050
stateno = 8050
pos = -10,2
postype = P1    ;P2, Front, Back, Left, Right
facing = 1
ownpal = 1
size.xscale=.4
size.yscale=.4
pausemovetime =999999
[State 0, Helper]
type = helper
trigger1 = time = 0 && command = "holdback" 
helpertype = Normal ;Player
name = "1"
ID = 8050
stateno = 8050
pos = 10,2
postype = P1    ;P2, Front, Back, Left, Right
facing = -1
ownpal = 1
size.xscale=.4
size.yscale=.4
pausemovetime =999999
[State 0, Explod]
type = Explod
trigger1 = time = 0 
anim = 8005
ID = 8005
pos = -10,1
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
vfacing = 1
bindtime = 1
vel = -.5,0
