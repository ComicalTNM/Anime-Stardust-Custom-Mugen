trigger1 = 1
pos = ((pos x) / (1 / camerazoom * 2)) * camerazoom, (pos y + cond(pos y <= -20, 20, 0)) / (1 / camerazoom * 2)
lag = (const(size.air.back)/10.0)
scale = 1 / camerazoom * (1.0+fvar(0))
ignorehitpause = 1

[State 0, DestroySelf]
