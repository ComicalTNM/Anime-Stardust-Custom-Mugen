[State 0, Null]
type = Null
trigger1 = time < const(size.mid.pos.x)
trigger1 = fvar(0) := fvar(0) + (const(size.yscale)/const(size.mid.pos.x))

trigger2 = const(size.ground.back) = 1
trigger2 = time >= const(size.ground.front)
trigger2 = time < (const(size.mid.pos.x) + const(size.ground.front))
trigger2 = fvar(0) := fvar(0) + (const(size.xscale)/const(size.mid.pos.x))

ignorehitpause = 1

[State 0, Null]
type = Null
trigger1 = time = [const(size.mid.pos.x),(const(size.mid.pos.x) + const(size.mid.pos.y))]
trigger1 = fvar(0) := const(size.yscale)

trigger2 = const(size.ground.back) = 1
trigger2 = time >= (const(size.mid.pos.x) + const(size.ground.front))
trigger2 = time <= (const(size.mid.pos.x) + const(size.mid.pos.y) + const(size.ground.front) + const(size.mid.pos.y))
trigger2 = fvar(0) := (const(size.yscale) + const(size.xscale))
ignorehitpause = 1

[State 0, Null]
type = Null
triggerall = fvar(0) > 0
trigger1 = const(size.ground.back) = 0
trigger1 = time >= (const(size.mid.pos.x) + const(size.mid.pos.y))
trigger1 = var(0) := (const(size.shadowoffset) - (const(size.mid.pos.x) + const(size.mid.pos.y)))
trigger1 = fvar(0) := fvar(0) - ((fvar(0)+.5)/var(0))

trigger2 = const(size.ground.back) = 1
trigger2 = const(size.mid.pos.x) != 0 || time >= (const(size.shadowoffset) +const(size.mid.pos.y))/2
trigger2 = time >= (const(size.mid.pos.x) + const(size.mid.pos.y) + const(size.ground.front) + const(size.mid.pos.y))
trigger2 = cond(const(size.mid.pos.x) != 0,var(0) := (const(size.shadowoffset) - (const(size.mid.pos.x) + const(size.mid.pos.y) + const(size.ground.front) + const(size.mid.pos.y))),var(0) := const(size.shadowoffset)/2)
trigger2 = fvar(0) := fvar(0) - ((fvar(0)+.5)/var(0))
ignorehitpause = 1

[State 0, AssertSpecial]
