[State 0]
type = Helper
trigger1 = !numhelper(12138)
helpertype = normal
ID = 12138
stateno = 12138
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 0
supermovetime = 0
pausemovetime = 0
size.yscale = .5 ;第一次镜头放大值 数值越大镜头越贴近人物 最小数值为0.0  最多六位小数 
size.xscale = .5  ;镜头二次放大的数值 输入负数则第二次放大会缩小镜头 负数需要小于等第一次放大的数值  （注意 第二次放大的【需要时间】和【停留时间】第一次的相同）
size.ground.back = 0 ;镜头是否二次放大 1为是 0为否
size.ground.front = 60 ;第二次镜头放大的时间 输入大于等于第一次拉镜的【需要时间】+【停留时间】的数值并且小于等于【持续时间】的数值 当第一次拉镜的【需要时间】小于等于0 第二次拉镜的【停留时间】会持续到拉镜结束
size.air.back = 8 ;拉镜速度数值越大，速度越慢，数值最大10 最小0 
size.mid.pos = 30,30 ; 镜头停留 第一个数值是第一次放大的【需要时间】 第二个是镜头放大结束时镜头的【停留时间】 二者相加需要小于等于【持续时间】
size.air.front = 1 ;是否用于出场动画 使用于出场动画时可以防止拉镜还没结束就开始战斗 不是使用在出场动画时改成0 是则为1
size.head.pos = 0,0 ;镜头偏移 第一个数值为左右偏移正值向右偏移，负值向左偏移 第二个数值为上下偏移正值向下偏移，负值向上偏移 
size.height = 0 ;是否触发时停 ————— 连同人物一起时停 仅适用于角色释放技能没有时停被打断拉镜 1为是 0为否
size.shadowoffset = 120 ;拉镜全程【持续时间】 ———————— 如果持续时间太短会没有镜头复原效果
ignorehitpause = 1
persistent = 0


