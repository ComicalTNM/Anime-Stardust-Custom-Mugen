trigger1 = AnimElemTime(14) >= 0 && AnimElemTime(14) < 5
x = -5



[State 角色移动]
type = VelSet
trigger1 = AnimElemTime(14) >= 5 && AnimElemTime(14) < 15
x = -5+0.05*(time-155)


[State 镜头聚焦-开始]
type = zoom
trigger1 = time = [150,160]
scale = 1+0.015*(time-149)
pos = pos x,pos y
ignorehitpause = 1

[State 镜头聚焦]
type = zoom
trigger1 = time = [161,178]
scale = 1.15
pos = pos x,pos y
ignorehitpause = 1

[State 1.1 镜头聚焦-缩♂回去]
type = zoom
trigger1 = time = [179,184]
scale = 1.15-0.03*(time-178)
pos = pos x,pos y
ignorehitpause = 1

[State 震屏]
