[State 攻击]
type = HitDef
guard.sparkno = s20006
trigger1 = AnimElem = 3
id=200
attr = S, NA                     ;Hitdef属性： 站立，普通攻击
damage = 30, 0                   ;招式造成的伤害, 防御伤害
animtype = Light                 ;动作种类: Light-轻, Medium-中, Heavy-重, Back-后仰 (默认: Light)
guardflag = MA                   ;能被什么状态的敌人防御
hitflag = MAFD                   ;能击中什么状态的敌人
priority = 3, Hit                ;攻击优先度: 0 (最低) to 7 (最高), 4 默认，相杀式的处理：Hit-可以击中非dodge情况的敌方/Miss-我方攻击一定miss/Dodge-一定躲避敌方攻击 (默认: Hit)
pausetime = 8, 13                 ;攻击者暂停的时间, 对手在hitshake的时间
sparkno = -1                      ;火花的动作号 (默认: 在上面设置的动作好)
sparkxy = -10, -62               ;火花相对于p2的X坐标偏移量，火花相对于p1的Y坐标偏移量
hitsound = s3, 2                  ;击中时播放的声音
guardsound = s5, 0                ;被防御时播放的声音
ground.type = Low               ;种类: High-上段, Low-下段, Trip-绊倒 (默认: Normal)
ground.slidetime = 3             ;对方向后滑的时间
ground.hittime  = 60             ;对方在被击中状态的时间
ground.velocity = -3             ;对方被向后推的速度
airguard.velocity = -1.9,-.8     ;空中防御的速度 (默认: (air.xvel*1.5, air.yvel/2))
air.type = High                  ;空中击中的种类: High-上段, Low-下段, Trip-绊倒 (默认: 和ground.type一样)
air.velocity = -1.4,-3.2           ;空中击中时对方被向后推的横向速度, 空中击中时对方被向后推的纵向速度
air.hittime = 18                 ;空中击中对方在被击中状态的时间、
p2facing =1
air.fall = 1
fall.recover = 0
fall.damage = 0
p2stateno = 1301
p2facing =1
