priority = 3, Hit                ;攻击优先度: 0 (最低) to 7 (最高), 4 默认，相杀式的处理：Hit-可以击中非dodge情况的敌方/Miss-我方攻击一定miss/Dodge-一定躲避敌方攻击 (默认: Hit)
pausetime = 5, 5                 ;攻击者暂停的时间, 对手在hitshake的时间
sparkno = -1                      ;火花的动作号 (默认: 在上面设置的动作好)
sparkxy = -10, -62               ;火花相对于p2的X坐标偏移量，火花相对于p1的Y坐标偏移量
hitsound = s2, 5                  ;击中时播放的声音
guardsound = s4, 0                ;被防御时播放的声音
ground.type = Low               ;种类: High-上段, Low-下段, Trip-绊倒 (默认: Normal)
ground.slidetime = 6             ;对方向后滑的时间
ground.hittime  = 50             ;对方在被击中状态的时间
ground.velocity = -6             ;对方被向后推的速度
airguard.velocity = -1.9,-.8     ;空中防御的速度 (默认: (air.xvel*1.5, air.yvel/2))
air.type = High                  ;空中击中的种类: High-上段, Low-下段, Trip-绊倒 (默认: 和ground.type一样)
air.velocity = -1.4,-3.2           ;空中击中时对方被向后推的横向速度, 空中击中时对方被向后推的纵向速度
air.hittime = 18                 ;空中击中对方在被击中状态的时间、
p2stateno = 116000+enemynear,statetype = C*10+enemynear,statetype = A*20
p2facing =1


