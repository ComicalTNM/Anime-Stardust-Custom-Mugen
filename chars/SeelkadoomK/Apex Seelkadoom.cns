Priority = 99999,Hit
trigger1 =! MoveContact
attr = S,NA
;hitflag = MAFD
priority = 3,Hit
;guardflag = MA
animtype = Hard
damage = Enemy,LifeMax/40+Const(Data.Attack)/8,Enemy,LifeMax/50+Const(Data.Attack)/8
