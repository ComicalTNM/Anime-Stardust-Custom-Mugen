EnvShake.Ampl = -10
EnvShake.Freq = 10
fall = 1

[State 0,Mid Hit Spark ]
type = Helper
SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
trigger1 = MoveHit = 1
helpertype = normal
ID = 8010
stateno = 8010
pos = Cond((P2Dist X<35),P2Dist X+0,30),-22
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .095*0.90
size.yscale = .095*0.90
size.head.pos = (random % 360), 15
ignorehitpause = 1
PERSISTENT = 0

[State 200,Chain]
type = ChangeState
Triggerall = MoveContact
trigger1 = ailevel = 0 && Command = "FF"
trigger2 = roundstate = 2 && ailevel > 0 && random<(ailevel * 100)
value = 110

[State 0, Air Combo 600]
type = ChangeState
triggerall = movehit
triggerall = fvar(16) < 2
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/Cond(Fvar(16),4,1)
value = cond(fvar(16) < 1,600,cond(fvar(16) < 2,601,600))+Var(11)

[State 0, Air B]
type = ChangeState
triggerall = movecontact
triggerall = fvar(17) < 3
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/Cond(Fvar(17) > 2,4,1)
value = Cond(Fvar(16) < 1,610,Cond(Fvar(16) < 2,611,612))+Var(11)

[State 0, Air C]
type = ChangeState
triggerall = movecontact
triggerall = fvar(18) < 2
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = Cond(!Fvar(18),620,625)+Var(11)

[State 0, Air Down A]
type = ChangeState
triggerall = movecontact
triggerall = fvar(19) < 1
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = 605+Var(11)

[State 0, Air Down C]
type = ChangeState
triggerall = movehit
triggerall = fvar(21) < 1
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/6
value = 650+Var(11)

[State 0, Air Down B]
type = ChangeState
triggerall = movecontact
triggerall = fvar(20) < 1
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = 615+Var(11)

[State 0, SD]
type = ChangeState
triggerall = movecontact
triggerall = fvar(24) < 1
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/7
value = 750+Var(11)

[State 0, D,F,a]
type = ChangeState
triggerall = !numexplod(1150) 
triggerall = movehit
triggerall = power >= 1000
triggerall = random < ((ailevel * 100)*enemy, gethitvar(hitcount)*50)
triggerall = random < (ailevel * 90+enemy, gethitvar(hitcount)*5)/2
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = Cond(Pos Y >= 0,Cond(Random >= 500,21000,Cond(Random >= 500,21300,Cond(Random >= 500,21200,Cond(Random >= 500,21400,21500)))),Cond(Random >= 500,21005,Cond(Random >= 500,21305,Cond(Random >= 500,21205,Cond(Random >= 500,21405,21505)))))

[State 200, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
