[Statedef 2565]
type    = S
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 9999
sprpriority = -1

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 0,0

[State 0, After image - 2]
type = Helper
SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
trigger1 = TimeMod = 8,0
name = "After image - 2"
ID = 2572
stateno = 2572
pos = 0,0
postype = p1    ;p2,front,back,left,right
facing = 1
ownpal = 1
Size.Xscale = Const(Size.Xscale)
Size.Yscale = Const(Size.Yscale)
SuperMoveTime = 9999
PauseMoveTime = 9999

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = root,stateno = 900
trigger2 = root,stateno = 190
trigger3 = root,stateno = 5110
id = 560

[State 200, End]
type = Destroyself
trigger1 = root,var(2) != 1
