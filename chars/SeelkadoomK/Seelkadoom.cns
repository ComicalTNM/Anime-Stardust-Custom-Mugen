;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S 
MoveType = I 
Physics = S 
VelSet = 0,0 
Anim = 11 

[State 0, Explod]
type = Explod
SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
Trigger1 = !Time
Anim = 9999
ID = Stateno
Pos = 0,0
BindTime = -1
RemoveTime = -1

[State 0, NotHitBy] 
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = !Var(2) 
Value = Cond(NumHelper(980),Cond(Pos Y >= 0,Cond(Random >= 500,1200,Cond(Random >= 500,1350,Cond(Random >= 500,1550,1050))),Cond(Random >= 500,1205,Cond(Random >= 500,1355,Cond(Random >= 500,1555,1055)))),Cond(Pos Y >= 0,Cond(Random >= 500,1200,Cond(Random >= 500,1300,Cond(Random >= 500,1000,1500))),Cond(Random >= 500,1205,Cond(Random >= 500,1305,Cond(Random >= 500,1005,1505)))))
