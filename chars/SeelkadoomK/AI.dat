[State 200, A Combo]
type = ChangeState
triggerall = fvar(10) < Cond(Var(2) = 3 || Var(2) = 4,5,6)
triggerall = ailevel = 0 && command = "a"
triggerall = statetype != A
triggerall = Cond(fvar(10)<1,movecontact,movehit)
