trigger2 = (stateno=[300+Var(11),370+Var(11)]) || stateno = 410 || stateno = 280 ;B
trigger3 = (stateno=[300+Var(11),320+Var(11)]) || stateno = 421 || stateno = 422 ;C
value = cond(fvar(10) < 1,200+Var(11),cond(fvar(10)<2,210+Var(11),cond(fvar(10)<3,220+Var(11),cond(fvar(10)<4,230+Var(11),cond(fvar(10)<5,240+Var(11),cond(fvar(10)<6,250+Var(11),200+Var(11)))))))

[State 300, B Combo]
type = ChangeState
