; Sonidos Comunes:
;-------------------------------------------------------------------------------
[State 0,Walk PlaySnd]
type=PlaySnd
triggerall = stateno = 20
trigger1 = animelem = 4 || animelem = 8
value = S20,1
volumescale = 50

[State 0, Run]
type = PlaySnd
triggerall = stateno = 60||stateno = 70
trigger1 = time = 1
value = S40,3

[State 0, Run (Aire)]
type = PlaySnd
triggerall = stateno = 62||stateno = 72
trigger1 = time = 1
value = S40,3

[State 0, Jump Start]
type = PlaySnd
triggerall = stateno = 40
trigger1 = Time = 1
value = S40,1
channel = -1

[State 0, Super Jump]
type = PlaySnd
triggerall = stateno = 80
trigger1 = Time = 1
value = S60,1
channel = -1

[State 0, Land]
type = PlaySnd
triggerall = stateno = 52
trigger1 = time = 1
value = S52,1

[State 0, RemoveExplod]
type = RemoveExplod
TRIGGERALL = stateno != 500 && stateno != 550
trigger1 = time = 1
id = 550

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 1

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 2

[State 0,StopSnd]
type = StopSnd
TRIGGERALL = stateno!=191 || stateno != 192
trigger1 = time = 1
channel = 4

[State 0,StopSnd]
type = StopSnd
TRIGGERALL = stateno!=190
trigger1 = time = 1
channel = 7

[State 0, Golpeado]
type = PlaySnd
trigger1 = movetype=H && (stateno!=[0,155]) && !time && HitOver=0 && random%3=0
value = 5000,ifelse(random < 500,1,ifelse(random < 500,2,3))

[State 0, Solucion Stand Aire]
type = ChangeState
triggerall = stateno = 0||stateno = 20
trigger1 = pos y < 0
value = 50
ctrl = 1

;===============================================================================
; Combos
;-------------------------------------------------------------------------------
[State 0, VarRangeSet]
type = VarRangeSet
trigger1 = StateNo = 0 || StateNo = 50
trigger2 = StateNo != [200+Var(11),370+Var(11)]	
trigger2 = StateNo != [400+Var(11),490+Var(11)]
trigger2 = StateNo != [600+Var(11),650+Var(11)]
Trigger2 = Stateno != 110
fvalue = 0
first = 10
last = 30

[State 370, A+B]
type = ChangeState
triggerall = fvar(25) < 1
triggerall = ailevel = 0 && command = "a" && command = "b" 
triggerall = statetype != A
triggerall = movecontact
trigger1 = (stateno=[200,490])+Var(11)  || stateno = 400 ;A
trigger2 = (stateno=[250,270]) || stateno = 410 || stateno = 280 || stateno = 361 || stateno = 381 || stateno = 1601 ;B
trigger3 = (stateno=[300,320]) || stateno = 421 || stateno = 422 ;C
value = 290

[State 40, Jump Cancel]
type= ChangeState
triggerall = !ailevel && command = "holdup" 
triggerall = statetype != A
triggerall = movecontact && time >= 5
trigger1 = (stateno=[200,490])+Var(11) 
trigger2 = (stateno=[250,270]) 
trigger3 = (stateno=[300,320]) || stateno = 331 || stateno = 351
value = 40

[State 60, Air Dash Forward]
type= ChangeState
triggerall = var(4) < cond(var(8)=1,2,1)
triggerall = !ailevel && command = "FF" 
triggerall = statetype = A
triggerall = movecontact && time >= 5
trigger1 = (stateno=[600,650])+Var(11) || stateno = 640 ;A
trigger2 = (stateno=620) || stateno = 650 ;B
trigger3 = (stateno=630) || stateno = 661 ;C
value = 100

;---------------------------------------------------------------------------
[State 640, State Air Down A]
type = ChangeState
triggerall = fvar(19) < 1
triggerall = ailevel = 0 && command = "holddown" && command = "a" 
triggerall = statetype = A
triggerall = movecontact
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = 605+Var(11)

[State 650, State Air Down B]
type = ChangeState
triggerall = fvar(20) < 1
triggerall = ailevel = 0 && command = "holddown" && command = "b" 
triggerall = statetype = A
triggerall = movecontact
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = 615+Var(11)

[State 660, Down C]
type = ChangeState
triggerall = fvar(21) < 1
triggerall = ailevel = 0 && command = "holddown" && command = "c" 
triggerall = statetype = A
triggerall = movecontact
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = 650+Var(11)

[State 600, Air Combo]
type = ChangeState
triggerall = fvar(16) < 2
triggerall = ailevel = 0 && command = "a" 
triggerall = statetype = A
triggerall = Cond(var(16)<1,movecontact,movehit)
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = cond(fvar(16) < 1,600,cond(fvar(16) < 2,601,600))+Var(11)

[State 620, Air B]
type = ChangeState
triggerall = fvar(17) < 2
triggerall = ailevel = 0 && command = "b" 
triggerall = statetype = A
triggerall = movecontact
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = cond(fvar(16) < 1,610,cond(fvar(16) < 2,611,610))+Var(11)

[State 630, Air C]	
type = ChangeState
triggerall = fvar(18) < 1
triggerall = ailevel = 0 && command = "c" 
triggerall = statetype = A
triggerall = movecontact
trigger1 = (stateno=[600,650])+Var(11) || (stateno = 620) || (stateno = 630) || (stateno = 640) || (stateno = 650) || stateno = 45
value = 620+Var(11)
;---------------------------------------------------------------------------
[State 400, Down A]
