SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
trigger1 = MoveContact = 1
helpertype = normal
ID = 25445
stateno = 25445
pos= -10+Random%35,-35+Random%20
postype=P2
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .14
size.yscale = .14
Size.Head.Pos = (Random % 360), 15
ignorehitpause = 1
Persistent = 6

[State 200, End]
type = Changestate
trigger1 = helper(25451),movehit && helper(25451),hitcount > 25
trigger2 = helper(25451),moveguarded && time > 20
trigger3 = frontedgebodydist < -100
trigger4 = time = 500
trigger5 = pos y >= -5
value = 25461
