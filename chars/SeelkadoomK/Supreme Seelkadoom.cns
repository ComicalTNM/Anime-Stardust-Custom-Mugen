value = cond(fvar(16) < 1,600,cond(fvar(16) < 2,601,600))+Var(11)

[State 0, Air B]
type = ChangeState
triggerall = movecontact
triggerall = fvar(17) = 2
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/Cond(Fvar(17) > 3,4,1)
value = Cond(Fvar(16) < 1,610,Cond(Fvar(16) < 2,611,Cond(Fvar(16) < 3,612,613)))+Var(11)

[State 0, Air C]
type = ChangeState
triggerall = movecontact
