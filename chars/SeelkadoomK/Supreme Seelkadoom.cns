triggerall = movehit
triggerall = power >= 1000
triggerall = random < ((ailevel * 100)*enemy, gethitvar(hitcount)*50)
triggerall = random < (ailevel * 90+enemy, gethitvar(hitcount)*5)/2
trigger1 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = Cond(Pos Y >= 0,Cond(Random >= 500,25000,Cond(Random >= 500,25100,Cond(Random >= 500,25200,Cond(Random >= 500,25400,Cond(Random >= 500,25500,25300))))),Cond(Random >= 500,25005,Cond(Random >= 500,25100,Cond(Random >= 500,25205,Cond(Random >= 500,25405,Cond(Random >= 500,25505,25305))))))
 ;,Cond(Pos Y >= 0,Cond(Random >= 500,1200,Cond(Random >= 500,1300,Cond(Random >= 500,1000,1500))),Cond(Random >= 500,1205,Cond(Random >= 500,1305,Cond(Random >= 500,1005,1505)))))

