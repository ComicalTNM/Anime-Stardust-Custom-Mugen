[Statedef 1000]
type    = S
movetype= A
physics = S
;juggle  = 1  = 1
velset = 0,0
ctrl = 0
anim = 1000
FaceP2 = 1
poweradd = -250
sprpriority = 2
[State 0, Limiter]
type = Explod
