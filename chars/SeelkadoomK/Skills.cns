anim = 9999
ID = 1150
pos = 0,0
postype = p1  
facing = 1
vfacing = 1
bindtime = -1
removetime = 600
pausemovetime = 9999
supermovetime = 9999
scale = 1,1
sprpriority = 3
ownpal = 1
removeongethit = 0
persistent = 0
; SUPER PAUSE ============
