[State 0, Gravity]
type = Gravity
trigger1 = pos y <= -5

[State 0, PosSet]
type = PosSet
trigger1 = pos y >= -5
y = -5

[State 0, NotHitBy]
Type = NotHitBy
trigger1 = 1
Value = SCA
Time = 1
IgnoreHitPause = 1

[State 200, 1]
type = HitDef
GivePower = Cond(NumHelper(980),-50-Random%50,0),0
Attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT,AA,AP,AT
HitFlag = MAFD
Priority = 99999,Hit
triggerall = !movecontact
trigger1 = 1
attr = A, SA
Hitflag = MAFD
animtype = Heavy
damage = 100,50
;guardflag = MA
pausetime = 2,2
sparkno = -1
guard.sparkno = -1
sparkxy = -8,-25
hitsound   = S1,19
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = -5,-2
air.velocity = -5,-2
Fall = 1
Envshake.time = 20

[State 0, TargetState]
type = TargetState
triggerall = enemy,numhelper(15000000) = 0
triggerall = enemy,stateno != 8450
trigger1 = movehit = 1
value = 8450

[State 200, Spark CVS]
type = Explod
SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
trigger1 = Movehit = 1
anim = 7260
ID = 7260
postype = P1
pos = 20,-16
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = .3,.3
removeongethit = 1
ontop = 1
persistent = 0
supermovetime = 999
ignorehitpause  = 1
angle = 0+random%360
pausemovetime = ifelse(numhelper(1350) > 0,99999,0)

[State 0, Boost FX]
type = Helper
SuperMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
PauseMoveTime = Cond(IsHelper && Root,Var(2) || NumHelper(980) || !IsHelper && Var(2),99999,0)
trigger1 = time = 0
helpertype = normal
name = "Boost FX"
ID = 1250
stateno = 1250
pos = 0,0
postype = p1
ownpal = 1
size.xscale = .45
size.yscale = .45
pausemovetime = ifelse(numhelper(1350) > 0,99999,0)

[State 0, ChangeState]
type = ChangeState
trigger1 = enemy,numhelper(15000002) = 1
trigger1 = numhelper(15000002) = 1 
value = 1202
ctrl = 0

[State 200, End]
type = ChangeState
triggerall = time >= 30
trigger1 = ailevel = 0 && command != "hold_b"
trigger2 = ailevel > 0 && p2bodydist x < 50
trigger3 = ailevel > 0 && time = 30+random%110
trigger4 = time = 110
value = Cond(Pos y<0,50,1203)
