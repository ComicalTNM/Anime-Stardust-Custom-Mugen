; JOJO:
;-------------------------------------------------------------------------------
[Statedef 980]
type    = A
movetype= I
physics = N
anim = 980
sprpriority = -1

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
Fv = 2
value = 1.5

[State 0, VarAdd]
type = VarAdd
trigger1 = time < 10
Fv = 2
value = -.15

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = 1+Fvar(2),1+Fvar(2)

[State 0, VarAdd]
type = VarAdd
trigger1 = time >= 25
v = 1
value = 25

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256-var(1),0+var(1)

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 200, End]
type = Destroyself
trigger1 = var(1) >= 256
