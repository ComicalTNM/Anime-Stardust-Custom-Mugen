;===================================================================================
;---------------- Constantes y Ataques normales--------------------------------------------
;===================================================================================

;Var List:

; - Var(5) = Limitador Air Jump
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(12) = Oscurecer Pantalla
; - FVar(16) = ESCALA

[Data]
life = 2000
power = 3000
attack = 140
defence = 130
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40
[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 1500 ; STATENO: normal assist attack
StateTagAssistHyper = 3000 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; 
[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 1.5
walk.back = -1.5
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82
;===============================================================================
; Crazy Diamond Guard:
;-------------------------------------------------------------------------------
; Start
[Statedef 160]
type    = A
movetype= I
physics = N
anim = 160
sprpriority = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S1,26
volume = 999

[State 0, BindToParent]
type = BindToroot
trigger1 = time >=0
time = 1
;facing = 0
pos = 15,0
[State 0, Trans]
type = Trans
triggerall = prevstateno != [1,99999]
trigger1 = time < 5
trans = addalpha
alpha = 0+time*25,256-time*25

[State 0, DestroySelf]
type = changestate
trigger1 =root,stateno != [120,155]
value = 345
[State 0, DestroySelf]
type = changestate
trigger1 = root,stateno = 140
value = 161
;-------------------------------------------------------------------------------
; Fin Destroy
[Statedef 161]
type    = A
movetype= I
physics = N
sprpriority = 1

[State 0, BindToParent]
type = BindToroot
trigger1 = time >=0
time = 1
;facing = 0
pos = 12,-1
[State 200, End]
type = ChangeState
trigger1 = root,stateno = 1200&&root,time<=20
value = 1210

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 1300&&root,time<=10
value = 1310

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 1400&&root,time<=20
value = 1410

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 3000&&root,time<=3
value = 3010

[State 200, End]
type = changestate 
trigger1 = time >= 5
trigger2 = root,stateno != [120,155]
value = 345
