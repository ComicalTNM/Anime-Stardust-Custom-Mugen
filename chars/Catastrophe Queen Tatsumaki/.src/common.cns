[state , 長いアニメ時変更 検索高速化]

type = Changeanim

triggerall = ishelper("間者ヘルパー")

triggerall = var(7) = -1

triggerall = anim = var(2)

trigger1 = animelemtime(animelemno(0)) > 1

trigger1 = animelemtime(animelemno(0)+1);次のアニメが存在している？

value = anim

elem = animelemno(0)+1

ignorehitpause = 1

[state , 長いアニメ時変更 検索高速化]

type = Changeanim

triggerall = ishelper("間者ヘルパー")

triggerall = var(7) = -1

triggerall = anim = var(2)

trigger1 = animelemtime(1) > 14

trigger2 = animelemtime(animelemno(0)+1) = 0

value = anim

elem = 1

ignorehitpause = 1

[state , 長いアニメ時変更 検索高速化]

type = changestate

triggerall = ishelper("間者ヘルパー")

triggerall = var(7) = -1

triggerall = anim = var(2)

triggerall = var(1)&&var(1)<14

trigger1 = !animelemtime(1);時間が経過しているのに最初に戻っている

trigger2 = animtime>=0;アニメを最後まで確認した

value = stateno+0*(var(1):=0)

ignorehitpause = 1



[state , 検索したアニメへ変更]

type = Changeanim

triggerall = ishelper("間者ヘルパー")

triggerall = var(7) = -1

triggerall = anim != var(2)

triggerall = selfanimexist(var(2))

trigger1 = var(2) != 5300;検索回避対象

                         ;5300に空アニメを持つキャラがいるのでエラー落ち対策のために回避します

                         ;ChangeAnim2式(= CA2式)という手法であればこうして指定せずとも回避が可能です

                         ;またエラー落ち回避目的以外にも既にステート返し用のアニメを取得しているならばコモンアニメは検索対象から外しても良いでしょう

                         ;理由としては検索するまでもなくコモンステートへ返す事は可能なのでわざわざ取得する価値が薄いからです

                         

trigger1 = !((name="Space Godzilla")&&(authorname="tokuiten")&&(var(2)=6&&var(2)=[10,12]));以下専用での空アニメ回避 これらは上記のCA2式で回避可能

trigger1 = !((name="G-Mizuchi-v2")&&(authorname="608")&&(var(2)=[9800,9801]))

trigger1 = !((name="will-o-the-wisp")&&(authorname="608")&&(var(2)=[3922,3923]))



trigger1 = var(1)

value = var(2)

ignorehitpause = 1



[state , アニメに攻撃判定があるかどうかhitdefを撃って確かめる]

type = hitdef
HitFlag = MAFD

triggerall = ishelper("間者ヘルパー")

trigger1 = var(7) = -1

numhits = 0

attr = , HA;当身を取られないように前半は省略 後半は被弾役に当てられるように調整

hitflag = MAFDLP

sparkno = -1

