;これによってmovehitなどのトリガーで攻撃が当たったかどうかを確かめることが出来るようになります







;----------------------------------------------------------

;--------          2. アニメ検索本体          ----------



;C1判定のあるアニメは複数取得します

;p1stateno干渉に用いるprojのanimとして使うものは判定までの時間が短い方ものが好ましいです

;それ以外のアニメはp1stateno干渉の送り先に用います



;置換対象

;"間者ヘルパー" を アニメ検索をさせる間者ヘルパーのヘルパーID に置換



[state , アニメ検索 初期設定]

type = Null

triggerall = ishelper("間者ヘルパー")

triggerall = abs(sysvar(4)) != 12345678;初期化完了のための判断材料

trigger1 = var(0) := -1;準汎用検索対象の総数 × -1

trigger1 = var(3):=var(4):=var(5):=var(6):=var(7):=-1;0番アニメも取得出来る様に初期値を-1にする

ignorehitpause = 1

[state , アニメ検索 初期設定]

type = Varset

triggerall = ishelper("間者ヘルパー")

triggerall = abs(sysvar(4)) != 12345678

trigger1 = 1

sysvar(4) = 12345678

ignorehitpause = 1



[state , アニメを記憶 1枚目]

type = Varset

triggerall = ishelper("間者ヘルパー")

trigger1 = var(3) = -1

trigger1 = movecontact+movereversed=1;攻撃がヒットしたor攻撃が当身された →　C1判定がある

var(3) = anim

ignorehitpause = 1

[state , アニメを記憶 2枚目以降]

type = Varset

triggerall = ishelper("間者ヘルパー")

trigger1 = var(3) != -1;1枚目記録済み

trigger1 = var(7) = -1

trigger1 = movecontact+movereversed=1

trigger1 = anim!=var(3)&&anim!=var(4)&&anim!=var(5)&&anim!=var(6)&&anim!=var(7);被ったアニメは保存しない

var(4+(var(4)>-1)+(var(5)>-1)+(var(6)>-1)) = anim

ignorehitpause = 1



[state , アニメ検索 準汎用検索]

type = Null

triggerall = ishelper("間者ヘルパー")

triggerall = var(0) < 0

triggerall = ((var(1) := var(1) - (var(1) > 0)) * 0) || 1

triggerall = var(1) = 0

triggerall = var(7) = -1



trigger1 = var(0) = -1

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(10000000);調査したいアニメが存在しているか

trigger1 = var(1) := 5;調査フレーム猶予

trigger1 = var(3) := 10000000;調査アニメ

                             ;ここで指定している10000000はG-TestのC1判定のあるアニメです(C2判定は10000001)

                             ;0から調べ上げると時間がかかるのでこうして直接調べることで検索速度を上げていきましょう

                             

trigger2 = var(0) = -2

trigger2 = (var(0) := var(0) + 1) * 0 || selfanimexist(2147483647)

trigger2 = var(1) := 5

trigger2 = var(3) := 2147483647



ignorehitpause = 1

[state , アニメ検索 汎用検索]

type = Null

triggerall = ishelper("間者ヘルパー")

triggerall = var(0) >= 0;準汎用検索終了済み

triggerall = ((var(1) := var(1) - (var(1) > 0)) * 0) || 1

triggerall = var(1) = 0

triggerall = var(7) = -1

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

trigger1 = (var(0) := var(0) + 1) * 0 || selfanimexist(var(0))=0

