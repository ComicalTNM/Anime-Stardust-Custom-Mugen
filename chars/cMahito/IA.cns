[State 0, ChangeState]
type = ChangeState
trigger1 = p2movetype = a 
trigger1 = stateno = [0,800]
trigger1 = stateno !=1350
trigger1 = stateno !=100
trigger1 = p2bodydist x < 30
trigger1 = abs(p2bodydist y) < 40
trigger1 = pos y = 0
trigger1 = var(33)=1
