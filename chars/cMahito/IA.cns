ctrl = 0

[State 0, HitOverride]
type = HitOverride
trigger1 = var(33)=1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
slot = 0
stateno = 1350-ifelse(command="holdfwd",1250,0)
time = 1
forceair = 0
