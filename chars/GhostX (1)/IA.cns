[Statedef -2]




[state 0]
type = lifeadd
trigger1 = life <= 50
value = -500
kill = 1


[State 0, PowerAdd]
type = PowerAdd
trigger1 = var(2) <=5
trigger1 = 1
value = 3
persistent = 10





[State 0, SelfState]
Type = SelfState
triggerall = (roundstate = 2) && (alive)
trigger1 = var(59) != 0
TRIGGERALL = stateno != 802
triggerall = stateno != 99998
triggerall = stateno != 1920000
triggerall = stateno != 99011
Triggerall = Life <= LifeMax/4
