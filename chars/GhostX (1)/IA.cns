[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "Var(0) = %d, Var(1) = %d, Var(2) = %d, Var(3) = %d, Var(4) = %d,Var(5) = %d"
params =  P2BodyDist x,P2BodyDist y,fVar(25),helper(48928),Var(3), helper(48928),Var(4),helper(48928),Var(5)
ignorehitpause = 1

[state 0]
type = helper
trigger1 = !numhelper(30990)
stateno = 30990
id = 30990
ownpal = 1
postype = p1
size.height = 2
size.ground.back = 0
size.air.front = 0 
size.air.back = 0 
size.head.pos = 30500, 0 
size.mid.pos = (const(size.mid.pos.x) + 0), 0 
size.xscale = .145
size.yscale = .145
supermovetime = 99999999999
pausemovetime = 99999999999
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
triggerall = Var(4) = 1
triggerall = cond(numenemy >= 2,fvar(12) != 1 ,enemy,life !=0)
trigger1 = Var(2) < 7 
flag2 = roundnotover
flag = NoKO

