[State 5050, 1] ;Change anim when done with transition
type = ChangeAnim
trigger1 = AnimTime = 0
trigger1 = Anim = 5035+var(59)
trigger2 = Time = 0     ;If no transition anim
trigger2 = Anim != 5035+var(59)
trigger2 = (Anim != [5051, 5059])+var(59) && (Anim != [5061, 5069])+var(59)
trigger2 = Anim != 5090+var(59) ;Not if hit off ground anim
value = 5050+var(59)

[State 5050, 2] ;Coming down anim
type = ChangeAnim
trigger1 = (anim = [5050,5059])+var(59)
trigger1 = Vel Y >= ifelse(anim = 5050+var(59), 1, -2)
trigger1 = SelfAnimExist(anim+10)
value = anim+10
persistent = 0

[State 5050, 3] ;Gravity
type = VelAdd
trigger1 = 1
y = GetHitVar(yaccel)

[State 5050, 6]
type = Selfstate
trigger1 = Vel Y > 0
trigger1 = Pos Y >= ifelse((anim = [5051,5059])+var(59) || (anim = [5061,5069])+var(59), 0, 25)
value = 5100 ;HIT_BOUNCE

