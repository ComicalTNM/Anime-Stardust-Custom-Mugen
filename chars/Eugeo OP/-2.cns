;===============================================================================
;Hitspark
;===============================================================================

[State -2, Null]
Type = Null
Trigger1 = MoveContact && Var(28) < 0
Trigger1 = Var(28) := (HitPauseTime)
IgnoreHitPause = 1

[State -2, Null]
Type = Null
Trigger1 = Var(28) := -1

[State -2, Helper ]
Type = Helper 
Trigger1 = Var(25) = [0,2]
Trigger1 = Var(28) = (HitPauseTime)
Name = "Physical Hitspark"
ID = 12000
StateNO = 12000
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = ID
Size.YScale = 0
IgnoreHitPause = 1

[State -2, Helper]
Type = Helper 
Trigger1 = Var(25) = [3,5]
Trigger1 = Var(28) = (HitPauseTime)
Name = "Slash Hitspark"
ID = 12010
StateNO = 12010
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = ID
Size.YScale = 0 ;0 - Nothing, 1 - Hit Effect, 2 - Guard Effect
Size.Height = Cond((StateNO = 250 || StateNO = 450 || (StateNO = [1000,1002]) || (StateNO = 1201 && Var(55)) || StateNO = 1500 || StateNO = 1550),9,12) ;PalNO (Check the sprite tab)
IgnoreHitPause = 1

;===============================================================================
;SHIELD
;===============================================================================

[State -2, ChangeState] ;ChangeState to Parry State
Type = ChangeState
TriggerAll = Var(12)
TriggerAll = Var(13)
TriggerAll = Var(14) >= 1
TriggerAll = StateNO != [1500,1501]
TriggerAll = Power >= 1000
TriggerAll = (StateNO = 150 || StateNO = 152 || StateNO = 154)
TriggerAll = StateType != A && Pos Y = 0
TriggerAll = GetHitVar(Guarded)  
TriggerAll = MoveType = H
TriggerAll = PlayerIDExist(Var(16))
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "c"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = PlayerIDExist(Var(16))
Trigger2 = PlayerID(Var(16)),StateType != A
Trigger2 = Var(20) = [(6 * AiLevel),(10 * AiLevel)]
Trigger2 = Fvar(39) <= 660
Trigger2 = EnemyNear,Pos Y >= Const(Size.Mid.Pos.Y)
Trigger2 = EnemyNear,StateType != L
Value = 1500
IgnoreHitPause = 1

[State -2, ChangeState]
Type = ChangeState
Trigger1 = Var(16) != 0
Trigger1 = Var(12)
Trigger1 = Var(13)
Trigger1 = Var(5)
Trigger1 = Var(6)
Trigger1 = PlayerIDExist(Var(16))
Trigger1 = Power = PowerMax
Trigger1 = SelfAnimExist(3500)
Trigger1 = !(CameraZoom > 1.0)
Trigger1 = (StateNO != [3000,3004]) || (StateNO != [3500,3501])
Trigger1 = (StateNO = [130,132]) || (StateNO = [150,155])
Trigger1 = StateType != A && Pos Y = 0
Trigger1 = GetHitVar(Guarded)  = 1
Trigger1 = MoveType = H
Trigger1 = GetHitVar(HitShakeTime) > 0
Trigger1 = !HitOver
Value = 3500
IgnoreHitPause = 1

