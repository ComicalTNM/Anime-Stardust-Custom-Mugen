;Lose
[StateDef 170]
Type = S
MoveType = I
Physics = S
Ctrl = 0
Anim = 170
SprPriority = 2

[State 170, AssertSpecial]
Type = AssertSpecial
Trigger1 = Time = [0,60]
Flag = RoundNotOver
IgnoreHitPause = 1

