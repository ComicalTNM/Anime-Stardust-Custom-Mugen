;Lose - Draw
[StateDef 175]
Type = S
MoveType = I
Physics = S
Ctrl = 0
Anim = 170
SprPriority = 2

[State 175, AssertSpecial]
Type = AssertSpecial
Trigger1 = Time = [0,60]
Flag = RoundNotOver
IgnoreHitPause = 1
;---------------------------------------------------------------------------
;Win
[StateDef 180]
Type = S
MoveType = I
Physics = S
Ctrl = 0
SprPriority = 2

[State 180, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Value = Cond(Random%2 = 0,182,180)
IgnoreHitPause = 1

;Anim 180

[State 180, PlaySnd]
Type = PlaySnd
Trigger1 = Anim = 180
Trigger1 = !AnimElemTime(13)
Trigger1 = !MatchOver
Value = S180, (Var(33) := 0)
VolumeScale = 80
IgnoreHitPause = 1
Persistent = 0

[State 180, PlaySnd]
Type = PlaySnd
Trigger1 = Anim = 180
Trigger1 = !AnimElemTime(13)
Trigger1 = MatchOver
Value = S180, (Var(33) := 1 + Random%2)
VolumeScale = 80
IgnoreHitPause = 1
Persistent = 0

[State 180, PlaySnd]
Type = PlaySnd
TriggerAll = Anim = 180
Trigger1 = !AnimElemTime(3)
Trigger2 = !AnimElemTime(7)
Value = S6000, 0 + Random%4
IgnoreHitPause = 1

[State 180, PlaySnd]
Type = PlaySnd
TriggerAll = Anim = 180
Trigger1 = !AnimElemTime(3)
Trigger2 = !AnimElemTime(7)
Value = S6001, 0 + Random%4
IgnoreHitPause = 1

[State 180, AssertSpecial]
Type = AssertSpecial
Trigger1 = Anim = 180
Trigger1 = Var(33) = 0
Trigger1= Time = [45,155]
Trigger2 = Anim = 180
Trigger2 = Var(33) = 1
Trigger2= Time = [45,240]
Trigger3 = Anim = 180
Trigger3 = Var(33) = 2
Trigger3= Time = [45,210]
Flag = RoundNotOver
IgnoreHitPause = 1

;Anim 182

[State 180, PlaySnd]
Type = PlaySnd
Trigger1 = Anim = 182
Trigger1 = !AnimElemTime(1)
Value = S180, (Var(33) := 3 + Random%2)
VolumeScale = 80
IgnoreHitPause = 1
Persistent = 0

[State 180, AssertSpecial]
Type = AssertSpecial
Trigger1 = Anim = 182
Trigger1 = Var(33) = 3
Trigger1 = Time = [0,105]
Trigger2 = Anim = 182
Trigger2 = Var(33) = 4
Trigger2 = Time = [0,110]
Flag = RoundNotOver
IgnoreHitPause = 1


