;Var(35) - In Ultimate
;Var(34) - Palette
;Var(33) - Random Voice Lines in Certain States
;Var(32) - Skill Lvl 1 || Lvl 2 || Lvl 3 Used
;Var(31) - Uses a Basic Skill to Cancel another Basic Skill 1x
;Var(30) - Air Dash Limit
;Var(29) - Hold Button to maker a strongest attack
;Var(28) - HitPauseTime (Used in Helpers)
;Var(27) - Spark Pos Y (Used in Helpers)
;Var(26) - Spark Pos X (Used in Helpers)
;Var(25) - Spark Type (Used in Helpers)
;Var(22)  - Hits Limit to Start Dampener
;Var(21) - Hits in Actual Combo
;Var(20) -  Random Numbers for IA (0 - 80)

;Var(19) - Agressor Width
;Var(18) - Agressor Pos X
;Var(17) - Stores the last generated ID
;Var(16) - Agressor ID
;Var(15) - Shield State Time
;Var(14) - Points for Fill Gauge and use Parry (Used in Helpers)
;Var(13) - Hold X Active in GuardState 
;Var(12) - Shield System Active/Desactive
;Var(11) - Shield Effect Pos Y
;Var(10) - Shield Effect Pos X

;Var(9) - Pos Y For Gauge
;Var(8) - Pos X For Gauge

;Var(7) - Limit Awaken One Use Per Round
;Var(6) - Awaken System Active/Desactive
;Var(5) - Awaken On

;Var(4) - Fourth Bar Unlock

;Var(3) -  Burst Active/Desactive

;Var(2) - AirJump Config
;Var(1) - AirJump Limit
;Var(0) - Active WindLines in Jump after Run

;Fvar(39) - Custom P2BodyDist
;Fvar(38) - CornerPush

