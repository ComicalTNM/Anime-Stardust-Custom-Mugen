Trigger1 = Command != "holdup"
var(2) = 0
IgnoreHitPause = 1

[State -1, Null]
Type = Null
Trigger1 = StateNO != 110  && StateNO != 115 && StateNO != 40  && Var(30) && Pos Y = 0 && StateType = S
Trigger1 = Var(30) := 0
IgnoreHitPause = 1

[State -1, Null]
Type = Null
Trigger1 = (StateNO != [1000,1999])
Trigger1 = Var(31) := 0 
IgnoreHitPause = 1

[State -1, Null]
