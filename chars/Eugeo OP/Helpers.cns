Trigger1 = AnimElemTIme(4) < 0
Trigger1 = !NumExplod(253)
Anim = 253
ID = 253
Pos = Var(1) * Facing, Var(2)
Space = Stage 
Facing = Facing
BindTime = -1
BindID = ID
RemoveTime = -1
Scale = (1.25 + ((Cos((GameTime + Time) / 16.0 * PI) * 1.0) * ((Cos((GameTime + Time) / 42.0 * PI) * 1.0) * ((Cos((GameTime + Time) / 56.0 * PI) * 1.0) * 0.25)))),(1.25 + ((Cos((GameTime + Time) / 16.0 * PI) * 1.0) * ((Cos((GameTime + Time) / 42.0 * PI) * 1.0) * ((Cos((GameTime + Time) / 56.0 * PI) * 1.0) * 0.25))))
