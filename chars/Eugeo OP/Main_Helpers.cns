Trigger1 = Cond(Floor(Const(Size.YScale)) != 0,Root,StateNO != Floor(Const(Size.YScale)) ,1)
Trigger1 = Cond(Floor(Const(Size.Mid.Pos.X)) != 0,Root,StateNO != Floor(Const(Size.Mid.Pos.X)),1)
Trigger1 = Cond(Floor(Const(Size.Mid.Pos.Y)) != 0,Root,StateNO != Floor(Const(Size.Mid.Pos.Y)),1)
