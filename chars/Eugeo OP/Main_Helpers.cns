Trigger1 = Cond(Floor(Const(Size.Ground.Back)) != 0,Root,StateNO != Floor(Const(Size.Ground.Back)),1)
Trigger1 = Cond(Floor(Const(Size.Ground.Front)) != 0,Root,StateNO != Floor(Const(Size.Ground.Front)),1)
Trigger1 = Cond(Floor(Const(Size.Air.Back)) != 0,Root,StateNO != Floor(Const(Size.Air.Back)),1)
Trigger1 = Cond(Floor(Const(Size.Air.Front)) != 0,Root,StateNO != Floor(Const(Size.Air.Front)),1)
