; GUARD (Start)
[StateDef 120]
Type = U   
Physics = U 
SprPrioritY = 0
FaceP2 = 1

[State 120, VelAdd]
Type = VelAdd
Trigger1 = PrevStateNO = 110 || PrevStateNO = 115
Trigger1 = !Time
X = Cond(PrevStateNO = 115,Abs(Vel X / 2),-(Vel X / 2))
IgnoreHitPause = 1
Persistent = 0

[State 120, Null]
Type = Null
TriggerAll = Var(12)
TriggerAll = !Time
Trigger1 = !AiLevel
Trigger1 = ((Command = "holdx" && Command != "holdback" ) || (Command = "holdx" && Command = "holdback")) 
Trigger1 = Var(13) := 1
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = Var(14) > 2 || (Var(5) && Power = PowerMax)
Trigger2 = EnemyNear,MoveType = A && Var(20) = [(0 * AiLevel),(5 * AiLevel)]
Trigger2 = Var(13) := 1
IgnoreHitPause = 1
Persistent = 0

[State 120, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Var(12)
Trigger1 = Var(13)
Trigger1= Var(14) := (Var(14) - 1)
IgnoreHitPause = 1
Persistent = 0

[State 120, VarAdd]
Type = VarAdd
Trigger1 = StateNO = StateNO ; 120
var(15) = 1
IgnoreHitPause = 1

[State 120, PlaySnd]
Type = PlaySnd
Trigger1 = Var(12)
Trigger1 = Var(13)
Trigger1 = !AnimTime
Value = S4015, 0
IgnoreHitPause = 1
Persistent = 0

[State 120, CtrlSet]
Type = CtrlSet
Trigger1 = !Time
Value = 0
IgnoreHitPause = 1

[State 120, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Value = 120 + (StateType = C) + (StateType = A)*2
Persistent = 0

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = S
Physics = S

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = C
Physics = C

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = A
Physics = A

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = StateType = S && Command = "holddown" 
StateType = C
Physics = C

[State 120, StateTypeSeti]
