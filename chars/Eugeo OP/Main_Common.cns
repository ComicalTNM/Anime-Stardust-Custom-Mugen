;---------------------------------------------------------------------------
; Stand to Crouch
[StateDef 10]
Type    = C
Physics = C
Anim = 10

[State 10, CtrlSet]
Type = CtrlSet
Trigger1 = !Time
Trigger1 = AiLevel
Value = 0
IgnoreHitPause = 1

[State 10, VelMul]
Type = VelMul
Trigger1 = !Time
X = .75

[State 10, VelSet] 
Type = VelSet
Trigger1 = Abs(Vel x) < Const(Movement.Crouch.Friction.Threshold)
X = 0

[State 10, ChangeState]
Type = ChangeState
Trigger1 = !AnimTime
Value = 11
Ctrl = 1

;---------------------------------------------------------------------------
; Crouching
[StateDef 11]
Type    = C
Physics = C
Anim = 11
SprPrioritY = 0

[State 11, ChangeAnim] 
Type = ChangeAnim
Trigger1 = Anim = 6 && !AnimTime
Value = 11

[State 11, VelSet]
Type = VelSet
Trigger1 = Abs(Vel x) < Const(Movement.Crouch.Friction.Threshold)
X = 0

