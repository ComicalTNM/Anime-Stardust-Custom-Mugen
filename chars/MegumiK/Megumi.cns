sprpriority = -1
ontop = 1
ownpal = 1
supermovetime = 9999
pausemovetime = 9999
removeongethit = 0
ignorehitpause = 0
[State 0, VelSet] ; Tracking Phase (Opponent Above)
type = VelSet
triggerall = p2bodydist y <= 0 
trigger1 = time = [1,11]
x = cond(P2Dist X < 0, 4, 6)
y = p2bodydist y / 16

[State 0, VelSet] ; Tracking Phase (Opponent Below)
type = VelSet
triggerall = p2bodydist y > 0 
trigger1 = time = [1,11]
x = cond(P2Dist X < 0, 3, 6) 
y = cond(((p2dist y = [-20,20])&&enemynear,statetype=L), 3, p2bodydist y / 15) ; Conditional vertical tracking

[State 0, AngleDraw]
type = AngleDraw
trigger1 = time < 11
value = cond(vel x =0,0,-vel x*5);vel y*3
scale = 1,1
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = Time >= 10
x = 0
y = 0
[State 0, AngleDraw]
type =AngleDraw
trigger1 = Time >= 10
value =0-p2bodydist y ;+var(3)
[State 0, Turn]
type = Turn
Triggerall = Time >= 10
trigger1 = p2dist X < Const720p(-10)
[state 501,1]
type = PosAdd
trigger1 = Time >= 10
x = 9*((p2bodydist x)/(abs(p2bodydist x - 0) + abs(p2bodydist y - 20) + 0.0000001))
y = 9*((p2bodydist y -20)/(abs(p2bodydist x- 0)+abs(p2bodydist y - 20) + 0.0000015))

