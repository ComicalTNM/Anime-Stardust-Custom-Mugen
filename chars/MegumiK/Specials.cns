[State 1000, ChangeState Forward]
type = ChangeState
triggerall = Helper(1020),movecontact = 1 
triggerall = Helper(1020),stateno != 1021 ;
trigger1 = ailevel = 0 && (command = "fwd" || command = "holdfwd")  
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)      
value = 1001                      


[State 1000, ChangeState Back]
type = ChangeState
triggerall = Helper(1020),movecontact = 1
trigger1 = ailevel = 0 && (command = "back" || command = "holdback")
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = 1002                       

; Down Input: Change to 1003
[State 1000, ChangeState Down]
type = ChangeState
triggerall = Helper(1020),movecontact = 1
triggerall = Helper(1020),stateno != 1021 ;
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
trigger1 = ailevel = 0 && (command = "down" || command = "holddown")    
value = 1003         

[State 200, End]
type = ChangeState
triggerall = Helper(1020),movecontact = 1
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = 200


