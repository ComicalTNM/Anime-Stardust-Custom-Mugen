; Start
[Statedef 160]
type    = A
movetype= I
physics = N
anim = 160
sprpriority = 1

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 20*Helper(999999),Fvar(16),5*Helper(999999),Fvar(16)

[State 0, Trans]
type = Trans
trigger1 = time < 5
trans = addalpha
alpha = 0+time*50,256-time*50

[State 200, End]
type = Destroyself
trigger1 = root,stateno != [120,155]

[State 200, End]
