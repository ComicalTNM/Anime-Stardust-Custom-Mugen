crouch.friction = .82

[Quotes]
victory1 = "Yeah! I did it! I didn't have to doubt myself for that!"
victory2 = "As Sonic would do. He wouldnt give up. So I cant give up!"
victory3 = "Whew... That was a tough fight. My tech is overheated."
victory4 = "Yeah. Don't underestimate a young 8 year old fox like me!"
victory5 = "That wasn't too bad! You gotta try better next time if you fight me."
victory6 = "Not really too shabby! Even for a young Smart fox boy!"
victory7 = "I just knew I could do it! I'm just as cool as Sonic!"
victory8 = "Hey how's that! Ya cant underestimate me! being an 8 year old fox!"
victory9 = "I can't always depend on sonic. Everything is a brand new challenge for me!"
victory10 = "Alright! Now I can keep it up with Sonic!"
