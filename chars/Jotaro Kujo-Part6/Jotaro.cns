[Statedef 160]
type    = A
movetype= I
physics = N
juggle  = 2
ctrl = 0
anim = 160
velset = 0,0
sprpriority = 3

[State 0, PlaySnd]
type = PlaySnd
triggerall = prevstateno != [1,99999]
trigger1 = time = 0
value = S1,18
volumescale = 150

[State 0, BindToParent]
type = BindToroot
trigger1 = time >=0
time = 1
pos = 15,0

[State 0, Trans]
type = Trans
triggerall = prevstateno != [1,99999]
trigger1 = time < 5
trans = addalpha
alpha = 0+time*25,256-time*25

[State 0, DestroySelf]
type = changestate
trigger1 =root,stateno != [120,155]
value = 345

[State 0, DestroySelf]
type = changestate
trigger1 = root,stateno = 140
value = 161
