trigger1 = Vel Y >= cond(anim = 5050+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10), 1, -2)
trigger1 = SelfAnimExist(anim+10)
value = anim+10
persistent = 0

