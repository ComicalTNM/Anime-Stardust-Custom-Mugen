value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 9999

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 1
ignorehitpause = 1

[State 5080, 1] ;Set default anim
type = VarSet
trigger1 = time = 0
sysvar(2) = cond(GetHitVar(yvel) = 0, 5080+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10), 5090+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10))

[State 5080, 2]
type = VarAdd
trigger1 = time = 0
trigger1 = (anim = [5081+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000,5089+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000])+var(10) || (anim = [5111+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000,5119+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000])+var(10)
trigger1 = SelfAnimExist(sysvar(2) + (anim % 10))
sysvar(2) = anim % 10

[State 5080, 3] ;If 5090 doesn't exist, default to 5030
type = VarSet
trigger1 = time = 0
trigger1 = sysvar(2) = 5090+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)
trigger1 = !SelfAnimExist(5090+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000)
sysvar(2) = 5030+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)

[State 5080, 3] ;Freeze
type = ChangeAnim
trigger1 = 1
value = sysvar(2)

[State 0, ChangeState]
