trigger1 = Time = 0
trigger1 = GetHitVar(animtype) = [3,5]
value = 5030+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)

[State 5000, 3] ;Anim for HIT_UP/HIT_DIAGUP (only if it exists)
type = ChangeAnim
trigger1 = Time = 0
