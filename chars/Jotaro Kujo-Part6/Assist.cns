value = s5000+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000,0+fvar(1)
volumescale = 255
ignorehitpause = 1

[State 15000, 1] ;Anim for HIT_LIGHT to HIT_HARD
type = ChangeAnim
trigger1 = Time = 0
trigger1 = GetHitVar(animtype) != [3,5]
value = cond((GetHitVar(groundtype) = 1),5000+var(10)+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000,5010+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)) + GetHitVar(animtype)

[State 5000, 2] ;Anim for HIT_BACK
