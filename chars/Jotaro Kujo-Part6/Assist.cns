trigger1 = anim = 5000+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)
trigger2 = anim = 5010+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)
persistent = 0
time = 6
waveform = square

[State 5000, FFB Medium]
