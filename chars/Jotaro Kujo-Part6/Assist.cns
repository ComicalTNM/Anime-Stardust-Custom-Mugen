trigger2 = Time = 0     ;If no transition anim
trigger2 = Anim != 5035+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000+var(10)
trigger2 = (Anim != [5051+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000, 5059+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000])+var(10) && (Anim != [5061+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000, 5069+cond(ishelper(6100),10000,0)+(root,var(54)-1)*10000])+var(10)
