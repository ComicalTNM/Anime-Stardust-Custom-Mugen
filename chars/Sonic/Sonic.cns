TriggerAll = (Time >= 24)
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = cond(pos y>=0,260,620)
ignorehitpause = 0

[State 200, End]
type = ChangeState
trigger1 = AnimTime = 0
value = cond(pos y>=0,0,50)
ctrl = 1
;-------------------------------------------------------------------------------
; A + B Escape
[Statedef 292]
type    = S
movetype= A
physics = S
juggle  = 1
ctrl = 0
anim = 292
poweradd = 30
velset = 0,0
sprpriority = 2

[State 0, PlaySnd]
type = PlaySnd
trigger1 =! Time
value = S200,4
volume = 999

[State 0, PlaySnd]
type = PlaySnd
trigger1 = Time = 4
value = S8,5+random%2
volume = 999

[State 0, VelSet]
type = VelSet
trigger1 = AnimElemTime(4)=0
x = 8
[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = AnimElemTime(4)=0
physics = N

[State 0,Turn]
type=Turn
trigger1 = AnimElemTime(9)>=0 && p2bodydist x<-0
trigger1 = AnimElemTime(9)<=2

[State 0, VelSet]
type = VelSet
trigger1 = AnimElemTime(8)=0
x = 3
[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = AnimElemTime(8)=0
physics = S

[State 0, PlayerPush]
type = PlayerPush
trigger1 = AnimElemTime(4)>=0 && AnimElemTime(9) < 0
value = 0
ignorehitpause = 1

[State 0, AfterImage]
type = Helper
Trigger1 = AnimElemTime(3)>=0 && AnimElemTime(9)<=0
trigger1 = (timemod = 6,0)
helpertype = normal
stateno = 7015
pos = 0,0
postype = p1
facing = 1
ownpal = 1
Size.Xscale = Const(Size.Xscale)
Size.Yscale = Const(Size.Yscale)
ignorehitpause = 1
SuperMoveTime = 9999
PauseMoveTime = 9999

[State 200, End]
type = ChangeState
TriggerAll = (Time >= 24)
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/4
value = 200
ignorehitpause = 0

[State 200, End]
type = ChangeState
TriggerAll = (Time >= 24)
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/4
value = 3230
ignorehitpause = 0

[State 200, End]
type = ChangeState
TriggerAll = (Time >= 24)
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 260
ignorehitpause = 0

[State 200, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
