name = "Spin Kick - FX"
ID = 01
stateno = 405
Pos = 5,-8
postype = p1
facing = 1
ownpal = 1
size.xscale = 1
size.yscale = 1
ignorehitpause = 1
Persistent = 0

[State 0, TargetBind]
type = TargetBind
trigger1 = movehit = 1
time = 1
id = -1
pos = 35,-3
ignorehitpause = 1

[State 0, Hit]
type = PlaySnd
trigger1 = MoveHit = 1
value = S4,32+random%2
volumescale = 100
ignorehitpause = 1
Persistent = 6

[State 200, 1]
type = HitDef
hitflag = MAFD
trigger1 = timemod = 8,0
attr = A,NA
;hitflag = MAFD
guardflag = MA
animtype = Light
damage = 7,4
pausetime = 2,6
guard.pausetime = 2,10
guard.sparkno = s7000
sparkxy = -8,-25
guardsound = S4,1
ground.type = Low
ground.slidetime = 18
ground.hittime = 15
ground.velocity = -1.5
air.velocity = -0.5,-1.2
EnvShake.Time = 7
EnvShake.Ampl = -7
EnvShake.Freq = 10
fall = 1
fall.recover = 0

[State 0,Mid Light - Hit Spark]
type = Helper
trigger1 = MoveHit = 1
helpertype = normal
ID = 8025
stateno = 8025
pos = Cond((P2Dist X<55),P2Dist X+0,45),-20
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .095*0.90
size.yscale = .095*0.90
ignorehitpause = 1
PERSISTENT = 5

[State 200, End]
type = ChangeState
TriggerAll = time >= 30 && time <= 35
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = 610

[State 200, End]
type = ChangeState
TriggerAll = time >= 30 && time <= 35
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/3
value = 620

[State 200, End]
type = ChangeState
TriggerAll = time >= 30 && time <= 35
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "c"
trigger2 = RoundState = 2 && AILevel > 0 && Random<(AILevel*100)*4
value = 635

[State 200, End]
type = ChangeState
trigger1 = Time = 55
value = 50
ctrl = 0

