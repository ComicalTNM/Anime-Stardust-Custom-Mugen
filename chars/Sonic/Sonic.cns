;---------------------------------------------------------------------------
; Down + C Homing Attack
[Statedef 450]
type    = S
movetype= A
physics = N
juggle  = 2
ctrl = 0
anim = coND(VAR(2) = 6,111450,450)
poweradd = 20
sprpriority = 2
facep2 = 1
[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
[State 0, PlaySnd] 
type = PlaySnd
trigger1 = animelem = 6
value = S200,21+Random%1
persistent = 0
[State 0, Turn]
type = Turn
trigger1 = p2dist X < Const720p(-10)
[State 0, PosAdd]
type = PosAdd
trigger1 = 1
x = 10*((p2bodydist x -0)/(abs(p2bodydist X - 0) + abs(p2bodydist y - 20) + 0.0000001))
y = 10*((p2bodydist y -20)/(abs(p2bodydist x - 0) + abs(p2bodydist y - 20) + 0.0000015))

[State 0,ChangeAnim]
type = ChangeAnim
TriggerAll = AnimElemTime(12)<=0
triggerall = Time > 15 && time < 23
Trigger1 = Timemod = 8,0
value = Anim
elem = 8
[State 0, ChangeAnim]
type = ChangeAnim
TriggerAll = AnimElemTime(8)>=0 && AnimElemTime(12)<=0
Trigger1 = MoveContact
value = anim
elem = 12
Persistent = 0

[State 0, EnvShake]
type = EnvShake
trigger1 = animelem = 6
time = 5
ampl = -4

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S8,43
volume = 999

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 6
value = S8,50
volume = 999

[State 0, AfterImage]
type = Helper
TriggerAll = AnimElemTime(12)<=0
trigger1 = (time >= 10) && (timemod = 4,0)
helpertype = normal
stateno = 7015
pos = 0,0
postype = p1
facing = 1
ownpal = 1
size.xscale = 1.2
size.yscale = 1.2
ignorehitpause = 1
SuperMoveTime = 9999
PauseMoveTime = 9999

[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = time = 10
statetype = A       
movetype = A       
physics = N         

[State 0, VelSet]
type = VelSet
trigger1 = !time
y = -1

[State Null]
type = Null
trigger1 = (!Time)
trigger1 = (FVar(16) := (P2Dist X * 10) / (Exp(0.5*ln((P2Dist X * P2Dist X) + (P2Dist Y * P2Dist Y)))))
trigger1 = (FVar(17) := (P2Dist Y * 10) / (Exp(0.5*ln((P2Dist X * P2Dist x) + (P2Dist Y * P2Dist Y)))))
  
[State  VelSet]
type = VelSet
trigger1 = animelem = 6
x = FVar(16)
y = FVar(17)

[State 0, StateTypeSet]
type = StateTypeSet
Trigger1 = AnimElemTime(12)=0
statetype = A       
movetype = A       
physics = A

[State 0, VelSet]
type = VelSet
trigger1 = MoveHit = 1
x = -4.5
y = -4.5

[State 0, VelSet]
type = VelSet
trigger1 = MoveGuarded = 1
x = -4.5
y = -4.5
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
Trigger1 = AnimElemTime(12)=0
x = 2
y = -2.5

[State 0,Homing Attack - Speed Helper]
type = Helper
trigger1 = AnimelemTime(6)=0
name = "Homing Attack - Speed Helper"
ID = 465
stateno = 465
Pos = -5,-10
postype = p1
facing = 1
ownpal = 1
size.xscale = .08
size.yscale = .08
ignorehitpause = 1
Persistent = 0

[State 0, Hit]
type = PlaySnd
trigger1 = MoveHit = 1
value = S1,32+random%2
volumescale = 100
ignorehitpause = 1
Persistent = 0

[State 200, 1]
type = HitDef
hitflag = MAFD
trigger1 =! MoveContact
Attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT,AA,AP,AT
Priority = 99999,Hit
animtype = Medium
damage = 18,9
pausetime = 7,39
guard.pausetime = 8,8
guard.sparkno = s7000
sparkxy = -8,-18
guardsound = S4,1
ground.type = High
ground.slidetime = 18
ground.hittime = 15
ground.velocity = -2.5,-5.5
air.velocity = -2.5,-5.5
EnvShake.Time = 9
EnvShake.Ampl = -9
EnvShake.Freq = 15
fall = 1
GetPower = 50,20
[State 0,Mid Hit Spark]
type = Helper
trigger1 = MoveHit = 1
helpertype = normal
ID = 8010
stateno = 8010
pos = Cond((P2Dist X<55),P2Dist X+0,45),-22
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .088*0.90
size.yscale = .088*0.90
ignorehitpause = 1
PERSISTENT = 0

[State 200,Chain]
TRIGGERALL = VAR(2) != 6
type = ChangeState
TriggerALL = AnimElemTime(14)>=0
Triggerall = MoveContact
trigger1 = ailevel = 0 && Command = "FF"
trigger2 = roundstate = 2 && ailevel > 0 && random<(ailevel * 100)/2
value = 110
ignorehitpause = 1

[State 200, Chain]
type = ChangeState
TRIGGERALL = VAR(2) != 6
TriggerALL = AnimElemTime(14)>=0
TriggerAll = Power >= 200
Triggerall = MoveContact
trigger1 = ailevel = 0 && Command = "holddown" && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/8
value = 455

[State 200, end]
type = ChangeState
TRIGGERALL = VAR(2) != 6
TriggerALL = AnimElemTime(14)>=0
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = COnd(pos y < 0,600,200)
ctrl = 1

[State 200, end]
type = ChangeState
TRIGGERALL = VAR(2) != 6
TriggerALL = AnimElemTime(14)>=0
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = COnd(pos y < 0,615,230)
ctrl = 1

[State 200, End]
type = ChangeState
TRIGGERALL = VAR(2) != 6
TriggerALL = AnimElemTime(14)>=0
Triggerall = movecontact
trigger1 = ailevel = 0 && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/4
value = COnd(pos y < 0,630,260)

[State 0,End]
type = ChangeState
TRIGGERALL = VAR(2) != 6
TriggerAll = AnimElemTime(12)<=0
trigger1 = time > 10
trigger1 = pos y >= -0
value = 451
ctrl = 0

