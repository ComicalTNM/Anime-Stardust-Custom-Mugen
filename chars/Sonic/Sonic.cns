; A - 5
[Statedef 251]
type    = A
movetype= A
physics = N
juggle  = 1
ctrl = 0
anim = 256
poweradd = 30
velset = 0,0
sprpriority = 2

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 4
value = S8,0+random%4

[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElemTime(5)=0
value = S9,1
volume = 50

[State 0, Posadd]
type = Posadd
trigger1 = AnimElemTime(5)=0
x = p2bodydist x - 5
y = p2bodydist y + -10
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = Animelemtime(5)>=0
x = 0.5
y = -0

[State 0, Hits Falsos - Helper]
type = Helper
triggerAll = AnimElemTime(5)>=0
trigger1 = timemod = 4,0
helpertype = normal
name = "Hits Falsos"
ID = 252
stateno = 252
pos = -20+random%60,30-random%80
postype = p1
facing = ifelse(random < 500,1,-1)
ownpal = 1
size.xscale = 3
size.yscale = .6

[State 0,TargetBind]
type = TargetBind
trigger1 = MoveHit = 1
time = 1
pos = 34,0
ignorehitpause = 1

[State 0, Hit]
type = PlaySnd
trigger1 = MoveHit = 1
value = S4,16
volumescale = 100
ignorehitpause = 1
Persistent = 6

[State 200, 1]
type = HitDef
hitflag = MAFD
trigger1 = timemod = 4,0
attr = A, SP
animtype  = Heavy
damage    = 4,2
;hitflag = MAFDE
guardflag = MA
pausetime = 0,20
sparkno = -1
guard.sparkno = s7000
sparkxy = -8,-5
hitsound   = -1
guardsound = -1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = -2
air.velocity = -2,-2
Fall = 0
Sprpriority = 3
Envshake.time = 10
Getpower = 0

[State 0,Helper]
type = Helper
triggerall = MoveHit >= 1
trigger1 = timemod = 6,0
helpertype = normal
ID = 8010
stateno = 8010
pos = 26+random%12,-34+random%28
postype = P1
facing = Cond(Random<500,1,-1)
ownpal = 1
size.xscale = .088*0.90
size.yscale = .088*0.90
ignorehitpause = 1
PERSISTENT = 6


[State 200, End]
type = ChangeState
Triggerall = movecontact && time >= 50
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 255

[State 200, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
