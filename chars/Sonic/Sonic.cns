; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = !Var(2)
Value =1100
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=1
Value =1600
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=2
Value =1500
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=3
Value =1700
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=4
Value =28300
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=5
Value =71000
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2)=6
Value =231000
Ctrl = 0
