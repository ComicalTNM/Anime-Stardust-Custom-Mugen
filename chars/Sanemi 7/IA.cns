;===========================================================================
;Basic:
;===========================================================================

[State 0, Run]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = 60

[State 0, Run Atras]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = 70


[State 0, Guard]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
TriggerALL = Random<(AILevel*100) || random < (ailevel * 100)/2
TriggerALL = Ctrl
TriggerALL = P2BodyDist X > -5
Trigger1 = (P2BodyDist X<50&&P2MoveType=A)||(Enemy,NumProj>0)
Trigger2 = ((P2BodyDist X=[-15,100])&&P2MoveType=A)||(Enemy,StateNo=[1000,2000])
trigger3 =((p2bodydist x<60)&&(p2stateno=[200,260])) ||  ((p2bodydist x<60)&&(p2stateno=[300,360])) ||  ((p2bodydist x<60)&&(p2stateno=[400,450])) || ((p2bodydist x<60)&&(p2stateno=[600,650]))
trigger4 = (p2bodydist x >= 0 && enemy,numproj > 0)
trigger5 = (p2bodydist x <= 100 && enemy,stateno=[1000,3000])
value = ifelse(statetype = A,132,130)


