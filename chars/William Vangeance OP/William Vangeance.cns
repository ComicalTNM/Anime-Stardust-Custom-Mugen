; Constants and state file.
; There are comments scattered through this file, so you may like to
; take a look if would like to learn more about the cns.

[Data]
life = 2000
power = 3000
attack = 130
defence = 135
fall.defence_up = 50
liedown.time = 60
airjuggle = 152132
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4.5
walk.back = -4.5
run.fwd  = 10
run.back = -7,-5
jump.neu = 0,-7.5
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 3500 ; STATENO: normal assist attack
StateTagAssistHyper = 1000 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.


[quotes]
victory0="I will protect the Clover kingdom's"
victory1="I couldn't fully believe in Master Julius, or in the future I had a duty to protect"
victory2="The members of the Golden Dawn are my pride and my dream!"

;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...

;---------------------------------------------------------------------------
; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 170
velset = 0,0

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; Win state decider
; CNS difficulty: basic
[Statedef 180]
type = S
ctrl = 0
anim = 180
velset = 0,0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
;trigger2 = time = 40
value = S500,15
volumescale = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
;trigger2 = time = 40
value = S500,15
volumescale = 999


[State 181, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = time <400
flag = roundnotover

;---------------------------------------------------------------------------
; Introduction
; CNS difficulty: basic
[Statedef 190]
type = A
ctrl = 0
anim = 190
velset = 0,0

[State 190, 4] ;Change to stand state
type = ChangeState
trigger1 = p2name = "Julius Novachrono"
value = 193
ctrl = 0

[State 0, PosSet]
type = PosSet
trigger1 = time= 0
y = -200

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 4
;trigger2 = time = 40
value = S500,16
volumescale = 999

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 0,0

[State 0, Explod]
type = Explod
trigger1 = timemod = 3,0  && time <= 13
anim = 7610+(random%4)
ID = 7610+(random%4)
pos = -35+(random%70),-50+(random%42)
postype = p1  ;p2,front,back,left,right
vel = 0,1.5
scale = .42,.42
sprpriority = 0

[State 0, Explod]
type = Explod
trigger1 = timemod = 3,0  && time <= 13
anim = 7610+(random%4)
ID = 7610+(random%4)
pos = -35+(random%70),-55+(random%35)
postype = p1  ;p2,front,back,left,right
vel = 0,1.5
scale = .47,.47
sprpriority = 5

[State 0, VelSet]
type = VelSet
trigger1 = time <80
x = 0
y = 2

[State 0, VelSet]
type = VelSet
trigger1 = time = [80,120]
x = 0
y = 0

[State 0, Helper]
type = Helper
trigger1 = time = 0
helpertype = normal ;player
name = "tree"
ID = 195
stateno = 195
pos = 20,3
postype = p1    ;p2,front,back,left,right
facing = 1

[State 190, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 190, 4] ;Change to stand state
type = ChangeState
trigger1 = Time = 100
value = 191
ctrl = 0
