;===============================================================================
; Var List
;-------------------------------------------------------------------------------
;Var(1) = Used for voices
;Var(2) = Used for random values
;Var(3) = Used for charged attacks
;Var(4) = Used for Air Dash limiter
;Var(7) = Boundary Push
;Var(8) = Infinite Void
;Var(10-??) = Transformations (If character has any)
;Var(57) = Palette Selector
;===============================================================================
; FVar List
;-------------------------------------------------------------------------------
;FVar(10) to FVar(30) Combo System
;-------------------------------------------------------------------------------
;===============================================================================
; States List
;------------------------------------------------------------------------------
;State 200-370 (Ground Attacks)
;State 400-420 (Crouch Attacks)
;State 500-515 (Power Charge)
;State 600-660 (Air Attacks)
;State 700-799 (???)
;State 800-899 (HitSparks)
;State 900-949 (Special Button) (Should replace until 989)
;State 950-959 (Installs) (Should replace with 4000)
;State 990-999 (Text Explods)
;State 1000-1600 (Specials)
;State 1900 (Guardbreak P2State)
;State 2000-2500 (Supers)
;State 3000 (Ultimate)
;State 9000-9001 (AfterImage)
;------------------------------------------------------------------------------
[Data]
life = 1700
attack = 90
defence = 100
fall.defence_up = 50	
liedown.time = 60		
airjuggle = 15		
sparkno = -1			
guard.sparkno = -1	
KO.echo = 0			
IntPersistIndex = 57	
FloatPersistIndex = 40  

[Size]
xscale = 1			;Horizontal scaling factor.
yscale = 1			;Vertical scaling factor.
ground.back = 10		;Player width (back, ground)
ground.front = 10		;Player width (front, ground)
air.back = 10		;Player width (back, air)
air.front = 10		;Player width (front, air)
height = 53			;Height of player (for opponent to jump over)
attack.dist = 100		;Default attack distance, 100 for close range characters
proj.attack.dist = 90	;Default attack distance for projectiles
proj.doscale = 0		;Set to 1 to scale projectiles too   
head.pos = 0, -45	;Approximate position of head
mid.pos = 0, -30		;Approximate position of midsection
shadowoffset = 0		;Number of pixels to vertically offset the shadow
draw.offset = 0,0		;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 1.5		;Walk forward
walk.back = -1.5		;Walk backward
run.fwd  = 0		;Run forward (x, y)
run.back = 0	;Hop backward (x, y)
jump.neu = 0,-7.5		;Neutral jumping velocity (x, y)
jump.back = -2.55		;Jump back Speed (x, y)
jump.fwd = 2.5		;Jump forward Speed (x, y)
runjump.back = -2.55,-8.1;Running jump speeds (opt)
runjump.fwd = 4,-8.1	;.
airjump.neu = 0,-8.1	;.
airjump.back = -2.55	;Air jump speeds (opt)
airjump.fwd = 2.5		;.

[Movement]
airjump.num = 5		;Number of air jumps allowed (opt)
airjump.height = 35	;Minimum distance from ground before you can air jump (opt)
yaccel = .44		;Vertical acceleration
stand.friction = .85	;Friction coefficient when standing
crouch.friction = .82	;Friction coefficient when crouching

[Constants]
switchAttack = 330 ; ANIM: Switch attack. 
;I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 620 ; ANIM: switch air attack.
snapBackAttack = 210 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 34365 ;765 ; STATENO: normal assist attack
StateTagAssistHyper = 34366 ;766 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

[Quotes]
victory1 = "I strive for something beyond the strongest, that challenging me would be the most ridiculous thought ever, that fighting me would be a sin!"
victory2 = "I’m too naive. With thoughts like If I saved someone maybe I can start all over again."
victory3 = "But then again, just because I’ve gotten weaker, it doesn’t mean that you got stronger, right?"

;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1= 1
Value = Cond(Random >= 500,1100,Cond(Random >= 500,1000,Cond(Random >= 500,1300,Cond(Random >= 500,1200,Cond(Random >= 500 && !NumHelper(6193) && NumHelper(6173) <= 2,6175,1400))))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

;-----------------------------------------------------------
; Assists Changer 2
;-----------------------------------------------------------
[StateDef 34366] ; Just To Make Sure 2 Cannons Are Placed In Mode
Type = S
MoveType = I
Physics = S
VelSet = 0,0
Anim = 11

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno-1
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1= 1
Value = Cond(Random >= 500,1100,Cond(Random >= 500,1000,Cond(Random >= 500,Cond(Random >= 750,Cond(Random >= 500,2000,2500),1300),Cond(Random >= 500,1200,Cond(Random >= 500 && !NumHelper(6193) && NumHelper(6173) <= 2,6175,1400))))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

