;==============================================
; Sistema de Choque de Dominio tipo Gojo vs Sukuna
; Variables utilizadas:
; var(53) = Flag para indicar si el choque de dominio está activo (1=activo, 0=inactivo)
; var(54) = Contador de fallos del jugador
; var(55) = Contador de fallos del enemigo
; var(56) = Botón actual que debe presionarse (1=y, 2=z, 3=b, 4=c, 5=a, 6=x)
; var(57) = Temporizador para botones
; var(58) = Duración del choque de dominio (aumenta con el tiempo)
; var(59) = Velocidad de aparición de botones (disminuye con el tiempo)
; var(60) = Flag para verificar si el botón fue presionado correctamente
;==============================================

; Inicialización del choque de dominio
[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(53) = 1  ; Activar flag de choque de dominio

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(54) = 0  ; Resetear contador de fallos del jugador

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(55) = 0  ; Resetear contador de fallos del enemigo

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(56) = 0  ; Botón actual (ninguno al inicio)

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(57) = 100  ; Temporizador para botones

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(58) = 50  ; Duración inicial para botones

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(59) = 50  ; Velocidad inicial de aparición

[State 3000, VarSet]
type = VarSet
trigger1 = Time = 0
var(60) = 0  ; Flag de botón presionado correctamente

; Generar botón aleatorio cada cierto tiempo
[State 3000, VarRandom]
type = VarRandom
trigger1 = var(57) = 0
v = 56
range = 1, 6  ; 1=y, 2=z, 3=b, 4=c, 5=a, 6=x

; Resetear temporizador para mostrar botones
[State 3000, VarSet]
type = VarSet
trigger1 = var(57) = 0
var(57) = var(59)  ; Establecer nuevo temporizador

; Reducir temporizador de botón
[State 3000, VarAdd]
type = VarAdd
trigger1 = 1
var(57) = -1

; Aumentar dificultad con el tiempo (más agresivo)
[State 3000, VarSet]
type = VarSet
trigger1 = Time % 400 = 0 && Time > 0 && var(59) > 40
var(59) = var(59) - 15  ; Reducir tiempo entre botones más rápidamente

; Comprobar si el jugador presiona el botón correcto
[State 3000, VarSet]
type = VarSet
trigger1 = var(56) = 1 && command = "y" && var(57) > 0 && var(57) < var(58)
trigger2 = var(56) = 2 && command = "z" && var(57) > 0 && var(57) < var(58)
trigger3 = var(56) = 3 && command = "b" && var(57) > 0 && var(57) < var(58)
trigger4 = var(56) = 4 && command = "c" && var(57) > 0 && var(57) < var(58)
trigger5 = var(56) = 5 && command = "a" && var(57) > 0 && var(57) < var(58)
trigger6 = var(56) = 6 && command = "x" && var(57) > 0 && var(57) < var(58)
var(60) = 1  ; Botón correcto

; Reproducir sonido de acierto
[State 3000, PlaySnd]
type = PlaySnd
trigger1 = (var(56) = 1 && command = "y") || (var(56) = 2 && command = "z") || (var(56) = 3 && command = "b") || (var(56) = 4 && command = "c") || (var(56) = 5 && command = "a") || (var(56) = 6 && command = "x")
value = 0, 178  ; Sonido de acierto
volumescale = 100

; Actualizar temporizador cuando se presiona el botón correcto
[State 3000, VarSet]
type = VarSet
trigger1 = var(60) = 1 && var(57) < var(58)
var(57) = 0
persistent = 0

; Resetear flag de botón presionado
[State 3000, VarSet]
type = VarSet
trigger1 = var(60) = 1
var(60) = 0

; Comprobar si el jugador presiona un botón incorrecto
[State 3000, VarAdd]
type = VarAdd
trigger1 = var(56) != 0 && var(57) > 0 && var(57) < var(58)
trigger1 = (var(56) != 1 && command = "y") || (var(56) != 2 && command = "z") || (var(56) != 3 && command = "b") || (var(56) != 4 && command = "c") || (var(56) != 5 && command = "a") || (var(56) != 6 && command = "x")
var(54) = 1  ; Incrementar contador de fallos
persistent = 0

; Reproducir sonido de fallo
[State 3000, PlaySnd]
type = PlaySnd
trigger1 = var(56) != 0 && var(57) > 0 && var(57) < var(58)
trigger1 = (var(56) != 1 && command = "y") || (var(56) != 2 && command = "z") || (var(56) != 3 && command = "b") || (var(56) != 4 && command = "c") || (var(56) != 5 && command = "a") || (var(56) != 6 && command = "x")
value = 0, 177  ; Sonido de fallo
volumescale = 100

; Reproducir sonido de fallo al agotarse el tiempo
[State 3000, PlaySnd]
type = PlaySnd
trigger1 = var(56) != 0 && var(57) = var(58)
value = 0, 177  ; Sonido de fallo
volumescale = 100

; Comprobar si se agotó el tiempo para presionar el botón
[State 3000, VarAdd]
type = VarAdd
trigger1 = var(56) != 0 && var(57) = var(58)
var(54) = 1  ; Incrementar contador de fallos cuando se agota el tiempo
persistent = 0

; Resetear temporizador cuando se agota el tiempo
[State 3000, VarSet]
type = VarSet
trigger1 = var(57) = var(58)
var(57) = 0
persistent = 0

