; Comprobar si el enemigo presiona el botón correcto (simula la IA)
[State 3001, VarSet]
type = VarSet
trigger1 = Random < 800 - (root, Time) / 10  ; La IA se vuelve menos precisa con el tiempo
trigger1 = root, var(56) != 0 && root, var(57) > 0 && root, var(57) < root, var(58) / 2
var(60) = 1  ; Botón correcto

; Resetear flag de botón presionado
[State 3001, VarSet]
type = VarSet
trigger1 = var(60) = 1
var(60) = 0

; Terminar el choque cuando el jugador gana
[State 3001, ChangeState]
type = ChangeState
trigger1 = root, var(55) >= 2
value = 3004  ; Estado de derrota para el enemigo
ctrl = 0

; Terminar el choque cuando el jugador pierde
[State 3001, ChangeState]
type = ChangeState
trigger1 = root, var(54) >= 2
value = 3005  ; Estado de victoria para el enemigo
ctrl = 0

