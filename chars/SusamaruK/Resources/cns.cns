Trigger1 = !Time
helperType = normal
name = "Spark"
ID = 981
Stateno = 981
pos = 0,0
PosType = P1
facing = -1
ownpal = 1
ignoreHitPause = 1
SuperMoveTime = 999
PauseMoveTime = 999

[State 200,End]
Type = Destroyself
Trigger1 = !AnimTime
