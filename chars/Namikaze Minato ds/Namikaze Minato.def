
[Info]
name = "Namikaze Minato"
displayname = "Minato(JT)"
versiondate = 3,25,2023
mugenversion = 1.1
author = "feiqiu"
pal.defaults = 1,2,3,4

; 人物文件
[Files]
sprite  = Minato.sff           ;图像文件
anim    = Minato.air           ;动作文件
sound   = Minato.snd           ;声效文件
cmd     = Minato.cmd           ;操作输入
cns     = Minato.cns           ;常量定义
stcommon = common1.cns      ;公用state (人物文件夹或者common文件夹中)
st = Minato.cns
st1 = IA.cns
st2 = Kyubi Mode.cns
st3 = Gamabunta.cns
[Palette Keymap]
a = 1
b = 2
c = 3
x = 4
y = 5
z = 6

a2 = 7
b2 = 8
c2 = 9
x2 = 10
y2 = 11
z2 = 12

; arcade模式的开头结局动画
[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
