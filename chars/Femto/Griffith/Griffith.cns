type = S
ctrl = 0
anim = 170
velset = 0,0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 4
value = S900,1


[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

