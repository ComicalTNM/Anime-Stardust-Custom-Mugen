;; Stand
[Statedef 500009]
type = S
physics = S
sprpriority = 0
anim = 500009




[state 0]
type = angledraw
triggerall = prevstateno != [190, 199]
trigger1 = time <= 3
scale = .95, 1.025 - (sin((time/ 50.0) * (pi / 2)) * 0.0125)
ignorehitpause = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0

[State 0, RemoveExplod]
