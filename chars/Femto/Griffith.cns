trigger1 = time= 0
id =  1050

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time= 0
id =  7110

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 0
id =  7900

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 0
id =  7901


[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0


