TriggerALL = IsHelper(000)
trigger1 = 1
x = -.5
ignorehitpause = 1
[State 0, VelSet]
type = VelSet
TriggerALL = IsHelper(001)
trigger1 = 1
x = -.5
ignorehitpause = 1

[State 0, PalFX]
type = PalFX
TriggerALL = IsHelper(000)
trigger1 = !Time
time = 9999999999999
add = 0,-50,-100
mul = 700,512,512
color = 0
ignorehitpause = 1
[State 0, PalFX]
type = PalFX
TriggerALL = IsHelper(001)
trigger1 = !Time
time = 9999999999999
add = 0,-50,-100
mul = 700,512,512
color = 0
ignorehitpause = 1

[State 0, VarSet]
