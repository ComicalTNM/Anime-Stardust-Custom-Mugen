TriggerALL = IsHelper(000)
trigger1 = !Time
value = 3
ignorehitpause = 1
[State 0, SprPriority]
type = SprPriority
TriggerALL = IsHelper(001)
trigger1 = !Time
value = 3
ignorehitpause = 1

[State 0, VelSet]
