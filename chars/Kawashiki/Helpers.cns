TriggerALL = IsHelper(000)
trigger1 = Time = [1,5]
fv = 7
value = .025
[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(000)
trigger1 = Time >=9
fv = 7
value = -.05

[State 0, VarAdd]
type = VarAdd
TriggerALL = IsHelper(000)
trigger1 = Time >= 9
fv = 8
value = 40

[State 0, AngleDraw]
