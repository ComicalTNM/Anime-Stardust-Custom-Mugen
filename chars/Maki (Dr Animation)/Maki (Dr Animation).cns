; Constants and state file.
; There are comments scattered through this file, so you may like to
; take a look if would like to learn more about the cns.
;---------------------- Integer variable list ----------------------

; var(0):= 909, 40, 45, 50, 55, 60, 132, 155, 5080, 5081, 5100, 5110
; var(1):= 167, 285, 2006, 3515, 981, 98010, 98011, 10200, 10201, 7803, 7801, 10500, 10501
; var(2):= 3999, 801, 802, 803, 804, 4545, 4502, -2, 7870, 7800
; var(3):= 4509, 7870, 7803, 7800, 101160
; var(4):= 2991, 7803, 7801
; var(5):= 7870, 7800
; var(6):= 7870, 7800
; var(7):= 7870, 7800
; var(8):= 7870, 7803
; var(9):= 4500
;var(10):= 4502, 98010, 98011, -2
;var(11):= -2
;var(12):= 3505, 3506, 3507, 3508, 3509, 3510, -2, 103000
;var(23):= -2
;var(40):= 167
;var(41):= 167
;var(47):= -2

;---------------------- Float variable list ----------------------

; fvar(1):= 101160
; fvar(2):= 101160
;fvar(31):= 167


[Data]
life = 2000
power = 3000
attack = 130
defence = 300
fall.defence_up = 50
liedown.time = 60
airjuggle =55 ;Dont fucking tpuch this faggot ass old man nanmed aki
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 999
IntPersistIndex = 0
FloatPersistIndex = 0

[Size]
xscale = .9
yscale = .9
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 5
walk.back = -5
run.fwd  = 10
run.back = -7,-5
jump.neu = 0,-7.5
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 101000 ; STATENO: normal assist attack
StateTagAssistHyper = 101400 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

[quotes]
victory0="What if someone who's looked down on like me became a great sorcerer?"
victory1="Don't go thinking you've been recognized or something."
victory2="Give up.."

;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...

;---------------------------------------------------------------------------
; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 180
velset = 0,0

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; Win state decider
; CNS difficulty: basic
[Statedef 180]
type = S
ctrl = 0
anim = 180
velset = 0,0

[State 230, end]
type = ChangeState
trigger1 = Time = 0 && random > 500
value = 181
ctrl = 1

[State 170, 1]
type = ChangeState
triggerall = var(2) = 1
trigger1 = Time = 0
value = 182

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 10
value = S500,17
volumescale = 999

[State 0, Explod]
type = Explod
triggerall = timemod =15,0  && time >= 0
trigger1 = var(10) = 1
anim = 6001
ID = 6001
pos = -0,0
postype = p1  ;p2,front,back,left,right
scale = .4,.4
sprpriority = 0

[State 181, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = time <180
flag = roundnotover

