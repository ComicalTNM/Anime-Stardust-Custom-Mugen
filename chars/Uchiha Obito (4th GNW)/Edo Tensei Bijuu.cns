; Edo Tensei - Start
[StateDef 2100]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 500
sprpriority = 2

[State 183, Zoom1]
type = zoom
triggerall = teammode != simul
trigger1 = Time < 73
pos = ((pos x) / (1/Camerazoom*1.5)) * CameraZoom, (pos y) / (1/Camerazoom*1.5) * CameraZoom
scale = 1.6/camerazoom
space = screen
lag = .7
ignorehitpause = 1
persistent = 1
supermovetime = 99999
pausemovetime = 99999

