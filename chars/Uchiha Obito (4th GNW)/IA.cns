[state -2, Enemy 4 ID T1 | Simul Mode]
type = varset
Triggerall = Enemynear,Teammode != Tag
Triggerall = !Var(57)
Triggerall = (Var(53)) && (Var(54))
;Triggerall = Teamside = 1
Triggerall = numenemy > 3
Triggerall = enemy(3),ID != ID ; prevent self ID
trigger1 = 1
var(57) = enemy(3),ID
[state -2, P8 ID | Tag Mode]
type = varset
Triggerall = !Var(57)
Triggerall = (Var(53)) && (Var(54))
Triggerall = Enemynear,Teammode = Tag
trigger1 = Enemynear,ID != Var(54) && Enemynear,ID !=  Var(53) && Enemynear,ID !=  Var(52)
var(57) = Enemynear,ID

