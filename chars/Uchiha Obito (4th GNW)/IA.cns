;V2
[state -2, P2 ID]
type = varset
Triggerall = !Var(52)
trigger1 = numenemy = 1
var(52) = enemy,ID

[state -2, P2 ID | Simul Mode]
type = varset
Triggerall = !Var(52)
trigger1 = numenemy > 1
var(52) = enemy(0),ID

[state -2, P4 ID | Simul Mode]
type = varset
;Triggerall = Teammode = Simul
Triggerall = !Var(53)
trigger1 = numenemy > 1
var(53) = enemy(1),ID
[state -2, P6 ID | Tag Mode]
type = varset
Triggerall = (Var(52))
Triggerall = Enemynear,Teammode = Tag
Triggerall = !Var(53)
trigger1 = Enemynear,ID !=  Var(52)
var(53) = Enemynear,ID
