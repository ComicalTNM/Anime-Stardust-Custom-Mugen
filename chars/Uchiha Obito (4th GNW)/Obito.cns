V = 1
value = 2 ; 1 = Type 1 | 2 = Type 2
ignorehitpause = 1
persistent = 1
[State 0, Enemy Defense UP?] ; Sets Defense UP ON or OFF When Madara or Edo Summons Are On Field
type = Varset
Trigger1 = !Var(2)
V = 2
value = 0 ; 1+ = ON | 0 = OFF
ignorehitpause = 1
persistent = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = !Root,Alive


