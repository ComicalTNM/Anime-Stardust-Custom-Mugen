;===============================================================================
;-------------------------------------------------------------------------------
; Madara - Stand
[StateDef 90000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 90000
sprpriority = 0

[State 0, ChangeState]
type = ChangeState
Triggerall = (Numhelper(90000))
Triggerall = (ishelper(90000)||ishelper(92200)||ishelper(92201)||ishelper(92202)||ishelper(92203)||ishelper(92204))
Trigger1 = Ishelper(90000)
trigger1 = (helper(90005),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger1 = pos y < 0
trigger2 = pos y < 0
value = 90045

[State 0, Turn]
type = Turn
trigger1 = p2dist x < -5

[State 0, PosSet]
type = PosSet
trigger1 = pos y >= 0
y = 0

[State 200, Walk FWD]
type = ChangeState
Triggerall = (Numhelper(90000))
Triggerall = (ishelper(90000)||ishelper(92200)||ishelper(92201)||ishelper(92202)||ishelper(92203)||ishelper(92204))
Trigger1 = Ishelper(90000)
trigger1 = (helper(90005),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger1 = p2bodydist x > 50
trigger1 = random < 200
trigger2 = p2bodydist x > 50
trigger2 = random < 200
value = 90100

[State 200, Walk FWD]
type = ChangeState
Triggerall = (Numhelper(90000))
Triggerall = (ishelper(90000)||ishelper(92200)||ishelper(92201)||ishelper(92202)||ishelper(92203)||ishelper(92204))
Trigger1 = Ishelper(90000)
trigger1 = (helper(90005),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger2 = p2bodydist x > 20
trigger2 = random < 50
value = 90020

[State 0, Run Atras]
type = ChangeState
Triggerall = (Numhelper(90000))
Triggerall = (ishelper(90000)||ishelper(92200)||ishelper(92201)||ishelper(92202)||ishelper(92203)||ishelper(92204))
Trigger1 = Ishelper(90000)
trigger1 = (helper(90005),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger1 = roundstate = 2
triggerall = backedgebodydist > 50
triggerall = abs(p2bodydist x) < 100 && p2movetype = A
triggerall = random < 25
trigger2 = roundstate = 2
value = 90110

[State 200, Jump]
type = ChangeState
Triggerall = (Numhelper(90000))
Triggerall = (ishelper(90000)||ishelper(92200)||ishelper(92201)||ishelper(92202)||ishelper(92203)||ishelper(92204))
Trigger1 = Ishelper(90000)
trigger1 = (helper(90005),fvar(30) > 0 && fvar(18) > fvar(17)*-1)
trigger1 = ishelper(90000)
trigger1 = random < 200-P2BodyDist x+var(9)/15
trigger2 = ishelper(90000)
trigger2 = enemynear,pos y <= -50 && random < 300
trigger3 = ishelper(90000)
trigger3 = random < 200-P2BodyDist x+var(9)/15
trigger4 = enemynear,pos y <= -50 && random < 300
value = 90040

[State 200, Leave]
type = ChangeState
Trigger2 = !(Numhelper(90000)) && Ishelper && !(ishelper(90000))
Trigger1 = (ishelper(90000))
trigger1 = (helper(90005),fvar(30) <= 0 ||fvar(18) <= fvar(17)*-1)
Trigger1 = 1
value = 90003
