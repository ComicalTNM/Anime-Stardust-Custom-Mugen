;===============================================================================
;--------------------------Constantes B�sicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[StateDef 0]
Type = S
Physics = S
SprPriority = 0

[State 0, DestroySelf]
Type = DestroySelf
Trigger1 = IsHelper

[State 0, Explod]
type = Explod
triggerall = Numexplod(1) = 0
triggerall = var(23)
trigger1 = timemod = 70,0
anim = 30001
ID = 1
pos = -10,-25
postype = p1
facing = -1
vfacing = 1
bindtime = 1
removetime = -2
scale = .4,.4
sprpriority = 4
removeongethit = 1
supermovetime = 999
angle = -35
ownpal=1

[State 0]
Type = ChangeAnim
Trigger1 = Anim != 0+Var(33)  &&  Anim != 5+Var(33)
Trigger2 = Anim = 5+Var(33)  &&  !AnimTime 
Value = 0+Var(33)

[State 0]
Type = VelSet
Trigger1 = !Time
Y = 0

[State 0] ;Stop moving if low Velocity or 4 ticks pass
Type = VelSet
Trigger1 = Abs(Vel X) < Const(Movement.Stand.Friction.Threshold)
Trigger2 = Time = 4
X = 0

[State 0] 
Type = ChangeState
Trigger1 = !Alive
Value = 5050
Ctrl = 0
;-------------------------------------------------------------------------------
; Stand to Crouch
[StateDef 10]
Type    = C
Physics = C
Anim = 10+Var(33)

[State 0]
Type = VelMul
Trigger1 = !Time
X = .75

[State 0]
Type = VelSet
Trigger1 = Abs(Vel X) < Const(Movement.Crouch.Friction.Threshold)
X = 0

[State 0]
Type = ChangeState
Trigger1 = !AnimTime
Value = 11
;---------------------------------------------------------------------------
; Crouching
[StateDef 11]
Type    = C
Physics = C
Anim = 11+Var(33)
SprPriority = 0

[State 0]
Type = ChangeAnim
Trigger1 = Anim = 6 +Var(33) &&  !AnimTime
Value = 11+Var(33)

[State 0]
Type = VelSet
Trigger1 = Abs(Vel X) < Const(Movement.Crouch.Friction.Threshold)
X = 0
;---------------------------------------------------------------------------
; Crouch to Stand
[StateDef 12]
Type    = S
Physics = S
Anim = 12+Var(33)

[State 0]
Type = ChangeState
Trigger1 = !AnimTime
Value = 0
;---------------------------------------------------------------------------
; Walk
[StateDef 20]
Type    = S
Physics = S
SprPriority = 0

[State 0, Walk // Run]
Type = PlaySnd
Trigger1 = AnimElem = 2
Trigger2 = AnimElem = 6
Value = S20,2
VolumeScale = 50

[State 0]
Type = VelSet
Trigger1 = Command = "holdfwd"
X = Const(Velocity.walk.fwd.x) + Cond(NumHelper(1950),1,0)
IgnoreHitPause = 1

[State 0]
Type = VelSet
Trigger1 = Command = "holdback"
X = Const(Velocity.walk.back.x) - Cond(NumHelper(1950),1,0)
IgnoreHitPause = 1

[State 0]
Type = ChangeAnim
TriggerAll = Vel X  >  0
Trigger1 = Anim != 20+Var(33)  &&  Anim != 5+Var(33)
Trigger2 = Anim = 5+Var(33)  &&  !AnimTime
Value = 20+Var(33)

[State 0]
Type = ChangeAnim
TriggerAll = Vel X < 0
Trigger1 = Anim != 21+Var(33)  &&  Anim != 5+Var(33)
Trigger2 = Anim = 5+Var(33)  &&  !AnimTime
Value = 21+Var(33)
;---------------------------------------------------------------------------
; Jump Start
[StateDef 40]
Type    = S
Physics = S
Anim = 40+Var(33)
Ctrl = 0
SprPriority = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = !Time
sysvar(1) = 0

[State 0]
Type = EnvShake
Trigger1 = !Time
Trigger1 = PrevStateNO = 100
Time = 10
Ampl = -5
Freq = 25

[State 0, VarSet]
Type = VarSet
Trigger1 = Command = "holdfwd"
Trigger2 = AILevel
Trigger2 = RoundState = 2
Trigger2 = PrevStateNO = 320
sysvar(1) = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = Command = "holdback"
sysvar(1) = -1

[State 0, Jump]
Type = PlaySnd
TriggerAll = StateNO = 40
TriggerAll = Time = [2,6]
Trigger1 = PrevStateNO != 100 && PrevStateNO != 320
Trigger1 = Command != "holdup" || Time = 6
Trigger2 = PrevStateNO = 100 || PrevStateNO = 320
Value = S40,5
VolumeScale = 50

[State 0, Explod]
Type = Explod
TriggerAll = Time = [2,6]
Trigger1 = PrevStateNO != 100 && PrevStateNO != 320
Trigger1 = Command != "holdup" || Time = 6
Trigger2 = PrevStateNO = 100 || PrevStateNO = 320
Anim = 7025
ID = 7025
Pos = (Pos X + CameraPos X) + (0 * Facing * Const(Size.XScale)),(Pos Y) + (0 * Const(Size.YScale))
Space = Stage
Facing = Facing
Scale = Cond((PrevStateNO = 100 || PrevStateNO = 320),.4 * Const(Size.XScale),((Time * .4) / 6 * Const(Size.XScale))),Cond((PrevStateNO = 100 || PrevStateNO = 320),.6 * Const(Size.XScale),((Time * .6) / 6 * Const(Size.XScale)))
SprPriority = 4
Shadow = 0,0,0
OwnPal = 1
IgnoreHitPause = 1
Trans = AddAlpha
Alpha = 256,256
Persistent = 0

[State 0, Explod]
Type = Explod
TriggerAll = Time = [2,6]
Trigger1 = PrevStateNO != 100 && PrevStateNO != 320
Trigger1 = Command != "holdup" || Time = 6
Trigger2 = PrevStateNO = 100 || PrevStateNO = 320
Anim = 11013
ID = 11013
Pos = (Pos X + CameraPos X) + (0 * Facing * Const(Size.XScale)),(Pos Y) + (0 * Const(Size.YScale))
Space = Stage
Facing = Facing
Scale = Cond((PrevStateNO = 100 || PrevStateNO = 320),.1 * Const(Size.XScale),((Time * .1) / 6 * Const(Size.XScale))),Cond((PrevStateNO = 100 || PrevStateNO = 320),.1 * Const(Size.XScale),((Time * .1) / 6) * Const(Size.XScale))
Angle = Cond(sysvar(1) = 1,Cond(PrevStateNO = 100,-30,-20),Cond(sysvar(1) = -1,Cond(PrevStateNO = 100,30,20),0))
SprPriority = 3
Shadow = 0,0,0
OwnPal = 1
RemoveOnGetHit = 1
Trans = AddAlpha
Alpha = 256,256
Persistent = 0

[State 0, VelSet]
Type = VelSet
TriggerAll = Time = [2,6]
Trigger1 = PrevStateNO != 100 && PrevStateNO != 320
Trigger1 = Command != "holdup" || Time = 6
Trigger2 = PrevStateNO = 100 || PrevStateNO = 320
X = Cond(sysvar(1) = 0, Const(Velocity.jump.neu.x), Cond(sysvar(1) = 1, Const(Velocity.jump.fwd.x) + Cond(NumHelper(1950),1,0), Const(Velocity.jump.back.x) - Cond(NumHelper(1950),1,0)))
Y = Cond((PrevStateNO = 100 || PrevStateNO = 320),Const(Velocity.Jump.Y),((Time * Const(Velocity.Jump.Y))/6)) - Cond(NumHelper(1950),1,0)

[State 0, VelAdd]
Type = VelAdd
Trigger1 = PrevStateNO = 100
Trigger1 = !AnimTime
X = Cond(Vel X  >  0,Const(Velocity.RunJump.Fwd.X) + Cond(NumHelper(1950),1,0),Const(Velocity.RunJump.Back.X) - Cond(NumHelper(1950),1,0))

[State 0]
Type = ChangeState
TriggerAll = Time = [2,6]
Trigger1 = PrevStateNO != 100 && PrevStateNO != 320
Trigger1 = Command != "holdup" || Time = 6
Trigger2 = PrevStateNO = 100 || PrevStateNO = 320
Value = 50
Ctrl = 1
;---------------------------------------------------------------------------
; AirJump Start
[StateDef 45]
Type    = A
Physics = N
Ctrl = 0
VelSet = 0,0

[State 45, 1]
Type = ChangeAnim
Trigger1 = SelfAnimExist(44)
Value = 44+Var(33)

[State 45, 2]
Type = ChangeAnim
Trigger1 = !SelfAnimExist(44)
Value = 41+Var(33)

[State 45, 3]
Type = VarSet
Trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
Type = VarSet
Trigger1 = Command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
Type = VarSet
Trigger1 = Command = "holdback"
sysvar(1) = -1

[State 45, 6]
Type = VelSet
Trigger1 = Time = 2
X = Cond(sysvar(1)=0, Const(Velocity.airjump.neu.x), Cond(sysvar(1)=1, Const(Velocity.airjump.fwd.x), Const(Velocity.airjump.back.x)))
Y = Const(Velocity.airjump.y)

[State 45, 7]
Type = ChangeState
Trigger1 = Time = 2
Value = 50
Ctrl = 1
;---------------------------------------------------------------------------
; Jump Up
[StateDef 50]
Type    = A
Physics = A

[State 0]
Type = VarSet
Trigger1 = !Time
sysvar(1) = 0

[State 0]
Type = ChangeAnim
Trigger1 = !Time
Value = Cond((Vel X) = 0, 41, Cond((Vel X) > 0, 42, 43))+Var(33)

[State 0]
Type = ChangeAnim
Trigger1 = PrevStateNO != [40,109]
Persistent = 0
Value = 44+Var(33)
;---------------------------------------------------------------------------
; Jump Down (empty State for compatibility)
[StateDef 51]
Type    = A
Physics = A

[State 51, 1]
Type = Null
Trigger1 = 1
;---------------------------------------------------------------------------
; Jump Land
[StateDef 52]
Type    = S
Physics = S
Ctrl = 0
Anim = 47+Var(33)

[State 0]
Type = VelSet
Trigger1 = !Time
Y = 0

[State 0]
Type = VelSet
Trigger1 = Abs(Vel X) < Const(Movement.Stand.Friction.Threshold)
X = 0

[State 0]
Type = PosSet
Trigger1 = !Time
Y = 0

[State 0, Land]
Type = PlaySnd
Trigger1 = !Time
Value = S52,2
VolumeScale = 50
[State 0, Land]
Type = PlaySnd
Trigger1 = !Time
Value = S52,3
VolumeScale = 10

[State 0, Land]
Type = Explod
Trigger1 = !Time
Anim = 7014
ID = 7014
Pos = (Pos X + CameraPos X) + (-1 * Facing * Const(Size.XScale)),(Pos Y) + (0 * Const(Size.YScale))
Space = Stage
Facing = Facing
Scale = .33 * Const(Size.XScale),.33 * Const(Size.YScale)
SprPriority = 1
Shadow = 0,0,0
OwnPal = 1
IgnoreHitPause = 1
Trans = AddAlpha
Alpha = 256,256

[State 0]
Type = ChangeState
Trigger1 = !AnimTime
Value = 0
Ctrl = 1
;---------------------------------------------------------------------------
; Guard (start)
[StateDef 120]
Type = U    ;Leave State Type unchanged
Physics = U ;Leave Physics unchanged

[State 120, 1]
Type = ChangeAnim
Trigger1 = !Time
Value = 120 + (StateType = C) + (StateType = A) * 2+Var(33)

[State 120, 2]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = S
Physics = S

[State 120, 3]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = C
Physics = C

[State 120, 4]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = A
Physics = A

[State 120, Hi to Lo]
Type = StateTypeSet
Trigger1 = StateType = S  &&  Command = "holddown"
StateType = C
Physics = C

[State 120, Lo to Hi]
Type = StateTypeSet
Trigger1 = StateType = C  &&  Command != "holddown"
StateType = S
Physics = S

[State 120, 5]
Type = ChangeState
Trigger1 = !AnimTime
Value = 130 + (StateType = C) + (StateType = A) * 2

[State 120, Stop Guarding]
Type = ChangeState
Trigger1 = !AILevel
Trigger1 = Command != "holdback"
Trigger2 = AILevel
Trigger2 = !InGuardDist
Trigger2 = Time >= 15
Value = 140
;---------------------------------------------------------------------------
; STAND Guard (Guarding)
[StateDef 130]
Type    = S
Physics = S

[State 130, 1]
Type = ChangeAnim
Trigger1 = Anim != 130+Var(33)
Value = 130+Var(33)

[State 130, Hi to Lo]
Type = ChangeState
Trigger1 = Command = "holddown"
Value = 131

[State 130, Stop Guarding]
Type = ChangeState
Trigger1 = !AILevel
Trigger1 = Command != "holdback"
Trigger2 = AILevel
Trigger2 = !InGuardDist
Trigger2 = Time >= 15
Value = 140
;---------------------------------------------------------------------------
; CROUCH Guard (Guarding)
[StateDef 131]
Type    = C
Physics = C

[State 131, 1]
Type = ChangeAnim
Trigger1 = Anim != 131+Var(33)
Value = 131+Var(33)

[State 131, Lo to Hi]
Type = ChangeState
Trigger1 = Command != "holddown"
Value = 130

[State 131, Stop Guarding]
Type = ChangeState
Trigger1 = !AILevel
Trigger1 = Command != "holdback"
Trigger2 = AILevel
Trigger2 = !InGuardDist
Trigger2 = Time >= 15
Value = 140
;---------------------------------------------------------------------------
; AIR Guard (Guarding)
[StateDef 132]
Type    = A
Physics = N

[State 132, 1]
Type = ChangeAnim
Trigger1 = Anim != 132+Var(33)
Value = 132+Var(33)

[State 132, 2]
Type = VelAdd
Trigger1 = 1
Y = Const(Movement.yaccel)

[State 132, 3]
Type = VarSet
Trigger1 = 1
sysvar(0) = (Pos Y  >=  0)  &&  (Vel Y  >  0)

[State 132, 4]
Type = VelSet
Trigger1 = sysvar(0)
Y = 0

[State 132, 5]
Type = PosSet
Trigger1 = sysvar(0)
Y = 0

[State 132, 6]
Type = ChangeState
Trigger1 = sysvar(0)
Trigger1 = Command = "holdback"
Trigger1 = inGuardDist
Value = 130

[State 132, 7]
Type = ChangeState
Trigger1 = sysvar(0)
Value = 52

[State 132, Stop Guarding]
Type = ChangeState
Trigger1 = !AILevel
Trigger1 = Command != "holdback"
Trigger2 = AILevel
Trigger2 = !InGuardDist
Trigger2 = Time >= 15
Value = 140
;---------------------------------------------------------------------------
; Guard (end)
[StateDef 140]
Type = U    ;Leave State Type unchanged
Physics = U ;Leave Physics unchanged
Ctrl = 1

[State 140, 1]
Type = ChangeAnim
Trigger1 = !Time
Value = 140 + (StateType = C) + (StateType = A) * 2+Var(33)

[State 140, 2]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = S
Physics = S

[State 140, 3]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = C
Physics = C

[State 140, 4]
Type = StateTypeSet
Trigger1 = !Time  &&  StateType = A
Physics = A

[State 140, Hi to Lo]
Type = StateTypeSet
Trigger1 = StateType = S  &&  Command = "holddown"
StateType = C
Physics = C

[State 140, Lo to Hi]
Type = StateTypeSet
Trigger1 = StateType = C  &&  Command != "holddown"
StateType = S
Physics = S
