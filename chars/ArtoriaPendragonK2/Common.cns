;---------------------------------------------------------------------------
; DRAWGAME (Time over)
[StateDef 175]
Type = S
Ctrl = 0
VelSet = 0,0

[State 175, 1] ; If no Anim, use go to lose State.
Type = ChangeState
Trigger1 = !Time
Trigger1 = !SelfAnimExist(175)
