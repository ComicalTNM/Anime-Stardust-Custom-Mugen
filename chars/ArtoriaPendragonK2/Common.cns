Trigger1 = GetHitVar(AnimType) != [3,5]
Value = Cond((GetHitVar(AirType) = 1),5000+Var(10),5010+Var(10)) + GetHitVar(AnimType)

[State 5020, 2] ;Anim for Hit_BACK
