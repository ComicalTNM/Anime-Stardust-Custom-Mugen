; NP Gauge HUD
[StateDef 3200]
Type = A
VelSet = 0,0
Ctrl = 0
Anim = 9999

; var(0) - Required Charge
; var(1) - Current Charge
; var(2) - Previous Power
; var(3) - Changes in Power

[State 0, VarSet]
Type = VarSet
Trigger1 = !Time
var(0) = 15000
IgnoreHitPause = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = !Time
var(1) = Parent,var(50)
IgnoreHitPause = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = var(1) > var(0)
var(1) = var(0)
IgnoreHitPause = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = Root,StateNO = 3000
Trigger1 = Root,Time = 1
var(1) = var(0)*9/10
IgnoreHitPause = 1

[State 0, VarSet]
Type = VarSet
Trigger1 = Root,StateNO = 3001
Trigger1 = Root,Time = 1
var(1) = 0
IgnoreHitPause = 1

[State 0, VarAdd]
Type = VarAdd
TriggerAll = RoundState = 2
TriggerAll = var(1) < var(0)
TriggerAll = Root,Power != var(2)
TriggerAll = var(3) := Root,Power - var(2)
TriggerAll = Root,Time = 1
Trigger1 = Root,MoveType = A
Trigger2 = var(3) > 0
Trigger2 = Root,MoveType = H
V = 1
Value = Abs(var(3))
IgnoreHitPause = 1

[State 0, VarAdd]
Type = VarAdd
TriggerAll = RoundState = 2
TriggerAll = var(1) < var(0)
Trigger1 = Root,Time = 1
Trigger1 = Root,MoveType = H
V = 1
Value = 15
IgnoreHitPause = 1

[State 0]
Type = Null
Trigger1 = var(2) := Root,Power
IgnoreHitPause = 1

