;===================================================================================
;---------------- Constantes y Ataques normales--------------------------------------------
;===================================================================================

;var List:
; var(1) = Local variable
; var(2) = Local variable - Often used for Random Voice Selection
; var(3) = Local variable - Often used for Random Number
; fvar(1) = Random Vel X for Explod 555
; fvar(2) = Random Vel Y for Explod 555
; fvar(3) = Random Vel Y for Explod 555
; fvar(4) = Zoom Scale/Pos X for Ultimate
; fvar(5) = Zoom Pos Y for Ultimate
; fvar(6) = Activating Ultimate - Flag the Player, put enemies into the correct Custom State based on Player's StateNO
; var(6) = Combo Escape Timer
; fvar(7) = Combo Escape for AI		1/0 : ON/OFF
; var(7) = Combo Escape CD		Must be >0?
; fvar(8) = "Holy sword, release!" for AI	1/0 : ON/OFF
; var(8) = "Holy sword, release!" Time Limit	-1 = permanently ON
; fvar(9) = "Dragon Reactor Core" for AI	1/0 : ON/OFF
; var(9) = "Dragon Reactor Core" Time Limit	-1 = permanently ON
; var(10) - Reserved for compatibility
; var(11) = Combo Connection Check for AI		Store the previously executed move's StateNO
; fvar(11) = Combo Connection Check Reset for AI	5 frames for combo connection
; var(12) = Super Pause Darken Screen
; var(13) = Combo Counter
; var(14) = Combo Counter Workaround
; var(50) = Ultimate Charge - Persist
; var(51) = Palette Number - Persist

