; A
[State -1, A]
Type = ChangeState
Triggerall = Time >= 10
Triggerall = Pos Y >= 0
TriggerAll = RoundState = 2
Trigger1 = !AILevel
Trigger1 = Command = "a"
Trigger2 = AILevel
Trigger2 = P2BodyDist X = [80,120]
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)/2
Value = 200+Var(33)

; B
[State -1, B]
Type = ChangeState
Triggerall = Time >= 10
TriggerAll = RoundState = 2
Triggerall = Pos Y >= 0
Trigger1 = !AILevel
Trigger1 = Command = "b"
Trigger2 = AILevel
Trigger2 = P2BodyDist X = [80,140]
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)
Value = 300+Var(33)

; C
[State -1, C]
Type = ChangeState
Triggerall = Time >= 10
TriggerAll = RoundState = 2
Triggerall = Pos Y >= 0
Trigger1 = !AILevel
Trigger1 = Command = "c"
Trigger2 = AILevel
Trigger2 = Cond(Var(23),P2BodyDist X > 100,P2BodyDist X < 70)
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)/2
Value = Cond(Var(23),30480,310)

; A
