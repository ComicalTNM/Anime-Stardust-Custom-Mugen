[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1


[State 0, End]
Type = ChangeState
Trigger1= !Var(23)
Value = Cond(Random >= 500,1000,Cond(Random >= 500,1100,Cond(Random >= 500,1200,Cond(Random >= 500,1300,Cond(Random >= 500,1500,Cond(Random >= 750,2100,Cond(Random >= 750,2000,1400))))))) ; Change This To Whatever Assist You Want (Before Mode)
