Value = Cond(Random >= 500,301000,Cond(Random >= 750,301100,Cond(Random >= 500,301200,Cond(Random >= 500,301400,Cond(Random >= 500,301600,301500))))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

