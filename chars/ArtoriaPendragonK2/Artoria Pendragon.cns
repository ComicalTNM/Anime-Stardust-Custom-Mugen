; Jump (AI)
[State -1, Jump]
Type = ChangeState
Trigger1 = AILevel
Trigger1 = RoundState = 2
Trigger1 = P2BodyDist Y < -50 || EnemyNear,MoveType = A
Trigger1 = Random < (AILevel * 100)/8
Value = 40

; Instant Dash
[State -1, Instant Dash]
Type = ChangeState
TriggerAll = Power >= 250
Trigger1 = !AILevel
Trigger1 = Command = "down_b"
Trigger2 = AILevel
Trigger2 = RoundState = 2
Trigger2 = FrontEdgeBodyDist >= 150
Trigger2 = P2BodyDist X = [100,200]
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,StateType != A
Trigger2 = Random < (AILevel * 100)/4
Value = 900

; A
[State -1, A]
Type = ChangeState
TriggerAll = RoundState = 2
Trigger1 = !AILevel
Trigger1 = Command = "a"
Trigger2 = AILevel
Trigger2 = P2BodyDist X = [80,120]
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)/2
Value = 200+Var(33)

; B
[State -1, B]
Type = ChangeState
TriggerAll = RoundState = 2
Trigger1 = !AILevel
Trigger1 = Command = "b"
Trigger2 = AILevel
Trigger2 = P2BodyDist X = [80,140]
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)
Value = 300+Var(33)

; C
[State -1, C]
Type = ChangeState
Triggerall = Time >= 4
TriggerAll = RoundState = 2
Trigger1 = !AILevel
Trigger1 = Command = "c"
Trigger2 = AILevel
Trigger2 = Cond(Var(23),P2BodyDist X > 120,P2BodyDist X < 70)
Trigger2 = EnemyNear,StateType != L
Trigger2 = EnemyNear,Pos Y >= -Const(Size.Height)
Trigger2 = Random < (AILevel * 100)/2
Value = Cond(Var(23),30480,310)

[State 200, End]
Type = ChangeState
TriggerAll = Time > 10
Trigger1 = !AILevel
Trigger1 = Command != "holdfwd"
Trigger2 = AILevel
Trigger2 = P2BodyDist X < 50
Trigger3 = AILevel
Trigger3 = FrontEdgeBodyDist < 15
Trigger4 = AILevel
Trigger4 = Time = 100 + Random%200
Value = 101
