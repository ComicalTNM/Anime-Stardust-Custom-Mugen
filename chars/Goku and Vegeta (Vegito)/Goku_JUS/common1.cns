; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 45, 1]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = SelfAnimExist(44)
value = 44+var(11)

[State 45, 2]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = !SelfAnimExist(44)
value = 41+var(11)

[State 45, 3]
type = VarSet
triggerall = var(20) = 0
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
triggerall = var(20) = 0
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
triggerall = var(20) = 0
trigger1 = Time = 2
value = 50
ctrl = 1

;------------------------Vegito-------------------------

