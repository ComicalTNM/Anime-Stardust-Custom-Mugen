;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 2

[State -3, Turn SS1]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 1
trigger1 = anim = 5
value = 2005

[State -3, Turn SS2]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 2
trigger1 = anim = 5
value = 11005

[State -3, Turn SS3]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 3
trigger1 = anim = 5
value = 13005

[State -3, Turn SSG]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 4
trigger1 = anim = 5
value = 15005

[State -3, Turn SSB]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = var(2) = 5
trigger1 = anim = 5
value = 17005

[State 0, 1]
Type = ChangeAnim
triggerall = var(20) = 0
Trigger1 = Anim != 0 + Var(11) && Anim != 5 + Var(11)
Trigger2 = Anim = 5 + Var(11) && AnimTime = 0
Value = 0 + var(11)

[State 0, 2]
type = VelSet
triggerall = var(20) = 0
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
triggerall = var(20) = 0
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
triggerall = var(20) = 0
trigger1 = !alive
value = 5050

[State -3, Stand SSJ]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = var(21) = 1
trigger1 = anim = 0
value = 90002000

[State -3, Stand SSB]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = var(21) = 2
trigger1 = anim = 0
value = 900011000

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = (Anim != 90000 && Anim != 90005 && Anim != 90002000 && Anim != 90002005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 90005 || anim = 90002005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 90000

[State 0, 2]
type = VelSet
triggerall = var(20) = 1
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
triggerall = var(20) = 1
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
triggerall = var(20) = 1
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = ifelse(Var(20) = 1,900010,10+var(11))

[State 10, 1]
type = VelMul
triggerall = var(20) = 0
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = ifelse(Var(20) = 1,900011,11+var(11))
sprpriority = 0

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = anim = 6
value = 6+var(11)

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 0
trigger1 = (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 6 || anim = 2006 || anim = 11006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 11+var(11)


;-------------------Vegito-----------------
[State 10, 1]
type = VelMul
triggerall = var(20) = 1
trigger1 = Time = 0
x = .75

[State 0, PosSet]
type = PosSet
triggerall = var(20) = 1
trigger1 = 1
y = 0

[State 0, Velset]
type = Velset
triggerall = var(20) = 1
trigger1 = 1
y = 0

[State 0, PosSet]
type = PosSet
triggerall = var(20) = 1
trigger1 = time = 0
y = 0

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = anim = 6
value = 90006

[State 0, 1]
type = ChangeAnim
triggerall = var(20) = 1
trigger1 = (Anim != 900011 && Anim != 90006 && Anim != 90002011 && Anim != 90002006 && Anim != 900011011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
trigger2 = (Anim = 90006 || anim = 90002006 || anim = 900011006 || anim = 13006|| anim = 15006 || anim = 17006 || anim = 19006) && AnimTime = 0
value = 900011
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = ifelse(Var(20) = 1,900012,12+var(11))

;------------------------Vegito
[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = 0

[State 0, velset]
type = velset
trigger1 = 1
y = 0

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0


[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
triggerall = var(20) = 0
x = const(velocity.walk.fwd.x)+ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
triggerall = var(20) = 0
x = const(velocity.walk.back.x)-ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
triggerall = var(20) = 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
triggerall = var(20) = 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
trigger2 = (Anim = 5 || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)


;------------------------Vegito
[State 20, 1]
type = VelSet
triggerall = var(20) = 1
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
triggerall = var(20) = 1
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = vel x > 0
trigger1 = (Anim != 900020 && Anim != 90005 && Anim != 90002020 && Anim != 90002005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 90005 || anim = 90002005 || anim = 900011005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 900020

[State 20, 4]
type = ChangeAnim
triggerall = var(20) = 1
triggerall = vel x < 0
trigger1 = (Anim != 900021 && Anim != 90005 && Anim != 90002020 && Anim != 90002005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
trigger2 = (Anim = 90005 || anim = 90002005 || anim = 900011005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 900021
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = ifelse(Var(20) = 1,900040,40+var(11))
ctrl = 0
sprpriority = 1

[State 8100, Dust]
triggerall = var(20) = 0
type=explod
trigger1= !time
anim=7009
sprpriority=3
postype=p1
pos=-3,-2
scale=.1,.1
pausemovetime=-1
supermovetime=-1
ownpal=1
vel = 0,-.2

[State 40, 1]
type = VarSet
triggerall = var(20) = 0
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
triggerall = var(20) = 0
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
triggerall = var(20) = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
triggerall = var(20) = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
triggerall = var(20) = 0
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;------------------------Vegito-------------------------

[State 40, 1]
type = VarSet
triggerall = var(20) = 1
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
triggerall = var(20) = 1
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
triggerall = var(20) = 1
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
triggerall = var(20) = 1
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
triggerall = var(20) = 1
trigger1 = AnimTime = 0
value = 50
ctrl = 1
