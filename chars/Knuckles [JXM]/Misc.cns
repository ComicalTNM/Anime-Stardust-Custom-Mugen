;---------------------------------- Var System
[State 0, SPIN A]
type = VarSet
trigger1 = var(57) > 950
v = 57
value = 950
ignorehitpause = 1

[State 0, SPIN B]
type = VarSet
trigger1 = (var(57) < 1)
v = 57
value = 0
ignorehitpause = 1

[State 0, SPIN Start]
type = VarSet
trigger1 = !time 
v = 57
value = 0;600
ignorehitpause = 1

;--------------------------------
; Full Power Drain Activation\
; ONLY drain when Full Power mode is active
[State 0, Drain Meter]
type = VarAdd
triggerall = roundstate = 2
triggerall = root,var(56) = 1 ; Full Power is ON
triggerall = var(57) > 0
trigger1 = timemod = 1,0
v = 57
value = -1

;--------------------------------
; Refill Mode Logic
[State 0, Refill Meter]
type = VarAdd
triggerall = roundstate = 2 
triggerall = root,var(56) = 0 ; Only refill when mode is OFF
triggerall = var(57) < 950
trigger1 = timemod = 3,0
v = 57
value = 2

[State 0, AntiBug]
type = VarSet
trigger1 = var(57) = 0 && roundstate != 2
v = 57
value = 1
ignorehitpause = 1

