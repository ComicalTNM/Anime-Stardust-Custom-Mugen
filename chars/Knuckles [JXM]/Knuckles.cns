[Constants]
switchAttack = 220 ; ANIM: Switch attack. 
I highly recommend to clone your favorite animation in Fighter Factory and extend the frametime of the animelem that has the red box.
switchAirAttack = 611 ; ANIM: switch air attack.
snapBackAttack = 300 ; ANIM: snapback attack
snapBackHit = 228 ; this is the ANIMATION used when the char get hit by the snapback attack
StateTagAssistSuper = 1100 ; STATENO: normal assist attack
StateTagAssistHyper = 1308 ; STATENO: Super assist attack, cost 1500 of power.
tauntWhileWaitingForPartners = 195 ; ANIM: If mvc1switch is on, taunt after switch. Used on switch attack or triple menace.

[Quotes]
victory1 = "Hah... That was tough. It is WAY rougher than leather."
victory2 = "Yeah! I feel good! I feel hard as nails!"
victory3 = "Is that all you got? Cause you're not as rough as leather."
victory4 = "You need more practice. Not even close enough to be tougher than the rest of them."
victory5 = "Score one for Knuckles! Cause I am the best of them!"
victory6 = "No one can match the power of my fists!"
victory7 = "Hmmm Not bad! That rivalry like battle was only temporarily"
victory8 = "Not too bad... Maybe it's how I find those weak spots on opponents"
victory9 = "I do things on my own and that's just how i like it. i don't need anyone else to get by"
victory10 = "My Master Emerald... Is my destiny to protect it from evil!"

