; GUARD (start)
[Statedef 120]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged

[State 120, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 120 + (statetype = C) + (statetype = A)*2

[State 120, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 120, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 120, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command != "holddown"&&ailevel=0
trigger2 =  statetype = S&&ailevel&&EnemyNear(0),statetype != A 
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&ailevel=0
trigger2 =  statetype = C&&ailevel&&EnemyNear(0),statetype = A 
statetype = S
physics = S

[State 120, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 130 + (statetype = C) + (statetype = A)*2

[State 120, Stop Guarding]
type = ChangeState
trigger1 = (command != "holdback"||!inguarddist)&&ailevel = 0
trigger2 = !inguarddist
value = 140
;---------------------------------------------------------------------------
; STAND GUARD (guarding)
[Statedef 130]
type    = S
physics = S

[State 130, 1]
type = ChangeAnim
trigger1 = Anim != 130
value = 130

[State 130, Hi to Lo]
type = ChangeState
trigger1 = command = "holddown"&&ailevel = 0
trigger2 =  statetype = S&&ailevel&&EnemyNear(0),statetype != A 
value = 131

[State -1, Vanish]
type = ChangeState
Triggerall = power >= 1000
value = 1780
trigger1 = command = "holdfwd"&&command="hold_z"&& ailevel = 0
trigger2 = ailevel && random%48=ailevel&& time = 4

[State 130, Stop Guarding]
type = ChangeState
trigger1 = (command != "holdback"||!inguarddist)&&ailevel = 0
trigger2 = !inguarddist
value = 140
;---------------------------------------------------------------------------
; CROUCH GUARD (guarding)
