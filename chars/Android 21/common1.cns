type = Explod
trigger1 = !time
anim = 7022
ID = 1051
pos = 0,0
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .4,.3
sprpriority = 3
ontop = 0
ownpal = 1
removeongethit = 1
pausemovetime = 999

[State 0, Explod]
type = Explod
trigger1 = timemod = 4,0 && time > 5 && pos y = 0
anim = 7022
ID = 1051
pos = 0,0
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .2,.2
sprpriority = 3
ontop = 0
ownpal = 1
removeongethit = 1
pausemovetime = 999

[State 0, VelSet]
type = VelSet
trigger1 = time > 2
x = 12

[State 0, VelSet]
type = PosSet
trigger1 = time > 2
trigger1 = pos y >= 0
y = 0

[State 200, JUMP]
type = ChangeState
triggerall = pos y >= 0
triggerall = time > 2
trigger1 = command = "up"||command = "holdup"
trigger2 = enemy, pos y < -30&&ailevel
value = 40

[State 200, LAND]
type = ChangeState
triggerall = time > 2
trigger1 = pos y > 0
value = 12
[State 200, End]
type = ChangeState
triggerall = time > 2
triggerall = ailevel = 0 
trigger1 = ailevel = 0 && command = "a" && command = "holddown"
value = 230
; A
[State -1, A]
type = ChangeState
value = 200
triggerall = ailevel = 0
triggerall = time > 2
triggerall = ailevel = 0
trigger1 = command = "a"
[State 200, End]
type = ChangeState
triggerall = time > 2
triggerall = ailevel = 0 
trigger1 = ailevel = 0 && command = "b" && command = "holddown"
value = 310
[State 200, End]
type = ChangeState
triggerall = time > 2
triggerall = ailevel = 0 
trigger1 = ailevel = 0 && command = "b" && command = "holddownfwd"
value = 311
; B
[State -1, B]
type = ChangeState
value = 300
triggerall = time > 2
triggerall = ailevel = 0
trigger1 = command = "b"

; B
[State -1, B]
type = ChangeState
value = 360
triggerall = time > 2
triggerall = ailevel = 0
trigger1 = command = "c"


; C
[State -1, C]
type = ChangeState
value = 400
triggerall = time > 2
triggerall = ailevel = 0
triggerall = power >= 200
trigger1 = command = "x"
[State 200, End]
type = ChangeState
triggerall = time > 10
trigger1 = ailevel = 0 && command != "holdfwd"
trigger2 = ailevel > 0 && time = 100+random%200
trigger3 = ailevel > 0 && p2bodydist x < 50
value = cond(pos y < 0,50,12)
ctrl = 1
