;===============================================================================
;--------------------------Constantes BÃ¡sicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, PalFX]
type = PalFX
trigger1 = 1
time = 1
mul = 256,256,256
color = 256

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0 &&Anim != 1 && Anim != 5 && anim != 2||((Var(56)=10 && anim!=1)||(Var(56)=9 && anim!=2))
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = Cond(Var(56)=10,1,Cond(Var(56)=9,2,0))

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0, A]
type = ChangeState
triggerall = numhelper(6500)
triggerall = ailevel > 0 && roundstate = 2
trigger1 = ((helper(6500),movehit)||(helper(6500),numexplod(10)))&&(prevstateno = 1205||prevstateno = 1105)
value = Cond(Var(15)=0,1500,40)

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0
;-------------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

[State 0, SelfState]
type = SelfState
trigger1 =ailevel>0
value = 0
ctrl = 1
;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0

[State 11, 1]
type = ChangeAnim
trigger1 = Anim = 6 && AnimTime = 0
value = 11

[State 11, 2]
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0
;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"&&ailevel = 0
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20
[State 0, A]
type = ChangeState
triggerall = numhelper(6500)
triggerall = ailevel > 0 && roundstate = 2
trigger1 = (helper(6500),movehit)||(helper(6500),numexplod(10))
value = Cond(Var(15)=0,1500,40)
[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21
;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = 1
id = 005

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
trigger2 = ailevel > 0
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback" && ailevel = 0
sysvar(1) = -1

[State 0, Speed FX]
type = Explod
trigger1 = numexplod(60)=0&&prevstateno = 60
anim = 9999
ID = 60
pos = -5,-30
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = cond(sysvar(1)=0, const(velocity.jump.neu.x), cond(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 60
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)


[State 0, SelfState]
type = SelfState
triggerall = enemy,statetype != A||enemy,pos y = 0
trigger1 = ailevel > 0
value = 0 
ctrl = 1

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = A
ctrl = 0

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 2]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41

[State 45, 3]
type = VarSet
trigger1 = !Time 
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
trigger2 = ailevel
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"&&ailevel = 0
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = cond(sysvar(1)=0, const(velocity.airjump.neu.x), cond(sysvar(1)=1,const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y =const(velocity.airjump.y)
[State 0, Speed FX]
type = Explod
trigger1 = time = 1
anim = 49
ID = 42
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
[State 0, Speed FX]
type = Explod
trigger1 = time = 1
anim = 9999
ID = 45
pos = -5,-30
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -1
[State 0, SelfState]
type = SelfState
trigger1 = !time && numexplod(45)
value = 50
ctrl = 1

[State 45, 7]
type = ChangeState
trigger1 = Time = 4
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0
value = 1701
[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = cond((vel x)=0, 41, cond((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > -2
persistent = 0
value = 44
;---------------------------------------------------------------------------
; Jump Down (empty state for compatibility)
[Statedef 51]
type    = A
physics = A

[State 51, 1]
type = Null
trigger1 = 1
;---------------------------------------------------------------------------
; Jump Land
[Statedef 52]
type    = S
physics = S
ctrl = 0
anim = Cond(prevstateno = 1500||prevstateno = 1501,48,Cond(numexplod(620),48,47))

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 1
id = 1550
[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = !time
id = 7014
[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 1
id = 620

[State 52, 1]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = (prevstateno != [5200,5210])&& time < 4
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard


[State 0, CtrlSet]
type = CtrlSet
trigger1 =  time = 4
value = 1

[State 52, 2]
type = PosSet
trigger1 = Time = 0
y = 0

[State 52, 4]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
