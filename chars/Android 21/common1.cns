trigger1 = Anim != 131
value = 131

[State 131, Lo to Hi]
type = ChangeState
trigger1 = command != "holddown"&&ailevel = 0
trigger2 = statetype = S &&ailevel
trigger2 =  statetype = C&&ailevel&&EnemyNear(0),statetype = A 
value = 130
[State 131, Stop Guarding]
type = ChangeState
trigger1 = (command != "holdback"||!inguarddist)&&ailevel = 0
trigger2 = !inguarddist
value = 140
