;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[Statedef -2]

[state 0]
type = removeexplod
trigger1 = pos y = 0
id = 45

[state 0]
type = changestate
triggerall = (roundstate = 2) && (pos y != 0) && (numexplod(45) = 0) && (movecontact = 1) && (cond(var(2) = 1, (stateno = [2600, 2699]), (stateno = [600, 699])))
trigger1 = ((!ailevel) && (command = "holdup"))
trigger2 = ((ailevel) && (random < (ailevel * 70)))
value = 45

[state 0]
type = changestate
triggerall = (roundstate = 2) && ((ctrl) || (stateno = [100, 110])) && (pos y != 0) && (numexplod(110) = 0)
trigger1 = (!ailevel) && (command = "FF") || (command = "BB")
trigger2 = ((ailevel) && (p2bodydist x = [5, 60]) && (p2movetype = a) && (random < (ailevel * 10)))
value = 110

; Saitama Sense:

[State 0, HitOverride]
type = HitOverride
trigger1 = numhelper(1550) > 0 && random < 500 && p2bodydist x = [-50,50]
attr = SCA,NA,SA,NP,SP
stateno = 1525
time = 1
ignorehitpause = 0

[State 0, Run]
type = ChangeState
triggerall = var(5) = 0
triggerall = stateno != 60
triggerall = stateno != 65
triggerall = stateno != 70
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = ifelse(pos y >= 0,60,65)

[State 0, Run Atras]
type = ChangeState
triggerall = var(5) = 0
triggerall = stateno != 60
triggerall = stateno != 65
triggerall = stateno != 70
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = 70

[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = random <=100
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State 0, Guard]
type = assertspecial
trigger1 = ailevel > 0 && roundstate = 2
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard
ignorehitpause = 1

[State 0, Power Charge]
type = ChangeState
triggerall = statetype != A
triggerall = power < 3000
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/4
value = 500

[State 0, Power Charge End]
type = ChangeState
triggerall = statetype != A
triggerall = time >= 12
triggerall = stateno = 500
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0)
trigger2 = power = 3000
value = 501

[State 0, Ciclar Kick]
type = ChangeState
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
triggerall = p2bodydist x < 30
trigger1 = random < (ailevel * 100)/4
trigger2 = power >= 6000 && random < (ailevel * 100)*2
