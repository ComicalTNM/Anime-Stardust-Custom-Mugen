;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Var(2),Cond(Random >= 500,Cond(Random >= 750,31500,31200),Cond(Random >= 500,31100,31000)),Cond(Random >= 500,1300,Cond(Random >= 500,1500,1000)))
Ctrl = 0

;-----------------------------------------------------------
; Assists Changer 2
;-----------------------------------------------------------
[StateDef 34366] ; Just To Make Sure 2 Cannons Are Placed In Mode
Type = S
MoveType = I
Physics = S
VelSet = 0,0
Anim = 11

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno-1
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, NotHitBy] ; Not Be Able To Get Hit In This State
Type = NotHitBy
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Trigger1 = RoundState = 2
Value = Cond(Var(2),Cond(Random >= 500,Cond(Random >= 750,31500,31200),Cond(Random >= 500,31100,31000)),Cond(Random >= 500,1300,Cond(Random >= 500,1500,1000)))
Ctrl = 0

