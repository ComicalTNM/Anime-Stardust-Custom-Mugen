;===============================================================================
;COMMANDS (Global)
;===============================================================================

;---------------------------------------------------------------------------
; Air Jump
[State -1, ChangeState]
Type = ChangeState
Trigger1 =  !AiLevel 
Trigger1 = !Var(1)
Trigger1 = Var(2)  < 2
Trigger1 = StateNO != 45
Trigger1 = Command = "holdup" || Command = "up"
Trigger1 = StateType = A && (Cond(Vel Y < 0, (Pos Y < Const(Movement.AirJump.Height)),1))
Trigger1 = Ctrl
Value = 45

;---------------------------------------------------------------------------
; Run Fwd
[State -1, ChangeState]
Type = ChangeState
Trigger1 =  !AiLevel 
Trigger1 =   Command = "FF"
Trigger1 = StateType = S
Trigger1 = Ctrl
Value = 100

;---------------------------------------------------------------------------
; Dash Back
[State -1, ChangeState]
Type = ChangeState
Trigger1 =  !AiLevel 
Trigger1 =   Command = "BB"
Trigger1 = StateType = S
Trigger1 = Ctrl
Value = 105

;---------------------------------------------------------------------------
; Air Dash
[State -1, ChangeState]
Type = ChangeState
Trigger1 =  !AiLevel 
Trigger1 = Cond(!Var(5),!Var(30),Var(30) < 3)
Trigger1 =   Command = "FF"
Trigger1 = StateType = A
Trigger1 = Ctrl
Value = 110

;---------------------------------------------------------------------------
; Air Back Dash
[State -1, ChangeState]
Type = ChangeState
Trigger1 =  !AiLevel 
Trigger1 = Cond(!Var(5),!Var(30),Var(30) < 3)
Trigger1 =   Command = "BB"
Trigger1 = StateType = A
Trigger1 = Ctrl
Value = 115

;---------------------------------------------------------------------------
; Guard/Shield
[State -1, ChangeState]
Type = ChangeState
Trigger1 = Var(12)
Trigger1 = Var(14) || Var(7)
Trigger1 = !AiLevel
Trigger1=  Command = "x" ||  Command = "holdx"
Trigger1 = Ctrl
Value = 120

;---------------------------------------------------------------------------
; 2AB
[State -1, ChangeState]
Type = ChangeState
Trigger1 = SelfAnimExist(500)
Trigger1 = StateNO != 500
Trigger1 =  !AiLevel
Trigger1 =  Command = "holddown"
Trigger1 = (Command = "a" ||   Command = "holda") && (Command = "b" ||   Command = "holdb")
Trigger1 = StateType != A && Pos Y = 0
Trigger1 = Power < Cond(Var(4),PowerMax,3000)
Trigger1 = Ctrl
Value = 500

;---------------------------------------------------------------------------
; 5BC
[State -2, ChangeState]
Type = ChangeState
Trigger1 = SelfAnimExist(700)
Trigger1 = StateNO != 700
Trigger1 = !Var(5)
Trigger1 = Var(6)
Trigger1 = !Var(7)
Trigger1 = Var(14) = 10
Trigger1 =  !AiLevel 
Trigger1 =  Command != "236BC" && Command != "214BC" 
Trigger1 =  Command = "5BC"
Trigger1 = Life <= Ceil(LifeMax / 1)
Trigger1 = StateType != A && Pos Y = 0
Trigger1 = Ctrl
Value = 700

;===============================================================================
;AI (Global)
;===============================================================================

[State -1, AssertSpecial]
Type = AssertSpecial
Trigger1 = AiLevel && NumEnemy
Trigger1 =  RoundState = 2
Flag = NoStandGuard
Flag2 = NoCrouchGuard
Flag3 = NoAirGuard
IgnoreHitPause = 1

;---------------------------------------------------------------------------
; 2AB
[State -1, ChangeState]
Type = ChangeState
Trigger1 = AiLevel && NumEnemy
Trigger1 = RoundState = 2
Trigger1 = Ctrl
Trigger1 = SelfAnimExist(500)
Trigger1 = StateNO != 500
Trigger1 = StateType !=  A && Pos Y = 0
Trigger1 = Power < Cond(Var(6),PowerMax,3000)
Trigger1 = Random > 350 && Var(20) = [(8 * AILevel),(10*AiLevel)]
Trigger1 = Fvar(39) >= 250
Value = 500

;---------------------------------------------------------------------------
; 5BC
[State 0, Super]
Type = SelfState
Triggerall = alive
Triggerall = !Var(7)
Triggerall = Stateno != 900
Trigger1 = Life <= lifemax/2
Value = 900
IgnoreHitPause = 1
[State 0, Super]
Type = SelfState
Triggerall = Var(7) = 2
Triggerall = Stateno != 700
Trigger1 = Life <= 300
Value = 700
IgnoreHitPause = 1
[State 0, ChangeState]
Type = ChangeState
triggerall = ctrl
triggerall = StateType = S
trigger1 = random >500
trigger1 = ailevel
triggerall = roundstate = 2
triggerall = P2bodydist X >= 150
Value = Cond(Pos y >= 0,100,110)

[State 0, ChangeState]
Type = ChangeState
Triggerall = StateType = A && (enemy,numproj = 0) && (Stateno != 100) && (Stateno != 110) && (Stateno != 105) && (AILevel > 0) && (roundState = 2) && (ctrl) && (P2BodyDist x > 100)
Trigger1 = Random < (AILevel * 100)/2
Value = Cond(Pos y >= 0,100,110)

[State 0, Run Atras]
Type = ChangeState
Triggerall = (Stateno != 100) && (Stateno != 110) && (Stateno != 105) && (AILevel > 0) && (roundState = 2) && (ctrl) && (P2BodyDist x < 100) && (backedgebodydist > 50) && (P2MoveType = A)
Trigger1 = Random < (AILevel * 100)/4
Value = Cond(Pos Y >= 0,105,111)
[State 0, A]
Type = ChangeState
Triggerall = StateType != A
Triggerall = AILevel > 0 && RoundState = 2
Triggerall = Ctrl
Triggerall = P2BodyDist x < 15
Trigger1 = Random < (AILevel * 100)/2
Value = 200
[State 0, Down + A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = Ctrl
triggerall = p2bodydist x < 15
trigger1 = random < (ailevel * 100)
value = 300
[State 0, B]
Type = ChangeState
Triggerall = StateType != A
Triggerall = AILevel > 0 && RoundState = 2
Triggerall = Ctrl
Triggerall = P2BodyDist x < 20
Trigger1 = Random < (AILevel * 100)/3
Value = 210

[State 0, C]
Type = ChangeState
Triggerall = StateType != A
Triggerall = AILevel > 0 && RoundState = 2
Triggerall = Ctrl
Triggerall = (p2bodydist x = [-15,15]) 
Trigger1 = Random < (AILevel * 100)/Cond((p2bodydist x=[-20,-5]),2,4)
Value = 220
;---------------------------------------------------------------------------
; Jump
[State -1, ChangeState]
Type = ChangeState
TriggerAll = AiLevel && NumEnemy
TriggerAll =  RoundState = 2
TriggerAll = StateNO != 40
TriggerAll = StateType = S && Pos Y= 0
TriggerAll = EnemyNear,StateType != L
TriggerAll = Ctrl
Trigger1 = EnemyNear,MoveType != A
Trigger1 = EnemyNear,Pos Y < Const(Size.Mid.Pos.Y)
Trigger1 = Fvar(39) <= 50
Trigger2 = EnemyNear,MoveType = A
Trigger2 = EnemyNear,Pos Y > Const(Size.Mid.Pos.Y)
Value = 40

;---------------------------------------------------------------------------
; Air Jump
[State -1, ChangeState]
Type = ChangeState
TriggerAll = AiLevel && NumEnemy
TriggerAll =  RoundState = 2
TriggerAll = !Var(1)
TriggerAll = Var(2)  < 2
TriggerAll = StateNO != 45
TriggerAll = StateType = A && Pos Y < Const(Movement.AirJump.Height)
TriggerAll = (Var(20) = [(0 * AiLevel),(5 * AiLevel)])
TriggerAll = Ctrl
Trigger1 = EnemyNear,MoveType != A
Trigger1 =  EnemyNear,Pos Y < (Pos Y - Abs(Const(Size.Mid.Pos.Y)))
Trigger1 = Fvar(39) <= 50
Trigger2 = EnemyNear,MoveType = A
Trigger2 = EnemyNear,Pos Y > (Pos Y - Abs(Const(Size.Mid.Pos.Y)))
Value = 45
;---------------------------------------------------------------------------
; Guard
[State -1, ChangeState]
Type = ChangeState
Trigger1 = AiLevel && NumEnemy
Trigger1 = RoundState = 2
Trigger1 = StateNO != [120,155]
Trigger1 = EnemyNear,HitDefAttr != SCA,AT
Trigger1 = Ctrl
Trigger1 = EnemyNear, MoveType = A || EnemyNear, NumProj > 0
Value = 120
