;Trigger1 = Var(5)
;Time = 1
;Add = 0,Abs(Ceil(0 +(Sin((GameTime/30.0) * (PI/2)) * 32))),Abs(Ceil(0 +(Sin((GameTime/30.0) * (PI/2)) * 128)))
;IgnoreHitPause = 1

;[State -3, PalFX]
;Type = PalFX
;Trigger1 = Name = "Ryougi Shiki"
;Trigger1 = Var(6)
;Trigger1 = Var(5)
;Time = 1
;Add = Abs(Ceil(0 +(Sin((GameTime/30.0) * (PI/2)) * 96))),0,0
;IgnoreHitPause = 1

[State -3, VarAdd]
Type = VarAdd
Trigger1 = Var(6)
Trigger1 = Var(5)
Trigger1 = StateNO != 700
Trigger1 = GameTime%60 = 0
var(5) = -1
IgnoreHitPause = 1

[State -3, Null]
Type = Null
TriggerAll = Var(6)
TriggerAll = StateNO != 700
Trigger1 = Var(5) <= 0
Trigger1 = Var(5) := 0
Trigger2 = RoundState != 2
Trigger2 = Var(5) := 0
IgnoreHitPause = 1

[State -3, Null]
Type = Null
TriggerAll = Var(6)
Trigger1 = Var(5)
Trigger1 = Var(7) := 1
Trigger2 = RoundState != 2
Trigger2 = Var(7) := 0
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = StateNO != 700
Trigger1 = StateNO = 3000 && ((PrevStateNO = [130,131]) || PrevStateNO = 150 ||PrevStateNO = 152)
Trigger1 = Movehit || ProjHit3500 = 1
Trigger1 = NumTarget(3000)
Trigger1 = !(Target(3000),IsHelper)
Trigger1 = Var(5) := 0
IgnoreHitPause = 1

[State -3, AttackMulSet]
Type = AttackMulSet
Trigger1 = Var(6)
Trigger1 = Var(5)
Value = 1.25
IgnoreHitPause = 1

[State -3, DefenceMulSet]
Type = DefenceMulSet
Trigger1 = Var(6)
Trigger1 = Var(5)
Value = 0.75
IgnoreHitPause = 1

[State -3, AttackMulSet]
Type = AttackMulSet
Trigger1 = Var(6)
Trigger1 = !Var(5)
Value = 1
IgnoreHitPause = 1

[State -3, DefenceMulSet]
Type = DefenceMulSet
Trigger1 = Var(6)
Trigger1 = !Var(5)
Value = 1
IgnoreHitPause = 1

[State -3, LifeAdd]
Type = LifeAdd
Trigger1 = Var(6)
Trigger1 = Var(5)
Trigger1 = StateNO != 700
Trigger1 = GameTime%20 = 0
Trigger1 = (StateNO != [5000,5999])
;Trigger1 = !GetHitVar(Guarded)
Value = 2
IgnoreHitPause = 1

;===============================================================================
;POWER BARS LIMIT
;===============================================================================

[State -3, PowerSet]
Type = PowerSet
Trigger1 = !Var(4)
Trigger1 = Power >= 3000
Value = 3000
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = StateNO = 700
Trigger1 = StateNO != [3000,4000]
Trigger1 = Var(4) := 1
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = StateNO != 700
Trigger1 = StateNO = [3000,4000]
Trigger1 = Movehit || ProjHit3500 = 1
Trigger1 = NumTarget(3000)
Trigger1= Target(3000),IsHelper = 0
Trigger1 = Var(4) := 0
IgnoreHitPause = 1

;===============================================================================
;HITSPARK
;===============================================================================

[State -3, Null]
Type = Null
Trigger1 = MoveContact && Var(28) < 0
Trigger1 = Var(28) := (HitPauseTime)
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = Var(28) := -1

[State -3, Helper ]
Type = Helper 
Trigger1 = Var(25) = 6
Trigger1 = Var(28) = (HitPauseTime)
Name = "Grab Hitspark"
ID = 12020
StateNO = 12020
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = ID
Size.YScale = 0
Size.Ground.Back = (80 + Random%20)
IgnoreHitPause = 1

;===============================================================================
;GAUGE
;===============================================================================

[State -3, Helper]
Type = Helper
Trigger1 = Var(3) || Var(6) || Var(12)
Trigger1 = !NumHelper(4050)
Trigger1 = RoundState = 2
Name = "HUD"
ID = 4050
StateNO = 4050
OwnPal = 1
PauseMoveTime = 99999
SuperMoveTime = 99999
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = RoundNO = 1
Trigger1 = RoundState < 2
Trigger1 = Var(14) := 10
IgnoreHitPause = 1

[State -3, VarAdd] ;Add 1 for each hit
Type = VarAdd
TriggerAll = Var(3) || Var(6) || Var(12)
TriggerAll = Var(14) = [0,9]
TriggerAll = !Var(5)
TriggerAll = (StateNO != [600,605]) && (StateNO != [2000,4000]) ;&& StateNO != 4000 && StateNO != 4010
TriggerAll = NumHelper(4050)
TriggerAll = RoundState = 2
Trigger1 = MoveHit
Trigger1 = NumTarget
Trigger1 = Target,GetHitVar(HitCount) < 2
Trigger1 = Var(28) = (HitPauseTime)
Trigger2 = MoveType = H
Trigger2 = !GetHitVar(Guarded) 
Trigger2 = GetHitVar(HitCount) = 1
Trigger2 = StateNO = 5000 || StateNO = 5010 || StateNO = 5020 || StateNO = 5070|| StateNO = 5080
Trigger2 = !Time
var(14) = 1
IgnoreHitPause = 1

[State -3, VarAdd] ;Reset in Awaken
Type = VarSet
Trigger1 = Var(6)
Trigger1 = Var(14) > 0
Trigger1 = Var(5)
Trigger1 = NumHelper(4050)
Trigger1 = RoundState = 2
var(14) = 0
IgnoreHitPause = 1

[State -3, VarSet] ;Limit Value of Var(14) 
Type = VarSet 
Trigger1 = Var(3) || Var(6) || Var(12)
Trigger1 = Var(14) <= 0
var(14) = 0
IgnoreHitPause = 1
[State -3, VarSet] ;Limit Value of Var(14) 
Type = VarSet
Trigger1 = Var(3) || Var(6) || Var(12)
Trigger1 = Var(14) >= 10
var(14) = 10 
IgnoreHitPause = 1

;===============================================================================
;SHIELD
;===============================================================================

[State -3, Null]
Type = Null
Trigger1 = Var(12)
Trigger1 = StateNO != 120 && (StateNO != [130,132]) && (StateNO != [150,155])
Trigger1 = Var(15) := 0 
IgnoreHitPause = 1

[State -3, Null] 
Type = Null
Trigger1 = Var(12)
Trigger1 = StateNO != 120 && (StateNO != [130,132]) && (StateNO != [150,155])
Trigger1 = Var(13) := 0 
IgnoreHitPause = 1

[State -3, Null] ;Reset Var(16) to 0 in moment a player is out of GetHit States
Type = Null
Trigger1 = Var(12)
Trigger1 = (!Var(13) || !(GetHitVar(Guarded))) && MoveType != H
Trigger1 = Var(16) := 0
IgnoreHitPause = 1

[State -3, ChangeState] ;ChangeState to Parry State
Type = ChangeState
TriggerAll = Var(12)
TriggerAll = Var(13)
TriggerAll = Var(14) >= 1
TriggerAll = StateNO != 350
TriggerAll = (StateNO = [150,155])
TriggerAll = StateType != A && Pos Y = 0
TriggerAll = GetHitVar(Guarded)  = 1
TriggerAll = MoveType = H
TriggerAll = GetHitVar(HitShakeTime) > 0
TriggerAll = PlayerIDExist(Var(16))
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "a"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = PlayerIDExist(Var(16))
Trigger2 = PlayerID(Var(16)),StateType != A
Trigger2 = Var(20) = [(0 * AiLevel),(2 * AiLevel)]
Trigger2 = Fvar(39) <= 50
Trigger2 = EnemyNear,Pos Y >= -(Const(Size.Height)/2)
Value = 350
IgnoreHitPause = 1

[State -3, ChangeState] ;ChangeState to Parry State
Type = ChangeState
TriggerAll = SelfAnimExist(350)
TriggerAll = Var(12)
TriggerAll = Var(13)
TriggerAll = Var(14) >= 1
TriggerAll = StateNO != 4010
TriggerAll = (StateNO = [150,155])
;TriggerAll = StateType != A
TriggerAll = GetHitVar(Guarded)  = 1
TriggerAll = MoveType = H
TriggerAll = GetHitVar(HitShakeTime) > 0
TriggerAll = PlayerIDExist(Var(16))
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "b"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
;Trigger2 = PlayerID(Var(16)),StateType != A
Trigger2 = Var(20) = [(4 * AiLevel),(6 * AiLevel)]
;Trigger2 = Fvar(39) <= 50
Value = 4010
IgnoreHitPause = 1

;[State -3, ReversalDef]
