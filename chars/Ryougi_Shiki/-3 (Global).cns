[Statedef -3]

;Var(34) - Palette
;Var(33) - Random Voice Lines in Certain States
;Var(32) - Skill Lvl 1 || Lvl 2 || Lvl 3 Used
;Var(31) - Uses a Basic Skill to Cancel another Basic Skill 1x
;Var(30) - Air Dash Limit
;Var(29) - Hold Button to maker a strongest attack
;Var(28) - HitPauseTime (Used in Helpers)
;Var(27) - Spark Pos Y (Used in Helpers)
;Var(26) - Spark Pos X (Used in Helpers)
;Var(25) - Spark Type (Used in Helpers)
;Var(22)  - Hits Limit to Start Dampener
;Var(21) - Hits in Actual Combo
;Var(20) -  Random Numbers for IA (0 - 80)

;Var(19) - Agressor Width
;Var(18) - Agressor Pos X
;Var(17) - Stores the last generated ID
;Var(16) - Agressor ID
;Var(15) - Shield State Time
;Var(14) - Points for Fill Gauge and use Parry (Used in Helpers)
;Var(13) - Hold X Active in GuardState 
;Var(12) - Shield System Active/Desactive
;Var(11) - Shield Effect Pos Y
;Var(10) - Shield Effect Pos X

;Var(9) - Pos Y For Gauge
;Var(8) - Pos X For Gauge

;Var(7) - Limit Awaken One Use Per Round
;Var(6) - Awaken System Active/Desactive
;Var(5) - Awaken On

;Var(4) - Fourth Bar Unlock

;Var(3) -  Power Blast Active/Desactive

;Var(2) - AirJump Config
;Var(1) - AirJump Limit
;Var(0) - Active WindLines in Jump after Run

;Fvar(39) - Custom P2BodyDist
;Fvar(38) - CornerPush

;==========================================================================================

;===============================================================
;RESET VARS / SET VARS
;===============================================================

[State -2, Null]
Type = Null
Trigger1 = StateNO != 40 && StateNO != 50
Trigger1 = Var(0) := 0
IgnoreHitPause = 1

[State -2, Null]
Type = Null
Trigger1 = StateNO != 45  && Var(1) && Pos Y = 0 && StateType = S
Trigger1 = Var(1) := 0 
IgnoreHitPause = 1

[State -2, VarAdd]
Type = Varadd
Trigger1 = Command = "holdup"
var(2) = 1
IgnoreHitPause = 1

[State -2, VarSet]
Type = VarSet
Trigger1 = Command != "holdup"
var(2) = 0
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = StateNO != 110  && StateNO != 115 && StateNO != 40  && Var(30) && Pos Y = 0 && StateType = S
Trigger1 = Var(30) := 0
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = (StateNO != [1000,1999])
Trigger1 = Var(31) := 0 
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = (StateNO != [600,605]) &&(StateNO != [1000,1999]) && (StateNO != [2000,2999]) && (StateNO != [3000,3999])
Trigger1 = Var(32) := 0 
IgnoreHitPause = 1

;==============================================================================
;CUSTOM RANDOM
;===============================================================================

[State -3, Null]
Type = Null
Trigger1 = AiLevel && NumEnemy
Trigger1 = RoundState = 2
Trigger1 = GameTime%(Cond((AiLevel = [1,2]),12,Cond((AiLevel = [3,4]),8,Cond((AiLevel = [5,6]),6,Cond((AiLevel = [7,8]),2,0))))) = 0
Trigger1 = Var(20) := 0 + Random%81
IgnoreHitPause = 1

;==============================================================================
;CUSTOM P2BODYDIST X
;===============================================================================

[State -3, Null]
Type = Null
Trigger1 = RoundState = 2
Trigger1 = !NumTarget
Trigger1 = NumEnemy = 1
Trigger1 = EnemyNear,ID = Enemy(0),ID
Trigger1 = FVar(39) := ((Abs((Enemy(0),Pos X - (Enemy(0),Const(Size.Ground.Front)*Facing)) - Pos X)) / 4)
IgnoreHitPause = 1

[State -3, Null]
Type = Null
TriggerAll = RoundState = 2
TriggerAll = !NumTarget
TriggerAll = NumEnemy = 2
Trigger1 = EnemyNear,ID = Enemy(0),ID
Trigger1 = FVar(39) := ((Abs((Enemy(0),Pos X - (Enemy(0),Const(Size.Ground.Front)*Facing)) - Pos X)) / 4)
Trigger2 = EnemyNear,ID = Enemy(1),ID
Trigger2 = FVar(39) := ((Abs((Enemy(1),Pos X - (Enemy(1),Const(Size.Ground.Front)*Facing)) - Pos X))  / 4)
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = RoundState = 2
Trigger1 = NumTarget
Trigger1 = FVar(39) := ((Abs((Target,Pos X - (Target,Const(Size.Ground.Front)*Facing)) - Pos X)) / 4)
IgnoreHitPause = 1

;===============================================================================
;AWAKEN
;===============================================================================

;[State -3, PalFX]
;Type = PalFX
;Trigger1 = Name = "Misaka Mikoto"; || Name = "Ryougi Shiki"
