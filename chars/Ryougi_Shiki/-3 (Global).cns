;PauseTime = 0, 0
;P1StateNO = 3500
;IgnoreHitPause = 1

;===============================================================================
;POWER BLAST
;===============================================================================

[State -3, HitOverride]
Type = HitOverride
TriggerAll = Var(3)
TriggerAll = Var(14) >= 2
TriggerAll = Power >= 2000
TriggerAll = SelfAnimExist(600)
TriggerAll = StateNO != [600,605]
TriggerAll = (StateNO != [120,155])
TriggerAll = Anim != [120,152]
TriggerAll = GetHitVar(Guarded)  = 0
TriggerAll = MoveType = H
TriggerAll = GetHitVar(HitShakeTime) > 0
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "5AC"
Attr = SCA, NA, NT, NP
StateNO = Cond(StateType = A && Pos Y < 0,605,600)
Time = 20
IgnoreHitPause = 1

[State -3, HitOverride]
Type = HitOverride
TriggerAll = Var(3)
TriggerAll = Var(14) >= 2
TriggerAll = Power >= 2000
TriggerAll = SelfAnimExist(600)
TriggerAll = StateNO != [600,605]
TriggerAll = (StateNO != [120,155])
TriggerAll = Anim != [120,152]
TriggerAll = GetHitVar(AnimType) != 2
TriggerAll = GetHitVar(Guarded)  = 0
TriggerAll = MoveType = H
TriggerAll = GetHitVar(HitShakeTime) > 0
TriggerAll = !HitOver
Trigger1 = AiLevel && NumEnemy
Trigger1 = RoundState = 2
Trigger1 = Fvar(39) = [-240,240]
Trigger1 = Var(20) = [(6 * AiLevel),(10 * AiLevel)]
Attr = SCA, NA,  NT
StateNO = Cond(StateType = A && Pos Y < 0,605,600)
Time = 20
IgnoreHitPause = 1

;===============================================================================
;CORNERPUSH
;===============================================================================

[State -3, VarSet];
Type= VarSet
Trigger1= FVar(38)
Trigger1= NumTarget
Trigger1= (Target, HitOver) || (Target, GetHitVar(HitShakeTime) > 0 && Target, Time <= 0)
fvar(38) = 0

[State -3, VarSet];
Type = VarSet
Trigger1 = MoveContact = 1
Trigger1 = NumTarget
fvar(38) = (Target, GetHitVar(XVel))
ignorehitpause= 1

[State -3, PosAdd]
Type= PosAdd
TriggerAll= FVar(38)
TriggerAll= (StateType = S || StateType = C) && NumTarget
TriggerAll = Target,StateNO != [5400,5403]
TriggerAll= !HitPauseTime && (Target, GetHitVar(HitShakeTime) <= 0)
Trigger1= Target, FrontEdgeBodyDist <= Abs(Target, Vel x)
Trigger1= (Target, GetHitVar(XVel) * Target, Facing) > 0
Trigger2= Target, BackEdgeBodyDist <= Abs(Target, Vel x)
Trigger2= (Target, GetHitVar(XVel) * Target, Facing) < 0
X= Cond(Target, FrontEdgeBodyDist <= 0, -1, 1) * (Target, Facing) * FVar(38)

[State -3, VarSet]
Type = VarSet
Trigger1 = NumTarget
Trigger1 = Target, GetHitVar(HitShakeTime) <= 0
fvar(38) = Cond(StateType = S,(Fvar(38) * Const(Movement.Stand.Friction)),(Fvar(38) * Const(Movement.Crouch.Friction)))

;===============================================================================
;DAMPENER
;===============================================================================

[State -3, Null]
Type = Null
Trigger1 = NumTarget
Trigger1 = Target,GetHitVar(HitCount) >= 20
Trigger1 = Var(21) := Target,GetHitVar(HitCount)
IgnoreHitPause = 1

[State -3, Null]
Type = Null
TriggerAll = !NumTarget
TriggerAll = NumEnemy > 0
Trigger1 = EnemyNear,ID = Enemy(0),ID
Trigger1 = (Enemy(0),MoveType = H && Enemy(0),GetHitVar(HitCount) >= 20)
Trigger1 = Var(21) := Enemy(0),GetHitVar(HitCount)
Trigger2 = Enemy(0),NumPartner
Trigger2 = EnemyNear,ID = Enemy(1),ID
Trigger2 = (Enemy(1),MoveType = H && Enemy(1),GetHitVar(HitCount) >= 20)
Trigger2 = Var(21) := Enemy(1),GetHitVar(HitCount)
IgnoreHitPause = 1

[State -3, Null]
Type = Null
TriggerAll = !NumTarget
TriggerAll = NumEnemy > 0
Trigger1 = EnemyNear,ID = Enemy(0),ID 
Trigger1 = Enemy(0),MoveType != H
Trigger1 = Var(21) := 0
Trigger2 = Enemy(0),NumPartner 
Trigger2= EnemyNear,ID = Enemy(1),ID 
Trigger2 = Enemy(1),MoveType != H
Trigger2 = Var(21) := 0
IgnoreHitPause = 1

[State -3, Null]
Type = Null
Trigger1 = Var(21) >= 20
Trigger1 = Var(22) := 20
Trigger2 = Var(21) < 20
Trigger2 = Var(22) := 0
IgnoreHitPause = 1

;===============================================================================
;TARGET EFFECTS
;===============================================================================

;Target 600/605

[State -3, Explod]
Type = Explod
TriggerAll = GameTime%2 = 0
Trigger1 = NumTarget(600)
Trigger1 = Target(600),StateNO = 5401
Trigger2 = NumTarget(605)
Trigger2 = Target(605),StateNO = 5401
Anim = 11003
ID = 11003
Pos = (Target,Pos X + CameraPos X) + (0 * Target,Facing), (Target,Pos Y) + ((Abs(Target,Const(Size.Mid.Pos.Y)) / 2) - Random%(Abs(Target,Const(Size.Mid.Pos.Y))))
Space = Stage
Facing = Facing
Scale = .175, .085
SprPriority = 3
Shadow = 0, 0, 0
OwnPal = 1
IgnoreHitPause = 1

[State -3, PlaySnd]
Type = PlaySnd
TriggerAll = !NumExplod(11006)
Trigger1 = NumTarget(600)
Trigger1 = Target(600),StateNO = 5401 || Target(600),StateNO = 5402 && Target(600),Time = 1
Trigger1 = Target(600),BackEdgeBodyDist < (Target(600),Const(Size.Ground.Back) + Target(600),Const(Size.Ground.Front)) || Target(600),StateNO = 5402 && Target(600),Time = 1
Trigger2 = NumTarget(605)
Trigger2= Target(605),StateNO = 5401 || Target(605),StateNO = 5402 && Target(605),Time = 1
Trigger2 = Target(605),BackEdgeBodyDist < (Target(605),Const(Size.Ground.Back) + Target(605),Const(Size.Ground.Front)) || Target(605),StateNO = 5402 && Target(605),Time = 1
Value = S5400, 500
IgnoreHitPause = 1

[State -3, Explod]
Type = Explod
TriggerAll = !NumExplod(11006)
Trigger1 = NumTarget(600)
Trigger1 = Target(600),StateNO = 5401 || Target(600),StateNO = 5402 && Target(600),Time = 1
Trigger1 = Target(600),BackEdgeBodyDist < (Target(600),Const(Size.Ground.Back) + Target(600),Const(Size.Ground.Front)) || Target(600),StateNO = 5402 && Target(600),Time = 1
Trigger2 = NumTarget(605)
Trigger2= Target(605),StateNO = 5401 || Target(605),StateNO = 5402 && Target(605),Time = 1
Trigger2 = Target(605),BackEdgeBodyDist < (Target(605),Const(Size.Ground.Back) + Target(605),Const(Size.Ground.Front)) || Target(605),StateNO = 5402 && Target(605),Time = 1
Anim = 11006
ID = 11006
Pos = Cond(Target, Facing = 1,0,ScreenWidth), (Target,ScreenPos Y)
Space = Screen
Facing = Target,Facing
Scale = .8 * CameraZoom, .8 * CameraZoom
SprPriority = 3
Shadow = 0, 0, 0
OwnPal = 1
Angle = -90
IgnoreHitPause = 1

;===============================================================================
;OTHERS
;===============================================================================

;-------------------------------------------------------------------------------
;STOP INTRO VOICE

[State -3, StopSnd]
Type = StopSnd
Trigger1 = StateNO != [190,199]
Channel = 15
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;STOP TAUNT VOICE

[State -3, StopSnd]
Type = StopSnd
Trigger1 = StateNO != 900
Channel = 16
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;GET ENERGY IN HURTSTATE

[State -3, PowerAdd]
Type = PowerAdd
Trigger1 = MoveType = H
Trigger1 = !GetHitVar(Guarded) 
Trigger1 = StateNO = 5000 || StateNO = 5010 || StateNO = 5020 || StateNO = 5070|| StateNO = 5080
Trigger1= !Time
Value = Abs(Ceil(GetHitVar(Damage) / 2))
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;ADD POWER TO THE BAR

[State -3, PowerAdd]
Type = PowerAdd
TriggerAll = Power < Cond(Var(4),PowerMax,3000)
TriggerAll = GameTime%2 = 0
Trigger1 = StateType != C && Pos Y <= 0
Trigger1 = StateNO = 0 || StateNO = 20 || (StateNO = [40,52]) || (StateNO = [100,110])
Value = Cond(!Var(5),2,5)
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;FIXES THE PROBLEM OF WALKING ON AIR

[State -3, StateTypeSet]
Type = StateTypeSet
Trigger1 = StateNO != [3000,4000]
Trigger1 = Pos Y < 0
Trigger1 = StateType = S
StateType = A
Physics = A
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;FIXES THE PROBLEM OF WALKING ON UNDERGROUND

[State -3, PosSet]
Type = PosSet
Trigger1 = StateNO != [3000,4000]
Trigger1 = Pos Y > 0
Trigger1 = MoveType != H
Y = 0
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;TARGET BOUNCE IN GROUND

[State -3, TargetState]
Type = TargetState
Trigger1= NumTarget
Trigger1 = Target,AuthorName != "Burako"
Trigger1 = Target,GetHitVar(Fall) 
Trigger1 = Target,GetHitVar(Fall.YVel) != 0
Trigger1 = Target,StateNO = 5100
Trigger1 = Target,AnimTime = 0
Value = 5101
IgnoreHitPause = 1

;-------------------------------------------------------------------------------
;DRAGON BALL CHARACTERS PASSIVE AURA
[State -3, Helper]
Type = Helper
Trigger1 = Name = "Caulifla"
Trigger1 = !NumHelper(520)
Name = "Dragon Ball Passive Aura"
ID = 520
StateNO = 520
OwnPal = 1
PauseMoveTime = 99999
Size.XScale = 1.0
Size.YScale = 1.0
IgnoreHitPause = 1

