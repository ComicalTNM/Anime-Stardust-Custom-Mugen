;===============================================================================
;SHIELD
;===============================================================================

[State -2, ChangeState] ;ChangeState to Parry State
Type = ChangeState
TriggerAll = Var(12)
TriggerAll = Var(13)
TriggerAll = Var(14) >= 1
;TriggerAll = !NumHelper(1310) && !NumHelper(1410) && !NumHelper(1510)
TriggerAll = StateNO != [1200,1201]
TriggerAll = Power >= 1000
TriggerAll = (StateNO = [150,155])
TriggerAll = StateType != A && Pos Y = 0
TriggerAll = GetHitVar(Guarded)  = 1
TriggerAll = MoveType = H
TriggerAll = GetHitVar(HitShakeTime) > 0
TriggerAll = PlayerIDExist(Var(16))
TriggerAll = !HitOver
Trigger1 = !AiLevel
Trigger1 = Command = "c"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = PlayerIDExist(Var(16))
Trigger2 = PlayerID(Var(16)),StateType != A
Trigger2 = Var(20) = [(6 * AiLevel),(10 * AiLevel)]
Trigger2 = Fvar(39) <= 125
Trigger2 = EnemyNear,Pos Y >= -(Const(Size.Height)/2)
Trigger2 = EnemyNear,StateType != L
Value = 1200
IgnoreHitPause = 1

[State -2, ChangeState]
