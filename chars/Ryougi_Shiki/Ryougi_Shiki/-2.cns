Trigger1 = Cond(NumTarget,(Target,TeamMode != Simul),(EnemyNear,TeamMode != Simul))
Trigger1 = (StateNO != [3000,3004]) || StateNO != 3500
Trigger1 = (StateNO = [130,132]) || (StateNO = [150,155])
Trigger1 = StateType != A && Pos Y = 0
Trigger1 = GetHitVar(Guarded)  = 1
Trigger1 = MoveType = H
Trigger1 = GetHitVar(HitShakeTime) > 0
Trigger1 = !HitOver
Value = 3500
IgnoreHitPause = 1


