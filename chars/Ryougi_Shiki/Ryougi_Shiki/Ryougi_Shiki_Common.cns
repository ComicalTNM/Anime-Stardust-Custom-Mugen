;Intro - Raincoat
[StateDef 194]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 194
SprPriority = 2

[State 194, VelSet]
Type = VelSet
Trigger1 = !Time
X = -8
Y = -8
IgnoreHitPause = 1

[State 194, VelAdd]
Type = VelAdd
Trigger1 = StateNO = StateNO
Y = Const(Movement.YAccel) / 2.5
IgnoreHitPause = 1

[State 194, Trans]
Type = Trans
Trigger1 = StateNO = StateNO
Trans = AddAlpha
Alpha = 256 -  Ceil(Time * (256/20)),0 + Ceil(Time * (256/20))
IgnoreHitPause = 1 

[State 194, DestroySelf]
Type = DestroySelf
Trigger1 = Time = 20
IgnoreHitPause = 1