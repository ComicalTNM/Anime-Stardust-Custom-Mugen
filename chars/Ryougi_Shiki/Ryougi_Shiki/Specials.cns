HitOnce = 1
Getpower = 50,25
Givepower = 10,5
EnvShake.Time = 8
EnvShake.Freq = 55
EnvShake.Ampl = -6
Persistent = 0
[State 0, TargetLifeAdd]
type = TargetLifeAdd
triggerall = var(7) = 1
trigger1 = movehit = 1
value = -15
kill = 1
absolute = 1
[State 1000, StateTypeSet]
Type = StateTypeSet
Trigger1 = AnimElemTime(13) >= 0
MoveType = I
IgnoreHitPause = 1

[State 1000, Null]
Type = Null
Trigger1 = NumTarget(StateNO)
Trigger1 = Var(26) :=  Ceil((Target(StateNO),Pos X - Pos X)  * Facing)
Trigger1 = Var(27) :=  -82
Trigger2 = !NumTarget(StateNO)
Trigger2 = Var(26) :=  Ceil((EnemyNear,Pos X - Pos X)  * Facing)
Trigger2 = Var(27) :=  -82
IgnoreHitPause = 1

[State 1000, ChangeState]
Type = ChangeState
Trigger1 = !Ailevel
Trigger1 = AnimElemTime(4) >= 2 ||  MoveContact 
Trigger1 = Command = "a" || Command = "b" || Command = "c"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = MoveContact 
Trigger2 = Fvar(39) <= 45
Trigger2= EnemyNear,Pos Y >= -(Const(Size.Height)/2)
Trigger2 = EnemyNear,StateType != L
Value = 1001

[State 1000, ChangeState]
Type = ChangeState
Trigger1 = !AnimTime
Value = 0
Ctrl = 1

