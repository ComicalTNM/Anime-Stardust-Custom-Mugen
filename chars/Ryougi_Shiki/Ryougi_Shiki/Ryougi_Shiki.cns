Trigger1 = Command = "holddown"
Trigger1 = Command = "holda" && Command = "holdb"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = Fvar(39) >= 250 && EnemyNear,MoveType != A && EnemyNear,NumProj = 0  && Time < (100 + Random%100) && !InGuardDist
Value = Anim
Elem = 4
IgnoreHitPause = 1

[State 500, ChangeAnim]
Type = ChangeAnim
TriggerAll = Time > 11
TriggerAll = Power = Cond(Var(4),PowerMax,3000)
