Trigger1 = 1
Text = "Value = %d" ;%f
Params = ((ATan((-1 * Vel Y) / Vel X)) * (180 / PI))
IgnoreHitPause = 1 

[State 285, ChangeState]
Type = ChangeState
Trigger1 = !HitPauseTime
Trigger1 = Cond(Facing = 1,(ScreenPos X  > GameWidth),(ScreenPos X < (GameWidth/GameWidth))) 
Value = 286
[State 0, AngleDraw]
type =AngleDraw
trigger1 = 1
value =0-p2bodydist y ;+var(3)
[State 0, Turn]
type = Turn
trigger1 = p2dist X < Const720p(-10)
[state 501,1]
type = PosAdd
trigger1 = 1
x= 12*((p2bodydist x -0)/(abs(p2bodydist x - 0) + abs(p2bodydist y - 20) + 0.0000001))
y= 12*((p2bodydist y -20)/(abs(p2bodydist x- 0)+abs(p2bodydist y - 20) + 0.0000015))

