;---------------------------------------------------------------------------
;5BC - Awakening Aura
[StateDef 710]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 99999

[State 710, Null]
Type = Null
Trigger1 = Fvar(0) := 0 + (Time * (0.125 / 10))
IgnoreHitPause = 1

[State 710, BindToRoot]
Type = BindToRoot
Trigger1 = StateNO = StateNO
IgnoreHitPause = 1

[State 710, Turn]
Type = Turn
Trigger1 = Facing != Root,Facing
IgnoreHitPause = 1

[State 710, ChangeAnim]
Type = ChangeAnim
Trigger1 =  SelfAnimExist(Root,Anim)
Value = Root,Anim
Elem = Root,AnimElemNO(0)
IgnoreHitPause = 1

[State 710, AngleSet]
Type = AngleSet
Trigger1 = Root,Anim = 41 || Root,Anim = 44
Trigger1 = Root,Vel X > 0
Value = -5
IgnoreHitPause = 1

[State 710, AngleSet]
Type = AngleSet
Trigger1 = Root,Anim = 5040
Trigger1 = Root,AnimElemTime(2) < 0
Value = 0 + ((Root,Time -1) * (270/10))
IgnoreHitPause = 1

[State 710, AngleSet]
Type = AngleSet
Trigger1 = Root,Anim != 41 && Root,Anim != 44 &&  Root,Vel X = 0
Trigger1 = Root,Anim != 5040 || (Root,Anim = 5040 && Root,AnimElemTime(2) >= 0)
Value = 0
IgnoreHitPause = 1

[State 710, AngleDraw]
Type = AngleDraw
Trigger1 = Root,Anim = 0 ; 103
Scale = (1.0 + Fvar(0)) ,(1.0 + Fvar(0)) + (Sin((Root,Time/ 60.0) * (PI / 2)) * 0.0125)
IgnoreHitPause = 1

[State 710, AngleDraw]
Type = AngleDraw
Trigger1 = Root,Anim = 20 ; 103
Trigger1 = Root,Command = "holdback"
Scale = -(1.0 + Fvar(0)) ,(1.0 + Fvar(0))
IgnoreHitPause = 1

[State 710, AngleDraw]
Type = AngleDraw
Trigger1 = Root,Anim = 20 ; 103
Trigger1 = Root,Command = "holdfwd"
Scale = (1.0 + Fvar(0)) ,(1.0 + Fvar(0))
IgnoreHitPause = 1

[State 710, AngleDraw]
Type = AngleDraw
Trigger1 = Root,Anim != 0 && Root,Anim != 20 ; 103
Scale = (1.0 + Fvar(0)) ,(1.0 + Fvar(0))
IgnoreHitPause = 1

[State 710, NotHitBy]
Type = NotHitBy
Trigger1 = StateNO = StateNO
Value = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT
IgnoreHitPause = 1

[State 710, AssertSpecial]
Type = AssertSpecial
Trigger1 = StateNO = StateNO ; 201
Flag = NoShadow
IgnoreHitPause = 1

[State 710, Trans]
Type = Trans
Trigger1 = StateNO = StateNO ; 103
Trans = AddAlpha
Alpha = 256 - Ceil(Time * (256/10)),256
IgnoreHitPause = 1 

[State 710, PalFX]
Type = PalFX
Trigger1 = !Time
Time = -1
Add = 256, 0, 0
Mul = 256, 0,0
IgnoreHitPause = 1

[State 710, SprPriority]
Type = SprPriority
Trigger1 = Root,StateNO = 0
Trigger2 = Root,StateNO = [10,12]
Trigger3 = Root,StateNO = 20
Trigger4 = Root,StateNO = 45
Trigger5 = Root,StateNO = 50
Trigger6 = Root,StateNO = 51
Trigger7 = Root,StateNO = 52
Trigger8 = Root,StateNO = [120,155]
Trigger9 = Root,StateNO = [5000,5403]
Value = 0
IgnoreHitPause = 1

[State 710, SprPriority]
Type = SprPriority
Trigger1 = Root,StateNO = 40
Value = 1
IgnoreHitPause = 1

[State 710, SprPriority]
Type = SprPriority
Trigger1 = Root,StateNO != 0
Trigger1 = Root,StateNO != [10,12]
Trigger1 = Root,StateNO != 20
Trigger1 = Root,StateNO != 40
Trigger1 = Root,StateNO != 45
Trigger1 = Root,StateNO != 50
Trigger1 = Root,StateNO != 51
Trigger1 = Root,StateNO != 52
Trigger1 = Root,StateNO != [120,155]
Trigger1 = Root,StateNO != [5000,5403]
Value = 2
IgnoreHitPause = 1

[State 710, DestroySelf]
Type = DestroySelf
Trigger1 = Time = 10
Trigger2 = !SelfAnimExist(Root,Anim) 
Trigger3 = Root,MoveType = H && ((Root,StateNO != [150,155]) && (Root,StateNO != [5000,5210]))
IgnoreHitPause = 1
;---------------------------------------------------------------------------
;Run - Afterimage Effect
[StateDef 103]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 99999

[State 103, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(0) := Root,Anim
IgnoreHitPause = 1

[State 103, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(1) := Root,AnimElemNO(0)
IgnoreHitPause = 1

[State 103, VelSet]
Type = VelSet
Trigger1 = !Time
X = Cond(Root,StateNO = 100,-5,0)
Y = 0
IgnoreHitPause = 1

[State 103, ChangeAnim]
Type = ChangeAnim
Trigger1 = StateNO = StateNO ; 103
Value = Var(0)
Elem = Var(1)
IgnoreHitPause = 1

[State 103, NotHitBy]
Type = NotHitBy
Trigger1 = !Time
Value = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT
Time = 10
IgnoreHitPause = 1

[State 103, AngleDraw]
Type = AngleDraw
Trigger1 = StateNO = StateNO ; 103
Value = 0
Scale = 1.0 + (Time * 0.00375),1.0 + (Time * 0.00375)
IgnoreHitPause = 1

[State 103, Trans]
Type = Trans
Trigger1 = StateNO = StateNO ; 103
Trans = AddAlpha
Alpha = 50 - Cond(Time > 5,((Time - 5) * 10),0), 256
IgnoreHitPause = 1 

[State 103, DestroySelf]
Type = DestroySelf
Trigger1 = Time = 10
IgnoreHitPause = 1

