;Run - Afterimage Effect
[StateDef 102]
Type = A
MoveType = I
Physics = N
VelSet = 0,0
Ctrl = 0
Anim = 99999

[State 102, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(0) := Root,Anim
IgnoreHitPause = 1

[State 102, Null]
Type = Null
Trigger1 = !Time
Trigger1 = SelfAnimExist(Root,Anim)
Trigger1 = Var(1) := Root,AnimElemNO(0)
IgnoreHitPause = 1

[State 102, VelSet]
Type = VelSet
Trigger1 = !Time
X = Cond(Root,StateNO = 100,-5,0)
Y = 0
IgnoreHitPause = 1

[State 102, ChangeAnim]
Type = ChangeAnim
Trigger1 = StateNO = StateNO ; 102
Value = Var(0)
Elem = Var(1)
IgnoreHitPause = 1

[State 102, NotHitBy]
Type = NotHitBy
Trigger1 = !Time
Value = SCA, NA, SA, HA, NP, SP, HP, NT, ST, HT
Time = 10
IgnoreHitPause = 1

[State 102, AngleDraw]
Type = AngleDraw
Trigger1 = StateNO = StateNO ; 102
Value = 0
Scale = 1.0 + (Time * 0.00375),1.0 + (Time * 0.00375)
IgnoreHitPause = 1

[State 102, Trans]
Type = Trans
Trigger1 = StateNO = StateNO ; 102
Trans = AddAlpha
Alpha = 50 - Cond(Time > 5,((Time - 5) * 10),0), 256
IgnoreHitPause = 1 

[State 102, DestroySelf]
Type = DestroySelf
Trigger1 = Time = 10
IgnoreHitPause = 1
