;---------------------------------------------------------------------------
; Stand to Crouch
[StateDef 10]
Type    = C
Physics = C
Anim = 10

[State 10, CtrlSet]
Type = CtrlSet
Trigger1 = !Time
Trigger1 = AiLevel
Value = 0
IgnoreHitPause = 1

[State 10, VelMul]
Type = VelMul
Trigger1 = !Time
X = .75

[State 10, VelSet] 
Type = VelSet
Trigger1 = Abs(Vel x) < Const(Movement.Crouch.Friction.Threshold)
X = 0

[State 10, ChangeState]
Type = ChangeState
Trigger1 = !AnimTime
Value = 11
Ctrl = 1

;---------------------------------------------------------------------------
; Crouching
[StateDef 11]
Type    = C
Physics = C
Anim = 11
SprPrioritY = 0

[State 11, ChangeAnim] 
Type = ChangeAnim
Trigger1 = Anim = 6 && !AnimTime
Value = 11

[State 11, VelSet]
Type = VelSet
Trigger1 = Abs(Vel x) < Const(Movement.Crouch.Friction.Threshold)
X = 0

;---------------------------------------------------------------------------
; Crouch to Stand
[StateDef 12]
Type    = S
Physics = S
Anim = 12

[State 12, CtrlSet]
Type = CtrlSet
Trigger1 = !Time
Trigger1 = AiLevel
Value = 0
IgnoreHitPause = 1

[State 12, ChangeState]
Type = ChangeState
Trigger1 = !AnimTime
Value = 0
Ctrl = 1
;---------------------------------------------------------------------------
; GUARD (Start)
[StateDef 120]
Type = U   
Physics = U 
SprPrioritY = 0

[State 120, VelAdd]
Type = VelAdd
Trigger1 = PrevStateNO = 110 || PrevStateNO = 115
Trigger1 = !AnimElemTime(1)
X = Cond(PrevStateNO = 115,Abs(Vel X / 2),-(Vel X / 2))
IgnoreHitPause = 1
Persistent = 0

[State 120, Null]
Type = Null
TriggerAll = Var(12)
TriggerAll = !Time
Trigger1 = !AiLevel
Trigger1 = ((Command = "holdx" && Command != "holdback" ) || (Command = "holdx" && Command = "holdback")) 
Trigger1 = Var(13) := 1
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = Var(14) > 2 || (Var(5) && Power = PowerMax)
Trigger2 = Var(20) = [(0 * AiLevel),(5 * AiLevel)]
Trigger2= Var(13) := 1
IgnoreHitPause = 1
Persistent = 0

[State 120, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Var(12)
Trigger1 = Var(13)
Trigger1= Var(14) := (Var(14) - 1)
IgnoreHitPause = 1
Persistent = 0

[State 120, VarAdd]
Type = VarAdd
Trigger1 = StateNO = StateNO ; 120
var(15) = 1
IgnoreHitPause = 1

[State 120, PlaySnd]
Type = PlaySnd
Trigger1 = Var(12)
Trigger1 = Var(13)
Trigger1 = !AnimTime
Value = S4015, 0
IgnoreHitPause = 1
Persistent = 0

[State 120, CtrlSet]
Type = CtrlSet
Trigger1 = !Time
Value = 0
IgnoreHitPause = 1

[State 120, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Value = 120 + (StateType = C) + (StateType = A)*2
Persistent = 0

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = S
Physics = S

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = C
Physics = C

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = !Time && StateType = A
Physics = A

[State 120, StateTypeSet]
Type = StateTypeSet
Trigger1 = StateType = S && Command = "holddown" 
StateType = C
Physics = C

[State 120, StateTypeSeti]
Type = StateTypeSet
Trigger1 = StateType = C && Command != "holddown"  
StateType = S
Physics = S

[State 120, ChangeState]
Type = ChangeState
Trigger1 = !AnimTime
Value = 130 + (StateType = C) + (StateType = A)*2

;---------------------------------------------------------------------------
; Stand Guard (Guarding)
[StateDef 130]
Type    = S
Physics = S
SprPrioritY = 0

[State 130, StateTypeSet]
Type = StateTypeSet
Trigger1 = Var(12)
Trigger1 = Var(13) 
Trigger1 = PrevStateNO = [150,154]
MoveType = H
IgnoreHitPause = 1
Persistent = 0

[State 130, StateTypeSet]
Type = StateTypeSet
Trigger1 = Var(12)
Trigger1 = Var(13) 
Trigger1 = MoveType = H
Trigger1 = !GetHitVar(HitShakeTime)
Trigger1 = !GetHitVar(HitTime)
MoveType = I
IgnoreHitPause = 1

[State 130, Helper]
Type = Helper
Trigger1 = !NumHelper(4015)
Trigger1 = !NumHelper(4016)
Trigger1 = Var(12)
Trigger1 = Var(13) 
Name = "Shield Effect"
ID = 4015
StateNO = 4015
OwnPal = 1
PauseMoveTime = 99999
IgnoreHitPause = 1
Size.XScale = .4
Size.YScale = .4
Size.Mid.Pos = Var(10),Var(11)
Size.Height = 10 
[State 0, ReversalDef]
type = ReversalDef
Trigger1 = !NumHelper(4015)
Trigger1 = !NumHelper(4016)
Trigger1 = Var(12)
Trigger1 = Var(13) 
trigger1 = 1
reversal.attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
pausetime = 0,15
sparkno = -1
p1stateno = 350
[State 130, VarAdd]
Type = VarAdd
Trigger1 = StateNO = StateNO ; 130
var(15) = 1
IgnoreHitPause = 1

[State 130, CtrlSet]
Type = CtrlSet
Trigger1 = Var(12) 
Trigger1 = Var(13) 
Value = 0
IgnoreHitPause = 1

[State 130, ChangeAnim]
Type = ChangeAnim
Trigger1 = Anim != 130
Value = 130
Persistent = 0

[State 130, ChangeState]
Type = ChangeState
Trigger1 = !AiLevel
Trigger1 = Command = "holddown"
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = EnemyNear,StateType = C
Value = 131

[State 130, ChangeState]
Type = ChangeState
TriggerAll = Var(13)
TriggerAll = Var(12) 
TriggerAll = Var(14) >= 0
TriggerAll = Time >= 5
Trigger1 = !AiLevel
Trigger1 = Command != "holdx" || Var(15) >= (5 * TicksPerSecond)
Trigger2 = AiLevel && NumEnemy
Trigger2 = RoundState = 2
Trigger2 = !InGuardDist || Var(15) >= (5 * TicksPerSecond)
Value = 140

[State 130, ChangeState]
Type = ChangeState
Trigger1 = Var(13) 
Trigger1 = Var(12) 
Trigger1 = !Var(14) && Var(15) >= (5 * TicksPerSecond)
Value = 140
IgnoreHitPause = 1

[State 130, ChangeState]
Type = ChangeState
TriggerAll = !Var(13)
TriggerAll = Time >= 5
Trigger1 = !AiLevel
Trigger1 = !InGuardDist ||  Command != "holdback"
Trigger2 = AiLevel && NumEnemy
Trigger2 = !InGuardDist
Value = 140
[StateDef 720] 
Type = S  
movetype= I
physics = S
anim    = Cond(Pos Y >= 0,130,130+2)
ctrl    = 0
sprpriority = 2

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1

[State 0, StateTypeSet]
Type = StateTypeSet
Triggerall = Pos Y < -1
Trigger1 = Anim = 130+2
StateType = A
Physics = A
MoveType = A

[State 0, StateTypeSet]
Type = StateTypeSet
Trigger1 = Pos Y >= -1
StateType = S
Physics = S
MoveType = I

[State 0, VelSet]
Type = VelSet
Trigger1 = Pos Y >= -1
x = 0
y = 0
IgnoreHitPause = 1

[State 0, PosSet]
Type = PosSet
Trigger1 = Pos Y >= -1
y = 0
IgnoreHitPause = 1

[State 0, ReversalDef]
type = ReversalDef
trigger1 = 1
reversal.attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
pausetime = 0,15
sparkno = -1
p1stateno = 32250

[State 130, Helper]
Type = Helper
Trigger1 = !NumHelper(4015)
Trigger1 = !NumHelper(4016)
Name = "Shield Effect"
ID = 4015
StateNO = 4015
OwnPal = 1
PauseMoveTime = 99999
IgnoreHitPause = 1
Size.XScale = .4
Size.YScale = .4
Size.Mid.Pos = Var(10),Var(11)
Size.Height = 10 

[State 0]
type = changestate
trigger1 = time >= 21 
value = Cond(Pos Y >= 0,0,50)
ctrl = 1
