Trigger1 = Var(13)
Trigger1 = !Time
Value = S4015, 1 + Random%3
IgnoreHitPause = 1
Persistent = 0

[State 150, CtrlSet]
Type = CtrlSet
Trigger1 = Var(13) 
Value = 0
IgnoreHitPause = 1

[State 150, ChangeAnim]
Type = ChangeAnim
Trigger1 = 1
Value = 150

[State 150, ChangeState]
Type = ChangeState
