;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, DestroySelf] ; Anti Bugs
type = DestroySelf
trigger1 = ishelper


[State 0, ChangeState]
type = ChangeState
Trigger1 = Ctrl && AILevel && AnimElem >= 2 && Enemy,Life > 0 && !IsHelper
value = Cond(Var(2) = 9,Cond(Pos y >= 0,65,71),Cond(Random >= 800,Cond(Random >= 500,70650,Cond((Var(2) = [1,2]),60750,650)),Cond(Pos Y >= 0,60,110)))

[State 0, ChangeState]
type = ChangeState
Trigger1 = !Ctrl && AILevel && (Enemy,Stateno != [0,199]) && AnimElem >= 2 && Enemy,Life > 0 && !IsHelper
value = Cond(Var(2) = 9,Cond(Pos y >= 0,65,71),Cond(Random >= 800,Cond(Random >= 500,70650,Cond((Var(2) = [1,2]),60750,650)),Cond(Pos Y >= 0,60,110)))

[State 0, PosSet]
type = PosSet
Trigger1 = time = 0
y = 0

[State -3, Turn Base]
type = ChangeAnim
Triggerall = var(2) = 0
Trigger1 = var(5) = 1
Trigger1 = anim = 5
value = 13005

[State -3, base Kaioken (new)]
type = ChangeAnim
Trigger1 = var(3) = 1
Trigger1 = var(2) = 0
Trigger1 = anim = 0
value = 2

[State -3, UI and MUI (new)]
type = ChangeAnim
Trigger1 = var(2) = 6
Trigger1 = anim = 15000
value = 15001

[State -3, SSB Kaioken (new)]
type = ChangeAnim
Trigger1 = var(3) = 1
Trigger1 = var(2) = 5
Trigger1 = anim = 17000
value = 17002

[State -3, SSB Kaioken x10 (new)]
type = ChangeAnim
Trigger1 = var(3) = 2
Trigger1 = var(2) = 5
Trigger1 = anim = 17000
value = 17003

[State -3, Turn SS1]
type = ChangeAnim
Trigger1 = var(2) = 1
Trigger1 = anim = 5
value = ifelse(var(5) = 1,15005,2005)

[State -3, Turn SS2]
type = ChangeAnim
Trigger1 = var(2) = 2
Trigger1 = anim = 5
value = ifelse(var(5) = 1,17005,11005)

[State -3, Turn SS2]
type = ChangeAnim
Trigger1 = var(2) = 3
Trigger1 = anim = 5
value = ifelse(var(5) = 1,17005,13005)

[State 0, 1]
type = ChangeAnim
Trigger1 = (Anim != 0+Var(11) && Anim != 2 && Anim != 17002 && Anim != 17003&& Anim != 15001 && Anim != 5+Var(11) && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
Trigger2 = (Anim = 5+Var(11) || anim = 2005 || anim = 11005 || anim = 13005|| anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 0+var(11)

[State 0, 2]
type = VelSet
Trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
Trigger1 = abs(vel x) < 2
Trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
Trigger1 = !alive
value = 5050
