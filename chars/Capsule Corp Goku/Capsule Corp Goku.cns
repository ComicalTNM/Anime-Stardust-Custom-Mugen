; HITA_FALL (knocked up, falling)
[Statedef 7500]
type    = A
movetype= H
physics = N
velset = cond(life<=0,vel x-1,0),cond(life<=0,vel y-4,0)

[State 0, NotHitBy]
Type = NotHitBy
Trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT,AA,AP,AT
time = 1

[State 7500]
Type=Lifeadd
Triggerall = time = 0
Value= 10
Trigger1=1
ignorehitpause=1

[State 5050, 1] ;Change anim when done with transition
type = ChangeAnim
Trigger1 = AnimTime = 0
Trigger1 = Anim = 5035
Trigger2 = Time = 0     ;If no transition anim
Trigger2 = Anim != 5035
Trigger2 = (Anim != [5051, 5059]) && (Anim != [5061, 5069])
Trigger2 = Anim != 5090 ;Not if hit off ground anim
value = 5050+var(10)

[State 5050, 2] ;Coming down anim
type = ChangeAnim
Trigger1 = (anim = [5050,5059])
Trigger1 = Vel Y >= ifelse(anim = 5050, 1, -2)
Trigger1 = SelfAnimExist(anim+10)
value = anim+10
persistent = 0

[State 5050, 3] ;Gravity
type = VelAdd
Trigger1 = 1
y = GetHitVar(yaccel)

[State 0, Camara lenta]
type = Helper
Trigger1 = time = 0 && numhelper(1705) = 0
helpertype = normal
name = "Camara lenta 2"
ID = 170600592
stateno = 170600592
pos = 9999,9999
postype = p1

[State 5050, 6]
type = ChangeState
Trigger1 = Vel Y > 0
Trigger1 = Pos Y >= ifelse((anim = [5051,5059]) || (anim = [5061,5069]), 0, 25)
value = 17000 ;HIT_BOUNCE
;---------------------------------------------------------------------------
; HIT_BOUNCE (hit ground)
[Statedef 17000]
type    = L
movetype= H
physics = N

[State 0, NotHitBy]
Type = NotHitBy
Trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT,AA,AP,AT
time = 1

[State 5100, 1]
type = VelSet
Trigger1 = Time = 0
Trigger1 = GetHitVar(fall.yvel) = 0
Trigger1 = vel x > 1
x = 1

[State 5100, EnvShake]
type = FallEnvShake
Trigger1 = Time = 0

[State 5100, Var] ;Save fall velocity
type = VarSet
Trigger1 = Time = 0
sysvar(1) = floor(vel y)

[State 5100, 2] ;Hit ground anim (normal)
type = ChangeAnim
Triggerall = time = 0
Trigger1 = (anim != [5051,5059]) && (anim != [5061,5069])
Trigger2 = !SelfAnimExist(5100 + (anim % 10))
value = 5100

[State 5100, 3] ;Hit ground anim (for hit up)
type = ChangeAnim
Trigger1 = time = 0
Trigger1 = (anim = [5051,5059]) || (anim = [5061,5069])
Trigger1 = SelfAnimExist(5100 + (anim % 10))
value = (5100) + (anim % 10)

[State 5100, 4]
type = PosSet
Trigger1 = Time = 0
y = 0

[State 5100, 5]
type = VelSet
Trigger1 = Time = 0
y = 0

[State 5100, 6] ;Reduce speed
type = VelMul
Trigger1 = Time = 0
x = 0.75

[State 5100, 7]
type = ChangeState
Trigger1 = Time = 0
Trigger1 = GetHitVar(fall.yvel) = 0
value = 1701 ;HIT_LIEDOWN

[State 5100, 8]
type = GameMakeAnim
Trigger1 = Time = 1
value = 60 + (sysvar(1) > 5) + (sysvar(1) > 14)
pos = -5, 0
under = sysvar(1) <= 14

[State 5100, 9]
type = HitFallDamage
Trigger1 = Time = 3

[State 5100, 10]
type = PlaySnd
Trigger1 = Time = 1
value = F7, (sysvar(1) > 5) + (sysvar(1) > 14)

[State 5100, 11]
type = PosFreeze
Trigger1 = 1

[State 5100, HitGroundMoanVariable]
type = VarRandom
Trigger1 = time = 0
v = 7
range = 1,22

[State 5100, Voice-1]
type = PlaySnd
Triggerall = Var(7) = 1 && alive = 1
Trigger1 = time = 0
value = 5000,0

[State 5100, Voice-2]
type = PlaySnd
Triggerall = Var(7) = 2 && alive = 1
Trigger1 = time = 0
value = 5001,0

[State 5100, Voice-3]
type = PlaySnd
Triggerall = Var(7) = 3 && alive = 1
Trigger1 = time = 0
value = 5002,0

[State 5100, Voice-4]
type = PlaySnd
Triggerall = Var(7) = 4 && alive = 1
Trigger1 = time = 0
value = 5003,0

[State 5100, VarSet]
type = VarSet
Trigger1 = Var(7) = 1 || Var(7) = 2 || Var(7) = 3 || Var(7) = 4
v = 7
value = 5

[State 5100, 12]
type = ChangeState
Trigger1 = AnimTime = 0
value = 1701

[State 5100, 13]
type = ForceFeedback
Trigger1 = Time = 0
waveform = sinesquare
ampl = 128,-3,-.2,.005
time = 20
