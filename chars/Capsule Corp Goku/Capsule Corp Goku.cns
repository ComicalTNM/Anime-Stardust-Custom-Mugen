physics = S
sprpriority = 0
[State 0, ChangeState]
type = ChangeState
Trigger1 = AILevel
value = Cond(Var(2) = 9,Cond(Pos y >= 0,65,71),Cond(Random >= 800,Cond(Random >= 500,70650,Cond((Var(2) = [1,2]),60750,650)),Cond(Pos Y >= 0,60,110)))
[State 20, 1]
type = VelSet
Trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)+ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
Trigger1 = command = "holdback"
x = const(velocity.walk.back.x)-ifelse(var(3) = 1,const(velocity.walk.fwd.x)/2,0)

[State 20, 3]
type = ChangeAnim
Triggerall = vel x > 0
Trigger1 = (Anim != 20+Var(11) && Anim != 5+Var(11) && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
Trigger2 = (Anim = 5+Var(11) || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
Triggerall = vel x < 0
Trigger1 = (Anim != 21+Var(11) && Anim != 5+Var(11) && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
Trigger2 = (Anim = 5+Var(11) || anim = 2005 || anim = 11005 || anim = 13005 || anim = 15005 || anim = 17005 || anim = 19005) && AnimTime = 0
value = 21+var(11)
