type    = L
movetype= H
physics = N

[State 0, NotHitBy]
Type = NotHitBy
Trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT,AA,AP,AT
time = 1

[State 5110, EnvShake]
