Trigger1 = Time = 0

[State 5110, 5]
type = PosSet
Trigger1 = Time = 0
y = 0

[State 5110, Var] ;Get fall velocity
type = VarSet
Trigger1 = Time = 0
Trigger1 = GetHitVar(fall.yvel) != 0
sysvar(1) = floor(vel y)

[State 5110, 6]
type = PlaySnd
Trigger1 = Time = 0
Trigger1 = !SysVar(0)
value = F7, (sysvar(1) > 5) + (sysvar(1) > 14)

[State 5110, 7]
