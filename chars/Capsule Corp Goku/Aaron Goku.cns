;-------------------------------------------------------------------
[State 200, FX VIENTO - PUÑETASO NORMAL]
Type = PlaySnd
Trigger1 = Time = 0
Value = S205,12
Volume = 50
;====================================================
[State 200, HitDef]
Type = HitDef
Sparkno = -1
Triggerall = !movecontact
Trigger1 = 1
Attr = S, NA ;Explicado en mi cuaderno de como aprender codes
AnimType = Light
Damage = 4 ;Daño
GuardFlag = MA ;MA se puede cubrir,  A no se puede cubrir
PauseTime = 2,4 ;value izquierda es pausa para anim, derecha es la pausa para el p2 
HitSound = S201,13 ;FX Puñetazo(Opción 2)
GuardSound = S204,1 ;FX Guardia - Impacto
Guard.HitTime = 1 ; Tiempo que p2 se quede cubriendoce
Ground.Type = High
Ground.SlideTime = 50 ;Este es el tiempo en los ticks del juego para el que P2 se deslizará de nuevo después de ser golpeado
Ground.HitTime  = 15 ;Tiempo que P2 permanece en el estado de golpe después de ser golpeado
Ground.Velocity = -2 ;Velocidad inicial para dar P2 después de ser golpeado
Air.Velocity = 0,-3 ;Velocidad inicial para dar P2, si P2 es golpeado en el aire
Fall = 0 ;Para mandar al p2 a volar, 0 si se omite
EnvShake.Time = 3 ;Tiempo para hacer temblar la pantalla
