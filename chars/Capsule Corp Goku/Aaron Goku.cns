Triggerall = (!(((pos y)>(enemy,pos y))&&(p2dist Y<=-53)&&(FVar(0)<3.5)))
Trigger1 = (!time)
value = cond(var(13) = 2||var(13) = 4||var(13) = 6,40401,40400)

