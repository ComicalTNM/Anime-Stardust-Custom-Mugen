;====================================================
;-------------------------------------------PRIORIDAD--------------------------------------------------------
;====================================================

[State 200, End]
type = ChangeState
Triggerall = P2BodyDist x = [-40,40]
Triggerall = P2BodyDist y = [-40,40]
Triggerall = Helper(433),MoveContact
Trigger1 = ailevel = 0 && command = "a"
Trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = Cond(Pos Y >= 0,Cond(Random >= 200 && Var(27),210,Cond(Random >= 500,70210,Cond(Random >= 500,50201,40210))),Cond(Random >= 200 && Var(27),610,Cond(Random >= 500,40687,Cond(Random >= 500,70615,50610))))

[State 200, End]
type = ChangeState
Triggerall = P2BodyDist x = [-40,40]
Triggerall = P2BodyDist y = [-40,40]
Triggerall = Helper(433),MoveContact
Trigger1 = ailevel = 0 && command = "b"
Trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = Cond(Pos Y >= 0,Cond(Random >= 200 && Var(27),220,Cond(Random >= 500,70300,Cond(Random >= 500,50230,40300))),Cond(Random >= 200 && Var(27),600,Cond(Random >= 500,40650,Cond(Random >= 500,70600,50600))))
;====================================================
[State 400, SuperDash]
type = Null;ChangeState
Triggerall = power >= 300
Trigger1 = (command="y") && (time>=5)
value = 750

[State 400, Salto - Comienzo]
type = ChangeState
Triggerall = pos y = 0
Triggerall = time > 0
Trigger1 = command = "up"
value = 40

[State 400, Fin]
type = ChangeState
Triggerall = pos Y = 0
Triggerall = command = "holdfwd" || command = "holdback"
Trigger1 = time > 1
value = 20
ctrl = 1

[State 400, Fin]
type = ChangeState
Trigger1 = animtime = 0
value = cond(pos y < 0,50,0)
ctrl = 1
