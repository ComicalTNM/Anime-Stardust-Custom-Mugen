;===============================================================================
;GOLPE A - 1 (SUELO)
;===============================================================================
[StateDef 40200]
Type = S
MoveType = A
Physics = S
Juggle  = 0 ;Infinidad de los golpes, mientras sea 0 podras conectar las veces que quieras osea infinito
Ctrl = 0
Anim = 40200 ;GOLPE A - 1
poweradd = 40 ;Energia que da al activar el estado
Sprpriority = 2 ;Capas
