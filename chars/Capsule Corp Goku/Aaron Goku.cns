Volume = 999
[State 200, GOKUBASE - VOZCAMBIO 3(GOLPE A - 1) VOZ 1]
Type = PlaySnd
Trigger1 = Time = 0
Value = S210,5+Var(34) ;GOKUBASE - VOZCAMBIO 3(GOLPE A - 1) VOZ 2
