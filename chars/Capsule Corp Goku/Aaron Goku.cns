[State 400, VarSet]
type = VarSet
Triggerall = var(13) = 6 ;|| prevstateno != 400
Trigger1 = time = 0
v = 13
value = 0

[State 400, VarSet] ;Caida P2
type = VarSet
Trigger1 = (enemy,Stateno = [5080,5150])
fv = 2    ;fv = 10
value = FVar(2) + .1
persistent = 0
;============================================================
[State 400, Anular]
type = Null
Trigger1 = (!Time)       ;thanks to David Suave for these 2 general equations
Trigger1 = (FVar(0) := (p2dist x*10.5/(exp(.5*ln(p2dist x**2+(p2bodydist y-15)**2)))))
Trigger1 = (FVar(1) := ((p2dist y-10)*18/(exp(.5*ln(p2dist x**2+(p2dist y-10)**2)))))

[state 400, X!=-]
type = null
Trigger1 = FVar(0) < 0
Trigger1 = (FVar(0) := .00001)

[State 400, VarAdd]
type = Varset
Triggerall = Stateno = 40400
Trigger1 = time = 0
v = 13
value = Var(13)+1
