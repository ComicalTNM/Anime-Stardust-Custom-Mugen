[State 0, DOWN B]
type = ChangeState
triggerall = fvar(24) = 0
trigger1 = ailevel = 0 && command = "holddown" && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 340

[State 0, DOWN C]
type = ChangeState
triggerall = fvar(25) = 0
trigger1 = ailevel = 0 && command = "holddown" && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
