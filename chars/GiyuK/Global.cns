triggerall = fvar(30) = 0
trigger1 = ailevel = 0 && command = "a" && command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 250

[State 0, B+C]
type = ChangeState
triggerall = power >= 250
triggerall = fvar(31) = 0
trigger1 = ailevel = 0 && command = "b" && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = 350

[State 0, A]
type = ChangeState
triggerall = fvar(20) < 4
trigger1 = ailevel = 0 && command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = cond(fvar(20) < 1,200,cond(fvar(20)<2,210,cond(fvar(20)<3,220,cond(fvar(20)<4,230,200))))

[State 0, B]
